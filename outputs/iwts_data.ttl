iwts_performer:5229 a schema:PerformingGroup;
  schema:name "Project Moshen Dance Company";
  schema:description "Project Moshen, a female based dance company is fully dedicated to advocating for women through the art of dance and community outreach. Project Moshen fulfills this mission by providing inspiring live performances on women’s issues such as female empowerment, equality and mental health. Project Moshen works with other nonprofits to support causes such as Ovarian Cancer Awareness along with partnering with youth organizations to provide education to girls & women through dance classes and other initiatives.";
