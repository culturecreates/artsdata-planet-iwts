iwts_performer:1615 a schema:PerformingGroup;
  schema:name "Spanish Brass";
  schema:description "Joyous, high-energy, virtuoso brass playing. Tremendous stage presence, personality, and audience appeal. Programs from Bach to tango, Frank Zappa to sound tracks from action and spy films (James Bond, The Pink Panther), and always a good dose of music from their native Spain. Christmas programs including carols and A Charlie Brown Christmas. Presenters rave: \"one of the best shows we have ever presented!\" \"SPECTACULAR!\" \"The crowd gave them a 5 minute standing ovation!\" \"Their outreach activities changed the lives of some of these students.\"";
  schema:url <http://www.spanishbrass.com>;
