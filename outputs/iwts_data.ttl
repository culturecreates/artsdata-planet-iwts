iwts_performer:9443 a schema:PerformingGroup;
  schema:name "West Trainz";
  schema:description "West Trainz is a musical project led by Erik West Millette, a multi-instrumentalist and producer. The band creates a unique blend of blues, rock and folk, inspired by the sounds and stories of North American railroads. The project pays homage to the builders, railroad workers, hobos, and nomads of the railways2. Erik West Millette has been passionate about trains and music for over two decades, and his work reflects his love for the sounds and stories of the railroad";
