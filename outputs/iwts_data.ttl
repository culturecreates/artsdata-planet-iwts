iwts_performer:10016 a schema:Person;
  schema:name "Ron Artis II";
  schema:description "Hailing from Haleiwa, Hawaii, Ron Artis II is an award-winning singer-songwriter and electrifying guitarist known for his soulful, deeply honest sound. Raised in a musical family and mentored from childhood, he grew into a powerful multi-instrumentalist and performer. Now touring globally with all-original music, Ron captivates audiences with blazing guitar work and heartfelt lyrics. He has collaborated with majors artists like Jack Johnson, Ben Harper and Joe Bonamassa.";
  schema:url <https://www.ronartisii.com/>;
