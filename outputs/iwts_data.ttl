iwts_performer:9565 a schema:Organization;
  schema:name "Viter Ukrainian Dancers and Folk Choir";
  schema:description "Edmonton’s Viter Ukrainian Dancers and Folk Choir are internationally acclaimed for their energy, innovation, and passion for Ukrainian Canadian culture. Over the last 30 years, Viter has grown from a small dance group to a renowned ensemble of dancers, choristers and musicians. They have performed for appreciative audiences worldwide, including Ukraine on five separate occasions. Today, Viter stands among Canada’s major performing ensembles, blending traditional Ukrainian folk art with modern themes.";
  schema:url <https://www.viter.ca/>;
