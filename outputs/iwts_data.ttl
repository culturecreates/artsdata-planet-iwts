iwts_performer:6541 a schema:Person;
  schema:name "Ethan Harrison Smith";
  schema:description "Ethan Harrison Smith is a North Georgia-based folk singer/songwriter who performs with acoustic guitar and harmonica. As a teenager, Ethan hoped to become a great bluegrass flatpicker, but switched his focus to songwriting after discovering folk artists such as Bob Dylan, Cat Stevens, Bright Eyes, and Josh Ritter. Ethan has won songwriting and performance competitions in a variety of music venues and performs regularly across the southeastern United States. He has also performed in countries including England, Malaysia, Hungary, and Poland.";
  schema:url <http://ethansmithmusic.com>;
