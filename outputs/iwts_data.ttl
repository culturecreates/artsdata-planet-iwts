iwts_performer:7884 a schema:PerformingGroup;
  schema:name "DeeDee Austin";
  schema:description "DeeDee Austin, 20 years old, Indigenous pop powerhouse from the Abegweit First Nation. DeeDee captivates crowds in seconds, before the first chorus lands, she's already won the room. With a voice that carries power and vulnerability, she weaves motivation, Inspiration, and lived experience into every note. DeeDee doesn't just sing, she tells stories of resilience, hope and purpose-turning each performance into a shared journey. Through song, she ignites emotion, uplifts spirits, and leaves audiences feeling seen, energized and ready to rise...";
