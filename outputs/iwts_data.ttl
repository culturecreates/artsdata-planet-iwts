iwts_performer:10072 a schema:Person;
  schema:name "Kyle";
  schema:description "Winnipeg-born vocalist Kyle Briscoe (he/him) is an interdisciplinary artist whose work explores healing and identity through performance. Working across opera, musical theatre, and pop, he combines classical training with original music and self-produced projects. A survivor of domestic violence living with PTSD, Kyle is committed to uplifting survivors and the 2SLGBTQIA+ community through music. He holds a Master of Music from McGill University and is a Jacqueline Desmarais Opera Fellow.";
  schema:url <https://sites.google.com/view/kyle-briscoe/get-in-touch?authuser=0>;
