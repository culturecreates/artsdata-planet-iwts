iwts_performer:8038 a schema:PerformingGroup;
  schema:name "Dan Cugnet";
  schema:description """Dan Cugnet burst onto the Canadian Country, Americana & Folk music scene in the Fall of 2021 releasing his debut album “Rodeo Cabaret” to critical acclaim. Since that time he has steadily wrote, recorded & released original music at an almost unheard of and blistering pace with his eighth full length album of original songs “Raven on a Ribcage” debuting on all streaming platforms April 2026.
The history, stories, people & prairie of Saskatchewan continue to inspire Dan to write the songs about the place he feels fortunate to call home.""";
  schema:url <https://www.instagram.com/incugneto>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
