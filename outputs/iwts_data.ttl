iwts_performer:5648 a schema:PerformingGroup;
  schema:name "Geri Hall and Gary Pearson";
  schema:description "Middle Raged is a 2 person sketch show starring Geri Hall who is well known for This Hour Has 22 Minutes (CBC), One More Time (CBC), Astrid and Lilly Save the World (CTV) and many more film and television projects. She is a veteran of The Second City Mainstage in Toronto. Gary Pearson is best known for writing Corner Gas (CTV), MadTV (Fox), The Ron James Show (CBC) and for creating Sunnyside for (RogersCityTV) and That's So Weird (YTV). Both Gary and Geri have extensive experience with sketch and improv comedy. The duo has won multiple awards.";
