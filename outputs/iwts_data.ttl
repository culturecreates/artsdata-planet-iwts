iwts_performer:10060 a schema:PerformingGroup;
  schema:name "Eagle Peak Trio";
  schema:description "Three celebrated musicians—Ian Parker (piano), Calvin Dyck (violin), and Oliver de Clercq (horn)—come together for an unforgettable evening of music. The program features some the most beloved romantic chamber works, including the iconic Brahms Horn Trio and César Franck’s monumental, deeply moving Sonata in A Major for Violin and Piano.";
