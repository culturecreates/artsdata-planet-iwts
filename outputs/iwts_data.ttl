iwts_performer:9858 a schema:Person;
  schema:name "Jack Pine";
  schema:description "Jack Pine’s namesake tree is the rising phoenix of a raging forest fire. He sings JUNO and CFMA Award nominated tunes blending Canadiana songwriting with alt-folk slacker attitudes.  Playing acoustic instruments with electrified energy, smouldering intensity, and lyrics that point to the beauty in the wreck and the heart of the wretch.  Jack howls and spits modern folk wisdom - at once biting and inspiring - mandolin and guitars play furious rhythms and gentle melodies too... But in the end, he's all about real good tunes for real dark times.";
  schema:url <http://jackpinefire.com>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
