iwts_performer:9429 a schema:PerformingGroup;
  schema:name "80Something";
  schema:description """80Something is a brand new project spearheaded by Juno-nominated vocalist Andrea Superstein and includes a who's who of the Vancouver jazz scene. 80Something breathes fresh life into your favourite 1980's rock, pop and metal songs with a jazz twist. It also reimagines some popular Jazz Standards that are about 80 years old, with a contemporary twist. 

It's Corey Hart, Cyndi Lauper and La Vie en Rose  like you've never heard before.

80Something brings the joy and will have you singing along to all your favourite oldies.""";
  schema:url <https://www.andreasuperstein.com>;
