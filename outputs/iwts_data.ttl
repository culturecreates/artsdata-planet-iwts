iwts_performer:9788 a schema:Person;
  schema:name "Hilary Adams";
  schema:description "Hilary Adams is a folk indie artist from Dartmouth, Nova Scotia, known for her soulful melodies and heartfelt lyrics. She gained national attention with “Sending Love” which resonated with listeners across Canada for its portrayal of spending the holidays away from family. Her discography includes her debut LP, four singles and an EP. Adams has also composed for short films and theatre across Ontario and Nova Scotia. Her singles, “Wildflower: Lakeview Version,” and “Hold Me” were released last fall and were both featured in the film \"LAKEVIEW\".";
  schema:url <https://hilaryadamsmusic.com/>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
  schema:genre "Folk/Bluegrass/Americana";
