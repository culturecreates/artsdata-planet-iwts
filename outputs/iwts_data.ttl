iwts_performer:9455 a schema:PerformingGroup;
  schema:name "Mark Perry";
  schema:description "Mark Perry calls what he does, “Northwest people music” and going to one of his concerts is like taking a Canadian road trip. He takes us into rural Canada, the spirit of its people, the power of its landscapes and the impacts of some unique historic events. He is one of northern Canada’s great storytellers, known and loved for his relatable songwriting, intra-song banter and down home performance style.";
  schema:url <https://markperry.ca/>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
