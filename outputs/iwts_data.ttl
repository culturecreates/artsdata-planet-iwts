iwts_performer:5322 a schema:PerformingGroup;
  schema:name "Brigade";
  schema:description "Brigade - A Heart Tribute is an Alberta-based act delivering a powerful, authentic live experience celebrating the legendary music of Heart and the Sisters of Rock - Ann & Nancy Wilson.  Featuring seasoned musicians, Brigade recreates every nuance of the band's iconic sound across three decades, from soaring ballads to hard-hitting rock anthems.  Their high-energy, polished performances bring hits like \"Barracuda\", \"Alone\", and \"Crazy on You\" to life with precision and passion, offering audiences a dynamic, unforgettable concert experience.";
