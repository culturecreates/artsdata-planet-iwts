iwts_performer:6422 a schema:PerformingGroup;
  schema:name "Windborne";
  schema:description """With a 25-year background studying polyphonic music, Windborne shares a vibrant energy onstage-a blending of voices that can only come from decades of friendship alongside dedicated practice. The ensemble shifts effortlessly between different styles of music, drawing their audience across continents & centuries, illuminating and expanding on the profound power and variation of the human voice.
Windborne also melds music with message, singing songs from past movements for social struggle that is strikingly relevant to the contemporary listener.""";
  schema:url <http://Windbornesingers.com>;
