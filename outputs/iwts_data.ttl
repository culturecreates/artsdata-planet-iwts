iwts_performer:9840 a schema:Person;
  schema:name "Elizabeth Sheppard";
  schema:description "Elizabeth Sheppard is a Mi’kmaw folk pop singer-songwriter from Corner Brook NL, living in St John’s, NL. Her sound has been compared to Joan Baez, Joni Mitchell, Karen Carpenter and Olivia Newton-John. Elizabeth has been nominated for 2025 Indigenous Artist of the Year with Music  NL. She has released 6 singles, 3 music videos and is currently finishing her first full length album. A therapist for 33 years, her songs address  the themes of love, loss and resilience because, she says “ life can be messy but healing doesn’t have to be”.";
  schema:url <https://www.elizabethsheppardmusic.ca/>;
