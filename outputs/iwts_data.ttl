iwts_performer:7809 a schema:PerformingGroup;
  schema:name "Danny Bell and His Disappointments";
  schema:description """Band arrangement: Accordion player and singer-songwriter with electric guitar, bass, and drums.  

Danny Bell and His Disappointments play western-folk-psych-punk.  They live on the unceded territory of the Lhedli T’enneh in Northern British Columbia.  Exclaim! Magazine called their sophomore release an “anti capitalist, anti-elitist, anti-asshole folk record for small moments in small places.”  The band’s latest album, “Contemporary Accordion Music” charted in the top 50 across Canadian Campus and Community Radio.""";
  schema:url <http://www.dannybell.org>;
