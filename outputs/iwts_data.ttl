iwts_performer:9096 a schema:PerformingGroup;
  schema:name "Eliana Cuevas Venezuelan Duo";
  schema:description "Award-winning Venezuelan vocalist Eliana Cuevas presents her Venezuelan Duo, an intimate project for voice and cuatro that highlights the richness of Venezuelan folk traditions. Blending jazz-infused originals with reimagined classics, the duo delivers raw, soulful, and adventurous performances that showcase virtuoso cuatro playing and Eliana’s powerful, expressive voice, inviting audiences on an emotional journey into the heart of Venezuelan music.";
  schema:url <https://elianacuevas.com/site/>;
