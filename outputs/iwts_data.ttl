iwts_performer:9930 a schema:PerformingGroup;
  schema:name "The Joni Mitchell Experience";
  schema:description "Inspired by David Yaffe’s biography Reckless Daughter, The Joni Mitchell Experience is a chronological journey through the life and music of one of the most influential artists of our time. Acclaimed vocalist Lauren Fox and pianist/narrator Andrew Powers weave iconic songs and storytelling to trace Joni’s fearless evolution from folk to jazz and pop—revealing an artist who defied expectations, never compromised her vision, and forever changed music.";
  schema:url <https://www.bicoastalproductions.com/lauren-fox>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
