iwts_performer:9604 a schema:PerformingGroup;
  schema:name "TapWater";
  schema:description """TapWater is a live \"World Twang\" experience out of Portland, OR bringing musical inspiration from around the world right back home to your front porch. 
The band’s homegrown humor and down-to-earth style complement their sound seamlessly while smart songwriting, polished musicianship and knockout performances keep you coming back for more.
“I had as much fun making Shoebox Photographs with TapWater as about anything I’ve ever done.” 
- Steve Berlin of Los Lobos aka legendary, 6-time Grammy award winning producer.""";
