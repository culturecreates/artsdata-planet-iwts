iwts_performer:8884 a schema:Person;
  schema:name "Carla Jayne";
  schema:description "Carla Jayne is an Edmonton-based singer-songwriter who explores her folk country roots through themes of home and leaving it. Originally from Hanna, Alberta, her catchy melodies and timeless lyrics evoke the work of Sheryl Crow, Brandi Carlile and Joni Mitchell. Chinooks and Sea Monsters, her FACTOR-funded debut EP, was recorded at Royal Studios in Edmonton. Released in April 2024, it garnered radio play across Canada and earned a spot on the Edmonton Journal’s Fresh Tracks list of “10 Must-listen Albums from Edmonton Artists in 2024”.";
  schema:url <https://carlajayne.noiseyard.com/>;
