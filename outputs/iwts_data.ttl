iwts_performer:9511 a schema:PerformingGroup;
  schema:name "Feed The Beast";
  schema:description "Singer-songwriter Abigail Galwey has pondered a question that cuts to the core of her artistry: What defines her sound? Yes, it’s trip-hop, laced with punk, avant-garde pop, and electronic influences, but it’s so much more. It’s an experimental journey into the depths of self-discovery, tackling the age-old queries of identity and desire. Abigail confronts the lurking beasts within and outside of us—those shadows that prey on our vulnerabilities.";
  schema:url <https://www.feedthebeastmusic.com/>;
