iwts_performer:9486 a schema:PerformingGroup;
  schema:name "Rebecca Northan";
  schema:description """Spontaneous Theatre specializes in crowd-pleasing, critically 
acclaimed  productions that respectfully break the \"fourth wall\". From \"audience participation lite\", to fully casting an audience member in a starring role, Spontaneous Theatre is known across Canada for Blind Date, Undercover & Legend Has It. Most recently, Goblin:Macbeth & Goblin:Oedipus are delighting fans of the classics, while enticinfg 20-somethings into theatres for the first time. They are also creating a new interactive murder mystery for the Shaw Festival in 2025.""";
