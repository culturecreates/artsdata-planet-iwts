iwts_performer:9150 a schema:Person;
  schema:name "Sujit Vaidya";
  schema:description "I am an independent dance artist living and working on the MST territories, aka Vancouver. Trained in Bharatanatyam, I approach the form as an evolving inheritance shaped by embodied memory and intergenerational lineage. My practice holds space for multiplicity, fluidity, and transformation. I investigate the body as a site of negotiation between structure and rupture. Engaging with themes of eroticism, gaze, intimacy, and stillness, I am invested in slowness as aesthetic strategy and in reframing virtuosity through non-Eurocentric lenses.";
  schema:url <https://www.sujitvaidya.ca>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/DancePerformance>;
