iwts_performer:10168 a schema:PerformingGroup;
  schema:name "Dendê Maced";
  schema:description "Celebrated for his infectious energy and masterful command of percussion, Dendê Macedo is a trailblazer in Afro-Brazilian music, blending Bahia’s rich sacred and popular traditions, including the ceremonial rhythms of Candomblé and the vibrant, community-driven sounds of samba and bloco afro, with global influences such as rumba, Afrobeat, and mbalax, delivering electrifying performances alongside his powerhouse band.";
