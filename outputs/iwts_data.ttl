iwts_performer:9333 a schema:Person;
  schema:name "Sadé Awele";
  schema:description "Sadé Awele is a Vancouver-based artist of Nigerian heritage. Recently awarded Western Canadian Music Awards R&B artist of the Year 2024. Recently performed at the Road to the Junos event in Vancouver. Sadé combines afrosoul and R&B to create an alluring sound. She's known for her melodies that stand out, with conscious songwriting while implementing her culture through subtle odes, be it in fashion or in the music itself. The type of artist who can turn a heartbreak song to a rhythmic celebration. Every element of her art is intentional.";
  schema:url <https://www.sadeawele.com>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
