iwts_performer:7023 a schema:PerformingGroup;
  schema:name "Kylie Fox";
  schema:description """Kylie Fox is equal parts Canadiana queen, free-spirited songbird, and tree hugging feminist. Her brand of Americana blends humour, wit, and 70s glitz to tell stories rooted in Canadian culture and sharply original observations of the world around her.  

Her joyous stage presence, two albums releases, and years of touring have amassed Fox a dedicated fanbase, an ECMA nomination for Solo Artist of the Year, and 3 nominations at the PrixNB awards in 2025.

She's also a Dolly Parton impersonator, a vocal coach, and a musical theatre composer.""";
  schema:url <https://kyliefox.ca/>;
