iwts_performer:1469 a schema:PerformingGroup;
  schema:name "The Whiskey Jerks";
  schema:description "Playing venues and festivals from Vancouver to Ottawa, The Whiskey Jerks have been entertaining audiences since 2012 with a sound that is rife with originality, sweet vocal blends, and a distinct whiskey-soaked sensibility! Soon after Gillian Snider decided to expand her one-woman accordion show, The Whiskey Jerks began to create their own distinct niche, blending klezmer, rock, folk and jazz with clever lyrics and an honest prairie sound. With two albums and two singles under their belt, a new EP is scheduled to be released in June, 2025.";
  schema:url <http://www.whiskeyjerks.com>;
