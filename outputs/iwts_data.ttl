iwts_performer:8983 a schema:PerformingGroup;
  schema:name "This Story";
  schema:description """Hailing from Regina, Saskatchewan, This Story began in the early 2000's as an acoustic trio acclaimed for their seamless weaving of heartfelt storytelling, intricate melodies, and innovative musicianship.  After reflection and time away, these life-long friends have returned with renewed motivation, focus and creativity. 

In their newest chapter, This Story has expanded their sound  to include intricate electric leads, rhythmic drums and bass. They are excited to be writing, performing and releasing music again as a full 5-piece ensemble.""";
  schema:url <https://linktr.ee/thisstoryband>;
