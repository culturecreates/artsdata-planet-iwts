iwts_performer:8103 a schema:PerformingGroup;
  schema:name "Jon Lehrer Dance Company";
  schema:description "Jon Lehrer Dance Company (JLDC) began in 2007 in Buffalo, NY and has received critical acclaim nationally and internationally. Jon moved the company to his hometown of NYC in 2019, where they have become a vibrant addition to the city’s dance community. Under Jon Lehrer’s artistic direction, the company showcases his unique choreography and definitive style. His extensive background in both the modern and jazz dance idioms fosters choreography that is organic, athletic, artistic, entertaining, and often humorous, reflecting human experiences.";
