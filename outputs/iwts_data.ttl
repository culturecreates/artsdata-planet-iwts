iwts_performer:9415 a schema:PerformingGroup;
  schema:name "La Famille Leblanc";
  schema:description """In the lands bathed by Atlantic tides, where pine trees meet the waves and stories are passed down through song, rises the singular voice of La famille LeBlanc. Hailing from New Brunswick, at the heart of Acadia, this family group embodies the soul of a people who sing so as not to forget.

Made up of parents and their three daughters, La famille LeBlanc performs 19th-century tunes deeply rooted in Acadian and Celtic traditions, musical treasures often unknown to other Celtic nations such as Ireland, Scotland, and Brittany.""";
  schema:url <https://en.agenceresonances.com/familleleblanc>;
