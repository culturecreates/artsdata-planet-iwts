iwts_performer:9440 a schema:Organization;
  schema:name "Nicolas";
  schema:description """À Sherbrooke, le ZemmourBallet a vu le jour sous l’impulsion de Nicolas Zemmour sous la forme d'une fondation privée reconnue de bienfaisance au Canada. Fondée le 19 octobre 2019, la compagnie s'est rapidement affirmée comme un acteur majeur de la danse dès 2020, avec pour mission de créer et de diffuser des œuvres chorégraphiques innovantes.
Nicolas Zemmour, avec une vision claire et audacieuse, souhaitait non seulement développer ses propres créations, mais aussi offrir une plateforme de diffusion aux chorégraphes.""";
  schema:url <https://www.zemmourballet.org/accueil>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/DancePerformance>;
  schema:genre "Classical";
  iwts:consent "agree_v_1.0";
