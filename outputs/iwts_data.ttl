iwts_performer:9328 a schema:Person;
  schema:name "Mary Liv";
  schema:description "Mary Liv is an emerging artist, performing old time and original music. With years of experience as a music teacher, she takes her life experiences to educate and entertain her audiences. As Mary Liv, she has played such venues as The Bassment (Saskatoon), E A Rawlinson (PA), and Northern Lights Bluegrass Festival (SK).  Her performances have a balance of traditional tunes and songs as well as clever and heartfelt originals sharing funny stories and true life tales. With a mix of banjo, fiddle, and guitar, Mary Liv will get you dancin’!";
  schema:url <https://marylivmusic.square.site>;
