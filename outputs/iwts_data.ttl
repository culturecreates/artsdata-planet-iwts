iwts_performer:9781 a schema:PerformingGroup;
  schema:name "Geoff Arsenault";
  schema:description "Singer songwriter in the Americana blues vein. Geoff Arsenault is an award winning, veteran touring and recording artist. His unique style behind the drum kit has taken him across North America  all through Europe and the UK. He has three solo recordings to his name with his recent release being his most ambitious. His music sits somewhere between JJ Cale and Tony Joe White.  A swampy blues roots music style tinged with Tex-Mex and New Orleans blues.";
