iwts_performer:845 a schema:PerformingGroup;
  schema:name "Joelle Rabu";
  schema:description "Spanning 4 decades, Canadian songstress and actor Joëlle Rabu has won international acclaim for her theatrical roles including the portrayal of Edith Piaf.  she toured through 5 continents and performed 2000+ shows. Joelle has played leading theatre roles in: ‘Cabaret’, ‘Irma la Douce’, ‘John Gray’s Don Messer’s Jubilee’, ‘Anything Goes’ and ‘Marion Bridge’. Off stage, Joëlle is a host/ writer for Knowledge Network, French CBC and featured in ‘Passeport Musique’. She has released 8 albums.";
  schema:url <http://www.joellerabu.com>;
