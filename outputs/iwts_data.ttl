iwts_performer:9753 a schema:PerformingGroup;
  schema:name "Many Worlds";
  schema:description "Many Worlds is an ensemble shaped by chance—an idea rooted in a life-changing accident I survived in 2012. That event, and my recovery, instilled a worldview centered on possibility, consequence, and improvisation. Our music blends composed frameworks with dice-generated parts, reimagined before each performance. Rooted in Jerry Granelli’s improvisational lineage, we embrace unpredictability as process.";
  schema:url <https://manyworldsband.com>;
