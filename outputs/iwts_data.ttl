iwts_performer:7412 a schema:Person;
  schema:name "Andee Joyce";
  schema:description "In her solo musical comedy, RHYTHM AND AUTISM, Andee Joyce tells the story of an autistic woman who spent most of her life hidden away, convinced no one would want to listen to her -- and now goes onstage multiple times a week to sing and talk about her autism, getting audiences clapping and swaying (and flapping!) to her beat, and laughing and nodding at her jokes, everywhere she goes. Her story of transformation and release is a full-throated call for inclusion, and a thunderously joyous invitation for everyone to be everything they are.";
  schema:url <http://rhythmandautism.com>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/TheatrePerformance>;
