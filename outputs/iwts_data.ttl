iwts_performer:10316 a schema:PerformingGroup;
  schema:name "Suitcase Stories created & performed by Maki Yi";
  schema:description "One newcomer, one carry-on, one hilariously epic search for freedom! Suitcase Stories created/performed by Maki Yi (starred as “Umma” in the national tour of Kim’s Convenience). With only a tiny suitcase in tow, Maki Yi leaves her home in South Korea and winds up in Regina. She finds that her new life in Canada is both everything she hoped for and the most difficult thing she has ever faced. A ludicrous and vulnerable real-life tale of faith, survival, and self-discovery. Audience Advisory: Includes discussions of racism, addiction & self-harm.";
  schema:url <https://burntthicket.com/suitcase>;
