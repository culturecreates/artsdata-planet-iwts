iwts_performer:10144 a schema:Person;
  schema:name "Liora Michelle";
  schema:description """Lyric soprano Liora Michelle has performed more than twenty leading operatic roles, with opera and concert engagements in Japan, Europe, Australia, and the United States.

Solo appearances also include Rodgers & Hammerstein and Cole Porter tribute tours, summer concert series, touring variety programs, Carols by Candlelight events, and diverse cultural, civic, and commercial events.

A versatile artist working across opera and cabaret, Michelle has received critical acclaim and is a two-time MAC Award nominee and a BroadwayWorld Award nominee.""";
