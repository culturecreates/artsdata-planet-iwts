iwts_performer:10045 a schema:PerformingGroup;
  schema:name "Gay4Nature Collective";
  schema:description "Gay4Nature Collective is a creative music collective dedicated to the amplification of queer joy, connection, and advocacy for nature at the intersection of sound, movement, and drama. Drawing on tools like Western classical music, contemporary dance, theatre, and film, founders Anna Bigland-Pritchard and Alex Chen assemble teams of innovative artists to grapple with experiences of climate crisis, queer love, friendship, and finding a way forward in a fraught modern world.";
