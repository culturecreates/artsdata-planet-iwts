iwts_performer:10154 a schema:PerformingGroup;
  schema:name "The Western Thistles";
  schema:description "The Western Thistles are an Edmonton folk duo known for their clawhammer banjo, rhythm guitar, and rich vocal harmonies. Blending old-time roots with modern-day storytelling, they create a sound that’s raw, resonant, and heartfelt. Their self-titled debut album, recorded live off the floor and co-produced by Miles Wilkinson (Emmylou Harris, Guy Clark), reached #26 on CKUA’s Top 100 most-played albums of 2025.";
