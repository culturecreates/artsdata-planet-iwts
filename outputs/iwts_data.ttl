iwts_performer:9584 a schema:Person;
  schema:name "Amy Blanding";
  schema:description "Amy Blanding is a queer, disabled musician who is unapologetically creating art that needs to be heard. Known for her profound songwriting and electric stage presence, Amy collects moments in the wild and turns them into stalwart folk songs with a raw edge. With the viral release of her single Sunbirds to international acclaim and her highly anticipated sophomore album slated for release Fall 2025, Amy’s original protest folk seamlessly bridges the gap between audience, artist, and advocacy toward a greater possibility for the collective";
  schema:url <https://www.amyblanding.com/>;
