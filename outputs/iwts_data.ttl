iwts_performer:6928 a schema:Person;
  schema:name "Ariana Pirela Sánchez";
  schema:description """Ariana Pirela Sánchez is a Venezuelan-born contemporary dance artist based in Montréal (Tiohtià:ke/Mooniyang). A performer and choreographer, her work explores migration, endurance, and the subtle dynamics of presence between bodies.

Her choreographic language combines physical intensity with finely detailed movement, creating performances that are both rigorous and intimate. Founder of MOVARI Danse, she develops touring-ready works that bridge contemporary creation with community engagement.""";
