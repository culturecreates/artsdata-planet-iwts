iwts_performer:10106 a schema:Person;
  schema:name "Mary Elizabeth Mikels";
  schema:description "Mary Mikels’ story is one of extraordinary resilience and determination. Born totally blind without eyes or optic nerves, with hearing loss in her left ear and with only half of a nose, she was born with near perfect pitch and a remarkable three octave range. Through Broadway favorites, classic songs and operatic selections, Mary inspires audiences across the Southeast with uplifting concerts. Her journey includes participation in American Idol and a memorable backstage meeting with Andrea Bocelli during his 2024 Love Tour.";
  schema:url <https://www.blindnotesmusic.com>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
  schema:genre "Musical Theatre";
