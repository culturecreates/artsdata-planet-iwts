iwts_performer:9532 a schema:PerformingGroup;
  schema:name "Tubbman Junction";
  schema:description """Tubbman Junction is a rich stew by the fire, or a cool drink on a warm summer day. Local & homegrown, natural & organic, wholesome, hearty, desirable, delicious, stick to your ribs kind of goodness. Join Joule & Riley on a harmonious journey through life on the land with their original music.

The duo is known for digging into your deep feelings like digging into the dusty old trunk where songs have been stored for a decade, bringing tears & smiles and healing hearts with a soul connection that can only be described as electric, acoustically.""";
  schema:url <https://linktr.ee/tubbman_junction>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
