iwts_performer:8995 a schema:Organization;
  schema:name "PUSH FOLD";
  schema:description "push/FOLD is an interdisciplinary performance company integrating original music, contemporary dance performance, and education. Based in Portland, OR, push/FOLD’s projects range from intimate site-responsive and smaller theatrical works to large-scale productions, including collaborations that merge contemporary dance with live vocal ensembles. push/FOLD’s immersive programs invite audiences into a world of power, beauty, and transformation, delivering performances, workshops, residencies, and community programs across the US.";
  schema:url <https://www.pushfold.org>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/DancePerformance>;
