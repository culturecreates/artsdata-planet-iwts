iwts_performer:9655 a schema:PerformingGroup;
  schema:name "The Harpoonist";
  schema:description "Meet Harpoonist (aka Shawn Hall) a harpoon/harmonica virtuoso with deep roots in blues-rock, best known from The Harpoonist and the Axe Murderer. Now teamed up with Gordie Johnson (Big Sugar) and Jonas Shandel, Hall returns with gritty, swampy new music, raw edge, and offbeat lyrics. Their debut single, Did We Come Here to Dance, dropped Nov 8, 2024, with plenty more on the way.";
