iwts_performer:9654 a schema:Person;
  schema:name "Aaron Larget-Caplan";
  schema:description "With over 1000 concerts across Europe, Russia, Taiwan, and 11 solo albums with over 10 million streams, the American classical guitarist virtuoso and composer AARON LARGET-CAPLAN finds life in music & music in life. He directs and curates the Spanish dance ensemble ¡Con Fuego!, creates educational programming, and has multiple contemporary music projects. An eloquent performer and speaker, he connects to audiences with a Bernstein-like ease. Raised in Colorado, he lives in Boston on faculty at the New England Conservatory.";
