iwts_performer:10222 a schema:PerformingGroup;
  schema:name "Melafrique";
  schema:description """Melafrique, an Afro-fusion powerhouse, took root in Edmonton, Canada, in 2016. Deriving its name from \"Melanin from Africa,\" Melafrique synthesizes a rich tapestry of genres Soul, R&B, Reggae, Pop, Jazz, and Neo-soul with diverse African musical traditions. Their mission? To ignite the world with the transformative power of music.

At the heart of their sound lies a celebration of identity, African, Caribbean, musician, Edmontonian all woven seamlessly into their sonic fabric.""";
  schema:url <https://www.youtube.com/watch?v=CvAijiAoMP8&list=PLddT2A24-3WYZzEhhR39qkFw0RU1OxI8G>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
