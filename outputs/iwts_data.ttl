iwts_performer:8155 a schema:PerformingGroup;
  schema:name "Boy Band Evolution- Doo Wop To Pop";
  schema:description """Doo Wop To Pop- The Evolution of Music
A Musical Journey from Barbershop Quartets to Modern Hits. Explore the past, present, and future of music genres in one unforgettable night. Join us as we blend timeless classics from the '50s, '60s, and '70s with today's greatest hits. Featuring the smooth choreography of the Jackson 5, the tight harmonies of Frankie Valli and the Four Seasons, and unique arrangements from the Beatles, Backstreet Boys, Bruno Mars and the Motown era. Take a memorable journey through the evolution of music with us!""";
  schema:url <https://www.boybandevolution.com>;
