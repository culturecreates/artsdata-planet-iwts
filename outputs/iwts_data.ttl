iwts_performer:10067 a schema:Person;
  schema:name "Lisa Randall";
  schema:description "Lisa Randall is a Toronto-based actor, playwright, songwriter, and arts facilitator whose work spans theatre, music, movement, and community-engaged creation. Her plays include The Sorauren Book Club (Patron’s Pick, Toronto Fringe 2022) and Sister Sophia Kicks the Habit (Hamilton Fringe 2025). A performer across theatre, film, music, and summer theatre, Lisa also facilitates storytelling and improv workshops and brings 30 years of leadership in community arts and cultural programming for two museums for the City of Toronto.";
  schema:url <https://lisarandall.ca>;
