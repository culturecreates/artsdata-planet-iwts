iwts_performer:1728 a schema:Person;
  schema:name "Eric Harper";
  schema:description """What do you get when a suburban North American metalhead spends his teenage years in the classical conservatories of Portugal, then graduates Berklee Magna Cum Laude in Film Scoring, wins an Emmy, and ends up on Vancouver Island playing guitar that sounds like it's on fire?
You get Eric Harper. And there's nobody else quite like him.
His sound sits at a crossroads that shouldn't work on paper but absolutely does in a room: the percussive fury of flamenco, the aching melancholy of fado, the confessions of a songwriter and skill of a composer.""";
  schema:url <http://www.ericharpermusic.com>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
  schema:genre "Global";
