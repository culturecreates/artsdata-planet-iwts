iwts_performer:9895 a schema:PerformingGroup;
  schema:name "BACKBEAT";
  schema:description "Backbeat is a pop music Tribute act dedicated to the music of the sixties.  Backbeat has two shows; Let's Go Surfin', a remarkable Tribute to the music of the Beach Boys, and Pop Goes the Sixties, the pop hits of six of the most popular bands of that generation; The Monkees, The Beach Boys, The Who, The Beatles, The Rolling Stones and CCR.  Both shows feature stunning vocal performances, supported by mesmerizing visuals that transport the audience back to the greatest era of pop/rock!";
  schema:url <https://www.backbeatentertainment.ca/>;
