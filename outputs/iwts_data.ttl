iwts_performer:8996 a schema:PerformingGroup;
  schema:name "Fiyin Obayan";
  schema:description """Fiyin Obayan has steadily built a name for herself as a dynamic singer-songwriter blending gospel, jazz, R&B, and neo-soul. Her latest single, Walking by Faith, has received international recognition, with features on Sons do Guardinha (Brazil), Smooth Jazz Nights, EJazz Radio, Nam Radio, Montréal Radio Cité, LMCB (Brazzaville), Anointed 100.3, CHVN 95.1FM, and songweb.net.

A regular performer at the SaskTel Saskatchewan Jazz Festival since 2018, Fiyin is also YWCA Women of Distinction Award for Arts and Culture in 2022.""";
  schema:url <https://sites.google.com/view/fiyinobayanmusic>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
  schema:genre "Jazz/Blues";
