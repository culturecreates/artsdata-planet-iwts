iwts_performer:9822 a schema:PerformingGroup;
  schema:name "Dans l'Shed";
  schema:description "The Gaspé duo Dans l’Shed is composed of Éric Dion and André Lavergne. They share their joie de vivre and are characterized by a great musical complicity. Thanks to their mastery of their respective instruments (guitars, dobro, banjo, lap steel, etc.), they perform original compositions with folk-country-blues accents and colorful improvisational sections! Inspired by Americana folk music, they tell rural stories through characters with whom everyone can identify. They have toured in Canada, the United States, and Europe.";
  schema:url <https://www.facebook.com/danslshed>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
