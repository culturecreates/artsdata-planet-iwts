iwts_performer:9799 a schema:PerformingGroup;
  schema:name "Altered by Mom";
  schema:description "Altered by Mom is a smart, irreverent, and effortlessly cool rock band from Toronto, Canada. The female fronted trio brings a mix of catchy, well-crafted rock music with a rebellious edge and a sense of humor. JUNO-winning songwriters Gina Kennedy (Bass/Vox) and Devon Lougheed (Guitar, Vox), joined by Max Trefler (Drums) play with gender roles, lean into DIY creativity, and embrace a badass, fun, and authentic energy.";
