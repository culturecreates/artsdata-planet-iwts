iwts_performer:9715 a schema:PerformingGroup;
  schema:name "Hannah Kaminer";
  schema:description "Hannah Kaminer is a singer-songwriter writing songs about love, loss, and home. Raised in small towns in Western North Carolina, she fuses echoes of Appalachian and country traditions with wistful, Americana-style songwriting. She has released three albums: Acre by Acre (2015), Heavy Magnolias (2018), and Heavy on the Vine (2024) which she produced with her band, The Wistfuls. Hannah and the band were recognized for their song \"Broke Down Girl\" by the NYTimes and named one of the “Best Things We Saw at AVLFest 2024” by Rolling Stone.";
  schema:url <https://www.hannahkaminer.com>;
