iwts_performer:10033 a schema:Person;
  schema:name "David Trasoff";
  schema:description "David Trasoff is an internationally renowned performer of North Indian classical music on the sarode. He carries forward the legacy of his legendary teacher, sarode maestro Ustad Ali Akbar Khan, with whom he studied directly for 37 years. David has performed in concert to acclaim worldwide at a wide range of venues, including arts centers, universities, conservatories and festivals. As a recognized educator and scholar in Hindustani music he has worked to promote and disseminate this marvelous art form to the broadest range of audiences.";
  schema:url <https://davidtrasoff.com>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
  schema:genre "Traditional";
