iwts_performer:9453 a schema:Person;
  schema:name "Mia Kelly";
  schema:description "Through the lush folk and earthy Americana of her sophomore record “To Be Clear”, singer-songwriter Mia Kelly, from Gatineau, Quebec, Canada establishes herself as a spellbinding voice, blurring the lines between intimate memoir and compelling, semi-fictional narratives. Performing in both French and English, the 2X Canadian Folk Music Award winner enthrals listeners with a distinctive blend of Folk, Rock, and Blues, while swiftly gaining recognition for her rich, poetic lyricism.";
  schema:url <https://miakellymusic.com/>;
