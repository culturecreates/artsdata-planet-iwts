iwts_performer:9974 a schema:PerformingGroup;
  schema:name "Mister Showtime";
  schema:description """Mister Showtime: Old School Charm. New School Edge.

Forget the \"squeaky-clean\" crooner. Mister Showtime is a high-octane collision of singer Scott Wichmann and arranger Ryan Corbitt—imagine Bobby Darin’s suave musicality spiked with the chaotic wit of Conan O’Brien. This isn't a museum piece; it’s a masterclass in showmanship that injects the Great American Songbook with pure adrenaline. With a powerhouse vocal performance, Wichmann blends original songs and Gen-X pop reimagined for an 8-piece band or jazz trio. A cross-generational slam dunk.""";
  schema:url <https://www.mistershowtime.com/>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
  schema:genre "Jazz/Blues";
  iwts:consent "agree_v_1.0";
