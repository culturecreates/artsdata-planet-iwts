iwts_performer:10124 a schema:Person;
  schema:name "Robert Sims";
  schema:description "Robert Sims, lyric baritone, is renowned for his rich, resonant voice and captivating stage presence. Recognized internationally for his artistry, Sims has earned praise for his interpretations of African American spirituals and concert repertoire including Broadway and the canon of American Song. He has graced prestigious venues such as Carnegie Hall, Lincoln Center, the Kennedy Center, and major concert halls across Europe, Asia, and North America. In addition to his solo work, Sims works with choirs, culminating in a joint performance!";
  schema:url <https://www.marianliebowitz.com/robertsims>;
