iwts_performer:9496 a schema:PerformingGroup;
  schema:name "Chants Libres";
  schema:description """Founded in 1990 by soprano Pauline Vaillancourt, Chants Libres pioneers contemporary opera, collaborating across disciplines to explore new vocal techniques. With 19 productions, it has earned a strong reputation in multidisciplinary opera.

Since 2022, mezzo-soprano Marie-Annick Béliveau has led the company, continuing its research-creation focus. A key figure in contemporary music, she won the Prix Opus for Canti del Capricorno and has premiered over 30 works.""";
  schema:url <https://www.facebook.com/MarieMezzoSoprano>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
