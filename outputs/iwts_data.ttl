iwts_performer:7257 a schema:PerformingGroup;
  schema:name "Little Misty";
  schema:description """Defying easy categorization, Little Misty stands out as a captivating fusion of progressive folk and indie rock. Hailing from Montreal, Canada, the group is led by long-time friends Kathryn Samman and Francois Jalbert. While deeply rooted in the traditions of Appalachian folk music, the legacy of their home city’s rich musical heritage is strongly infused in their songs.

Their repertoire, driven by an insatiable curiosity, ranges from cinematic landscapes to whimsical arrangements and epic guitar solos, always in service of storytelling.""";
  schema:url <http://www.littlemistyband.com>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
  schema:genre "Folk/Bluegrass/Americana";
