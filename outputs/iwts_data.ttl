iwts_performer:10069 a schema:Person;
  schema:name "Ella Eva West";
  schema:description "Ella Eva West is a Canadian artist blending the intimacy of bluegrass storytelling with the warmth of country and traditional folk. After growing up playing in concert band and singing in choir, she fell in love with folk music in the summer of 2025 while working in the Yukon. Jam sessions and gatherings in her trailer inspired her to begin writing songs. Inspired by Sierra Ferrell, Joan Baez, and Dolly Parton, she is currently recording her debut EP, set for release in 2026.";
  schema:url <https://ellaevawest.squarespace.com>;
