iwts_performer:10218 a schema:Organization;
  schema:name "Mojuba! Dance Collective";
  schema:description """Mojuba! Dance Collective creates transformative performance, education, and community experiences rooted in African diasporic traditions, Black futurity, and embodied storytelling. We use dance as a living archive, a tool for healing, and a strategy for cultural continuity—connecting past, present, and future through movement.

We deliver culturally rooted, high-quality dance education and performance that uses African diasporic movement traditions to build embodied knowledge, artistic excellence, and collective liberation.""";
  schema:url <https://www.mojubadance.com>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/DancePerformance>;
  schema:genre "Traditional";
