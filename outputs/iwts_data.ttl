iwts_performer:9623 a schema:PerformingGroup;
  schema:name "Viento South";
  schema:description "Viento South is a lively Latin American folk music band based in Winnipeg, MB, with members from Mexico, Colombia, and Canada. The band blends original songs with popular covers in Spanish, French, and English, drawing from Colombian Andean music, Latin rhythms, Brazilian sounds, and jazz. With their infectious energy and passion, Viento South takes audiences on a musical journey that celebrates Latin America's rich cultural heritage, making every performance memorable.";
