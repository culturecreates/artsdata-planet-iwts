iwts_performer:9917 a schema:Person;
  schema:name "Marten Borch";
  schema:description """Marten Borch is known for his raw authenticity, heartfelt lyrics, and a deep commitment to using music as a tool for connection and change. Influenced by folk, Celtic, swing, and even a touch of EDM. His songs tackle themes of social justice, environmentalism, and the human experience.
Borch performs solo—but you’d never guess it. The sheer fullness of his sound, rhythm, and presence often leaves audiences convinced they’re hearing a full band. It’s an experience that turns every set into something bigger than the sum of its parts.""";
  schema:url <https://martenborchmusic.com/>;
