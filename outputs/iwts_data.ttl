iwts_performer:10113 a schema:PerformingGroup;
  schema:name "The Eric Byrd Trio";
  schema:description "The Eric Byrd Trio are internationally acclaimed jazz ambassadors whose sound blends swing, bebop, gospel, and blues with energy and soul. For 25 years, the Maryland-based trio has performed worldwide. Their recording Twenty won the 2022 Washington Area Music Award for Jazz Recording of the Year, and their latest release, Echoes of Arrival (2025), marks a bold new chapter. Former Kennedy Center/U.S. State Department Jazz Ambassadors, EBT continues to honor the tradition while pushing jazz forward.";
  schema:url <https://www.ericbyrdtrio.com/>;
