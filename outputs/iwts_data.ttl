iwts_performer:9408 a schema:PerformingGroup;
  schema:name "Gamelan Kembang Telang";
  schema:description "Gamelan Kembang Telang performs traditional and contemporary Balinese gamelan music. The ensemble’s unique instruments are associated with the most compact and innovative forms of Balinese gamelan. The group’s repertoire features contemporary works by Ryan Swaryandana and I Made Subandi which showcase bold new directions in techniques and styles. The ensemble’s name refers to the blossoming of the blue telang flower, a vibrant and medicinal plant which adorned the gamelan studio of I Made Subandi, the group’s late mentor.";
  schema:url <https://www.publiksecrets.com/kembangtelang/>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
