iwts_performer:10296 a schema:PerformingGroup;
  schema:name "Swift Silver";
  schema:description "Swift Silver is the songwriting partnership of Anna Kline and John Looney. Anchored by vivid lyrics and masterful musicianship, their sound is rooted in place. They’ve performed at MerleFest, Bristol Rhythm & Roots, Master Musicians Festival, CountryFest (Belgium), and Your Roots Are Showing (Ireland), with TV features on Bizarre Foods with Andrew Zimmern and ESPN’s True South. They regularly collaborate, co-write and record with their Appalachian music community. Swift Silver is a powerful voice in Kentucky’s musical legacy and evolution.";
  schema:url <https://www.swiftsilverband.com>;
