iwts_performer:9985 a schema:Person;
  schema:name "Jess B Parker";
  schema:description """Jess B Parker is an Indigenous and Irish Canadian singer/songwriter, actress, and multidisciplinary artist. Honesty, expression, and the transformative power of music are at the centre of her what she does, taking often painful emotions and turning them into something beautiful. An Indie songstress, she is proud of her Irish Canadian and Sagamok Anishnawbek First Nations 
identity, coming from a long line of singers and storytellers before her.""";
