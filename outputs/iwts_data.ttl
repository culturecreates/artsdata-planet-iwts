iwts_performer:9348 a schema:Person;
  schema:name "Digawolf";
  schema:description "Digawolf hails from the community of Behchoko, the capital of the T???ch? Nation, located in Canada’s Northwest Territories. His songs are often inspired by his father’s stories of life on the land, as well as his own experience of navigating two worlds. He has released 4 albums, all of them gaining national attention with airplay and multiple nominations for Junos, Western Canadian Awards, Canadian Folk Music Awards and Indigenous Music Awards. Touring solo to trio, Digwolf’s concerts are an invitation into Canada’s northern musical landscape.";
  schema:url <https://digawolf.com/booking>;
