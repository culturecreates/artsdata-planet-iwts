iwts_performer:10011 a schema:PerformingGroup;
  schema:name "Trio Hochelaga";
  schema:description "The Trio Hochelaga features violinist Anne Robert (ex-OSM), cellist Dominique Beauséjour-Ostiguy (Prix d’Europe), and pianist Dantonio Pisano. Blending heritage and innovation, the ensemble is renowned for its artistic integrity and precision. Since 2000, the Trio has performed globally, from Wigmore Hall to Palazzetto Bru Zane, and collaborated with major orchestras (OSM, Tokyo). With 12 acclaimed recordings, they have also produced their own concert series in Montreal for over 20 years.";
  schema:url <https://www.triohochelaga.com/>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
  schema:genre "Classical";
