iwts_performer:8205 a schema:PerformingGroup;
  schema:name "Quote The Raven";
  schema:description "Quote the Raven is an award-winning folk-pop duo known for haunting harmonies, sharp wit, and evocative storytelling. Blending East Coast narratives with Americana, their music has captivated audiences across Canada, the USA, the UK, Australia, and Germany. They've shared stages with Graham Nash, The Barenaked Ladies, Molly Tuttle, and more. With 1.5M+ streams and multiple awards, they now return with Map the Dark, their third studio album, out April 23, 2025.";
