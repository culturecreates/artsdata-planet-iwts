iwts_performer:10213 a schema:PerformingGroup;
  schema:name "Abigail Stauffer and The Wisdom";
  schema:description "Abigail Stauffer and the Wisdom blend soulful pop vocals with the rare and distinct sound of jazz cello. Dave’s fluid mastery over his instrument lays down a foundation over which Abigail effortlessly jumps between registers, revealing her astounding vocal control and tone palate. Every song is a captivating showcase of confidence and vulnerability, crafting a balance of pain, hope, and joy. Their show evokes so much emotion, it’s hard to believe each song isn’t specifically about you.";
  schema:url <https://greatlakespaa.org/our-roster/abigail-stauffer-and-the-wisdom/>;
