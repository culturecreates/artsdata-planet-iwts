iwts_performer:8572 a schema:Organization;
  schema:name "Inverso Productions";
  schema:description """Inverso Productions  creates  dance that is innovative, thought-provoking and multi-disciplinary. Inverso has produced four full-length works: Brittle Failure, Spooky Actions, Gem-like, and Borrowed Time. Our work has been presented nationally and internationally in Spain, the Netherlands and Canada.

Inverso’s focus is the continuum from emerging artists to professionals to older adults. By bringing artists from different stages of life in dialogue, we challenge age-based assumptions, and expand the field’s understanding of who dance is for.""";
  schema:url <https://inverso.ca>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/DancePerformance>;
