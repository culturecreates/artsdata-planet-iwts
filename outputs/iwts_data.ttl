iwts_performer:8280 a schema:PerformingGroup;
  schema:name "Proximus 5";
  schema:description "We are Proximus 5, a five-voice male a cappella group based on Treaty One Territory. Since our inception during the COVID-19 pandemic, we have shared a musical experience with “proximity” with over 2000 audience members across Canada & the U.S. We create closeness and connection through our welcoming stage presence, poignant harmonies, & heartfelt performances. Equally proficient in choral, folk, classical & pop music from the 1300s to today, our versatility & personability ensure that all audiences feel an authentic connection with our music.";
  schema:url <https://www.prox5.ca/>;
