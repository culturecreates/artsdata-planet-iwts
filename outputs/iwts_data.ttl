iwts_performer:9459 a schema:PerformingGroup;
  schema:name "Kutapira";
  schema:description """Zimbabwean Marimba, Afro-Cuban & West African rhythms, Reggae, Samba, Afrobeat, Funk, Jazz, Cumbia, Disco and Hip Hop all contribute to a fusion of styles intelligently selected, seamlessly blended and brought to you by Kutapira. 

The band is a crowd pleasing percussion explosion in schools, festivals, and PACs. Kutapira means “sweetness” in the Shona language of Zimbabwe, a fitting title for a band that plays a fusion of Zimbabwean marimba with West African and Afro-Cuban percussion.""";
  schema:url <https://www.kutapira.com/>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
