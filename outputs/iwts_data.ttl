iwts_performer:3988 a schema:PerformingGroup;
  schema:name "Svetlana Shmulyian";
  schema:description "Hailed a “NYC darling” by Time Out New York, Svetlana's New York Collective is an award-winning, internationally touring ensemble. Known for “exuberant, foot-stomping music” (WPIX 11), they blend swing, straight-ahead jazz, and originals with charismatic vocals and virtuoso improvisation. Their Billboard #1 album Night at the Movies amassed over 2M streams. They headline major venues worldwide (Carnegie Hall, etc) and lead the award-winning Swing Makes You Sing! program presenting 'jazz to kids' interactive shows, movement, and storytelling.";
  schema:url <http://www.swingmakesyousing.com>;
