iwts_performer:10122 a schema:PerformingGroup;
  schema:name "Black Crow Funk";
  schema:description "Black Crow Funk is the music project of Jody Funk, a Métis singer songwriter rooted in the western prairie plains. Her music blends folk, country and blues with raw, poetic storytelling. Her upcoming six song EP, Boiling Bones, is an intimate collection exploring resilience, love, and loss. She collaborates with Scott Baird, whose ethereal guitar textures deepen the emotional pull of her songs.";
  schema:url <https://linktr.ee/blackcrowfunkmusic>;
