iwts_performer:8430 a schema:Person;
  schema:name "Sara Porter";
  schema:description "Sara Porter is an adventurous performer, writer and vocalist working at the intersection of contemporary dance, improvisation, clown, storytelling and poetry. Sara Porter has created over 30 works since 1990, performing across Canada, US and UK. Noted for being truly multi-disciplinary and her wry sense of humour, Porter's work is rooted in her feminist Queer worldview and deals with the body as a point of personal reflection. “Sara does a Solo” about dancing after having kids; “Getting to know your fruit” as a Queer take on memoir.";
  schema:url <https://www.saraporter.ca/>;
