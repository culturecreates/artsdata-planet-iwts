iwts_performer:9748 a schema:Organization;
  schema:name "Green Thumb Theatre - Caged";
  schema:description "How can you navigate a relationship when you don’t even know what a healthy one looks like? Can a friendship survive the tension between love and control? After a summer apart, two teenage friends reunite in their secret park spot, where shared memories have always been a refuge. It all shifts when Ronnie brings her new boyfriend, Trev—a charming & increasingly controlling presence. His influence seeps into every part of Ronnie’s life; subtle red flags emerge. Ronnie is torn between the demands of her relationship & her deep connection to Jas.";
  schema:url <http://www.greenthumb.bc.ca>;
