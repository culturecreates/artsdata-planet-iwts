iwts_performer:10111 a schema:PerformingGroup;
  schema:name "Christin Hyshka and the Modern Sons";
  schema:description "Christin Hyshka & The Modern Sons deliver a heartfelt folk-roots/rock sound that blends honest storytelling with energetic performances that invite audiences to laugh, reflect, and sing along. Inspired by real life — the beauty, struggle, and humor that connect people — their songs bring authenticity to every stage. Featuring music from albums The First Word, Rescue, and unrecorded gems, they combine the intimacy of classic folk with the drive of modern roots-rock. With each performance the goal is the same, to make people feel something real.";
  schema:url <https://www.christinhyshkamusic.com/>;
