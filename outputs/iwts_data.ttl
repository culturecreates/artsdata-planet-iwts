iwts_performer:9941 a schema:PerformingGroup;
  schema:name "Kanola Band";
  schema:description "Kanola Band is a joyful, high-energy 7-piece ensemble that brings the spirit of New Orleans to life. With bold brass, soulful vocals, and grooves that make it impossible to sit still, they cover everything from traditional jazz and second-line to funk, soul, gospel, and R&B. More than just a band, Kanola shares the stories and culture behind the music, honoring the Crescent City’s rich legacy while creating meaningful moments of joy, connection, and celebration. Every show is a taste of New Orleans - full of heart, soul, and good vibes.";
  schema:url <https://www.kanolaband.com/epk>;
