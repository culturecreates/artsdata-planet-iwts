iwts_performer:10078 a schema:PerformingGroup;
  schema:name "Brady Lee";
  schema:description "Brady Lee delivers stadium-level country anthems with 3.6M streams, 60K global fans, and stages at Summerfest, Kansas State Fair, and a debut at Nashville’s Whiskey Jam (2025). A CMA member artist, Brady earned three Josie Music Award nominations — Entertainer of the Year, Country Artist of the Year, and Song of the Year. His Watertown Summers tour sold out a hometown theater and a Los Angeles date across 20+ U.S. markets including Vegas, Tampa, Nashville, and Chicago. Brady is built for the road and delivers an unstoppable show.";
  schema:url <https://www.thomasbradylee.com/>;
