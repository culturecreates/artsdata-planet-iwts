iwts_performer:17 a schema:Person;
  schema:name "Matthew Byrne";
  schema:description "After a long hiatus from the studio and the road, Matthew Byrne releases his 4th studio album, Stealing Time. This project brought him to Yellow Arch Studios in Sheffield, UK, where Byrne teamed up with folk legend Martin Simpson as producer. The album features instrumentation from some of the finest musicians on the English folk scene: Nancy Kerr, Andy Cutting, Liz Hanks, James Fagan, Louis Campbell, and Ben Nicholl. Stealing Time is available now as stream, download, CD, and vinyl LP.";
  schema:url <https://www.matthewbyrne.net>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
  schema:genre "Traditional";
