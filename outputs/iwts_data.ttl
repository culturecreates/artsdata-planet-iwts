iwts_performer:253 a schema:Person;
  schema:name "Johnny B.";
  schema:description "Johnny B. brings fifteen years of Pacific Northwest touring and an international award-winning catalog to every performance. His music has earned him Best Original Score at the Washington Independent Film Festival, Best Composer at the San Francisco Arthouse Short Film Festival and Best Talent Award at the Great Message International Film Festival in Mumbai, India.  After leaving Berklee College of Music in 1979, he has performed nationwide including his home state of Alaska where his hometown awarded him a Lifetime Achievement for the Arts.";
  schema:url <http://www.AlaskaJohnnyB.com>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
