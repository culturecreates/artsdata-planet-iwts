iwts_performer:10231 a schema:PerformingGroup;
  schema:name "Joe Alterman";
  schema:description "JOE ALTERMAN is a jazz pianist devoted to joy. A longtime mentee of Les McCann and Ramsey Lewis, he blends swing, soul, blues, and melodic clarity into a sound that is rooted in tradition yet unmistakably his own. He has released eight acclaimed albums, performed at the Kennedy Center, Lincoln Center, Birdland, and the Blue Note, and shared the stage with legends including McCann, Lewis, Houston Person, and Dick Gregory. He hosts The Upside of Jazz on Atlanta's NPR affiliate, WABE 90.1.";
