iwts_performer:9474 a schema:Person;
  schema:name "Gary Negbaur";
  schema:description "A “witty songwriter” (Austin Chronicle) with a “jazzy croon” (St. Louis Post Dispatch) who can “control the black and whites like Captain Kirk manning the Enterprise” (The Tennessean), pianist/vocalist/composer Gary Negbaur performs jazz, blues and American roots music across the country and around the globe from Tipitina’s and the French Quarter Fest in New Orleans to Birdland in NYC, from South by Southwest in Austin to the Copenhagen Jazz Festival. He tours as a soloist and with the Gary Negbaur Group.";
  schema:url <https://garynegbaur.com/>;
