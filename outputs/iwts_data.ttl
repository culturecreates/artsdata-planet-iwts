iwts_performer:9856 a schema:Organization;
  schema:name "The Boo Revue!";
  schema:description "The Boo Revue! features a talented team of professional puppeteers and comes to life with colourful puppets and props created by the expert fabrication team at Puppet Stuff Canada. The show includes ten original musical numbers composed by Michael Gordon, with a book by Brendan James Boyd. Each year, new numbers and characters are added, constantly expanding the cast of frighteningly fun friends and bringing new spooktacular delights to life. This show is designed to be a one of a kind holiday tradition for  audiences of all ages.";
  schema:url <https://www.theboorevue.ca>;
