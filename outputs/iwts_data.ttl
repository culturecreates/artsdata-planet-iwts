iwts_performer:9818 a schema:Person;
  schema:name "Holly M Brinkman";
  schema:description """Holly M. Brinkman is an award-winning artist who is known for her vulnerability, comedic timing, and physical storytelling. She has captivated audiences across North America with her unique blend of clown, burlesque, and soul-baring narrative.
Her works—A Woman’s Guide to Peeing Outside, My Body of Work, and Pack Animals—have toured nationally and internationally, earning rave reviews and multiple awards, including Best Dance Show (The Jenny Revue, Winnipeg), and Critic’s Picks from CBC Manitoba, Orlando Sentinel, and Saskatoon Fringe.""";
  schema:url <https://hollymbrinkman.ca>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/TheatrePerformance>;
