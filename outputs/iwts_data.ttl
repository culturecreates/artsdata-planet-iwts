iwts_performer:7047 a schema:PerformingGroup;
  schema:name "Eleanor & Dario";
  schema:description "Charismatic Argentine–USA duo offering intimate, high-level performances with guitar, charango, cello, percussion, and rich vocal harmonies. Their multilingual, transcontinental repertoire blends jazz, Latin grooves, and heartfelt storytelling. Eleanor and Dario’s current concerts feature their new album *Just The Three of Us*, with personal, reimagined takes on classics by Simon & Garfunkel, Jobim, Buena Vista Social Club, Bill Withers, Pink Martini, and The Beatles—alongside originals. Audiences take an inspiring trip around the world.";
  schema:url <https://www.eleanoranddario.com>;
