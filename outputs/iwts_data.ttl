iwts_performer:10252 a schema:Person;
  schema:name "Tramaine Long";
  schema:description "Tramaine Long is a producer, singer, and songwriter who began his musical journey in church at age five.  A 2023 Full Sail Entertainment Business graduate, he’s been featured on Rapzilla & VoyageATL with standout performances on Dr. Bobby Jones Gospel Show, Preach the Word Network ATL, and major festivals. In 2025, he won Emerging Artist & Gospel Rap Artist of the Year, & Kingdom Image Hip Hop Artist of the Year. His single “Put On Your Wings” hit #1 on Mediabase & “Father” is currently charting. His new album Legendary II arrives May 8, 2026.";
