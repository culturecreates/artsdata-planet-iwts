iwts_performer:10386 a schema:PerformingGroup;
  schema:name "JJ Lavallee";
  schema:description "JJ Lavallee and his band fuse traditional country with Métis sounds, rhythms, and musical roots, creating a warm and distinctive live experience. A Métis country artist now calling Saskatoon home, JJ is known for heartfelt storytelling, rich vocals, and engaging performances. His 2023 album Rebirth reflects his strong musicianship, lived experience, and commitment to authentic songs rooted in community, culture, and connection. On stage, JJ delivers an honest, energetic, and memorable performance.";
  schema:url <https://jjlavalleemusic.com/>;
