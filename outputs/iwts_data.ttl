iwts_performer:7434 a schema:Person;
  schema:name "Ben Sures";
  schema:description """Winnipeg bred, Edmonton based Ben Sures has
performed at festivals and concerts across
Canada. He’s a songwriter who sees the little
things we take for granted and reminds us how
those everyday moments and feelings are the
sum of our parts. These stories, drawn from
reality, sometimes embellished, are all
wrapped in melody, heartbeat and words that
stay with you.
Ben Sures is a natural performer, verging on
stand up comedian at times in his storytelling
and song introductions.""";
  schema:url <http://www.bensures.com>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
