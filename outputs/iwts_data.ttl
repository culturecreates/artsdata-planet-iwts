iwts_performer:5029 a schema:PerformingGroup;
  schema:name "Son of John";
  schema:description "Son of John isn't country, Americana or folk - they're all three. The father/son duo from the southern interior of BC are 2025 BC Country Music Association nominees for Roots Artist and Album of the Year (\"Lucky\") produced by John Ellis (Blake Berglund, Doc Walker, Colin James). Their storytelling and instrumentations are a product of a family bond making music together for almost two decades with the name Son of John a homage to Javan and Johnny's shared last name. Signature harmonies perfectly blend two generations of country music.";
  schema:url <http://sonofjohnmusic.com>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
