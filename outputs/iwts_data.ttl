iwts_performer:9830 a schema:PerformingGroup;
  schema:name "Zack Ingles";
  schema:description """Foot-stompin, banjo driven, folk twang with a splash of
pop. That's the promise of Zack Ingles' latest project
\"Get Ahead.\" From the rural valleys of New Brunswick
comes the songwriter with a refreshing ability to explore
complex and often taboo social conversations, packaging them within heart-pumping 4-on-the-floor
bluegrass rhythms.""";
