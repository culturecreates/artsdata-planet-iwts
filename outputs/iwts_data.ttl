iwts_performer:10075 a schema:PerformingGroup;
  schema:name "Benjamin Deschamps";
  schema:description "Québec saxophonist and composer Benjamin Deschamps is one of the most exciting rising voices in Canadian jazz. With a warm tone, expressive improvisation and memorable melodies, his music connects easily with audiences while maintaining a high level of artistry. Leading vibrant ensembles, Deschamps delivers concerts that are energetic, accessible and deeply engaging — a perfect balance of virtuosity and musical storytelling that consistently leaves audiences delighted.";
