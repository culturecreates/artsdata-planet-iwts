iwts_performer:9873 a schema:Person;
  schema:name "Tippy Topwell";
  schema:description "Jamie Graham is a dancer, improvisor, and physical comedienne based in Brooklyn, New York. She conjures delight, discovery and invention through physicality and strives to forge a vital connection with the audience through complicité. Her solo show Tippy Topwell Dances Around The Subject, created in collaboration with Virgina Scott (Fizgig Studio, Discovering the Clown) recently premiered at PhysFestNYC. Past work includes Third Rail Project’s Then She Fell, The Raving Jaynes, Jenny Rocha and Barbara Mahler.";
