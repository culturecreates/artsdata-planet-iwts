iwts_performer:743 a schema:Person;
  schema:name "Melanie Gall";
  schema:description """Melanie Gall is an internationally-acclaimed vocalist who has performed in over 30 countries, including Royal Albert Hall in London and Lincoln Center and Carnegie Hall in New York. She has won several awards for her work and has recorded 8 commercial albums. 

Melanie has toured many countries that were under-represented theatrically, where she performed and led outreach programs.  In addition, Melanie has also worked with First-Nations communities in Northern Manitoba, fostering a love of music and building performance skills in youth.""";
  schema:url <http://www.melaniegall.com>;
