iwts_performer:8471 a schema:Organization;
  schema:name "Foolish Operations Society";
  schema:description "Based in Vancouver, Foolish Operations is a bilingual non-profit \"creating togetherness\" via dance. They create participatory performances for children 0–8, their families, and educators. Their work debuts in Norway in fall 2026. Baby Space Opera premieres May 2026, engaging families in a poetic, sensory exploration of our place in the universe.";
