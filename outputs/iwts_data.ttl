iwts_performer:9690 a schema:PerformingGroup;
  schema:name "Aurora String Quartet";
  schema:description "The Aurora String Quartet, based in Billings, Montana, features Hannah Clough and Lauren Griffin on violin, Paige Driscoll on viola, and Kassidy Conlon on cello. This talented ensemble brings together a passion for chamber music and a deep commitment to their craft, offering vibrant performances that captivate audiences throughout the region. With a repertoire ranging from timeless classics to contemporary works, the Aurora String Quartet is dedicated to enriching the cultural landscape of their community.";
