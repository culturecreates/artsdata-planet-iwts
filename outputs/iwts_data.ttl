iwts_performer:10098 a schema:Person;
  schema:name "Carly Reirson";
  schema:description "Carly Reirson is an Alberta-born, Vancouver-based singer-songwriter commitmed to honesty, vulnerability, and emotional storytelling. Guided by a voice that moves effortlessly from delicate to powerful, she writes songs that explore loss, resilience, love, and the quiet moments that shape us. Onstage, Carly creates an inviting, immersive atmosphere, drawing listeners into her world through heartfelt performances that leave a lasting sense of connection and authenticity.";
