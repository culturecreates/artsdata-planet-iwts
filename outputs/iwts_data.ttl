iwts_performer:8873 a schema:Person;
  schema:name "Julian Taylor";
  schema:description "Julian Taylor is a four-time JUNO Award-nominated, Polaris-nominated singer-songwriter whose music blends folk, rock, and soul with deeply personal storytelling. A staple of the Canadian music scene, he has earned acclaim for his evocative lyrics and rich, textured sound. His latest album, Pathways (2024), showcases his signature warmth and authenticity. With a career spanning decades, Taylor continues to captivate audiences worldwide with his heartfelt performances and genre-defying artistry.";
