iwts_performer:10190 a schema:Person;
  schema:name "Gilbert (Gil) Drapeau";
  schema:description "Gil is an Alberta-based actor, performer, playwright, speaker and stand-up comedian known for his high-energy, comedic, and thought-provoking work. Performing across Canada on stage, radio, and television, he has appeared on CBC/Radio-Canada and in several documentaries. He has created and produced educational seminars and plays, which seeks to provide a better understanding of marginalized communities. Equal parts entertainer and advocate, he will make you laugh, think, and enjoy the discomfort.";
