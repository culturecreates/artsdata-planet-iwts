iwts_performer:10042 a schema:Person;
  schema:name "Tamra Hayden";
  schema:description "Tamra Hayden is a celebrated vocalist, multi-instrumentalist, and singer-songwriter whose heart-centered music has touched listeners all over the world. Hayden has appeared on Broadway in Les Misérables and Cabaret, toured nationally in The Phantom of the Opera, Fiddler on the Roof, and Anastasia, and has performed with orchestras across the United States. Whether captivating Broadway audiences with her stunning soprano or sharing her soulful original songs in an intimate club, Tamra infuses \"peace, love, and hilarity\"  into every performance.";
  schema:url <https://tamrahayden.com/>;
