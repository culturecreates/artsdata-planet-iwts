iwts_performer:8093 a schema:PerformingGroup;
  schema:name "Karla Harris";
  schema:description "Dynamic jazz vocalist Karla Harris has captivated audiences at events such as the Sarasota Jazz Festival, Portland Jazz Festival, Oregon Coast Jazz Party, Nantucket Arts Festival, Atlanta Jazz Festival, and a TED Talk. She has performed for the John F. Kennedy Center for the Performing Arts as part of the Arts Across America live performance series, and in 2022 was awarded a distinguished Jazz Road grant through the South Arts foundation. She is works with the Kennesaw State University Jazz program teaching applied vocal jazz to young singers.";
