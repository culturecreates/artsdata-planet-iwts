iwts_performer:9460 a schema:Person;
  schema:name "Claire Coupland";
  schema:description "Moving songwriter and compelling guitarist, Claire combines her signature folk finger picking, jazz-influenced progressions and soaring melodies, with powerful tender vocal delivery. Claire is touring her new album and drawing audiences with intimate and heart-wrenching performances. After joining forces with Juno award winning musician Sam Weber (Bahamas) and some of LA’s finest musicians (Dawes, Alan Hampton), the album presents fresh and spontaneous arrangements of her songs. Claire brings a graceful contemporary feel to indie folk music.";
  schema:url <https://www.clairecoupland.com>;
