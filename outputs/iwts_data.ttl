iwts_performer:9480 a schema:PerformingGroup;
  schema:name "MONKS";
  schema:description "Veronica Hortigüela and Annie Luján are Toronto based Dora Award-winning actors, as well as clowns and playwrights. They are close friends and collaborators of 15 years, with a particular interest in modern clowning. MONKS marks their professional writing and directing debuts. Hortigüela and Luján hold BFAs from TMU and Cocordia, respectively, and collectively have performed for companies such as Stratford, Soulpepper, Crow’s, Tarragon, Buddies in Bad Times, Bad New Days, and, Howland Co. to name a few.";
  schema:url <https://www.instagram.com/monksonstage/>;
