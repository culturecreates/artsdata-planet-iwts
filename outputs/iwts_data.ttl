iwts_performer:9444 a schema:Person;
  schema:name "Alexis Baro";
  schema:description "Alexis Baro is an award-winning Cuban-Canadian trumpeter known for his electrifying fusion of jazz, Afro-Cuban, funk, and soul. A classically trained musician, he has performed with icons like Dee Dee Bridgewater, David Foster and Paquito D’Rivera while leading his own acclaimed projects. With multiple JUNO nominations and a dynamic discography, Alexis blends virtuosic improvisation with deep storytelling and infectious rhythms, making him one of Canada’s most compelling and versatile trumpet players.";
  schema:url <https://www.alexisbaro.com>;
