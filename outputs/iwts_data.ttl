iwts_performer:9483 a schema:PerformingGroup;
  schema:name "Joe Troop's Whirlwind";
  schema:description "GRAMMY-nominated bandleader, songwriter, and multi-instrumentalist Joe Troop (Larry & Joe, Che Apalache) has formed an eclectic ensemble to play his new, original music. Featuring electric banjo (Joe Troop), flute (Rebecca Kleinmann), viola (Bailey Poesnecker), electric bass (Ramon Garcia), drum set (Gaston Reggio), this music draws from a kaleidoscope of influences - Latin jazz to R&B, candombe to bluegrass, classical music to samba, rock and roll. Like nothing you've heard before, Whirlwind will leave you on the edge of your seat.";
  schema:url <https://www.joetroop.com/whirlwind>;
