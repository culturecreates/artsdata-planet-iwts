iwts_performer:9672 a schema:PerformingGroup;
  schema:name "Good Co";
  schema:description """Seattle's Good Co is the USA's first Electro Swing band. Combining the sounds of 1920's and 30's jazz with the electronic music of today Good Co uses live horns, vintage samples, and funky beats to create a whole new type of concert experience via dance party. Since 2013 Good Co 
has performed throughout the US, Canada, and Europe for concerts, music festivals, and special events.  The band offers community & educational outreach with school shows (including study guides), swing dance lessons and more.  The Roaring ‘20s meet the 2020s!""";
