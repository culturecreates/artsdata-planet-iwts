iwts_performer:10371 a schema:Person;
  schema:name "Beth Lapides";
  schema:description "Beth Lapides is a writer, performer, and creator of UnCabaret, the groundbreaking show credited with redefining alternative comedy as a more personal and theatrical form. Called “a completely unique stand-up theater artist” by The Hollywood Reporter, her work blends comedy, music, and storytelling. She is founder of The Infinite Creator and author of “So You Need to Decide,” creating performances that invite audiences to laugh, reflect, and leave changed—work devoted to making rooms come alive.";
