iwts_performer:9864 a schema:Person;
  schema:name "Geneviève Johnson";
  schema:description "Geneviève Johnson is an interdisciplinary artist whose work spans dance, performance-installation, and screendance. Butoh-trained in Japan, she holds a PhD from UQAM researching the transformative poetic body in performance. Johnson regularly shares her Poetry in Motion practice with community and artists alike. Recent works include Quantum Conversation I&II, Nanaimo; Threading Side by Side, Comox Valley Art Gallery; dance-documentary Breathing on Eggshells–on Tedd Robinson’s creative process, selected for the Montreal Women Film Festival 2025.";
  schema:url <https://genevievejohnson.ca/>;
