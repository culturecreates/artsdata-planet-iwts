iwts_performer:9261 a schema:PerformingGroup;
  schema:name "Andy Kahrs";
  schema:description "Andy Kahrs honors the music of one of country music’s brightest stars in ‘Rhinestone: The Songs of Glen Campbell’, featuring unique, soulful interpretations of Campbell’s vast catalogue, including Galveston, Gentle On My Mind, Wichita Lineman, and many more. Alternating between full-band and solo performances, ‘Rhinestone’ showcases Andy’s unique roots sound that blends classic country with blues, soul, and bluegrass.";
