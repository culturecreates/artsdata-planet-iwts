iwts_performer:9169 a schema:PerformingGroup;
  schema:name "Ethnosonic";
  schema:description """Fierce. Meditative. Ancient. Funky.
Every Ethnosonic concert starts somewhere different — a fierce Caucasian dance, then a single duduk note that stops the room, then a lament rebuilt into something wild. Toronto's seven-piece ensemble writes entirely original music: jazz fused with the folk traditions of the Caucasus, Eastern Europe, and the Balkans. First year stats: two sold-out shows, all-time tip records at Drom Taberna, Hugh's Room Live, debut album ONE, and an Ontario Arts Council grant. The only duduk jazz fusion ensemble in the world.""";
  schema:url <https://www.ethnosonic.ca>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
  schema:genre "Jazz/Blues";
