iwts_performer:9464 a schema:Person;
  schema:name "Vidya Kotamraju";
  schema:description "Vidya Kotamraju (She/Her) is a Vancouver-based dance artist, choreographer, and educator merging tradition with innovation. She founded House of Indian Dance to empower artists and push boundaries in dance. Trained in Bharata Natyam, she has performed at the Vancouver International Dance Festival and other Canadian festivals, both independently and as a soloist and ensemble dancer with Mandala Arts and Culture. Offstage, she has served on arts boards and works in tech.";
