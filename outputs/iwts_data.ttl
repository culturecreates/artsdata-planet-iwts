iwts_performer:9760 a schema:PerformingGroup;
  schema:name "Mango Street Trio";
  schema:description "The Mango Street Trio is a genre-blending powerhouse from East Coast Canada, fusing the sophistication of jazz with the edge of pop-rock, the soul of the blues, and the pulse of hip-hop, Latin, and fusion grooves. Born from diverse international backgrounds, their sound is bold, electric, and impossible to categorize. Since the release of their debut single \"Fraggle's Loft,\" the Mango Street Trio has performed at the Charlottetown Canada Day Celebration, the UPEI Welcome Week Music Fest, Island Jazz and at the Rustico Surf Club, to name a few.";
