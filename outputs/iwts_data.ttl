iwts_performer:810 a schema:Person;
  schema:name "Comedy in Motion with Bob Cates";
  schema:description "Farm boy-turned-entertainer Bob Cates, is an award-winning clean comedian and variety artist. His memorable interactive comedy show includes advanced juggling, wild unicycling and balancing skills, audience participation and an insane 24 plate spinning finale. Bob has been performing full time for over 30 years, at every imaginable venue, including theatres and cruise ships. He was awarded Best Variety Act by the Canadian Comedy Awards in 2018. In 2016, Bob was awarded National Entertainer of the Year at the Canadian Event Industry Awards.";
  schema:url <http://www.comedyinmotion.com>;
