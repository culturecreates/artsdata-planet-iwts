iwts_performer:6654 a schema:PerformingGroup;
  schema:name "The Blue Mules";
  schema:description "The Blue Mules deliver a distinct style with a variation of  raw blues to countrified rock. The Blue Mules personify Solid Blues with a Powerful Kick .Three  guys who love to play music!  Touring  Western Canada regularly as one of Sask's  top touring blues bands. TBM have had airplay in over 100 markets across Canada, the U.S. and Europe. and Australia  TBM deliver a distinct style with varied flavours to each song from raw blues to countrified rock, tying it all together. They personify Solid Blues with a Powerful Kick.";
