iwts_performer:9814 a schema:PerformingGroup;
  schema:name "Ensemble Renouveau";
  schema:description "Ensemble Renouveau was founded in Quebec in 2017 by five friends united by a shared passion: to renew and reclaim the great pages of classical music. Through the inventive arrangements and compositions of cellist Simon Desbiens, the group blends opera, film music, French chanson, pop, and folk influences into lyrical, accessible concerts. Featuring sopranos Carole-Anne Roussel and Evelyne Larochelle, violinist Jessy Dubé, pianist Bruce Gaulin, and Desbiens, the ensemble offers a warm and vibrant musical experience.";
  schema:url <https://www.agencedlefebvre.com/ensemblerenouveau-en>;
