iwts_performer:10280 a schema:Person;
  schema:name "PAZ The Sports Guy";
  schema:description "PAZ The Sports Guy is an award winning entertainer that has been performing circus, variety, and comedy for over 30 years.  Specializing in family friendly entertainment, PAZ has been featured in film, television, theatre, circus, fairs, festivals, cruise ships, and high profile sports events around the world.  Named “one of the 21 most Canadian things you’ll ever see” (Buzzfeed), PAZ is best known for his uncanny ability to connect with audiences from all demographics.  PAZ aims to use his art to remind communities that sport is for everyone.";
  schema:url <https://equilibriumcircus.com/the-hockey-circus-show>;
