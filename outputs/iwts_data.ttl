iwts_performer:9893 a schema:Person;
  schema:name "CARA LUFT";
  schema:description "Award winning singer-songwriter-musician Cara Luft is that rare artist steeped in folk & traditional roots music almost from birth, yet willing to alter the fabric, stretch the boundaries & fearlessly bend genres and styles.  Luft deserves her solid reputation as one of Canada’s finest live performers. She makes a long-anticipated return in 2026 with a joyful solo album –– her first in over 13 years. The result is a tour de force, a personal declaration & a celebration of music’s enduring power to heal, connect and bring joy.";
  schema:url <https://caraluft.com/home>;
