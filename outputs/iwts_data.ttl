iwts_performer:9398 a schema:PerformingGroup;
  schema:name "Lemon Bucket Orkestra";
  schema:description "Lemon Bucket Orkestra are Toronto's original guerrilla-folk-party-punks. The award-winning crew has been called frenetic, charismatic, and gloriously anarchic by the New York Times, The Guardian, the Winnipeg Free Press and media across the globe and over the past 14 years have performed all over the world from WOMAD in England and New Zealand and Pohoda in Slovakia, Festival D’Été in Québec City to New Orleans Jazz Fest in Louisiana.";
