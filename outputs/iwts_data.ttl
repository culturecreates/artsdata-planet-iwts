iwts_performer:9301 a schema:Person;
  schema:name "Ayla Tesler-Mabé";
  schema:description "Ayla Tesler-Mabé is a 23-year-old songwriter, producer, and musician known for her soulful sound and unique guitar skills. After gaining viral attention at 15 with a Led Zeppelin cover, Ayla toured worldwide with her former band, Calpurnia. She later co-wrote with Willow Smith and featured in her song \"Come Home.\" In 2023, Ayla launched her solo career with Let Me Out!!, an entirely self-written, produced, and performed EP. She is now exploring a more psychedelic rock sound with her new single \"Am I.\"";
