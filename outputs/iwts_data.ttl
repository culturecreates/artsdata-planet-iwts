iwts_performer:9605 a schema:PerformingGroup;
  schema:name "Lady Muse & The Inspirations";
  schema:description """Lady Muse is a drag entertainer and singer inspired by musical divas such as Dolly, Judy, and Lady Gaga. Merging a lifetime of musical training with the artistry of drag, she creates performances that blend live music, storytelling, and humor to celebrate queerness, femininity, and the transformative power of performance. 

The Inspirations are a 6-piece band comprised of  some of Winnipeg's first call musicians. Together they play selections from the queer zeitgeist in funk, disco, pop, and rock styles that are sure to get you dancing, queen.""";
  schema:url <https://www.instagram.com/ladymusewpg/>;
