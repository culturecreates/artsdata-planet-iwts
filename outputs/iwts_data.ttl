iwts_performer:9553 a schema:PerformingGroup;
  schema:name "Young Original";
  schema:description "Young Original is an acoustic band reviving classic American music with riveting live shows and viral performance videos. Since 2022, they’ve toured nationwide, including a Christmas run with pianist Jim Brickman. Their originals, “Doubt Your Love” and “Perfect World,” were featured on NPR’s Tiny Desk Top Shelf. Blending jazz, classical, folk, and pop, they showcase masterful instrumentation and rich harmonies. Their dynamic performances and genuine audience connection make them a must-see act.";
  schema:url <https://youngoriginalband.com>;
