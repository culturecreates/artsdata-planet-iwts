iwts_performer:3376 a schema:PerformingGroup;
  schema:name "Chris Henderson";
  schema:description """Chris Henderson’s blend of a modern country sound, with traditional roots has made him one of Canada’s busiest Country recording artists. Since his debut, the veteran singer/songwriter has toured relentlessly, releasing 20 singles, including “My Regret” (#47), “Don’t Miss Your Kiss Goodbye” (#47), and more. 

The 3x SCMA “Male of Artist of the Year” (2018-20) has released albums, and is currently working on a fifth slated for 2026. He's been seen on stages such as Big Valley Jamboree, Dauphin’s Countryfest, Telemiracle, and many more.""";
  schema:url <http://www.chrishendersonmusic.com>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
