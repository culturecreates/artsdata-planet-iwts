iwts_performer:10364 a schema:PerformingGroup;
  schema:name "The Very Groovy Things Band";
  schema:description "The Very Groovy Things perform music of the mid 60s to the early 70s, featuring hits of the Mamas and the Papas, some British Invasion and the Laurel Canyon scene. The band includes 4 of the city ‘s finest vocalists, backed by à 6 piece band. Music director Rick Boughton on keys and trumpet, Kinzey Posen of Finjan, first call drummer Rob Siwik, new  flautist Cal Wiese , and legendary r and b guitarist Terry Barnett  with strings man James Hickerson in à backing band for singers Jodie Borle , Bill Quinn, Signy Baragar and Dan Rochegood.";
