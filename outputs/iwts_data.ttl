iwts_performer:9717 a schema:Person;
  schema:name "Carolina Quiroga";
  schema:description "Carolina is a dynamic bilingual storyteller who captivates audiences with stories of her immigrant journey and traditional Latin American tales. She has mesmerized listeners at renowned festivals like the National Storytelling Festival and in schools, libraries, and cultural institutions nationwide. As a Teacher-Artist, she inspires and educates through storytelling in Asheville City Schools. With her creativity and dedication, Carolina Quiroga is a cultural ambassador, weaving Latin American heritage into the hearts of audiences everywhere.";
  schema:url <https://www.carolinaquiroga.com>;
