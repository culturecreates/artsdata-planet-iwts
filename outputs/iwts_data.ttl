iwts_performer:7178 a schema:Organization;
  schema:name "ShaLeigh Dance Works";
  schema:description """ShaLeigh Dance Works (SDW) is redefining what dance can be. Based in Durham, NC and now entering its 9th season, this nonprofit dance-theater company delivers bold, inclusive, and emotionally resonant performances that captivate audiences and create lasting community impact.
Nationally recognized for innovation, SDW blends virtuosic movement with social relevance—offering powerful stories that uplift underrepresented voices and challenge what’s possible on stage. The company's original works deliver a singular, world-class experience.""";
