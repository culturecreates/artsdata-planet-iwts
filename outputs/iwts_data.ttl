iwts_performer:10139 a schema:PerformingGroup;
  schema:name "Michael Longoria: SURFIN' SENSATION";
  schema:description """Michael Longoria: SURFIN' SENSATION is an electrifying celebration of The Beach Boys starring original Jersey Boys and Midtown Men vocalist Michael Longoria. This high-octane concert showcases Longoria’s iconic falsetto and magnetic stage presence alongside a sizzling live band and dynamic backup singers.

Audiences will catch a wave of feel-good energy with classics like “Good Vibrations,” “Surfin’ USA,” and “I Get Around.” It’s a vibrant, joy-filled experience that invites you to relive the magic of summer and celebrate the kings of surf rock""";
  schema:url <https://Thesurfnotes.com>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
  schema:genre "Popular";
