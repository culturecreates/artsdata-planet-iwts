iwts_performer:8406 a schema:PerformingGroup;
  schema:name "Backbeat";
  schema:description "Backbeat is a 60's tribute band from Victoria, BC.  Their mandate is to faithfully recreate the hits from the greatest decade in music.  Backbeat has been performing at festivals and concert venues for over a decade.  They have created a show called Let's Go Surfin'!  featuring the many hits of The Beach Boys, which has been touring theatres in BC for three years";
