iwts_performer:8948 a schema:PerformingGroup;
  schema:name "AmeriCoustic";
  schema:description "For over 20 years, award-winning television host Dan Miller has brought his unique brand of music, humor, western history and poetry to audiences from around the globe. With Dan on lead vocals and guitar, and Wendy Corr singing lead and harmony vocals and playing the bass guitar, Dan Miller’s AmeriCoustic presents a variety of song stylings, from traditional western fare such as “Back In the Saddle” and “Rawhide” to iconic tunes from Simon and Garfunkel and Marty Robbins. They have performed over 70 community concerts around the country.";
  schema:url <https://www.cowboymusicrevue.com/americoustic>;
