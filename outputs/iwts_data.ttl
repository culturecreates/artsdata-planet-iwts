iwts_performer:9946 a schema:PerformingGroup;
  schema:name "Paige Ballagh";
  schema:description "Paige Ballagh performs original folk-pop rooted in storytelling, warm vocals, and melodic ease. Ontario-born singer, songwriter, and poet Paige Ballagh is joined by her multi-instrumentalist brother, Mike Ballagh, and her husband, guitarist and CFMA winner Kyle Waymouth. Drawing from her album Shoes Untied, EP Oh Maggie, and her #1 best-selling poetry collection Waking Up, their sets blend heartfelt lyricism, lived-in melodies, and moments of humour and human connection.";
