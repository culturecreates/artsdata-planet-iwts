iwts_performer:2980 a schema:PerformingGroup;
  schema:name "Myrna Clayton";
  schema:description "Myrna Clayton, known as “America’s Songbird,” is an internationally touring jazz vocalist commissioned by the U.S. State Department as a Cultural Ambassador, representing American music at U.S. Embassies worldwide. She has performed across five continents, was featured at the PAE Juried Showcase, and led a six-city tour of historic theatres across Georgia. Her program Jazz Heals Humanity – Worldwide blends jazz, storytelling, and global connection to celebrate our shared humanity.";
  schema:url <http://www.MyrnaClayton.com>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
