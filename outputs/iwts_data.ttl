iwts_performer:9694 a schema:PerformingGroup;
  schema:name "The New York Tenors";
  schema:description "The New York Tenors are a vocal trio composed of three talented and diverse singers: Daniel Rodriguez, Andy Cooney, and Christopher Macchio. They Blend their unique backgrounds - Rodriguez as a former NYPD officer and operatic tenor, Cooney as an Irish-American singer and entertainer, and Macchio as a classically trained tenor all into a powerful and moving performance. Their repertoire spans opera, broadway, pop, and patriotic songs, capturing the spirt and energy of New York City.";
