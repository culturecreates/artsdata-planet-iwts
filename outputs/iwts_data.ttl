iwts_performer:10362 a schema:PerformingGroup;
  schema:name "BIG FUZZ";
  schema:description "BIG FUZZ is the \"immaculately gritty\" creation of producer & multi-instrumentalist Anthony Cenerini. After landing festival bills from Rifflandia to Treefort, everything stopped—within weeks, a serious injury and eviction forced him from the West Coast back to his hometown of Winnipeg, MB. He reemerged in 2026 with a chip on his shoulder. The debut single \"FEARS\" earned features from The Manitoban and !earshot before landing on Alan Cross's Five Songs You Must Hear, syndicated across Corus Radio rock stations nationwide. Debut EP drops Q3 2026.";
  schema:url <https://www.bigfuzz.ca>;
