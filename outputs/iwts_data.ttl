iwts_performer:8649 a schema:Person;
  schema:name "Matt Zimmerman";
  schema:description "Matt Zimmerman is a Country performing songwriter who draws inspiration from his heritage and a small town lifestyle. Over his career Matt has performed extensively, and has graced stages in over 50 Manitoban communities. He's toured the prairies, played on the east coast, and in Nashville. Some of Matt's songs have aired on radio stations across Canada. He's opened for Aaron Pritchett, Owen Riegling, Don Amero, and soon Gord Bamford on May 9th in Steinbach! Matt created and facilitates the Southeast Songwriters Circle.";
