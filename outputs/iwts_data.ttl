iwts_performer:10109 a schema:Person;
  schema:name "Prophocey";
  schema:description "Prophocey is a Christian hip-hop artist known for delivering impactful, faith-driven music that fuses hard-hitting beats with scripture-inspired lyricism. His authentic storytelling and energetic performances communicate messages of redemption, purpose, and hope, connecting hip-hop culture with the life-changing message of Christ. Prophocey uses music as ministry, reaching audiences both inside and beyond the church with clarity, conviction, and purpose.";
