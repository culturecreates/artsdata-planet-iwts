iwts_performer:9586 a schema:PerformingGroup;
  schema:name "The Crickettes";
  schema:description """The Crickettes are an acoustic ukulele duo from Calgary, Canada, known for their inviting and intimate vibe that draws audiences in. Comprising Sara Tkachuk on vocals and baritone ukulele, and Julianne Clease on vocals and tenor ukulele, they create a warm atmosphere that feels like a cozy gathering with friends.

Their performances feature a delightful mix of catchy original songs and beloved covers, all enhanced by heartfelt lyrics that resonate with listeners. 

With every note, The Crickettes invite you to be part of their music.""";
  schema:url <https://www.thecrickettes.com/>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
  schema:genre "Folk/Bluegrass/Americana";
