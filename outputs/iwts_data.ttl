iwts_performer:7182 a schema:PerformingGroup;
  schema:name "Nico Rhodes";
  schema:description "Lifelong friends Nico Rhodes and Patrick Courtin were taken aback by the stark realization that the piano had fallen out of favour. Determined to restore its luster and reclaim its title as the ultimate instrument, they embarked on an exhilarating journey. Drawing inspiration from legendary composers, songwriters, and performers over the last three centuries, they crafted a mesmerizing show that spans the spectrum from classical piano to boogie-woogie, ballads, and epic 80s synth battles in their show: Piano Heist - Keys are the Champions!";
  schema:url <http://pianoheist.com>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
  schema:genre "Musical Theatre";
