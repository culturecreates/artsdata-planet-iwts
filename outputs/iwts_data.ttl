iwts_performer:55 a schema:Person;
  schema:name "Susan Claassen";
  schema:description "Susan “Suz” Claassen (Edith Head/Designer/Playwright) was Managing Artistic Director of Tucson’s  Invisible Theatre (IT) for 50 years evolving to “Emeritus” in 2024.  Susan's award-winning A CONVERSATION WITH EDITH HEAD tours coast to coast and internationally. Susan in A CONVERSATION WITH EDITH HEAD was awarded Phoenix New Times Best Actor, LA Stage Alliance Ovation Award Nominee, Best Actres,  BroadwayWorld LA Award Nominee as Best Actress, The San Francisco Bay Area Theatre Critics Circle nominee for Best Solo Production & Best Production.";
  schema:url <http://www.edithhead.biz>;
