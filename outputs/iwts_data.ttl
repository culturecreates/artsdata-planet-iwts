iwts_performer:9779 a schema:Person;
  schema:name "Fernanda Cunha";
  schema:description "Fernanda Cunha is a Brazilian-Canadian singer based in Brampton, Ontario, with a career spanning over 25 years. She performs alongside Canadian musicians, blending the smooth rhythms of bossa nova with the improvisational spirit of jazz. Her repertoire includes both original compositions and timeless standards. Fernanda’s distinctive voice has earned recognition across Canada, where she has made a meaningful impact on the national music scene—performing coast to coast  to showcase collaborations with talented artists from both countries .";
  schema:url <https://www.fernandacunha.com>;
