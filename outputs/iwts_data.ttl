iwts_performer:8512 a schema:Organization;
  schema:name "Green Thumb Theatre - Funny, You Don't Look Autistic";
  schema:description "FUNNY, YOU DON'T LOOK AUTISTIC is a theatrical adaptation of Michael’s autobiographical book of the same name, published in 2019 by Annick Press. The show blends Michael’s trademark deadpan delivery with Green Thumb’s history for bringing socially conscious theatre to the stage. The show will touch audiences deeply while making them laugh out loud. Michael’s story is one of challenge, growth, and ultimately triumph.";
