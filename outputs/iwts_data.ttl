iwts_performer:9491 a schema:PerformingGroup;
  schema:name "Ne. Sans Opera & Dance";
  schema:description "Ne. Sans Opera & Dance, under the artistic direction of Idan Cohen, is a Vancouver-based company committed to reimagining opera and contemporary dance through an interdisciplinary lens. By seamlessly integrating movement, voice, and theatrical expression, Ne. Sans presents innovative and thought-provoking performances that honor classical traditions while engaging contemporary audiences. Through bold artistic collaborations, the company challenges conventions and enhances the operatic and dance experience.";
