iwts_performer:5604 a schema:PerformingGroup;
  schema:name "Tad Emptage";
  schema:description """This season, prepare to be swept away as our award-winning circus brings a world of wonder to the stage! With dazzling acrobatics, breathtaking feats, and a cast of world-class performers, we blend heart-stopping spectacle with irresistible charm, creating a show that is as thrilling as it's joyous.
Seen in over 70 countries and honored with the New York Parents’ Choice Award for Best Family Entertainment, we are proud to carry forward the grand tradition of American circus, rooted in awe, laughter, and togetherness.""";
