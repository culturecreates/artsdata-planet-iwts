iwts_performer:10080 a schema:PerformingGroup;
  schema:name "Rhythm of the Rocket Man";
  schema:description "Rhythm of the Rocket Man is a sensational tribute show celebrating the legendary Elton John and his unforgettable music. This high-energy performance brings to life the iconic hits, flamboyant style, and larger-than-life persona of Elton John. Featuring Colte Julian from Broadway’s Million Dollar Quartet, the show recreates some of Elton’s most beloved songs, including “Rocket Man,” “Tiny Dancer,” “Your Song,” and “Bennie and the Jets.”";
  schema:url <https://bass-schuler.com/talent/rhythm-of-the-rocket-man/>;
