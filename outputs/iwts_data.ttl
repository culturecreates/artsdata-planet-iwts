iwts_performer:6821 a schema:PerformingGroup;
  schema:name "Molly Wilson - Molly's Comedy Cabaret";
  schema:description "Molly Wilson is an award-winning Canadian singer/actor/writer with a powerhouse voice, hilarious comedic timing, and the charm that turns a room of strangers into friends. She has performed across Canada, the U.S. and UK, blending musical theatre chops with comedy instincts. Her style is inclusive and unapologetically fun, grounded in performance and love of connecting with people. A disabled artist, Molly creates joyful, welcoming spaces where audiences feel seen—and leave feeling like a new best friend. She trained at MacEwan University.";
  schema:url <http://www.mollyscomedycabaret.com>;
