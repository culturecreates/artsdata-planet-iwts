iwts_performer:253 a schema:Person;
  schema:name "Johnny B.";
  schema:description """After Berklee College of Music in 1979, Johnny B. traveled the Lower 48 states composing and performing until he ventured north to Alaska. His first juried show, Rhythm of the North is a celebration of our wild lands waterways and wildlife.  He has performed that program for numerous communities throughout the Northwest over the past fifteen years. 
Johnny B. has been awarded a Lifetime Achievement Award and other accolades including Music Score of the Year, Touring Support Grants, Original Music for Film and Composition Residency awards.""";
  schema:url <http://www.AlaskaJohnnyB.com>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
