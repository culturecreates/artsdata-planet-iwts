iwts_performer:7476 a schema:Person;
  schema:name "Denver Venoit";
  schema:description "Denver Venoit, known as Ole Man Kidd, is a Yukon-born rambler who writes lonesome folk-country blues steeped in raw truth. A former touring drummer turned wandering songwriter, he carries stories from the tundra to the desert, from bison ranches to barroom stages. With a steel guitar howl and dust on his boots, Ole Man Kidd sings about heartbreak, history, and the miles in between.";
  schema:url <http://www.denvervenoit.com>;
