iwts_performer:9973 a schema:PerformingGroup;
  schema:name "Rain City Improv";
  schema:description """Fast paced, hilarious, and highly interactive! Every show features fun, interactive improv scenes using willing volunteers and audience suggestions. Taz VanRassel (He/Him) and Rae Carson (They/Them) adapt to and engage any crowd, whether it’s a gymnasium full of elementary school students or a small group of high school seniors. Kids gain confidence through the collaboration, creativity, and imagination of improv storytelling.
Rain City Improv focuses on unscripted comedy theatre for ages 5 to 105.""";
  schema:url <https://www.kbamonline.com/#/raincityimprov/>;
