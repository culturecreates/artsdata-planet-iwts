iwts_performer:10044 a schema:PerformingGroup;
  schema:name "Big Sky City Lights";
  schema:description "Nick Spear and Susan O’Dea live in two completely different worlds. She’s Urban, he’s Rural. She’s Millennial, he’s GenX. She’s a kale chicken caesar, he’s last night’s cold pizza. But when they sing together, they are undeniably aligned. Two things that shouldn’t work actually do, and the connection point for them has always been harmony.";
  schema:url <https://www.bigskycitylights.com>;
