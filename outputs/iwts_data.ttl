iwts_performer:9934 a schema:Person;
  schema:name "Candy Roberts";
  schema:description "Candy Roberts is a Canadian theatre artist, writer, and fifth-generation European-Canadian settler, residing on the Unceded Territories of the Skwxwú7mesh (Squamish), S?lílw?ta? (Tsleil-Waututh), and xwm??kw?y?m (Musqueam) Nations, also known as Vancouver, BC. Her innovative works blend physical theatre, music, and clowning to explore the hilarity and heartbreak of our human condition. Candy tours extensively with her critically acclaimed productions, Candy Roberts is LARRY, OOPSIE, and The Myrtle Sisters.";
