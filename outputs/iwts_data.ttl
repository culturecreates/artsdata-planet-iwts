iwts_performer:10307 a schema:PerformingGroup;
  schema:name "David LaMotte";
  schema:description "David is an award winning songwriter, speaker and author. He has performed over 3500 concerts and toured in all of the fifty states and on five of the seven continents. As a touring artist for 30+ years, LaMotte has developed a large and loyal following. His music has been honored with numerous awards and artist grants, and has been featured on dozens of artist compilations. Notably, his song Dark and Deep was included on Songs Inspired By Literature, a benefit album to raise money for adult literacy.";
