iwts_performer:9543 a schema:PerformingGroup;
  schema:name "Daredevils of Deception";
  schema:description """Featuring Central Canada’s most dangerous
performer (Brett Oddly) and leading mentalist
(Patrick Gregoire), Daredevils of Deception is a
unique fusion of danger, deception, and laughs.
Brett’s vaudeville-inspired escapes and dangerous
feats collide with Patrick’s modern mastery
