iwts_performer:9813 a schema:Person;
  schema:name "Sébastien Lépine";
  schema:description "Recognized as one of Canada’s standout cellists, Sébastien Lépine has built an enviable reputation through bold and authentic musical projects. A former student of the legendary Janos Starker, he brings virtuosity and sincerity to every performance. Acclaimed for his recordings and concerts worldwide, he is a recipient of several major awards, including the Grands Prix culturels de Trois-Rivières and the Gala Arts Excellence Award.";
