iwts_performer:10249 a schema:Person;
  schema:name "Marla Goodman";
  schema:description "An obsession with a rare and fascinating musical instrument propelled Bozeman grandmother Marla Goodman's unlikely trajectory into performance art. Her \"Vinyl Sisters Theremin Show\" combines visual art, storytelling, and music produced live on the Theremin, a gesture controlled synthesizer invented in 1920. In an imaginary world enhanced by kitsch-infused contemporary art and quirky collage animations,  Goodman's personae, Polly & Dolly Vinyl, perform songs spanning from folk to film scores as they share their wildly fictional family history.";
  schema:url <https://goodwerks.com/wordpress/marla-goodman-theremin/>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
  schema:genre "Spoken Word";
