iwts_performer:8807 a schema:PerformingGroup;
  schema:name "Almost Johnny Cash";
  schema:description "Almost Johnny Cash, featuring David James, is often described as one of the most authentic Outlaw Country tribute shows touring today. From the way James holds his guitar to the way he talks his audience, the legendary musicians live again when James steps to the mike and says, “Hello - I’m almost Johnny Cash.” or plays that classic leather bound telecaster guitar like Waylon.";
