iwts_performer:8835 a schema:PerformingGroup;
  schema:name "Lewis & Royal";
  schema:description "Lewis Lewis & Royal are an Alberta-based folk duo known for their rich harmonies, warm storytelling, and infectious energy. Blending folk, country, and roots music, they captivate audiences with songs that celebrate prairie life, love, and laughter. With over two decades of performing together, they’ve become favourites across Western Canada. Their hit musical “Chickens” remains a standout. Whether playing beneath the open sky or in an intimate venue, Lewis & Royal promise a performance full of charm, humour, and unforgettable melodies.";
  schema:url <https://lewisandroyal.com>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
