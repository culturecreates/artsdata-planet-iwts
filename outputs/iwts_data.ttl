iwts_performer:7802 a schema:PerformingGroup;
  schema:name "Elise Boulanger";
  schema:description "Elise Boulanger is a sweet darkness. This Cinematic Indie-Folk artist captivates audiences with her haunting avalanche of a voice. Boulanger is a bilingual operatically trained musician that creates dreamscapes atop orchestral strings, piano, drums and ukulele. She is reminiscent of Kate Bush with her angelic yet raw artistry. Her actions are bold and beautiful as she teaches audiences how to live well with the planet. She has performed for several theatres and Canada Day Victoria. Boulanger’s most recent release is music video “Chrysalis.”";
  schema:url <https://www.eliseboulanger.com>;
