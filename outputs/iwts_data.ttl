iwts_performer:9580 a schema:PerformingGroup;
  schema:name "Adam Johnson";
  schema:description "Adam Johnson is a country rock artist from Saskatoon, Saskatchewan. Adam is a multi-SCMA-nominated and award-winning artist who has achieved early success in his short career, receiving thousands of radio plays worldwide and performing shows across Canada. In the fall of 2024, he released his first full-length album, “For The Record.” The album features two top 100 radio singles and has accumulated more than 200,000 streams across platforms. Adam is currently in the studio with plans to release new music in the fall of 2025.";
