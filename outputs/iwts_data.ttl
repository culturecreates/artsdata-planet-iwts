iwts_performer:9207 a schema:PerformingGroup;
  schema:name "The Out Seer";
  schema:description "The Out Seer is a Canadian alt-rock indie band based in Vancouver, featuring Ashley Pearce (vocals/guitar), Amanda Chan (vocals/keys), Lachlan Tocher (bass), Aybars Savat (drums), and Davis Yates (session guitar). The members first connected while studying music at Selkirk College and later regrouped in Vancouver to focus on original music. They released their debut album Changes in 2025, have toured the Okanagan twice, performed at multiple festivals, and are currently working on a new album slated for release in 2026.";
  schema:url <https://www.theoutseer.com>;
