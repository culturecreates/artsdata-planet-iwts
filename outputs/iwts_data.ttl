iwts_performer:8661 a schema:Person;
  schema:name "Jordyn Rayne";
  schema:description "Jordyn Rayne is a 26-year-old pop/punk powerhouse from Edmonton, blending early-2000s pop/punk with a modern edge; her lyrics champion female empowerment. Her 2025 single “Hellhound” stormed international radio and earned semi-finalist recognition at the Music in Motion Canada Awards. Her recent accomplishment is recording with Juno Award-winning and original member of Glass Tiger, Michael Hanson. Her debut album, Lady, gained chart success, national press, and festival stages across Alberta. Jordyn’s redefining pop/punk—bold and unstoppable.";
