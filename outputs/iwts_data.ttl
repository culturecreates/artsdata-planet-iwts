iwts_performer:8587 a schema:PerformingGroup;
  schema:name "Tina Hartt";
  schema:description """Tina Hartt is a singer, composer and musician. She has been gaining recognition since her 2023 album “Absence of You” was nominated for Jazz Recording of the Year by JazzYYC.

Known as Calgary’s “jazz singer with a French twist”, Tina Hartt brings a performance full of 'joie de vivre' that is both intense and mischievous. You'll hear funky bilingual originals, romantic French chansons, a fresh take on jazz standards and an abundance of Latin grooves.""";
