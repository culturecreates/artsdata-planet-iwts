iwts_performer:9576 a schema:Person;
  schema:name "Maclayne";
  schema:description "Maclayne is a Calgary and Toronto-based singer-songwriter whose music is as hooky, fun & quirky as it is sincere & moving. A gifted storyteller with a natural ability to connect deeply with her audience, Maclayne delivers relatable folk-pop songs that will play in your head on repeat. Her debut album \"Off The Deep End\" was named one of the year's best by the Calgary Herald and CBC Calgary, and she was recently nominated for three YYC (Calgary) music awards. Maclayne is currently recording her sophomore album, set for release in spring 2027.";
  schema:url <https://maclayne.com/>;
