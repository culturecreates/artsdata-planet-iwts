iwts_performer:9841 a schema:Person;
  schema:name "Catherine Gignac";
  schema:description "Catherine Gignac is a sand artist working at the intersection of visual and performance art. She creates sand theatre performances, a rare art form in which she draws live with sand on a light table, guided by music. Her drawings come to life and transform before the audience’s eyes, in a wordless, universal visual language. Her artistic world is profoundly poetic, imbued with mystery, silence, and beauty. Both delicate and powerful, her works open a space for contemplation and intimacy.";
  schema:url <https://www.art-catherine.com/>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/TheatrePerformance>;
