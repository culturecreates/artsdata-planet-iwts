iwts_performer:9352 a schema:Person;
  schema:name "Gigi Vega";
  schema:description "Gigi Vega is a Billboard Charting artists. She recently won the Best Music Video Award at the Spirit of Independence Awards in Beverly Hills for her moving visual, Back Home, inspired by the many people around the world who are separated from their loved ones due to war and devastation. Gigi's holiday song, Mistletoe Kiss, went Tik Tok viral and was featured in an Amazon/TUBI movie called \"The Drone that Saved Christmas.\" Gigi Vega is a professional dancer, in addition to being a singer songwriter/producer.";
  schema:url <https://breakoutmusic.com/gigi-vega/>;
