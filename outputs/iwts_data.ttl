iwts_performer:836 a schema:Person;
  schema:name "Tayo Aluko";
  schema:description "Nigerian-born British-based writer, actor singer performing one-man plays viewing world history through an Afrocentric lens, and using his fine baritone voice as a vehicle for storytelling and social justice activism. Two previous plays (Call Mr. Robeson and Just an Ordinary Lawyer) have taken him as far North as Inuvik in North West Territories of Canada and as far South as Wellington New Zealand. He has also performed across Britain, Africa and the Caribbean. Most notable venue is Carnegie Hall, NY but also comfortable in rural village halls.";
  schema:url <http://www.tayoalukoandfriends.com>;
