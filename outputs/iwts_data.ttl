iwts_performer:9734 a schema:Person;
  schema:name "Andrew Rodgers";
  schema:description "Andrew Rodgers is a MusicNL award-winning and ECMA-nominated singer-songwriter based in St. John’s, NL. His debut album Let It Out earned three MusicNL nods, and his single “Downtown” hit #7 on 103.9 New Country FM’s \"10 Most Wanted List.\" A founding member of Fairgale, Andrew has shared stages with Arkells, Melissa Etheridge, and Bryan Adams. He co-wrote “Already Gone,” which won “Roots Release of the Year” at the 2025 ECMAs. Andrew also performs with Nick Earle & The Reckless Hearts, opening for major acts like Nickelback & ZZ Top.";
  schema:url <https://andrewrodgersmusic.com/>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
