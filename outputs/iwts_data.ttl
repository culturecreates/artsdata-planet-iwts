iwts_performer:7885 a schema:PerformingGroup;
  schema:name "Catherine Kennedy";
  schema:description """Singer-songwriter Catherine Kennedy invites you to join her on the long way home. Her music’s nostalgic routes, soulful lyrics, and bluesy tones make for an unforgettable journey, drawing you in to explore your own story through her sound.

 Whether she's delivering an intimate ballad or a heart-pounding anthem, her music weaves together personal truths and universal emotions, creating a space where listeners feel seen and understood.""";
