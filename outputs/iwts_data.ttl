iwts_performer:9597 a schema:PerformingGroup;
  schema:name "Sankofa Dance Collective";
  schema:description "Sankofa Dance Collective is dedicated to preserving and celebrating African and Caribbean dance traditions with the powerful rhythms of live drumming. Rooted in Sankofa“go back and fetch it”they embrace cultural heritage to inspire movement, connection, and storytelling through drumming, dance, and song. Their performances blend traditional folk dances, contemporary fusions, and rhythmic storytelling, honoring the resilience, history, and spirit of the African diaspora.";
