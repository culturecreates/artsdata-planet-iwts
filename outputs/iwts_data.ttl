iwts_performer:10073 a schema:PerformingGroup;
  schema:name "OIivier Madore-Millette";
  schema:description "Olivier Madore-Millette is a Québec-based jazz organist, pianist, composer and arranger known for his vibrant command of the Hammond organ. Blending jazz tradition, soul and funk with a modern groove-driven approach, he founded the Pulsart Trio in 2017, a distinctive ensemble featuring organ, vibraphone and drums. The trio has earned two GAMIQ nominations and the Grand Prize for Emerging Artists at Festi-Jazz de Rimouski. His debut album Live au Ste-Angèle was named Best Album of 2024 by critic Christophe Rodriguez.";
  schema:url <https://linktr.ee/madoreo>;
