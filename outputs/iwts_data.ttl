iwts_performer:7429 a schema:Person;
  schema:name "Alysha Brilla";
  schema:description "Alysha Brilla is an Indo-Tanzanian Canadian singer-songwriter, producer and multi-instrumentalist blending global roots with folk sounds. A 2025 Women In Music International Leadership Honouree, three-time JUNO nominee, and 2024 Canadian Screen Award-nominated composer (The Queen Of My Dreams), Brilla’s music fuses Indian and East African elements with layered vocals and percussive guitar. A Berklee professor and sought-after speaker, her dynamic live shows showcase her artistry on guitar, piano, drums and percussion.";
  schema:url <http://www.alyshabrilla.com>;
