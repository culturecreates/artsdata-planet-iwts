iwts_performer:10225 a schema:Person;
  schema:name "Marissa K";
  schema:description "Marissa K is an Edmonton-based singer-songwriter known for her theatrical, story-driven pop music. With a background in dance and theatre, she creates a unique, colourful world for her listeners, blending the vitality of artists like Sara Bareilles with her own distinct style. Her discography includes the EP Postcards (2017) and the deeply personal concept album Train to Lviv (2025), which explores her Ukrainian heritage and themes of cultural identity. Marissa's music is a journey for anyone seeking a sense of belonging.";
