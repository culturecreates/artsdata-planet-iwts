iwts_performer:4893 a schema:Person;
  schema:name "Ron Pearson";
  schema:description """Ron Pearson has presented his unique magic show around the world, performing everywhere from the Royal National Theatre in London, England to Carnegie Hall in New York City.
He was chosen to represent Canada as a performer at both the Commonwealth Games in Manchester, England and the Smithsonian Institute in Washington, DC.
The Globe and Mail has called his magic, “Brilliant”, the Edmonton Journal has said he performs “Mind-Boggling Sleight of Hand”, and the CBC has said his show is “Outstanding”.""";
