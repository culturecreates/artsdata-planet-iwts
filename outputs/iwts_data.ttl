iwts_performer:3691 a schema:PerformingGroup;
  schema:name "JARABE";
  schema:description "JARABE has cultivated a signature nostalgic sound they call Bordeño Soul that highlights their Southwest border roots. They combine musical genres from different eras including Mexican Folk, American Rock & Roll, Norteño/Tex-Mex, Caribbean-style Trío Romántico, Rock En Español, and popular Cumbia. Performing on traditional folk instruments with a modern attitude, Jarabe’s dynamic storytelling and powerful bilingual vocals leave audiences singing, dancing, and cheering for more!";
  schema:url <https://www.marianliebowitz.com/jarabe>;
