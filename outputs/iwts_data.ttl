iwts_performer:9745 a schema:PerformingGroup;
  schema:name "Duane Forrest";
  schema:description "Duane Forrest is a Toronto-based singer-songwriter and multimedia artist. He has released two albums, toured internationally, and received radio play across Canada, Europe, and Central America. His theatre work includes Climb (runner-up “Show of the Festival,” Milan Fringe 2023) and Bob Marley: How Reggae Changed the World (5-star, sell-out, Edinburgh Fringe 2024). Born in Scarborough to Jamaican parents, his work blends reggae, jazz, and storytelling with themes of history and social justice.";
