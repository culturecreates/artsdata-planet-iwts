iwts_performer:9599 a schema:Person;
  schema:name "Bryce Morin";
  schema:description "Bryce Morin is a multi-faceted artist, theatre actor, vocalist, cultural revitalist, educator, powwow dancer, traditional drummer/singer, and storyteller. Recently Bryce has taken the theatre world by storm for his lead role performance as “Danny” in the all-star, Indigenous hit –musical, BEAR GREASE! Bryce showcases as a solo act performing a mix of R&B Soul and traditional hand drum music, focusing on the interconnectedness of \"past, present, and future\".";
