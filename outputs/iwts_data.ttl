iwts_performer:10147 a schema:PerformingGroup;
  schema:name "Jacie Sites";
  schema:description "Miss Jacie and the Nitpickers deliver a high energy fusion of bluegrass and Americana led by 5 time National Fiddle Champion and Grand Master Fiddler Champion Jacie Sites. A featured performer at the Grand Ole Opry, Jacie brings virtuosity and engaging stage presence. Featuring Sophie on cello, Pete on guitar and banjo, and Alan on bass and dobro, the band creates a rich acoustic sound driven by Jacie’s roots vocals, offering broad audience appeal and a rapidly growing social media presence.";
