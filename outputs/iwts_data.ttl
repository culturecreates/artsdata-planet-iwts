iwts_performer:9350 a schema:PerformingGroup;
  schema:name "Imaginary Expedition";
  schema:description "Emerging acoustic folk duo with snug harmonies and cozy vibes. This Toronto-based songwriting collaboration features classical-composer Glyph Greenleaf and vocalist Victoria Dobbs, who take the intricate melodies and structures of classical music, and combine them with familiar folk harmonies. The duo is known for lap-style classical guitar, memorable melodies, dynamic vocal harmony & counterpoint, and moving lyrics that reward listeners with timeless stories. So take off your shoes, and let the music lead you on an Imaginary Expedition.";
  schema:url <https://www.imaginaryexpedition.com>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
  schema:genre "Folk/Bluegrass/Americana";
