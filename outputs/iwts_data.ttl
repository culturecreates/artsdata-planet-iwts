iwts_performer:7308 a schema:Person;
  schema:name "Darcy Stamp";
  schema:description "Darcy Stamp is a Canadian jazz violinist whose sound captures the charm of the swing era—think fedoras, late-night clubs, and classic cocktails. He’s performed at the Kennedy Center and Jazz YYC Festival, and worked with Josh Groban, George Canyon, and The Calgary Jazz Orchestra. A major milestone in his career was premiering The Stamp Collector Suite in 2023. His latest album, It Doesn’t Have To, But It Might, reflects his passion for expanding the jazz violin repertoire. He proudly endorses REMIC Microphones.";
  schema:url <http://www.darcystamp.com>;
