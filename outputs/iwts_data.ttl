iwts_performer:9550 a schema:PerformingGroup;
  schema:name "Elana James";
  schema:description "Austin, TX-based Hot Club of Cowtown (HCCT)'s jaw-dropping musicianship & exhilarating live shows have become the band's global brand. Drawing its inspiration from the western swing of Bob Wills & the American Southwest, the band effortlessly combines vintage string music, three-part harmony singing, & swinging dance music with unmatched joy & virtuosity. The HCCT has won numerous awards, including Ameripolitan Music Awards for Western Swing Group & Western Music Association's Crescendo Award, & inducted into the TX Western Swing Hall of Fame.";
  schema:url <https://hotclubofcowtown.com>;
