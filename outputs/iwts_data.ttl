iwts_performer:8661 a schema:Person;
  schema:name "Jordyn Rayne";
  schema:description "Jordyn Rayne is a pop/punk singer-songwriter who is becoming known as Edmonton's Punk Princess. Jordyn just released her second full-length album, “Lady\" which received coverage in The Edmonton Journal, and hit #10 on CJSR-Edmonton's Top 30 list in August. This past summer, Jordyn was invited to perform at the world-renowned Taste of Edmonton Festival and embarked on a 10-stop Alberta-based tour in the summer of 2024. In 2025, Jordyn will be playing at the Highlight Festival, recording new music and releasing her deluxe album for “Lady.\"";
