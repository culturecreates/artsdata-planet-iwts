iwts_performer:9344 a schema:PerformingGroup;
  schema:name "Exact Resemblance";
  schema:description "Exact Resemblance produces thought-provoking theatre that tackles complex societal issues and promotes a culture of equity, diversity, and inclusion. Committed to amplifying the voices of women-identifying, gender-diverse, and refugee and immigrant artists, we seek to foster an inclusive cultural environment. Exact Resemblance values collective decision-making and maintains high standards in all aspects of production, ensuring transparency, accountability, and cultural safety.";
