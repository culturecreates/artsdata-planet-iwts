iwts_performer:8921 a schema:PerformingGroup;
  schema:name "Veranda";
  schema:description "Formed at Montreal’s Barfly, Veranda unites actress Catherine-Audrey Lachapelle and multi-instrumentalist Léandre Joly-Pelletier. With harmonies as pure as mountain air, Veranda brings a rare, cinematic glow to North American roots music. Blending heartfelt old country with bluegrass virtuosity, they’ve charmed audiences across Canada, Europe and the U.S. With 250+ shows and showcases (RIDEAU, RADARTS, IBMA and FAI) and five award nominations for their album Là-bas (2022), the duo readies their second full-length release for winter 2026.";
  schema:url <https://www.verandamusic.com/>;
