iwts_performer:10082 a schema:Organization;
  schema:name "Dance Kaleidoscope";
  schema:description "Celebrating its 54th season, Dance Kaleidoscope is one of the longest running professional companies in the Midwest and is acclaimed for its legacy of athletic, engaging, and artistically compelling performances. Under Artistic Director Joshua Blake Carter, the company showcases dynamic works from today’s top choreographers—bold, unforgettable for dance lovers and welcoming to first-time audiences. This diverse company of 14 captivates with magnetic stage presence, technical brilliance, and genuine connection.";
