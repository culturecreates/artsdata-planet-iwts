iwts_performer:9000 a schema:PerformingGroup;
  schema:name "HeZza FeZza & Nomadic Nebula Band";
  schema:description "HeZza FeZza (vocals/keys) leads an eclectic soul-world-pop collective. With a 5-octave range and speaking 5 languages (learning more), HeZza bridges people, place, and purpose. The band—a cowboy’s grandchild, Saipan picker, shredding drummer, and Charm City beauty queen—specializes in site-specific, all-ages performances and local festivals. HeZza is a 6th-gen PNW artist with Montana roots and a nomadic upbringing across Europe and Turtle Island, expressing the universalities of journeying back to self, finding love and family, courageously.";
  schema:url <https://www.hezzafezza.com>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
