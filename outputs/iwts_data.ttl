iwts_performer:9531 a schema:Person;
  schema:name "Aly Williams";
  schema:description """Aly's music celebrates the history and landscape of her home in near the Rocky Mountains and the experiences of women in the wild place she calls home.
Experiences on the trails and rivers in Canada, as well as a deep inspiration from the women who broke trail before her, inspire her folky music.
Her debut album: \"Mountain Matriarchy\" tells the stories of 6 women who made a life near her homestead in Southern Alberta before she did: women she admires as she tries to make a life in Pincher Creek, Alberta.""";
  schema:url <https://www.alywilliams.ca>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
