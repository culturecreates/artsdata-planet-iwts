iwts_performer:1860 a schema:Person;
  schema:name "The Story Ship / Sean Driscoll";
  schema:description "The Story Ship provides immersive theatrical adventures for children pre k - 5th grades and family audiences. The shows combine interactive animation with musical theater, comedy, magic, movement, puppets and puzzles. Each show is highly interactive and based upon themes that teach. Kids are on adventure to solve a singular problem and must work together to solve puzzles, help with magic tricks, sing songs, and move to music.";
