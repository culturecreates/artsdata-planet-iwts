iwts_performer:9916 a schema:Person;
  schema:name "Devin Matthews";
  schema:description "Devin Matthews is a Billings-based classical guitarist. A lifelong guitar lover, she cites her grandfather's stories of playing flamenco guitar in Spain and New York City as her earliest inspiration. In addition to teaching guitar in Billings, she performs in the greater Southwest Montana/Northern Wyoming area at community concerts, weddings, and events. She holds a Bachelor of Music Performance from Webster University in St. Louis and a Master of Music Performance from the University of Montana (anticipated Fall 2026).";
