iwts_performer:10246 a schema:Person;
  schema:name "CALL ME IRRESPONSIBLE: Collin O'Connor sings Bobby Darin";
  schema:description "Collin O'Connor is a powerhouse vocalist and entertainer whose career has taken him all around the world, performing in over 35 countries! Highlights are the smash hit musicals of \"Jersey Boys\" and \"Mamma Mia!\", and studying with the legendary comedy improv troupe: The Second City. When he's not singing, you can hear his voiceover work on the hit podcast \"Thamro,\" see him in national commercials for Wendy's and Taco Johns, or find him on television in notable shows like \"Law and Order\" and \"The Americans.\"";
