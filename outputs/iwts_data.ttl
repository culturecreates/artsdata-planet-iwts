iwts_performer:10028 a schema:PerformingGroup;
  schema:name "Blue Rivera";
  schema:description "Blue Rivera is a multifaceted four piece alternative rock band from Vancouver BC.  Founded in 2018 by twin brothers and producers Julian and Joaquin, Blue Rivera's style ranges from indie/alternative rock performances to classic latin  renditions. Their EP releases such as \"c'est la vie\"(2024) and \"sleeping\"(2025) have helped them find a spot in the Vancouver music scene. The band prides itself in its Mexican-Canadian background and francophone roots, a trilingual statement that defines what they do.";
  schema:url <https://www.bluerivera.ca/>;
