iwts_performer:8544 a schema:PerformingGroup;
  schema:name "Pulsart Trio";
  schema:description "Pulsart Trio, Canada’s only vibraphone, organ, and drum trio, fuses modern jazz, funk, and blues in original compositions. Redefining 60s jazz with a progressive and experimental edge, each show is an improvised journey where instruments come alive. Nearing their tenth anniversary, Olivier Madore-Millette, Simon Beauséjour, and Jérémie Carrier shine with four acclaimed albums, GAMIQ nominations, and the 2021 Festi Jazz Grand Prix.";
