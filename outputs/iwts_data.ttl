iwts_performer:10127 a schema:Person;
  schema:name "Simon Farintosh";
  schema:description "Simon Farintosh is an award-winning classical guitarist and composer known for his innovative approach to the instrument. A prominent figure in the Pacific Northwest, he is a Guitar Instructor at the University of Victoria and President of the Victoria Guitar Society. Specializing in the 8-string guitar, Farintosh has gained recognition for his unique arrangements, from Alexander Scriabin to Aphex Twin. A DMA candidate, his work bridges classical tradition with modern landscapes to push the boundaries of the genre.";
  schema:url <https://www.simonfarintosh.com>;
