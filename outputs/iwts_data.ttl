iwts_performer:9319 a schema:Person;
  schema:name "Jocelyn Lai";
  schema:description """Juilliard-trained classical concert pianist, Jocelyn Lai, has captivated audiences across British Columbia and abroad through passionate performances of innovative programs. She has performed at festivals and academies across Canada, the United States, and Spain, with recent performance highlights including a solo concert tour in British Columbia and a featured faculty recital at Hunter College.
Currently based in Vancouver, Jocelyn teaches award-winning students at the Vancouver Academy of Music while maintaining an active performing career.""";
