iwts_performer:5345 a schema:Person;
  schema:name "Mitchell Makoons";
  schema:description """Mitchell Makoons (he/him) is a Roots/Rock musician from Brandon, Manitoba. Mitchell started playing guitar at the age of seven to accompany his grandfather and brother playing Metis fiddle tunes. The songs Mitchell writes incorporate traditional Ojibway music and culture with modern influences.
In 2024, singles “Courage” and “Changing Man” from his debut album Lady Boots reached No. 1 on the Indigenous Music Countdown. At the 2025 Manitoba Country Music Awards, Makoons was named “Roots Artist of the Year.”""";
  schema:url <http://mitchellmakoons.com>;
