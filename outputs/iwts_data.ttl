iwts_performer:9410 a schema:PerformingGroup;
  schema:name "Heistek & Plato";
  schema:description "The Vancouver duo features Karin Plato (vocals/ukulele) and Guido Heistek (vocals, ukulele and guitar) performing arrangements of jazz, pop, folk and original songs. They radiate a rare chemistry and charm which has garnered them a loyal Vancouver following. The baritone and concert ukes intertwine to create a delicate yet utterly satisfying support for two voices that complement each other so very well. You'll find yourself smiling or laughing at this duo's mercurial banter, or swept away by their irresistible groove, and vocal harmonies.";
  schema:url <https://www.karinplato.com/>;
