iwts_performer:10115 a schema:Person;
  schema:name "Jaiden Riley";
  schema:description "Jaiden Riley is an Albertan Métis singer/songwriter whose music captures the heart of the prairies and the pull of old-soul storytelling. Rooted in folk songwriting, classic country, and bluegrass, her sound is both timeless and unmistakably her own. Often punctuated by a cheeky yodel or two, Jaiden leans into an old-world country spirit inspired by Hank Williams, Patsy Cline, and Dolly Parton, while blending heart-worn ballads with gritty, hard-driving arrangements that strike a rare balance.";
  schema:url <https://www.jaidenrileymusic.com/>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
