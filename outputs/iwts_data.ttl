iwts_performer:7184 a schema:PerformingGroup;
  schema:name "Appalachian Road Show";
  schema:description "A visionary acoustic ensemble, bringing new-generation interpretations of traditional Americana, bluegrass and folk songs, each telling the story of Appalachia. GRAMMY-nominated banjoist Barry Abernathy, GRAMMY-winning fiddler Jim VanCleve, esteemed vocalist and mandolinist Darrell Webb, 26-year-old  “old soul” guitarist Zeb Snyder, and GRAMMY-winning bassist Todd Phillips musically describe jubilation and deep despair in the impoverished hills and valleys of Appalachia.";
  schema:url <https://www.theappalachianroadshow.com/>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
