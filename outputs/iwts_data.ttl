iwts_performer:9316 a schema:Person;
  schema:name "Morgan Klaiber";
  schema:description "Morgan isn't just flying the flag for Western country music; you should say she is riding for the brand itself. After many  high impact performances across the west, including Country Thunder Alberta and Big Valley Jamboree, she debuted her album Hardgrass Country to a soldout crowd at the Esplanade Theatre. Shortly after it was awarded \"Album of the Year\" at the Country Music Alberta Awards. Masterfully written tales of the western way of life, and honkytonk bangers, showcase how versatile she is as a vocalist, but even more so as a songwriter";
  schema:url <https://morganklaiber.com/>;
