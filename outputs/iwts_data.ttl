iwts_performer:10244 a schema:PerformingGroup;
  schema:name "GO79MAN (Gold Man)";
  schema:description "Walter Gilmore (GO79MAN) is a Paramount Studios sync artist and theme composer delivering \"The Golden Intervention\"—a high-energy, 100% profanity-free theatrical production. This multidisciplinary stage show features a live ensemble (saxophone and keyboards) alongside professional choreography and scripted narrative storytelling. Following a sold-out headline show at Boxyard RTP, GO79MAN brings a \"stadium-ready\" energy that bridges the gap between modern rhythm and soulful art, offering a polished, intergenerational experience for 2026.";
  schema:url <https://www.instagram.com/go79man>;
