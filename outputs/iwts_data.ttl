iwts_performer:9876 a schema:PerformingGroup;
  schema:name "James Vickers Band";
  schema:description "James Vickers bloodlines are from the Tsimshian, Heiltsuk, and Haida Nations, as well as of British descent.  James started playing guitar in March of 2020.  He has been self taught with the aid of You Tube. James made his stage debut in August 2021 one week before his 12th birthday.  Since then he's formed his band in 2023, performed in the International Blues Challenge, released his debut EP containing 5 originals in 2024, released his first full album in 2025, did his first tour in June 2025, and has opened for many established musicians.";
  schema:url <https://we.tl/t-S9BqiTsvqn>;
