iwts_performer:9711 a schema:Person;
  schema:name "Mike Murray";
  schema:description "With a career in the music industry that spans well over a decade, thousands of performances across the US and beyond, seven studio albums, and music featured on network and streaming television, Montana Singer/Songwriter, Mike Murray, has developed the experience and versatility to explore a broad range of genres, both on stage and in the studio. With the pureness of a classic folk storyteller, his music carries a message of camaraderie, empathy, and naturalism while drawing inspiration from his adventurous life experiences in the outdoors.";
