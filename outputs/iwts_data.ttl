iwts_performer:8462 a schema:PerformingGroup;
  schema:name "Jeremy Ledbetter Trio";
  schema:description "Forged in a cauldron of electrifying contemporary jazz, the Jeremy Ledbetter Trio is a force of nature—blurring the lines between jazz and world music with a fearless, high-voltage sound. Audiences beware: once you experience this trio’s relentless energy and masterful musicianship, there’s no going back. If the Jeremy Ledbetter Trio were an inanimate object, it would be a runaway train—unstoppable, exhilarating, and utterly unforgettable.";
