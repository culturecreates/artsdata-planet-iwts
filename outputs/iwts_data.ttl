iwts_performer:9752 a schema:PerformingGroup;
  schema:name "Maggie's Wake";
  schema:description "Maggie’s Wake is an award winning Canadian, female fronted roots band that delivers unforgettable performances while creating a sound that is at once, both classic and modern. With original compositions that remain faithful to our influences in traditional folk and classic country music, our songs are enhanced by Celtic instrumentation which gives us an unmistakable sound.  Our music is rooted in our heritage and we are building on the foundation of trad and folk while managing to create something authentic, original and inspired.";
