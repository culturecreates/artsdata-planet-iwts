iwts_performer:3138 a schema:Person;
  schema:name "Saxsational";
  schema:description "In 1984, Rob co-founded the Side Street Strutters Jazz Band which presented formal concerts and symphony pops programs in 49 states and 7 European countries.  In 2008 he formed \"Saxophobia\", a show featuring many rare saxophones with a focus on historical saxophonists in jazz history.  Several years later Rob created \"Saxsational\", a solo guest artist program where high school jazz and concert bands join him on stage.  Rob has been employed with the Disney Entertainment Division for 41 years as a performer, clinician and educator.";
  schema:url <https://saxophobia.net>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
  schema:genre "Jazz/Blues";
  iwts:consent "agree_v_1.0";
