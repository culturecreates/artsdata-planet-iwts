iwts_performer:2819 a schema:Person;
  schema:name "Adi Braun";
  schema:description "ADI BRAUN has a long list of cabaret, concert and theatre successes to her credit.  She has performed in every major jazz and concert venue in Toronto, has toured Canada, the United States, and Europe.  In 2023 Adi released her sixth CD recording “Night and Day - The Cole Porter Songbook” – which follows her previously celebrated recordings “Moderne Frau – Modern Woman” (2017), a tribute to the music of Weimar Cabaret, “Canadian Scenes I” (2010), Live at the Metropolitan Room (2007), The Rules of the Game (2006), and Delishious (2003).";
  schema:url <http://www.adibraun.com>;
