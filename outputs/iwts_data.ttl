iwts_performer:8889 a schema:PerformingGroup;
  schema:name "Forever Simon & Garfunkel / The Everly Set (Celebrating The Everly Brothers)";
  schema:description "Sean Altman (founder Rockapella, Carmen Sandiego theme songwriter) and Jack Skuller (Songwriters Hall of Fame’s Buddy Holly Prize) offer 2 outstanding shows celebrating 4 of the most acclaimed songwriters in Rock & Roll history.  ‘The Everly Set’, ultimate concert celebration of the legendary Everly Brothers and ‘Forever Simon & Garfunkel’  celebrates the bestselling duo in rock’n’roll history.  Each show is available as a duo or a quartet and features all of the amazing songs that made these 2 groups history makers!";
