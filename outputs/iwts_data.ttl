iwts_performer:7818 a schema:PerformingGroup;
  schema:name "Stick&Bow (Krystina Marcoux & Juan Sebastian Delgado)";
  schema:description "Montreal-based duo Stick&Bow, formed by two passionate musicians, won the 2022-23 Opus Awards for “Artists of the Year” and “International Outreach.” Known for their strong stage presence and eclectic repertoire, they fuse marimba and cello in original arrangements. They recently toured France (40 dates) with Jeunesses Musicales, played the Bach Festival Montreal and Festival du Bout du Monde, represented Quebec in Colombia, performed in Argentina, and toured Atlantic Canada with Debut Atlantic.";
