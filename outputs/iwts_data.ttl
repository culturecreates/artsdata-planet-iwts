iwts_performer:8384 a schema:PerformingGroup;
  schema:name "James Gordon";
  schema:description "Veteran Songwriter/performer known for his \"Melodious Documentation of ourLives\", now touring with his \"Exceptional Ensemble\"- known as \"Canadian Folk Royalty\"- who offer compelling arrangements of his unique songs with a roots/folk feel , exploring our history and landscape:  environmental, social justice issues, and the humour he became known for as CBC Radio Songwriter-in-residence with \"Basic Black\". With 42 albums to his credit, he's honed a lively stage show that includes lots of BC-based material and his classics like \"Frobisher Bay.\"";
