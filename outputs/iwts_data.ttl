iwts_performer:9886 a schema:Person;
  schema:name "Shawn Daniels";
  schema:description "Shawn Daniels is a Canadian outlaw country rocker blending gritty country, blues soul, and high?voltage rock. From Langley, BC, he’s earned attention with singles like “Louder Than Ten,” “Country Wild,” and the reflective “We All Find a Way.” With raw energy, heartfelt storytelling, and a rebellious edge, Daniels is carving out a bold new lane in modern country music.";
  schema:url <https://www.shawndanielsmusic.com/>;
