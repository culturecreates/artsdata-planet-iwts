iwts_performer:9898 a schema:PerformingGroup;
  schema:name "Jackson Klippenstein";
  schema:description "Jackson Klippenstein is a Kenora, Ontario based singer-songwriter who has been sharing his passion on stage for as long as he can remember. His music brings a laid-back blend of Indie, Rock, Folk, and Blues to the table. Jackson’s latest project, One Piece at a Time, showcases a range of lyrical themes, along with unique melodies and driving rhythms. Lately, Jackson has been expanding his audience with high-energy shows across Northwestern Ontario and Manitoba, with the rest of Canada on the horizon.";
  schema:url <https://www.jacksonklippenstein.com/>;
