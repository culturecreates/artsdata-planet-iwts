iwts_performer:8141 a schema:PerformingGroup;
  schema:name "Ollee Owens";
  schema:description "Far more than a vocal powerhouse,Calgary-based Blues/Americana artist Ollee Owens blends grit and intensity with exquisite skill. With the warmth of Mavis Staples and the soulful delivery of Bonnie Raitt, Ollee’s voice goes directly to the heart, drawing on a wealth of experience, acknowledging trials while never losing sight of what truly matters. Her live performances are unforgettable, emotionally charged musical experiences moving both body and soul- creating lasting connection with her audiences.";
