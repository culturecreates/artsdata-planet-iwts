iwts_performer:6538 a schema:PerformingGroup;
  schema:name "Joyride";
  schema:description "Colin Maier (oboe, saw, vocals, from Quartetto Gelato) & Mark Camilleri (pianist and music director for The Tenors) are “Joyride”, a super high-energy show of Latin, klezmer, Celtic, ragtime, pop jazz, and more.  JoyRide has performed at the Collingwood Festival, Hamilton’s Westdale Theatre, the Burlington Performing Arts Centre, and at regional theatres in Deep River, Cornwall, St. Catherine’s, Brantford & Bobcaygeon. “Ridiculous, virtuosic, outside-the-box fun … It takes a lot of nerve to make music as amusing as JoyRide’s!” (NY Music Daily)";
  schema:url <http://www.joyrideconcerts.com>;
