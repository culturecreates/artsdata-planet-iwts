iwts_performer:9370 a schema:PerformingGroup;
  schema:name "The North Wind";
  schema:description """The North Wind is a dynamic flute and guitar duo featuring Bailey Finley and Tina Hebner. The duo first met in 2020 and when the stars aligned they started playing together while working at a music summer camp in Kamloops. Tina invited Bailey to join in on some Celtic tunes and then they just kept on playing together! 
Blending elements of folk, jazz, Celtic, pop, and classical music, The North Wind offers a fluid and captivating sound.""";
