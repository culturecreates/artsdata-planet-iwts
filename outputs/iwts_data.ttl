iwts_performer:9635 a schema:PerformingGroup;
  schema:name "Fiddle Express";
  schema:description "Fiddle Express is a dynamic family band captivating audiences across the western U.S. with lively performances and heartfelt music. Blending bluegrass, folk, and modern styles, siblings Andrew, Rachel, and Eliza each bring unique talents to the stage. Andrew shines on mandolin and guitar, Rachel dazzles on fiddle with charisma, and Eliza anchors the group with soulful playing. Their third album, Musical Rizz, is gaining traction worldwide, solidifying their spot as a festival favorite known for tight harmonies and electric energy.";
  schema:url <https://fiddleexpress.com/>;
