iwts_performer:9503 a schema:Person;
  schema:name "Wylie Gustafson";
  schema:description "Singer, songwriter, rancher, horseman, and the original, world-famous Yahoo!® yodeler, Wylie Gustafson is a real life cowboy born into a 4th generation ranching family on the empty sprawl of Northern Montana.  He is an authentic artist who genuinely reflects the rural life of the American West.   With 35 years of touring under his belt Wylie has brought his unique brand of American Music to audiences all over the world.   He is considered “A national treasure of the American Folk Music scene” by the National Council for the Traditional Arts.";
  schema:url <https://www.wyliewebsite.com>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
