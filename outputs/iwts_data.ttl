iwts_performer:8657 a schema:Person;
  schema:name "Rick Miller";
  schema:description "Rick Miller is one of Canada’s most celebrated theatre artists. His award-winning creations have toured to five continents in six languages, and Entertainment Weekly called him “one of the 100 most creative people alive today”.  His solo show \"MacHomer: The Simpsons do Macbeth\" toured the United States for over 17 years, and played to over 500,000 audience members in 175 cities. His current \"BOOM Trilogy\" of solo shows has been performed over 700 times around the world, and is only now beginning to tour the USA.";
  schema:url <https://www.rickmiller.ca>;
