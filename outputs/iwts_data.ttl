iwts_performer:8797 a schema:PerformingGroup;
  schema:name "GQ - Gentlemen's Quartet";
  schema:description "GQ is a modern, elegant take on some of the most famous classical and popular music the world has ever known. From Beethoven to John Legend, their one-of-kind arrangements fuse multiple genres together in a perfect symphony of sophistication, virtuosity and humor. Featuring Peter Sachon on cello, Matt Scharfglass on guitar & bass, Ben Saporito on drums and David Shenton on piano and violin, these world-class musicians boast impressive musical credits including Broadway, The West End, celebrity performances and major symphonies around the globe.";
  schema:url <https://www.gqnyc.com/>;
