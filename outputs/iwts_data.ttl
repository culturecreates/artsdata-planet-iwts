iwts_performer:9693 a schema:PerformingGroup;
  schema:name "Candlelight Celtic";
  schema:description "Candlelight Celtic surrounds their audiences with a soft, warm glow of over 1100 candles, in a one-of-a-kind ethereal atmosphere coupled with the soul-stirring melodies of Ireland.  The 7-pc ensemble combines flutes/whistles, violin, guitar/vocals, bodhran/percussion and 3 lead vocalists.  The audience will feel as if enchanted by a spell, as the beauty of Irish music and the intimacy of candlelight come together in perfect harmony.  “Candlelight Celtic was magical and such a great performance!” – Perkinson Center (VA)";
  schema:url <https://www.ecetouring.com/artist/candlelight-celtic>;
