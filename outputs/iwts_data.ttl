iwts_performer:10176 a schema:PerformingGroup;
  schema:name "CELIN";
  schema:description "CELIN is a Calgary-based alternative pop and neo-soul artist whose music feels like golden hour—warm, unhurried, and good for the soul. Her music creates space for the conversations people are often afraid to have. With rich vocals and introspective songwriting, she explores themes of mental health, identity, and growth. Her debut EP, Purely Chemical (April 2026), turns honesty into connection—breaking down barriers and stigma. CELIN’s live presence is intimate, immersive, and emotionally resonant.";
  schema:url <https://www.celinmusic.com/epk>;
