iwts_performer:2618 a schema:Person;
  schema:name "Glenn Sutter";
  schema:description """Glenn Sutter (sue-ter) is a Saskatchewan folk-rocker whose songs and stories draw you in, like a gentle fire. From finger-style guitar to boogie piano, his shows help people escape for a while and find common ground, with hints of Greg Keelor, John Prine, and John Hiatt.

Shortly after his 2008 debut, Sutter hit the national spotlight when his tune “Weight of the World” landed on David Suzuki’s Playlist for the Planet. Since then, he has toured, played big stages, and released four more albums, including a 2024 release called “Truth and Lies.\"""";
  schema:url <http://www.glennsutter.com>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
