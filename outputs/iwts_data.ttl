iwts_performer:10207 a schema:PerformingGroup;
  schema:name "Heartland Marimba";
  schema:description "Heartland Marimba has worked since 2014 to build a sustainable future for the classical marimba art form. Inspired by the legacy of Claire Omar Musser, the organization brings performances and educational programs to communities of all sizes, especially underserved areas. Since its founding, Heartland Marimba has presented 200+ concerts in 50+ cities, commissioned 20+ composers, employed 30+ young artists, and reached thousands of children through outreach and education.";
  schema:url <https://www.heartlandmarimba.com/>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
