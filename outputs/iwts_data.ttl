iwts_performer:9145 a schema:Person;
  schema:name "Logan Richard";
  schema:description "Logan Richard (pronounced Re-shard) is one of music’s rarest creatures—a sharp, versatile songwriter and electrifying guitarist. Raised on Prince Edward Island and influenced by Stevie Ray Vaughan, John Mayer, and Jason Isbell, he blends slick pop, spacey R&B, and soulful folk. Produced by David Myles and Joshua Van Tassel, his album Character Traits showcases both heart and range. His music has earned multiple awards and over two dozen syncs, including Hudson & Rex and Ginny & Georgia.";
  schema:url <https://loganrichardmusic.com/>;
