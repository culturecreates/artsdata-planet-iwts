iwts_performer:9437 a schema:PerformingGroup;
  schema:name "Beòlach";
  schema:description "Beolach celebrates 25 years as the stalwarts of Cape Breton traditional music. International touring ambassadors they have presented time honoured arrangements with fiddle, bagpipes, piano and stepdance highlighting the unique voice of Canada's Celtic Island. All members were raised in communities with rich musical legacies of interconnected histories of Scotland and Canada. With nods to the past but encouraging succession in the arts, Beolach is integral to Cape Breton's beloved musical identity and cannon of tunes that capture Celtic life.";
  schema:url <https://www.beolach.ca>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
