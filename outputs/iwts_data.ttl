iwts_performer:10220 a schema:PerformingGroup;
  schema:name "Erwilian";
  schema:description "Erwilian is a Seattle-based Billboard® #1 acoustic ensemble celebrated for blending Celtic, New Age, and World music into richly textured, all-acoustic instrumental works. Since 2000, the group – led by soprano recorder, violin, harp, and hammered dulcimer – has built a reputation for innovative live performances and chart-topping albums like CASCADIA and ADVENT. Their music has appeared on GRAMMY® Award-winning releases, earning worldwide airplay through masterful, synthesizer-free soundscapes that expand the boundaries of acoustic artistry.";
  schema:url <https://www.erwilian.com>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
  schema:genre "Global";
  iwts:consent "agree_v_1.0";
