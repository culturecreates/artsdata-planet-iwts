iwts_performer:9510 a schema:PerformingGroup;
  schema:name "PIANOMANIA!";
  schema:description "Take a Rock 'n' Roll rollercoaster ride through one of the most influential musical styles of the 20th Century in PIANOMANIA! – Jared Freiburg’s high-energy celebration of the 1950s. Featuring music made famous by the most prolific piano entertainers from that era (including Little Richard, Ray Charles, and more) as well as many of the artists who influenced them and were influenced BY them, this show has electrified audiences worldwide by showcasing Jared’s incredible virtuosity on a cavalcade of rock-and-roll, blues, jazz, and country hits.";
  schema:url <https://jfreiburg.com/pianomania>;
