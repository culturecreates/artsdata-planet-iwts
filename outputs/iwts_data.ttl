iwts_performer:9500 a schema:Person;
  schema:name "Sarah Banker";
  schema:description """Sarah Banker is a TEDx featured songwriter and performing artist with the intention to be a source of light and love through sound. Her soothing voice and catchy lyrics accentuate her soulful indie vibe and message of compassion and resilience. Recently, Sarah exhibited the philosophy
behind her music during her TEDx presentation titled “Our Love”, which sets the stage for her upcoming EP release, Into the Heart (April 25').""";
