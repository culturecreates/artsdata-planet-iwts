iwts_performer:10229 a schema:Person;
  schema:name "Poor Nameless Boy";
  schema:description "The soft, melodic delivery of Poor Nameless Boy is born from a keen perception of the human condition. With shiver-worthy vocal tones reminiscent of Donovan Woods and Gregory Alan Isakov, Henderson’s stark vulnerability sets him apart. Since the release of EPs The Activity Book (2013) and Wake Up Call (2019) and the stunningly beautiful album Bravery (2016), Henderson has seen notable milestones, including a worldwide publishing deal, rotation on SiriusXM, several successful international tours and official showcases, and a Global Music Award.";
  schema:url <https://www.poornamelessboy.com/>;
