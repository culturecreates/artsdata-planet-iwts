iwts_performer:9421 a schema:Person;
  schema:name "Simon Denizart";
  schema:description "Originally from Créteil, a small suburd outside of Paris. French pianist Simon Denizart moved to Montreal in 2011 and quickly made his mark. He won the Audience Award at FestiJazz de Rimouski in 2014, leading to three albums with 270 Sessions and a Radio-Canada Revelation award in 2016. Critically acclaimed, he has toured worldwide and collaborated with Fred Wesley and Dominique Fils-Aimé. His album, NOMAD (2021), blends jazz, world, and electronic music. In 2023, he joined Justin Time Records for his quartet album Piece of Mind.";
  schema:url <https://www.simondenizart.com/>;
