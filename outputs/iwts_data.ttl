iwts_performer:1616 a schema:PerformingGroup;
  schema:name "Collision of Rhythm";
  schema:description """The duo: a tap-dancing classical and jazz
virtuoso, Aaron Williams, and beatbox-juggling
keynote speaker, Bronkar Lee. Aaron’s background in
music education (Level 3 Certification in Orff Schulwerk
pedagogy) and Bronkar’s entertainment background (Featured on the Tonight Show with Jay Leno,
Madison Square Garden, and a SuperBowl commercial)
and public speaking  makes them a triple
threat. The duo brings world-class entertainment, a
passion for community outreach, and an empowering
message of joy, hope, and connection through rhythm
and music.""";
