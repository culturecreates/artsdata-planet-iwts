iwts_performer:9165 a schema:PerformingGroup;
  schema:name "John Dagostin";
  schema:description "John from Dawson is an Anishinabeg Hip-Hop artist raised on the Traditional Territory of the Tr'ondëk Hwëch’in. JFD has released three full length albums, multiple singles and 4  music videos. JFD has performed at large venues such as Dawson City Music Festival, Edmonton Fringe Festival, Keno City Music Festival and Break Out West. He has opened for artists such as Haviah Mighty, Super Duty Tough Work and Shad.  JFD uses emotional inner thoughts to create catchy hooks that keep crowds energized and engaged.";
  schema:url <https://www.johnfromdawson.ca/>;
