iwts_performer:9963 a schema:Person;
  schema:name "Audrey Ochoa";
  schema:description "Audrey Ochoa is an Edmonton based trombonist, vocalist, composer and arranger. She has won the Edmonton Music Prize (2018), a Western Canadian Music Award for Jazz Artist of the Year (2020) and was nominated for Juno for Solo Jazz album (2023). She composes and performs many genres from traditional jazz to latin, pop, ska and rock and has appeared on stages with the Dave Matthews Band, Marcus Miller, Tito Nieves and Dave Hillyard to name a few.";
  schema:url <https://www.audreyochoa.ca>;
