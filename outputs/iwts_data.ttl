iwts_performer:9977 a schema:Person;
  schema:name "Miarlequin";
  schema:description """The thread that keeps one from getting lost, that is what music is to Miarlequin. A whimsy pop artist, she moves through reality in ways that blur the boundary between the familiar and the strange. Shaped by a nonlinear experience of reality, she has glimpsed fractured worlds. 
Miarlequin holds a Bachelor of Music in Composition from the University of Calgary and has released her debut EP. She has participated in the TD Music Residency and the Write On! Program. Miarlequin seeks truth in a world that is both unimaginably vast and small.""";
  schema:url <https://miarlequin.squarespace.com/>;
