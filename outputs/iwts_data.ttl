iwts_performer:9714 a schema:Person;
  schema:name "Aleksi Campagne";
  schema:description "Named Penguin Eggs & Roots Music Canada's New Discovery of the Year, Aleksi Campagne offers a contemporary, indie-folk take on the time-honoured fiddle-singing tradition. From Montreal, Aleksi’s music blends folk songwriting with an edgy, multi-layered sound resulting from his unique combination of voice, violin and looping-effect pedals. His debut album For The Giving / Sans rien donner won a Canadian Folk Music Award 2024 for French Songwriter of the Year and is fully bilingual, offering 10 songs in French and the same 10 songs in English.";
  schema:url <https://www.aleksicampagne.com/>;
