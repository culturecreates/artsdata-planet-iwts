iwts_performer:7440 a schema:PerformingGroup;
  schema:name "Tennyson King";
  schema:description "Tennyson King ?? is an award-winning, nomadic folk artist from Hong Kong and Canada known for his joyful, high-energy live show. Blending Western indie-folk with traditional Chinese sounds, he performs in English and Chinese, layering kick drum, Zhongruan, and guitar. Fresh off international tours, including a standout set at Glastonbury Festival, he delivers interactive, uplifting performances filled with playful stories from life on the road, getting audiences moving and leaving them feeling better than they arrived.";
  schema:url <http://www.tennysonking.com>;
