iwts_performer:9695 a schema:PerformingGroup;
  schema:name "Light Chasers";
  schema:description "Light Chasers is an immersive performance blending live rock music, dance, theatrical storytelling, projections, and live painting. Created with Cloud Cult, it explores love, loss, and resilience—particularly the grief of child loss—transforming performance into a communal ritual of healing that fosters connection, catharsis, and hope through multi-arts expression.";
