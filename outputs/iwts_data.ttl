iwts_performer:9305 a schema:Person;
  schema:name "Krista Hartman";
  schema:description "Krista Hartman is an old country singer-songwriter and storytelling traveller. Her musical vibe is rare and akin to the hidden gem you might find in a thrift store. She has independently released four shabby-chic albums. Her distinct voice and cinematic lyrics are picturesque and heartfelt. Her songs are deep and  acoustic guitar tones rich, memorable and catchy. Her latest record, Transcend, explores themes of alignment and contemplates the connection between mind, soul body and spirit. \"Her lyric is compelling, I love her voice.\"- Ron Sexmith";
  schema:url <https://linktr.ee/kristahartman?utm_source=linktree_profile_share&ltsid=94e03f29-77e9-49c0-8df9-f569>;
