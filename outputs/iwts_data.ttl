iwts_performer:8904 a schema:Person;
  schema:name "Bobby Dove";
  schema:description """Bobby Dove is a trans/non-binary singer-songwriter in the genres of Americana, Country and Roots music. 
Born in Montreal, Quebec, Bobby moved to rural Manitoba in 2020, and has performed at Winnipeg Folk Festival, Vancouver Island Music Fest and Vancouver Folk Festival. Slated to release a new full length album in 2025, Bobby Dove has been showcasing over the past twelve months at SXSW, AmericanaFest, Folk Music Ontario and Folk Alliance International.""";
