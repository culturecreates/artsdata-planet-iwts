iwts_performer:9890 a schema:Organization;
  schema:name "Wapanacahkos";
  schema:description "Wâpanacahkos is a groundbreaking BIPOC dance collective that blends diverse Indigenous cultural stories with innovative movement. Committed to reshaping the dance and theatre landscape, Wapanacahkos creates an inclusive space where artists explore new forms of expression while honouring their rich heritages. Through cutting-edge choreography and collaborative performances, the collective challenges traditional boundaries and invites audiences to experience dance in its most dynamic and transformative state.";
