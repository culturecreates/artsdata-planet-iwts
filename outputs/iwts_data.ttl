iwts_performer:10041 a schema:PerformingGroup;
  schema:name "Christine Jensen Quartet";
  schema:description "Christine Jensen, hailed as one of Canada's most influential composers and saxophonists, leads an exceptional quartet that includes the talented pianist Steve Amirault, the skillful bassist Adrian Vedady, and the remarkable drummer Jim Doxas. They form an ensemble which can only be cultivated through years of collaboration, it’s a date where she creates an improvisational community of close friends in quartet and duo settings.The music (Album Day Moon Juno Winner 2024) is at turns, melancholic and ebullient, sober and playful.";
  schema:url <https://christinejensenmusic.com/>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
