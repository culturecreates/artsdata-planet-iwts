iwts_performer:10065 a schema:PerformingGroup;
  schema:name "The Lolas";
  schema:description "Founded in 2018 in Vancouver, BC, The Lolas are a collective of professional dancers and showgirls creating original revue-style productions inspired by vaudeville, silent films, and classic cabarets. Their performances blend Broadway jazz, physical comedy, and musical theatre into dazzling, story-driven spectacles. Their current touring production, Stardust, is a diamond-heist dance cabaret combining espionage, romance, and high-energy choreography.";
  schema:url <https://TheLolas.ca>;
