iwts_performer:9754 a schema:PerformingGroup;
  schema:name "The Dusty Halos";
  schema:description "With celestial harmonies and intricate fingerstyle guitar, The Dusty Halos combine the textures of old time acoustic music with original songwriting. Since forming in 2022, the Halifax-based duo has quickly gained attention for their songcraft and intimate vocal chemistry. Weaving themes of heartbreak and longing into tuneful tapestries, The Dusty Halos explore the interplay of light and darkness, finding solace in the shadows. The duo's second EP, “Keep Us this Night,” will be released in November 2025, featuring the single “With You.\"";
  schema:url <https://www.rebeccafairless.com/the-dusty-halos>;
