iwts_performer:4522 a schema:Person;
  schema:name "Kellie Haines";
  schema:description "Vancouver ventriloquist Kellie Haines has been performing since the age of 8. She’s built a reputation as a dynamic in-demand entertainer, filling rooms with laughter and wonder. How does that bird talk by itself?! She’s performed thousands of shows in theatres, schools and headlining children’s festivals throughout BC, northern and western Canada. Recently she played VentFest and Vent Haven in the USA, where she represented Canada. Kellie channels the energy of Tourette syndrome into performances that are electric, fun and uplifting.";
  schema:url <http://www.kelliehaines.com>;
