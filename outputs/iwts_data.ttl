iwts_performer:6232 a schema:PerformingGroup;
  schema:name "Kiran Ahluwalia";
  schema:description "Two-time JUNO Award winner Kiran Ahluwalia's open-hearted vocals are rooted in Indian and Pakistani traditions with a strong contemporary edge bringing together the disparate traditions of South Asia, West African blues and Jazz. Ahluwalia’s band is led by Pakistani-American guitarist Rez Abbasi - a Guggenheim Fellow and one of Downbeat’s Top Ten Guitarists. Kiran and Rez are a real-life couple; born in the warring motherlands of India and Pakistan they transcend borders by creating music that is elegant, complex and ultimately universal.";
  schema:url <http://www.KiranMusic.com>;
