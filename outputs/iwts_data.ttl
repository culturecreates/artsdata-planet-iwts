iwts_performer:17 a schema:Person;
  schema:name "Matthew Byrne";
  schema:description "Matthew Byrne's rich and powerful vocals, refined guitar style, masterful storytelling, and compelling interpretations of unique traditional songs have made him a favourite of folk audiences in Canada and abroad. After a long hiatus from the studio and the road, Byrne released his 4th studio album, Stealing Time. This project brought Byrne to Yellow Arch Studios in Sheffield, UK, where he teamed up with folk legend Martin Simpson as producer. Byrne's newest release has gained him two Canadian Folk Music Award nominations.";
  schema:url <https://www.matthewbyrne.net>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
  schema:genre "Traditional";
  iwts:pronouns "He/Him";
