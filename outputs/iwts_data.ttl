iwts_performer:10071 a schema:Person;
  schema:name "Eric Leclerc";
  schema:description "Eric Leclerc is a globe-trotting comedy magician performing feel-good magic for your brain. He was the host of TRICKED on Disney+ for 3 seasons and a regular on NatGeo's top-rated show Brain Games. A two-time Canadian Magic Champion, Eric's high-energy style has taken him around the world, from performing at Reddit's LIVE Super Bowl event to wowing crowds at the Rio Casino in Las Vegas. He recently starred in BIG TRICK ENERGY on TruTV and Netflix. He also fooled Penn & Teller on their hit CW show Fool Us, earning him international acclaim.";
  schema:url <https://ericleclerc.com>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/VarietyShow>;
