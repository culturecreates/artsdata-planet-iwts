iwts_performer:7394 a schema:PerformingGroup;
  schema:name "Jon Martin";
  schema:description "Jon Martin is a songwriter, producer, and musician from Edmonton, and the artist behind Jon Martin and Lovers. Producer Gethin Pearson described his music as “timeless capsules… whilst also feeling fresh and from your life.” His 2022 album This Could Be Our Year was named one of the Edmonton Journal’s 10 Best Local Releases, with airplay across Canada including live performance on CBC Radio One. His latest album, Late September Garden Party (2025), reflects a period of major life change, including becoming a father, with more music on the way.";
  schema:url <https://jonmartin.ca>;
