iwts_performer:631 a schema:Person;
  schema:name "Chris Ronald";
  schema:description "Chris Ronald’s “keenly luxuriant voice and immaculate songcraft” (The Georgia Straight) have won him many accolades including a nomination for “Songwriter of the Year” at the Canadian Folk Music Awards. Originally from England, Chris' music has been described as Canadian folk with British roots. In live performance, Chris draws on his abilities as an accomplished singer, storyteller, and multi-instrumentalist to deliver a captivating show. His latest and fifth album, Light and Dark, was released on esteemed Canadian label Borealis Records.";
  schema:url <http://www.chrisronald.com>;
