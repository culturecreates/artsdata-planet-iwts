iwts_performer:10180 a schema:PerformingGroup;
  schema:name "The One Hit Wonderers Band";
  schema:description "The One Hit Wonderers—a powerhouse five-piece band of world-class musicians—bring audiences back to the golden age of AM/FM radio with spot-on recreations of the one-hit wonders everyone knows, loves, and sings along to. In their crowd pleasing show, ‘I Love That Song,’ fans of classic rock, pop, disco, and R&B from the 1950s through the 1980s will rediscover the unforgettable hits that defined generations—performed exactly as they remember them.";
  schema:url <https://youtu.be/D9bjJS5uo8E?si=GJvoSE_Za_5E7oSN>;
