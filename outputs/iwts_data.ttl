iwts_performer:9816 a schema:PerformingGroup;
  schema:name "Pony Girl";
  schema:description "Pony Girl is a shape-shifting art-rock collective from Ottawa-Hull whose music transforms the familiar into something surreal. Described as “pure magic to see live” (Ottawa Showbox) and “astonishing to experience in person” (Exclaim!), their performances reveal meticulous craft and emotional daring. Signed to Paper Bag Records, Pony Girl has released four acclaimed albums—including a #1 record on CBC Radio 3—and performed at SXSW, Pop Montréal, Ottawa Jazz Festival, Canada's National Arts Centre, and Festival d’été de Québec.";
  schema:url <https://www.ponygirl.ca>;
