iwts_performer:9600 a schema:PerformingGroup;
  schema:name "Adrian Xavier and Ska Island";
  schema:description "Adrian Xavier & Ska Island is a dynamic fusion band blending reggae, ska, and Afro-Latin rhythms into an electrifying, spiritually uplifting live experience. A regional supergroup, the group has come together over the past two years on Lopez Island to develop a unique sound that draws from their diverse musical backgrounds. Their infectious energy and cross-cultural blend of styles have been captivating audiences across the Pacific Northwest.";
