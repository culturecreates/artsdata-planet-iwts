iwts_performer:9309 a schema:PerformingGroup;
  schema:name "Mommy, Daddy";
  schema:description "Mommy, Daddy is a singer and guitarist duet consisting of Alanna Finnson and Sean Mourre who play jazz, pop, blues, rock, prog and more.  The two met serendipitously and soon realized they had a deep musical gift between them that had to be developed and shared.  It wasn’t long before Mommy, Daddy were taking on iconic songs by Ella Fitzgerald, Patsy Cline, Nat “King” Cole and Etta James while also finding joy in lesser played pop songs which intend to bring forgotten nostalgia to any audience.  ";
  schema:url <https://www.instagram.com/mommydaddy1713/profilecard/?igsh=aGU1c2NvN3E0Z2gw>;
