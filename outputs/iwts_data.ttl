iwts_performer:9689 a schema:Person;
  schema:name "Jason A Mullinax";
  schema:description """My name is Jason Mullinax and I'm a songwriter, percussionist, instrument builder, videographer, and music educator with nearly 40 years of drumming and performance experience.

I started facilitating Music Discovery Lab workshops in 2015 and I've been continuously inspired by the enthusiastic response from both children and adults ever since. I feel that my job as an instructor is to demystify the process of instrument building and music making so that anyone who has a passion for exploring sound can create something of their very own.""";
  schema:url <http://www.musicdiscoverylab.com/workshops.html>;
