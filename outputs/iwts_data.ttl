iwts_performer:8917 a schema:Person;
  schema:name "Aliya Kanani";
  schema:description "Aliya Kanani is an award-winning comedian and Canadian Academy–nominated actress. Her internationally toured show was awarded Best of Fest and Patron’s Pick. Aliya has performed at Just For Laughs, Melbourne International Comedy Festival, NBC Breakout Festival, Johannesburg International Comedy Festival, and Edinburgh Fringe. She was a finalist in Just For Laughs’ Standup and Pitch competition and wrote on the comedy series Abroad. Nominated for Best Lead Actress for Scarborough, Aliya continues expanding her repertoire in film and television.";
