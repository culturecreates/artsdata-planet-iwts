iwts_performer:10018 a schema:Person;
  schema:name "Tiffany Sparrow";
  schema:description "Tiffany Sparrow is a soulful folk-roots singer-songwriter blending acoustic warmth with cultural depth. A Métis artist and certified music therapist, she creates from the belief that music is medicine, weaving resilience and growth through songs in English, Cree, French, and Sanskrit. Her albums “Good Place” and “Journey On” explore personal and collective healing and her sound evokes Brandi Carlile, Sarah McLachlan, Jason Mraz, and Leela Gilday. She's toured across Canada and internationally and is poised for expanded touring worldwide.";
  schema:url <https://tiffanysparrow.com>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
