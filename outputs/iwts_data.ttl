iwts_performer:7688 a schema:PerformingGroup;
  schema:name "The North Sound";
  schema:description "At the heart of great songwriting is great storytelling. For award winning duo The North Sound, songs are a declaration of joy, a hallmark of yearning, and a tender tale of honesty. Yet amidst the rawness, trials and tribulations, there are notes of hope and happiness. This is the duo at their best: Sharing stories in the way they know how. The North Sound is a partnership between lead singer, songwriter and multi-instrumentalist Forrest Eaglespeaker and vocalist and composer Nevada Eaglespeaker.";
  schema:url <http://www.thenorthsoundmusic.com>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
