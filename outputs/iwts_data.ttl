iwts_performer:9388 a schema:Person;
  schema:name "Saveeta Sharma";
  schema:description "Saveeta Sharma is an internationally recognized dancer and choreographer specializing in Indian classical dance forms (Kathak & Odissi) and modern dance. She has trained under esteemed mentors and earned degrees in Dance from the University of New Delhi. She founded Upasana the Spirit of Dance in 1990, and the Saveeta Sharma Dance Company in 2008. She has presented numerous events and festivals, and her award-winning work blends classical and modern dance, influencing the global dance community through performances, choreography, and education.";
