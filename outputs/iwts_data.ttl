iwts_performer:9747 a schema:PerformingGroup;
  schema:name "Wolfville";
  schema:description "Wolfville is the folk-pop duo of acclaimed songwriters Scarlett Flynn and Kevin Howley, former leaders of Running Red Lights. With credits including opening slots for Great Big Sea, Barenaked Ladies, and Counting Crows, a Canadian Songwriting Contest win, and Anthem Entertainment’s first artist deal, they bring proven artistry to the stage. Their upcoming FACTOR-supported debut album (Winter 2026) chronicles their 13-year romance in cinematic, emotionally charged storytelling.";
