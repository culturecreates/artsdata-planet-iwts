iwts_performer:5113 a schema:PerformingGroup;
  schema:name "Daniel Gervais";
  schema:description "Daniel Gervais is a two-time Canadian Grand Master Fiddle Champion (2011 & 2016). He has a Master of Music in classical performance from the University of Alberta. He performs extensively throughout the year with ~100 dates (school, community and festival dates). Some of his performance highlights include the Smithsonian Folklife Festival, the London Olympics, fiddle soloist performances with ESO and RSO. He lives in Edmonton with his wife, a French-Canadian step-dancer, and four kids.";
