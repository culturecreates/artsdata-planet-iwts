iwts_performer:6104 a schema:Person;
  schema:name "Chiara Izzi";
  schema:description "Chiara Izzi is a leading international vocalist who rose to prominence after moving to New York City. Her breakthrough came when Quincy Jones awarded her first prize at the Montreux Jazz Festival. Blending jazz with Italian songwriting and Brazilian influences, she is also an acclaimed composer; her song Circles of the Mind won Best Jazz with Vocals at the Independent Music Awards (2020). Her albums Live in Bremen (2022) and Across the Sea (2019, with Kevin Hays) highlight her expressive, multilingual style.";
  schema:url <http://www.chiaraizzi.com>;
