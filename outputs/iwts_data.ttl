iwts_performer:9341 a schema:Organization;
  schema:name "Elena Belyea";
  schema:description "Elena Belyea (they/she) is an award-winning writer, actor, producer, and director from amiskwaciwâskahikan (Treaty 6 territory.). Their work has been produced across Turtle Island and internationally. She's Artistic Director of Tiny Bear Jaws, which has produced three national tours. Elena was recipient of the 2023 Betty Mitchell Award (Calgary) for Outstanding Lead Performer in a Musical for their portrayal of “The Singer” in Young Jean Lee’s of We’re Gonna Die (Verb Theatre).";
  schema:url <https://elena.belyea.com>;
