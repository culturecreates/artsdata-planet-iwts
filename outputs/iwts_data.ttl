iwts_performer:10359 a schema:PerformingGroup;
  schema:name "Priyanka Vemuganti";
  schema:description """Satyam Shivam School of Dance is a premier Kuchipudi ensemble dedicated to the revival and evolution of one of India’s most vibrant classical dance forms. Based in RTP, the group is comprised of five seasoned dancers who blend the precision of Nritta (pure dance) with the deep emotional storytelling of Abhinaya .
With over 3 years of collective experience and performances at many venues , the ensemble is committed to making classical Indian arts accessible to diverse audiences offers a visually stunning, high-energy cultural experience.""";
