iwts_performer:10112 a schema:PerformingGroup;
  schema:name "Cris Derksen";
  schema:description "Cris Derksen is a two-spirit Juno Award–nominated Cree cellist, originally from Northern Alberta, Canada. Derksen is known for her unique musical sound, which blends classical music with traditional Indigenous music. Her music is often described as \"electronic cello\" or classical traditional fusion.";
