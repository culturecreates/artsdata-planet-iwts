iwts_performer:9607 a schema:Person;
  schema:name "John Heffron";
  schema:description "John Heffron, a 35-year comedy vet and Last Comic Standing winner, brings clean, nostalgic Americana Comedy to small-town theaters and corporate stages. Loved by Fortune 500s, his storytelling sparks 'I’ve been there!' laughs—free of politics or division. A bestselling author, John’s humor celebrates real-life moments that unite us, feeling like home. From Comedy Central to Netflix, his customized, relatable sets make every audience say, 'That’s me!'—a fresh take on stand-up rooted in Main Street USA";
