iwts_performer:10327 a schema:Person;
  schema:name "Daniel Reichard";
  schema:description "Daniel Reichard starred as Bob Gaudio in the Original Cast of Broadway’s Tony-winning JERSEY BOYS and appears on its Grammy-winning, multi-platinum cast album. NYC credits include Candide (NY City Opera/Lincoln Center), Radiant Baby (Public Theater), The Thing About Men, Emmet Otter, and Forbidden Broadway. A founding Midtown Men member, he’s played 1,000+ concerts worldwide and recorded albums and PBS specials. He’s sung with 35+ major symphonies (Boston Pops, National, Philly), headlined Lincoln Center, 54 Below, Birdland, Joe’s Pub & more.";
