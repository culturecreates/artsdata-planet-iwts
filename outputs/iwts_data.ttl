iwts_performer:10066 a schema:Person;
  schema:name "Tracy Lee Johnson";
  schema:description "Tracy Lee Johnson is a singer, performer, storyteller and educator based in Guelph, Ontario. Born in Brantford, she is a fifth-generation Black Canadian with ancestral roots in North Buxton, the Queen’s Bush settlement, and the Niagara-Brantford region. Known for her warm contralto voice influenced by gospel, jazz, and R&B, Tracy has performed in numerous schools, musical reviews, theatre productions, and community events. Through her work, she aims to inspire pride, connection, and deeper understanding of Canada’s diverse cultural legacy.";
  schema:url <https://tracylee.ca>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/ChildrensEvent>;
  schema:genre "Musical Theatre";
  iwts:consent "agree_v_1.0";
