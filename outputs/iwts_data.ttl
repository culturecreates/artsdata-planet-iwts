iwts_performer:4486 a schema:Person;
  schema:name "Travis Dolter";
  schema:description "With 100+ performances in 2025, Travis has been busy entertaining audiences across Western Canada. Authentic country-raised on the family farm near Edmonton, Travis has always been a performer. In theatres, bars, rodeos or festivals, he captivates everyone in attendance with his wide range of styles and is often compared to a country version of the Barenaked Ladies. His new single “Hell of a Saturday Night” had airplay on Sirius XM,  sync placements on Hockey Night in Canada and is an example of the energy that Travis brings to every show.";
