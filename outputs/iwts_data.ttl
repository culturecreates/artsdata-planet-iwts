iwts_performer:10136 a schema:Person;
  schema:name "Veronica Raine";
  schema:description "Veronica Raine is an indie folk singer/songwriter local to Southern Alberta, whose music is deeply rooted in personal storytelling and authentic connection. Her eclectic style reflects her diverse range of influences and most recently, Veronica has released her debut single, \"august\", which has brought her to bigger audiences world wide through articles and radio including SiriusXM and CBC. She has cultivated a distinctive musical style that blends folk, pop, and indie elements.";
  schema:url <https://www.veronicaraine.com>;
