iwts_performer:9458 a schema:Person;
  schema:name "Gabriel Schwartz";
  schema:description """Gabriel Schwartz is a Brazilian multi-instrumentalist who skillfully plays wind, string, and percussion instruments. Using a loop station, he single-handedly recreates the sound of an entire orchestra, sometimes building his arrangements in real-time.
He presents a repertoire rooted in Brazilian music, influenced by jazz and world music, featuring Brazilian standards as well as original compositions. Folk guitar and Brazilian percussion blend together, sometimes melancholic, sometimes light. Gabriel Schwartz plays with rare elegance. Dazzling!""";
  schema:url <https://linktr.ee/gabrielschwartzmusic>;
