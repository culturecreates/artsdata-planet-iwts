iwts_performer:9727 a schema:Person;
  schema:name "Gabriel Penna";
  schema:description "Gabriel has been performing since 2005 when his debut album, Coffee Cup, was released. For Gabe the message of folk music has been consistent: be free to be yourself, stand up for freedom for all, and love is the answer. Gabe believes his songs, his stories in song, his reflections on life in song, continue that tradition. Audiences come away from his shows feeling positive and encouraged. Gabe has 2 other CD's with his early band Gabe Penna & The Rising.";
  schema:url <https://www.facebook.com/profile.php?id=100024195159983>;
