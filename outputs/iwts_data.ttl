iwts_performer:8729 a schema:Person;
  schema:name "Glenn Buhr";
  schema:description "Composer/Producer Glenn Buhr is a soloist on guitar, piano, and voice and also an ensemble performer.  He's performed all over Canada at various festivals, concert halls and music clubs.  He has also appeared as a concerto soloist with the Esprit Orchestra, the Winnipeg Symphony Orchestra and the Vancouver Symphony Orchestra. He performed his 4th Symphony - subtitled Guernica 2017 - with the Vancouver Symphony Orchestra and the Button Factory Band in 2017. He's toured Canada twice as a jazz artist.";
