iwts_performer:9255 a schema:Person;
  schema:name "Kyrst Hogan";
  schema:description "A professionally trained singer, actress and dancer, Kyrst was based in NYC for over a decade, in such productions as the Radio City Rockettes Christmas show, Norwegian Cruise Lines, Atlantic City Casinos and more. She has presented musical, cabaret and theatrical events since 2008 through Brixxhouse Arts. Winner of \"Pick of the Fringe\" & \"Leaping Fringer\" in the 2022 Vancouver Fringe Fest, she was also dubbed \"A Dynamic Cabaret Chanteuse\" by Canada's Globe and Mail, \"phenomenal\" by Stir magazine and a \"Burlesque Star\" by The Georgia Straight.";
