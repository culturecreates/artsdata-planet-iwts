iwts_performer:8992 a schema:Person;
  schema:name "Randy Otto";
  schema:description """Renowned worldwide, Seasoned Actor and Keynote Leadership Speaker Randy Otto (from Beaufort, SC) has embodied Winston Churchill for over 4 decades and hundreds of appearances, earning him the distinction: Churchill Leadership Expert.
He immerses audiences in powerful, interactive \"Churchill Fueled\" one-man plays - Churchill: The Blitz, Man of the Century, Defending Liberty, Churchill: CEO, with every presentation including \"Ask Winston\" an interactive Q&A with Winston himself. 
Add \"Dining With Winston\" for an exhilarating fundraising idea.""";
