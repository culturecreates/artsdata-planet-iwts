iwts_performer:10342 a schema:PerformingGroup;
  schema:name "Chinobay";
  schema:description "Chinobay is touring as a solo artist, with a full band, and in a duo with David LaMotte. His band moves from Afrobeat rhythms to jazz inflections, transcending genres and creating a sound that is both distinctive and accessible. In all of his performances, Chinobay incorporates traditional instruments such as the kora, a West African harp-lute; the kalimba, a thumb piano native to East and Southern Africa; the tamani, a West African talking drum from Mali; and the endongo, a traditional Ugandan lyre.";
  schema:url <https://chinobay.com/>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
