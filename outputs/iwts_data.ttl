iwts_performer:9944 a schema:Person;
  schema:name "Kele Fleming";
  schema:description "Kele Fleming is the distinct love child of Linda Perhacs & Ani DiFranco. She’s 70’s psychedelic, feministic, intelligent- quoting Darwin & Foucault mid song.  Kele Charted at #1 3 weeks running on the New Queer Canada Music Charts, featured in The New Yorker Mag, & is a proud member of the LGBTQ2A community. Kele’s dynamic vocals range from choir girl naivete to raging Sinead O'Connor, profound lyrics that are more like a call to action. She recently quit Spotify in protest of the platform's link to military development and it's payola schemes.";
  schema:url <https://www.tinforest.com>;
