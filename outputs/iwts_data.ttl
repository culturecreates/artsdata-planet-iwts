iwts_performer:7609 a schema:PerformingGroup;
  schema:name "Alash";
  schema:description "Alash are masters of Tuvan throat singing, blending ancient vocal traditions with modern musical innovation. Fronted by Bady-Dorzhu Ondar—who first stunned American audiences as a child prodigy on The Tonight Show—Alash carries forward centuries-old techniques while pushing creative boundaries. Their recent collaborations with genre-defying artists such as Bela Fleck and the Flecktones highlight the group's versatility while pairing traditional Tuvan instruments with contemporary sounds.";
  schema:url <https://www.alashensemble.com/>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
  schema:genre "Traditional";
