iwts_performer:9709 a schema:Person;
  schema:name "Jessie Bird";
  schema:description "Jessie Bird is a country-folk singer-songwriter from Camrose, Alberta. Known for heartfelt lyrics and a voice compared to Joni Mitchell, she’s performed on CBC, CFCW’s Heartstrings tour, and at Edmonton Folk Fest. A Canadian Idol Top 100 finalist, she’s opened for Eric Kane and The Hearts. Her debut EP, The Way Love Goes, drops June 5, 2025. Jessie’s solo shows blend raw emotion, honest storytelling, and a deep love for connecting through music and shared experience.";
  schema:url <https://jessiebirdmusic.com/>;
