iwts_performer:8125 a schema:PerformingGroup;
  schema:name "AV and the Inner City";
  schema:description "AV & the Inner City is an award winning soul/roots vocal group which formed during the COVID-19 pandemic in Edmonton’s inner city.  Led by multi-award winning soul/blues artist AV (Ann Vriend) the group is a vibrant reflection of Canada’s musical diversity, with its’ all-female cast hailing from a very wide range of backgrounds. Their coveted stage performances are marked by emotional depth and vocal power, and while their lyrics cover sobering inner city topics their concerts also contain anecdotal personal stories and wry Canadian humour.";
  schema:url <https://avandtheinnercity.ca>;
