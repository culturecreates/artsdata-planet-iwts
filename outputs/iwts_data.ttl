iwts_performer:1054 a schema:PerformingGroup;
  schema:name "Dock Side Drive";
  schema:description "Dock Side Drive is one of the West Coast’s hottest swing & show bands. This dynamic band, known for their high caliber polished performances, powerhouse voices tight harmonies and fresh musical arrangements, offer a creative blend of vocal and instrumental tunes that will usher you through eight decades of song in a “Little Big Band” style. The 8-piece band hosts a roster of seasoned and established musicians from the Vancouver Island and has toured their high energy, engaging shows in theatre & festival stages through western Canada.";
