iwts_performer:10029 a schema:PerformingGroup;
  schema:name "The Black Market Trust";
  schema:description "The Black Market Trust is a 5 piece acoustic swing band who deliver rock-show intensity and infectious energy, pairing virtuosic musicianship with genuine interaction that keeps audiences engaged all night. We breathe fresh life into Great American Songbook classics with bold arrangements and raw charisma. Each member is a world class instrumentalist and and also sings to create unforgettable harmonies. For both a night of sophisticated entertainment or pure infectious joy, The Black Market Trust deliver a show that audiences crave.";
  schema:url <https://www.theblackmarkettrust.com/>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
  schema:genre "Jazz/Blues";
  iwts:consent "agree_v_1.0";
