iwts_performer:10184 a schema:PerformingGroup;
  schema:name "Cirque Us";
  schema:description "Cirque Us, an ensemble-driven troupe of teaching artists formerly with Circus Smirkus, dazzle with feats of aerial artistry, mind-bending acrobatics, high-wire hijinks, confounding contortionists, and more. Touring original, full-length productions that blend spectacle with inclusive, socially conscious storytelling and live music, the company specializes in ‘accessible spectacle,’ offering curated programming, camps, residencies, and hands-on workshops for communities of all ages and abilities, alongside dynamic mainstage performances.";
