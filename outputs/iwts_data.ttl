iwts_performer:10135 a schema:PerformingGroup;
  schema:name "Laurie Middaugh-Slater";
  schema:description """The Stevie Project - A Tribute to Stevie Nicks - The Stevie Project is not just a tribute band — it’s a living, breathing homage to the magic, mystery, and magnetism of Stevie Nicks. 

Fronted by Edmonton’s own Laurie Slater, this captivating show channels decades of Stevie’s storytelling, spellbinding vocals, and unforgettable stage presence into a one-of-a-kind concert experience, in a theatrical, chronological journey through Stevie’s life and music from her earliest songs to her timeless solo hits.""";
  schema:url <https://www.thestevieproject.ca>;
