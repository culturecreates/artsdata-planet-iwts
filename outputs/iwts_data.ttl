iwts_performer:7367 a schema:Person;
  schema:name "Devin Cooper";
  schema:description "Southern-Rock influenced country may seem contradictory in the Great White North, but that’s where Devin Cooper hangs his wide-brimmed hat. Cooper's signature sound is identifiable by his thoughtful songwriting and gritty rock 'n roll vocals. Kicking off 2025, Cooper secured six Country Music Alberta Nominations, making him the most-nominated solo artist at this year’s awards. This recognition is a testament to the success and impact of his 22-track double album, Good Things: Deluxe Edition released in 2024.";
  schema:url <https://www.DevinCooperMusic.com>;
