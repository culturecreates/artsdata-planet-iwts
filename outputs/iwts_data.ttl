iwts_performer:8778 a schema:Person;
  schema:name "Artaska Strings";
  schema:description """Artaska, a classically trained violinist with an innovative twist on the traditional, has made a notable mark in the music industry by merging the deep, soulful sounds of the violin with the contemporary elements. 

