iwts_performer:9349 a schema:PerformingGroup;
  schema:name "Linzle";
  schema:description "The creation of frontwoman Lindsay Donnick, Linzle is new to the Manitoba music scene and is eager to share her passion for performance and storytelling. Linzle’s music is a culmination of years of writing, and the stories depicted in songs- although heavily based in personal experiences- are inspired by her love of fairytales and gothic literature. These stories are brought to life through the blend of acoustic folk and harder rock genres, infusing romantic melodies with a cool edge.";
