iwts_performer:9308 a schema:PerformingGroup;
  schema:name "Sebastián Natal";
  schema:description "Sebastián Natal from Montevideo, Uruguay - now in NYC - began his career accompanying legends of Afro-Uruguayan music, and now tours with artists such as Pedrito Martínez. Sebastián Natal Candombe Septet, performs Afro-Uruguayan Candombe Jazz Fusion and explores the rich, centuries-old Afro-Uruguayan tradition of candombe, an expression declared as Intangible Cultural Heritage of Humanity by UNESCO.";
  schema:url <https://www.sebastiannatal.com/s-n-candombe-fusion>;
