iwts_performer:9789 a schema:Person;
  schema:name "Jake Martin";
  schema:description "Jake Martin is a New Brunswick-based actor, writer and comedian who has performed from coast to coast across Canada. A Second City Conservatory alum, he is a former member of the Canadian Comedy Award-winning sketch comedy group, The Sketchersons, the former Artistic Director of the Next Folding Theatre Company, and has performed with Second City Toronto's FamCo. His play \"Someone Gets Shot\" (Samuel French Off Off Broadway Festival) was shortlisted for the Carol Tambor Best of Edinburgh award.";
  schema:url <https://www.jakemartin.xyz>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/TheatrePerformance>;
