iwts_performer:4170 a schema:PerformingGroup;
  schema:name "Edda Glass and Max Hatt";
  schema:description "Edda Glass and her long-time collaborator Max Hatt have “forged a unique sound,” says NPR’s Larry Groce. Their work stretches from award-winning originals to reinventions like “Wichita Lineman” and “Girl from Ipanema,” carried by Glass’s unmistakable voice and Hatt’s atmospheric guitar. Ann Powers of NPR Music tags it “Beautiful… #chills,” while Nels Cline says it’s “subtly poignant, elegantly funky, and haunting without trying to be.” The duo has been featured by NPR, PBS, Lincoln Center, and the Kennedy Center. An immersive live experience.";
  schema:url <http://maxhatteddaglass.com>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
  schema:genre "Jazz/Blues";
  iwts:consent "agree_v_1.0";
