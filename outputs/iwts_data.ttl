iwts_performer:7740 a schema:Organization;
  schema:name "Corporeal Imago Performing Arts Society";
  schema:description """Corporeal Imago explores the tension between agency and tragedy through aerial acrobatics, contemporary dance and visual theatre. Our work bridges the apotheosis of circus, and its metaphor for surpassing our human limitations, with the cathartic potential of dance.

Choreographers Gabrielle Martin and Jeremiah Hughes founded CI while performing as principal characters with Cirque du Soleil’s TORUK in 2018. For two artists used to performing circus as entertainment, CI became a carte blanche to explore the shadow side of our human experience.""";
  schema:url <http://www.companyci.com>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/DancePerformance>;
  schema:genre "Circus";
  iwts:consent "agree_v_1.0";
