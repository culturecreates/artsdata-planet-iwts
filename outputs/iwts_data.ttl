iwts_performer:9685 a schema:PerformingGroup;
  schema:name "Mason Wasik";
  schema:description "Mason Wasik is an indie folk singer-songwriter and guitarist from the heart of North Carolina, whose music blends the rich traditions of the state’s bluegrass scene with elements of acoustic folk, indie-Americana, alt-rock, and bluegrass. Drawing on the storytelling roots of the Appalachian mountains and a deep love for the natural world, Mason’s sound resonates with listeners from all walks of life.";
