iwts_performer:371 a schema:PerformingGroup;
  schema:name "PUSH Physical Theatre";
  schema:description "ward-winning, genre-defining PUSH Physical Theatre blends gravity-defying acrobatics with soulful artistry, delivering original stories—funny, intimate, heartbreaking, and universal—through signature athleticism and fearless, no-holds-barred physicality. Founded in Rochester, NY in 2000, PUSH tours internationally, with highlights including Off-Broadway’s Soho Playhouse, Jerusalem’s International Festival for Jewish Theatre, multiple “Best of the Fest” awards, and a finalist finish on truTV’s Fake Off.";
  schema:url <http://www.pushtheatre.org>;
