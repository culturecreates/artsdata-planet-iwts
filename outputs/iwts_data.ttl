iwts_performer:7855 a schema:PerformingGroup;
  schema:name "Adrian and Meredith";
  schema:description "Adrian and Meredith, with their full band, deliver a high-energy performance blending Americana roots, bohemian spirit, and global rhythms. Their dynamic and unique sound combines fiddle tunes, brass swagger, and driving percussion, creating an unforgettable experience. With guitar, fiddle, saxophone, upright bass, and drums, they weave folk traditions, cultural influences, and evocative storytelling into a captivating show that keeps audiences dancing and fully immersed from start to finish.";
