iwts_performer:10215 a schema:PerformingGroup;
  schema:name "Warren & Flick";
  schema:description "Warren & Flick explore the nuanced textures of a two-person ensemble. Using both original material and arranged standards from many genres, this ensemble finds new depth in the simplicity of a duo. Jacob Warren plays double bass, while Grant Flick plays violin, tenor guitar and nyckelharpa. With Jacob’s classical foundation and Grant’s experience in bluegrass and jazz, their contrasting backgrounds give this collaboration a unique and compelling musical narrative.";
  schema:url <https://greatlakespaa.org/our-roster/warren-flick/>;
