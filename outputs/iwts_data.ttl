iwts_performer:10008 a schema:Person;
  schema:name "Michel Rivero";
  schema:description "Michel Rivero is a Canadian singer-songwriter and multi-instrumentalist based in Victoria, British Columbia. Known for his distinctive voice and expressive guitar style, he blends Latin, folk, jazz, and Afro-Cuban rhythms into a sound that is both rooted in tradition and contemporary. A founding member of Sweet SantaFe, he released Santa Fe (2017) and Dichoso (2021) before launching his solo career. His bilingual performances create intimate, emotionally rich connections with audiences.";
  schema:url <https://michelriveromusic.com>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
