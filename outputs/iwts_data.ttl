iwts_performer:9034 a schema:Person;
  schema:name "Cory Howard";
  schema:description "Cory Howard wants to reimagine the role of the storyteller. Passionate about centering the audience in the narrative and nudging storytelling beyond its preconceived boundaries, Cory hopes to subvert expectations so that anticipation gives way to participation leading to brand new collective experiences. Cory has performed at the National Storytelling Festival, is a Moth Grand Slam winner and has an M.A. in Storytelling from East Tennessee State University where his original show, The Campfireball, was awarded ‘Outstanding Capstone Project’.";
  schema:url <https://campfireball.net>;
