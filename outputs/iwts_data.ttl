iwts_performer:9808 a schema:Person;
  schema:name "Roberta Lea";
  schema:description "American Songwriter Magazine describes Roberta Lea as “a compelling artist” while The Nashville Scene praises her ability to “score hits with her catchy, textured and beautifully sung originals.” The Virginia native is known as a powerful songwriter and engaging storyteller. As an award-winning artist, one of CMT’s Next Women of Country Class of 2023 and a voting member of The Recording Academy, Lea is steadily building a successful, sustainable artist career that will be etched in Virginia’s history and beyond.";
