iwts_performer:9730 a schema:PerformingGroup;
  schema:name "Lahore Wept";
  schema:description """Lahore Wept emerged as a raw and personal
project, born from disillusionment and betrayal
by cultural and familial institutions. This shift pushed him towards darker, unsettling sounds that mirror his inner turmoil and reflect the unfiltered influences of his youth.

Distorted guitars, furious basslines, screeching feedback, and high-octane vocals share space with melodic contemplations and narratives around love, loss, violence, the hidden conflicts within South Asian culture and the quest for hope and meaning.
amid disillusionment.""";
  schema:url <https://www.lahorewept.com>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
  schema:genre "Rock";
