iwts_performer:580 a schema:PerformingGroup;
  schema:name "Lorraine Desmarais";
  schema:description "Pianist and composer Lorraine Desmarais is known worldwide for her solo, trio and big band performances. She has also appeared with many symphony orchestras and has twelve albums of original compositions. Three of these albums have received FE?LIX awards. In 2011, she received a Doctorat Honoris Causa from the Universite? du Que?bec a? Montre?al (UQA?M). In 2013, she was awarded by becoming Member of the Order of Canada. Lorraine Desmarais played in concert with artists of worldwide renown such as, Chick Corea or Oliver Jones.";
