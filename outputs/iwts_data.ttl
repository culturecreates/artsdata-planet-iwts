iwts_performer:8130 a schema:PerformingGroup;
  schema:name "The Ladies of Jazz";
  schema:description "The Ladies of Jazz is a four-piece jazz band with an untraditional twist—replacing a standard drummer with the rhythm of tap dance. Featuring four talented Edmonton musicians, Jocelyn (vocals), Simon ( keys), Kessler (bass) and Paige (tap dance).  A delightful mix of classics and swanky modern tunes, the Ladies of Jazz take audiences on a wild journey through jazz. Infusing a post-modern charm into their performances, they will take you from Ella to Gaga in one show. Their creative arrangements, tap dance and comedy will charm any audience.";
  schema:url <https://www.instagram.com/theladiesofjazz/>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/DancePerformance>;
  schema:genre "Jazz/Blues";
