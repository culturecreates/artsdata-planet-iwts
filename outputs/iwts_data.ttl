iwts_performer:9820 a schema:Person;
  schema:name "Sara-Danielle Faucher";
  schema:description "Sara-Danielle blends R&B, pop-soul and folk to make here own genre she calls “Ginger-Soul”. Her music has been featured in TV show Emily in Paris and international platforms such as Wonderland and local press Le Devoir. Sara-Danielle released the LP “ReRUN” under Simone Records in September 2024, and has performed at major festivals and venues including Montreal’s International Jazz Festival and LA’s Soho House. She just released “Keep It Open” on October 15th, produced by Duncan Hood (Charlotte Day Wilson, Billianne).";
  schema:url <https://sara-danielle.bandcamp.com/track/keep-it-open>;
