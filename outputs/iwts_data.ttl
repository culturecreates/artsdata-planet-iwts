iwts_performer:9698 a schema:PerformingGroup;
  schema:name "3 Redneck Tenors";
  schema:description "The 3 Redneck Tenors are a musical comedy trio blending operatic talent with southern humor. Created by opera veteran Matthew Lord, alongside Blake Davidson and Jonathan Fruge, they gained national attention as finalists on America's Got Talent in 2006. Their performances feature a mix of country, gospel, broadway, pop, and classical music all delivered with comedic flair. Described as \"Duck Dynasty goes to Carnegie Hall,\" their shows offer a unique blend of down-home laughs and big city music.";
