iwts_performer:9394 a schema:Person;
  schema:name "Jami Reimer";
  schema:description "Jami Reimer (she/her) is an interdisciplinary artist, composer and performer working between Winnipeg MB and Vancouver, BC. From choral music to field recording practices, Jami explores voice— human and otherwise! In 2023, Jami was awarded the Robert Fleming Prize for composition from the Canada Council for the Arts for her performance research about bioacoustics, wetlands, and frog choirs.";
