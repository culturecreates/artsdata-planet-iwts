iwts_performer:10272 a schema:Person;
  schema:name "PK Mayo";
  schema:description "PK Mayo is a musician from northern Minnesota who is equally known for his masterful guitar playing, his gritty soulful singing voice as well as his song writing. He’s racked up a shelf of awards, including induction into both the Minnesota Blues Hall of Fame and the Minnesota Rock & Country Hall of Fame. His song, Arms of the Blues, won him a Minnesota Music Award for best blues recording. PK's performances are an aural quilt of American roots music featuring his signature slide on acoustic guitars, resonators and electric Mando-guitar.";
  schema:url <https://pkmayo.com/>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
