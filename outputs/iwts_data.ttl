iwts_performer:10245 a schema:PerformingGroup;
  schema:name "Honky Tonk Man Show";
  schema:description """The Honky Tonk Man tribute show celebrates country music icon Dwight Yoakam. Delivered by the lively and talented five-piece HTM tribute band, you'll hear hits including Guitars Cadillacs, Fast as You, 1000 Miles From Nowhere, and Suspicious Minds. 
Dwight Yoakam’s popularity spawned 30+ albums, and his hits would fill the airwaves for four decades. Yoakam’s clothes, nasally twang, swagger, and dance moves made him unmatched among his peers. 
Honky Tonk Man show. Tight songs, tight band, tight pants. A tribute to the music of Dwight Yoakam!""";
  schema:url <https://www.honkytonkmanshow.com>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
