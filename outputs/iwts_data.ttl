iwts_performer:9974 a schema:PerformingGroup;
  schema:name "Mister Showtime";
  schema:description "Mister Showtime is a one-man Rat Pack. But this high-octane collision of singer Scott Wichmann and arranger Ryan Corbitt isn't just some dusty museum piece; it’s a masterclass in swingin’ showmanship. Imagine Bobby Darin’s suave musicality spiked with the chaotic wit of Conan O’Brien.A powerhouse vocal performance, blending comedy with original songs, classic standards and reimagined Gen-X pop tunes arranged for an 8-piece band or jazz trio. The result? A cross-generational slam dunk—and an unforgettably ‘Old School’ night on the town.";
  schema:url <https://www.mistershowtime.com/>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
  schema:genre "Jazz/Blues";
  iwts:consent "agree_v_1.0";
