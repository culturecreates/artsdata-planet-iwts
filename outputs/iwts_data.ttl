iwts_performer:7054 a schema:PerformingGroup;
  schema:name "Jhoely Triana";
  schema:description """Jhoely Triana is a Colombian-born flamenco dancer artist based in Vancouver. With a diverse dance background, Jhoely trained at the Goh Ballet, earned a Bachelor of Fine Arts in Contemporary Dance from Simon Fraser University, and honed her flamenco skills at Al Mozaico Flamenco.
Her work has been showcased at renowned events and venues such as the Victoria Flamenco Festival, Vancouver International Flamenco Festival, Vines Festival, New Works Dance, and the Vancouver Fringe Festival, The Dance Centre and the Evergreen Cultural Centre.""";
