iwts_performer:10377 a schema:PerformingGroup;
  schema:name "Band After Midnight";
  schema:description "Band After Midnight is a sensational ABBA tribute band uniting an all-star ensemble from Taken by the Sky, Glass of Hearts, and Life During Wartime. Featuring Oregon Hall of Famer Brian Foxworth on drums, they blend exceptional musicality with the iconic costumes and choreography that defined ABBA’s global appeal. With dazzling harmonies and high-energy performances, they deliver an immersive, nostalgic journey through the timeless hits that continue to captivate audiences across generations.";
