iwts_performer:10312 a schema:PerformingGroup;
  schema:name "Newbridge";
  schema:description "Newbridge is a Halifax, Nova Scotia roots rock/Americana band blending cinematic storytelling with an East Coast perspective. Their debut Past Lives, recorded at Creative Workshop Studio in Nashville with Robbie Crowell, earned national exposure on Hockey Night in Canada and Rogers Sportsnet. The band has played Cavendish Beach Music Festival, earned a Music Nova Scotia Americana Award nomination, signed with Rough Trade Publishing NYC, and will appear in a CBC documentary while recording their next album.";
