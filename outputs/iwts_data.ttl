iwts_performer:7749 a schema:PerformingGroup;
  schema:name "Sonia Johnson";
  schema:description "Multitalented singer-songwriter Sonia Johnson has built a remarkable jazz career with acclaimed albums including Le Carré de nos amours (Juno Award, 2012), Chrysalis, Airs givrés, and Ladies of Jazz. Renowned for her improvisational talent, emotional depth, and vocal flexibility, she is frequently invited as a soloist by leading ensembles and composers. She also collaborates as a lyricist with respected jazz artists. Celebrating 20 years of musical entrepreneurship, she marks the milestone with the reissue of her debut album, Don’t Explain.";
  schema:url <https://soniajohnson.com/>;
