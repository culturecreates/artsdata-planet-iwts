iwts_performer:9626 a schema:PerformingGroup;
  schema:name "Mariachi Rio Rojo";
  schema:description """Mariachi Rio Rojo
Winnipeg's new and only authentic Mariachi band. Great for surprise opr pop up performances, Mariachis can be the highlight of any event or venue. This group of 9 professional musicians from Mexico and Latin America will make sure you and your guests feel right at Plaza Garibaldi in Mexico.  They have invested not only in the authentic hand-crafted instruments such as vihuela and guitarron that give mariachi bands their unique sound but also in the iconic \"charro\" outfits.""";
  schema:url <https://linktree.com/mariachiriorojo>;
