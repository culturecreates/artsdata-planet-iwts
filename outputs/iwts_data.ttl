iwts_performer:9949 a schema:Person;
  schema:name "Daylin Jørgensen";
  schema:description """With a voice rooted in 70s–90s country and lyrics laced with wit and warmth, Daylin blends tradition with a fresh, introspective edge. She champions creativity, health, and humor by writing songs that celebrate holistic living, mental clarity, and the joy of not taking life too seriously. Whether she’s penning a tongue-in-cheek anthem or a soul-searching ballad, her honesty remains the throughline. 
Daylin has performed at various events and charity functions across Alberta, and her performances appeal to a wide audience.""";
  schema:url <https://daylinjorgensen.com/>;
