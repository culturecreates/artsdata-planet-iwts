iwts_performer:8550 a schema:PerformingGroup;
  schema:name "Alma Narrows";
  schema:description "Alma Narrows is the latest music project of married couple Anna & Regan Luth, who have honed their craft over a decade of musical expression and collaboration. As half of BC-based indie-folk quartet The Crescent Sky, they have won the hearts of listeners across British Columbia, playing at notable festivals such as Mission Folk Festival, Nelson's Tiny Lights Festival, and Peace Valley Folk Fest in Hudson’s Hope. They placed in the top 100 of CBC's Canada-Wide Searchlight, and are recipients of the Fraser Valley Emerging Artist award.";
  schema:url <https://almanarrows.com/home>;
