iwts_performer:10390 a schema:PerformingGroup;
  schema:name "Here I Come Again: A Nod to Dolly";
  schema:description "\"HERE I COME AGAIN\" is Run Katie Run's nod to Dolly Parton and her decades-long career. The roots-rock band takes Dolly's greatest hits and adds their own flare to these country & pop classics. Katie Coleman has often been compared to Parton and enjoys adding fun trivia that she's learned about Dolly's life and songs. Run Katie Run has been playing at Dollywood- Dolly Parton's theme park- for 6 years and their bond to Parton and her songs is continually strengthened every year. Enjoy this inspirational and uplifting show of Dolly's songs!";
  schema:url <https://www.runkatierun.com/dolly-show>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
