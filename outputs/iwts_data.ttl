iwts_performer:9366 a schema:PerformingGroup;
  schema:name "Donna Leny Hansen";
  schema:description """The 11 O’clock Number is Grindstone’s award winning improvised musical comedy! Based on suggestions from the audience the cast improvises a brand new musical comedy on the spot, complete with twisting plots and showstopping numbers. Laughs are guaranteed. You have to see it to believe it.

4.5 Stars \"A near perfect hour long narrative\",  - Edmonton Journal

4 Stars \"Fabulous foolishness is five part harmony\" - CBC

4 Stars \"Hilarious! The show left me laughing uncontrollably!\" - Edmonton Journal""";
