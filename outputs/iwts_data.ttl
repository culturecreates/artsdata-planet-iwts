iwts_performer:9396 a schema:PerformingGroup;
  schema:name "Desirée Dawson";
  schema:description "Desirée is a recording artist, songwriter, producer, facilitator, and yoga teacher. She is a two time SXSW music video winner and was nominated for a 2022 Juno- Award for adult contemporary album of the year. Desirée’s main instrument is her voice, yet she often accompanies it with her baritone ukulele, body percussion and other musicians. She blends folk, soul, pop, Americana, and old-time  influences into her creations, though she often labels her music as 'singer-songwriter' for simplicity.";
  schema:url <https://www.desireedawsonmusic.com/>;
