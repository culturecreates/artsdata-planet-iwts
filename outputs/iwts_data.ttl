iwts_performer:9947 a schema:Organization;
  schema:name "Action at a Distance";
  schema:description "Action at a Distance is a contemporary dance company located on ancestral and unceded territories of the S?wx?wú7mesh (Squamish), Stó:l?, s?l?ílw?ta?? (Tsleil-Waututh) and x?m??k??y??m (Musqueam) Nations.  Directed by choreographer Vanessa Goodman, the company focuses on creating experiential generative systems to build immersive environments. Its work is driven by questions surrounding intimacy through performance-based practices.  Action at a distance has been presented in Canada, the US, Europe, the UK and South America.";
  schema:url <https://actionatadistance.ca>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/DancePerformance>;
  schema:genre "Traditional";
