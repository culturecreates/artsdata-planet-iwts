iwts_performer:10063 a schema:Organization;
  schema:name "Ryan Gladstone";
  schema:description "Founded in 2000 Monster Theatre creates original plays that challenge preconceptions, excite imaginations and embody the way of the Monster: strange, twisted and bizarre on the outside, but always with a noble heart. Monster Theatre produces work that engages the hearts, brains and guts of all audiences; comedies that excite intellectuals, histories that shock teenagers, and theatre for young audiences that makes adults roll on the floor laughing.";
  schema:url <https://monstertheatre.com>;
