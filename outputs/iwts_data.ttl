iwts_performer:10076 a schema:PerformingGroup;
  schema:name "Inferno";
  schema:description "Inferno is a hip-hop opera by Omari Newton and Amy Lee Lavoie blending rap, beatboxing, R&B, and contemporary opera in celebration of IBPOC voices. A feminist, anti-colonial reimagining of Dante's Inferno, the story follows Vie, a young producer whose music has been co-opted by a streaming platform. To reclaim it, Vie must ascend a Spotify-esque skyscraper — each floor a new layer of hell — to confront the CEO: the Devil himself. In the age of AI and stolen art, singing together is an act of resistance and a reclamation of what cannot be taken.";
  schema:url <https://reopera.ca/inferno/>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/PerformingArtsEvent>;
  schema:genre "Hip Hop/Rap";
  iwts:consent "agree_v_1.0";
  schema:location _:ca4f8f5a6bc7431495dad07af7a2b5913519 .

