iwts_performer:8253 a schema:PerformingGroup;
  schema:name "Cathy Fink & Marcy Marxer with Chao Tian";
  schema:description "FROM CHINA TO APPALACHIA creates a unique fusion of music with American Roots music and Chinese classical music traveling an imaginary road from China to Appalachia in a blended family. GRAMMY® Award winning American Roots artists Cathy Fink & Marcy Marxer join with Chinese virtuoso Chao Tian with vocals and instruments including yangqin, five-string banjo, ukulele, guitars, dumbek, cello-banjo, gourd banjo, sibao and mandolin. Songs are in both Chinese and English. Performances often include a crankie original artwork by Chao Tian.";
  schema:url <https://www.cathymarcy.com/from-china-to-appalachia/>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
