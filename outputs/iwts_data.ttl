iwts_performer:8187 a schema:PerformingGroup;
  schema:name "Tommy Charles";
  schema:description "Based out of Edmonton, Alberta, Tommy Charles brings a classic sound with natural vocals and solid production to Americana country music. With his deep, singing voice, Tommy's sound is both nostalgic and distinctive. A native of Montérégie, Québec, Tommy's talent led him to be a candidate for the successful television show La Voix. Tommy often performs in a variety of languages and genres, including Spanish, French, Portuguese and English, revisiting the classic sound of his heroes—legends like Marty Robbins, Roy Orbison and Sam Cooke.";
  schema:url <https://instagram.com/tommycharlesmusic>;
