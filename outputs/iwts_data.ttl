iwts_performer:8819 a schema:PerformingGroup;
  schema:name "Stephanie Westdal";
  schema:description "The most striking aspect of queer indie-pop artist Stephanie Westdal’s music is the power and sensuality of her voice. Based in Winnipeg after years of living and performing abroad — not only exudes technical ability, she invites audiences into her soul by exploring deeply personal perspectives on human intimacy and vulnerability. Her 2024 releases include Drive Your Car, Gonna Love You, Bleed and Want You So Bad, which Honk Magazine says radiates “tenderness and seductive charm.”";
  schema:url <https://thestephaniewestdalband.com/>;
