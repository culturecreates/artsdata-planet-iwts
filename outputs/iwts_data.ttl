iwts_performer:9833 a schema:PerformingGroup;
  schema:name "Rose Morrison";
  schema:description "Cape Breton fiddler, singer-songwriter, and visual artist Rose Morrison blends traditional Celtic music with original songwriting and visual storytelling. A founding member of The Cottars, she has toured internationally and shared stages with Glen Hansard, Breanndán Ó Beaglaoich, and John McDermott. Rose’s work is deeply rooted in ancestral connection and place, with recent projects including The River She Knows and her upcoming Sable Island residency.";
  schema:url <https://www.rosemorrison.com/>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
