iwts_performer:10074 a schema:PerformingGroup;
  schema:name "Greenhouse Ensemble";
  schema:description "Greenhouse Ensemble brings together seven emerging musicians from Québec’s vibrant jazz scene. Featuring a unique lineup combining voice, violin and trumpet, the group blends orchestral textures, folk colours and modern jazz energy. Built on collaboration and collective creativity, their music moves between lyrical moments and vibrant improvisation. Their debut album Rez-de-chaussée (2023) introduces a bold new generation shaping the evolving sound of Québec jazz.";
