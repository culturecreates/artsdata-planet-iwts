iwts_performer:9373 a schema:PerformingGroup;
  schema:name "African Chamber Music Ensemble";
  schema:description "The African Chamber Music Ensemble is an innovative project which aims to showcase the lesser-known, reflective side of African music, moving beyond its famous drumming and dances. By presenting traditional African music in a chamber setting with a string quartet, we’re expanding the way audiences experience these rich cultures. This concert not only celebrates African musical heritage but also invites a rethinking of the string quartet’s role, addressing its historical ties to colonialism and promoting a more inclusive musical landscape.";
  schema:url <https://www.curtisandrews.ca/african-chamber-music-ensemble-epk.html>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
  schema:genre "Global";
  iwts:consent "agree_v_1.0";
  schema:sameAs <https://www.youtube.com/watch?v=KFq-4HCdQeU>, <https://www.youtube.com/watch?v=O48Pc9xLyO0>;
