iwts_performer:3563 a schema:PerformingGroup;
  schema:name "The Misery Mountain Boys";
  schema:description "You might hear the tunes of the Misery Mountain Boys drifting from behind a rotating bookcase of a 1930’s speakeasy. Harkening back to a simpler time, the MMB’s create a soundscape infused with tongue in cheek wit, playfulness, and nostalgia. The bands performance delivers as both classic and fresh, offering a generous variety of speakeasy jazz numbers, velvety love songs, and swingin' jump-blues.";
  schema:url <http://www.miserymountainboys.com>;
