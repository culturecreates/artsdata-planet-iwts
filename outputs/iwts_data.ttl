iwts_performer:9225 a schema:Person;
  schema:name "Daniel James McFadyen";
  schema:description "Daniel James McFadyen is an award-winning indie-folk artist whose expressive lyricism, charismatic stage presence, and road-worn storytelling have made him one of Canada’s most compelling contemporary voices. His 2025 sophomore album, Back To The Country (LHM Records), marks a defining moment in his artistic evolution—an intimate, organic, and boldly confident full-length that leans into the Americana/Canadiana textures he has grown increasingly known for.";
