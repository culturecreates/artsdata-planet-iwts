iwts_performer:2042 a schema:PerformingGroup;
  schema:name "kory livingstone";
  schema:description "Kory is a Juno nominated composer-performer. \"I have admired your persistent quiet determination & attention to details. It's more than talent. It's a mature determination\"...( a fan).A professional musician since his early teens, Kory composes music that melds classical, jazz and blues & pop.  He studied piano and composition at the Toronto Conservatory of Music, WLU and YorkU. He's the author of \"Quiet Determination, 15 ways to break the barriers of your untaped success\". Musical influences include Monk, Evans, Beethoven, Bach and Tom Waits.";
  schema:url <http://korylivingstone.com>;
