iwts_performer:10083 a schema:PerformingGroup;
  schema:name "Caleb Tomlinson";
  schema:description "Caleb Tomlinson performs beautifully crafted and lyrically driven Canadiana and roots music. With songs distinctly rooted in place, his engaging performance and storytelling transports the audience into the landscapes and seasons of northern and western Canada, creating an unforgettable live show. He released his debut EP, Solstice, in 2024 and has been honing his live performance since, including a 21-date tour of the UK and Ireland in early 2026, and appearances at the Alaska Folk Festival, Atlin Arts & Music Festival, and Breakout West.";
  schema:url <https://calebtomlinsonmusic.com>;
