iwts_performer:7874 a schema:PerformingGroup;
  schema:name "Jonathan";
  schema:description "Jonathan Williams is a modern country artist whose music blends heartfelt storytelling with the grit and soul of lived experience. A retired RCMP officer turned singer-songwriter, his journey from service to stage has shaped a sound rooted in authenticity and resilience. His singles “That’s What a Heartbreak Tastes Like,” “Wild Fire,” and “Goodbye Back” have earned national radio play, charted on the Canadian Indie Country Countdown (#3), and surpassed 150,000 streams—bringing honest country music to fans across Canada.";
