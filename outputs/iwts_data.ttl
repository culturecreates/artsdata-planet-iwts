iwts_performer:9544 a schema:Person;
  schema:name "Thomas Gut";
  schema:description "Thomas Gut is a singer-songwriter known for his raw storytelling and soulful melodies. Blending elements of folk, rock, and Americana, his music captures themes of love, loss, and the human experience. With a knack for evocative lyrics and heartfelt performances, Thomas delivers songs that resonate deeply with listeners. Whether performing intimate acoustic sets or full-band arrangements, his music tells stories that feel both personal and timeless.";
