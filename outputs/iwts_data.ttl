iwts_performer:773 a schema:PerformingGroup;
  schema:name "Boreal";
  schema:description "Boreal brings together Canadian singer-songwriters Katherine Wheatley, Tannis Slimmon and Angie Nussey in a trio renowned for 3 distinct voices, rich and unique harmonies, reflective ballads and rhythm-driven numbers. Blending folk, roots, and pop, their music ranges from intimate and delicate to joyful and uplifting. They are nominated for 3 Canadian Folk Music Awards (2026). \"Magic happens when these three women combine their wonderful songs and voices on stage…They are a rare and wonderful band and they’re not to be missed.” David Francey";
  schema:url <http://www.borealsongs.ca>;
