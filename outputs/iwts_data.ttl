iwts_performer:9560 a schema:PerformingGroup;
  schema:name "Paula Boggs Band";
  schema:description "Since 2007 Paula Boggs Band has blended jazz and Americana, opening for the likes of Sunny War and Eric Bibb along the way.  The  band releases 5th studio album “Sumatra” in early 2026, featuring Blind Boys of Alabama and Valerie June.  “Sumatra” was produced and mixed by Portland’s Tucker Martine at Flora Studios. They have played NW Folklife four times, traveled to Ireland in 2025 to perform at Killarney’s Your Roots Are Showing Folk Conference and Paula was a Finalist in NewSong Music’s 23rd Annual Songwriter Competition and Performance.";
  schema:url <http://paulaboggsband.net/>;
