iwts_performer:10171 a schema:PerformingGroup;
  schema:name "Couldn't Be Happiers";
  schema:description "What’s in a name? For Couldn't Be Happiers, the whole damn thing. This award-winning folk-rock/Americana duo enjoys every moment performing together, and it’s pretty contagious. Their playful “Violent Femmes meets Johnny and June” vibe and onstage chemistry all but dare you not to enjoy yourself.  The duo's repertoire includes stories about the drive of a Bigfoot hunter, the misadventures of a plastic bag, and the end of the world.  Their homespun harmonies and powerful vocals will take you from church to holler to Opry and back.";
  schema:url <https://www.couldntbehappiers.com>;
