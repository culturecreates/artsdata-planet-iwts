iwts_performer:8749 a schema:Person;
  schema:name "Kim Gates";
  schema:description """Soulful folk songs and stories played on guitar. Songs about life that reveal shared life experience. We have kids, we have loves, we have losses, we suffer the world around us. Reminders that we all live through similar things and we're not so different after all. 
A singer and writer, Kim has been entertaining enthusiastic audiences across Western Canada with his soulful lyrics and simple melodies.  Kim plays high energy pub shows weekly, with all the songs you love to sing and hear, as well as performances of his soulful original music.""";
  schema:url <https://www.kimgatesmusic.com>;
