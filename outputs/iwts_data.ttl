iwts_performer:10366 a schema:Person;
  schema:name "Hannah Belle Terrell";
  schema:description "Hannah Belle Terrell is a performer, songwriter, artist and music educator who has drawn the majority of their inspiration from natural landscapes. Hannah Belle weaves together original music and covers to tell stories, bringing in familiar tunes, friendly interaction, and relatable tropes and tales to create an atmosphere of oneness. Outside of acoustic guitar and serenading vocals, Hannah Belle uses a looper pedal with her cello and lap harp to create ethereal sonic landscapes and rich harmonic musical journeys.";
  schema:url <https://linktr.ee/belle.musique>;
