iwts_performer:5948 a schema:PerformingGroup;
  schema:name "Brian Hilligoss";
  schema:description "\"Southern Nights - A Tribute to Glen Campbell\" stars Brian Hilligoss and a five-piece Nashville all-star band. Utilizing his decades of experience as a stage and TV performer, vocalist, guitarist, and storyteller, Brian takes you on a musical journey weaving together career highlights from legend, and award-winning recording artist, Glen Campbell. Folks reminisce & sing along with Gentle On My Mind, Wichita Lineman, Galveston, By the Time I Get to Phoenix, Rhinestone Cowboy, & other hits. \"He clearly communicates Glen's spirit in every note.\"";
  schema:url <https://www.brianhilligoss.com/southernnights>;
