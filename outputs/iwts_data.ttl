iwts_performer:8650 a schema:Person;
  schema:name "Joey O'Neil";
  schema:description "Critically acclaimed Yukon folk singer-songwriter, Joey O'Neil, is bewitching audiences across Canada with hauntingly heartfelt anecdotes from a queer, woodland life.  Offering engaging banter and bittersweet wordplay floating atop a bed of fingerpicked guitar, O'Neil's clever sincerity is sure to make you laugh and cry simultaneously.  With a decade of touring to her name, her live performance has been described as “gentle and intimate” by Exclaim! and “absolutely touching, even a little heartbreaking” by NEXT Magazine.";
  schema:url <https://joeyoneil.com/>;
