iwts_performer:9884 a schema:PerformingGroup;
  schema:name "The Hoss Mountain Stringband";
  schema:description "The Hoss Mountain Stringband is a dynamic bluegrass ensemble based in Victoria, British Columbia. Their repertoire features a mix of classic standards, original compositions, and innovative arrangements that showcase their musicianship and passion for the genre. Their music is further influenced by their deep connections to old-time and swing. Featuring tight harmonies along with rapid fire pickin' and strummin', the band's charismatic stage presence invites the audience into a world of shared stories, laughter, and foot-stomping good times.";
  schema:url <https://hossmountain.com/>;
