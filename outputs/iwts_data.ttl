iwts_performer:9598 a schema:Organization;
  schema:name "First Impressions Theatre";
  schema:description "Opera on the rocks is a whimsical, operatic comedy event for audiences of all ages. It features acclaimed Tenor Luciano Paparazzi, a character based on the great Luciano Pavarotti, who takes the audience on a journey through the last 100 years of popular music to demonstrate how modern artists have all been influenced by opera and classical music.";
