iwts_performer:9736 a schema:Person;
  schema:name "Bowen Lyam Lee";
  schema:description "Bowen Lyam Lee is a storyteller who conducts workshops for educators and performs with national, international, and regional storytelling programs. She has won numerous national story slams and is a Chautauqua scholar performing Asian women of history. Bowen was a public school teacher specializing in language development, science and environmental education. She is now a professional storyteller who specializes in historical, educational, and environmental storytelling and lives in Tumwater.";
  schema:url <https://bowenstories.com>;
