iwts_performer:9479 a schema:PerformingGroup;
  schema:name "Lost Highway Navigators";
  schema:description """Lost Highway Navigators deliver swinging original honky tonk tunes that recall the classic country music of the 50's, 60's and 70's.

\"We call our music 'Cosmic Honky Tonk'. But really, it’s simple, old-fashioned, swallow-and-grin country music. Expect pedal steel, fiddle, telecaster, upright bass, harmonica, and a sackful of tunes about lovin', hurtin', drinkin' and flirtin. You'll hear straight-up 4/4 country shuffles, some Harlan Howard classics, barnburners, a trucking song,  tearjerkers, and a bucket of songs about love gone wrong.\"""";
  schema:url <https://losthighwaynavigators.com/>;
