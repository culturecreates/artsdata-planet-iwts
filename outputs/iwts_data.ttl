iwts_performer:9878 a schema:Person;
  schema:name "Karisma Collins";
  schema:description "Karisma Collins is a Vancouver-based performer and musician blending cinematic pop with emotionally driven storytelling. Her work has gained significant online traction, including her “Wolves” music video, which has amassed substantial views across platforms, and she has been featured and interviewed by major outlets including Radio Disney. In addition to her music releases, Karisma has extensive experience performing for camera, live audiences, and digital platforms, building an engaged social following in the hundreds of thousands.";
