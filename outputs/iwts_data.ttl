iwts_performer:9688 a schema:PerformingGroup;
  schema:name "La Candela Flamenco";
  schema:description """La Candela (from Spanish, fire or flame) embodies the essence of fiery flamenco, Latin, classical, and world music. Established in 2014 and directed by flamenco dancer Ania La Candela, the company captivates audiences with its vibrant performances. La Candela creates experiences that resonate deeply with the heart and soul by blending traditional flamenco rhythms with modern influences. La Candela Flamenco’s mission is to bring people of diverse backgrounds together, inspiring them through traditional
and reimagined flamenco performances.""";
  schema:url <https://www.lacande.la>;
