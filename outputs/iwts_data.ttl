iwts_performer:9535 a schema:Person;
  schema:name "Uchechi";
  schema:description "Uchechi is an alt-pop and surf noir artist. If I could describe her, I would compare her to the sea. Serene yet melancholic. If you really want to understand her, you'll have to dive in. Born in 2002 in Lagos Nigeria, but emigrated to Toronto, Canada at nine years old where she began to write occasional short stories and poems only ever for school, eventually joining her local church choir a year after her arrival. Now a confident woman, Uchechi is a welcomed tsunami creating her path.";
  schema:url <https://linktr.ee/uchechis>;
