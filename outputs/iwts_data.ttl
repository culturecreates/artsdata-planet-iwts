iwts_performer:82 a schema:Person;
  schema:name "Robin Spielberg";
  schema:description "Steinway Artist  Robin Spielberg has 1/2 billion streams of her music across the globe. Whether playing music that embraces the transitions of the seasons, celebrating the thrill of romance, or familiar holiday songs, Robin Spielberg’s concerts intertwine accomplished musical performance with humor and stories that inspire. She has released 24 studio recordings, several of which have charted on Billboard.  She is the recipient of the 2024 grand prize in the Intercontinental Music Awards.";
  schema:url <http://www.robinspielberg.com>;
