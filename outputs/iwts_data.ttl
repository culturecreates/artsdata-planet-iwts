iwts_performer:9502 a schema:Organization;
  schema:name "Eastern Front Theatre";
  schema:description "EFT creates, presents, and promotes the work of Atlantic Canadian theatre artists. We seek out experimental, immersive and innovative works that represent the various cultures and communities in Atlantic Canada. We strive to program content that pushes the boundaries of what it is to be Atlantic Canadian, and tell our stories in new ways. EFT supports work from underrepresented storytellers and provides them with a large scale audience, while exposing local audiences to the brand new work of their peers and contemporaries.";
  schema:url <https://www.easternfronttheatre.com>;
