iwts_performer:9825 a schema:PerformingGroup;
  schema:name "Evan Turnbull";
  schema:description "The Turnbull Brothers are Evan and Aaron Turnbull, 22-year-old twins from Glace Bay, Nova Scotia who placed 3rd in the finals of Canada's Got Talent season two. They have been playing small cafes and restaurants since the age of 16 and were always a local crowd favorite. Since competing on Canada's Got Talent, they have been playing shows all across Nova Scotia. And 2025 is not slowing down for them as they are working on their first full-length album.";
