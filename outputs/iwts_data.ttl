iwts_performer:9100 a schema:PerformingGroup;
  schema:name "(in)sight";
  schema:description "Working under the collective name (in)sight, Ella Steele (Winnipeg, MB) and David Lafleur (Gatineau, QC)  develop multidisciplinary creations that explore the contemporary possibilities of Tap dance. Inspired by the Jazz tradition, their work draws links between the past, present, and future, blurring boundaries between repertoire, choreography, and improvisation. Their work includes M/W/D: Sentiment du moi, presented in Toronto and across Quebec, I/DEI\\A, a short film about Source, and Entrelacés, which premiered at Tangente in January 2026.";
  schema:url <https://www.insightdance.ca/>;
