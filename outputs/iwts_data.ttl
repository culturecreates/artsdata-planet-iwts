iwts_performer:9964 a schema:Person;
  schema:name "Rebecca Kelley";
  schema:description "Becca has been playing guitar since 2005, writing songs since 2010, and performing them since 2017.  She has collaborated with other musicians in the past and created an EP and album of original songs, both of which are available on all major music platforms.  These days she is a solo performer, popping up to play around Missoula at a variety of local venues and events, including breweries, markets and moon ceremonies.  Becca is super stoked to recently have incorporated a kick drum into her set, and is looking forward to finishing her webpage.";
  schema:url <https://www.strummingbirdvegabond.com>;
