iwts_performer:10077 a schema:PerformingGroup;
  schema:name "ESCA";
  schema:description "Esca Quartet is a dynamic all-female string quartet founded in 2004 and composed of Édith, Sarah, Julie and Amélie. Known for its refined classical sound, creativity and strong stage presence, the ensemble moves seamlessly between classical repertoire and popular music. Esca’s immersive sound and contagious energy captivate audiences everywhere. The quartet is also frequently invited to collaborate with leading artists of Québec’s music scene, both on stage and in the studio.";
  schema:url <https://quatuor-esca.com/en/>;
