iwts_performer:285 a schema:PerformingGroup;
  schema:name "Bettman & Halpin";
  schema:description "The award-winning duo Bettman & Halpin performs a fresh and enduring combination of Americana, folk and bluegrass. The perfect blending of Stephanie Bettman’s angelic voice and exquisite fiddle playing with Luke Halpin’s adept musicality on mandolin, fiddle, and banjo result in mesmerizing performances filled with irresistible lyrics, transcendent harmonies and roof-raising instrumentals. The duo weaves masterful storytelling into their live shows, taking audiences on a heartfelt journey.";
  schema:url <http://www.bettmanandhalpin.com>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
