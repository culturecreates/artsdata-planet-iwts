iwts_performer:9545 a schema:PerformingGroup;
  schema:name "Night Howl";
  schema:description "Powerful, dynamic, theatrical, and dusted with glitter, Night Howl is a 6-piece festival dance band from Edmonton, Alberta. With a heavy helping of swing and Latin, their genre-bending music is written for the dance floor and tells fantastical tales of love, murder, and creatures of the night. Their unique cocktail of instruments feature haunting cello, blazing trumpet, groovy percussion, psychedelic electric guitar, and powerful lead vocals.";
  schema:url <https://nighthowl.ca/>;
