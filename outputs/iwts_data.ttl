iwts_performer:10030 a schema:PerformingGroup;
  schema:name "Makiisma";
  schema:description "Makiisma is a violin-led alt-folk trio moving between intimacy and intensity. Led by songwriter, violinist, and vocalist Megan Brown, the band blends haunting vocals, soulful violin, and heavy riff-driven arrangements marked by dramatic dynamics and dark harmonic turns. Rooted in classical training but driven by raw expression, their sound merges doom-folk and alt-rock. Live, Brown leads on a five-string electric violin through pedals and amp, creating a powerful, immersive performance where violin replaces the traditional guitar role.";
  schema:url <https://www.makiisma.com/epk>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
