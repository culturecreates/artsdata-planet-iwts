iwts_performer:10282 a schema:PerformingGroup;
  schema:name "Louise Buhler";
  schema:description "Sunday morning riot was birthed in 2020 out of the Paris of the Prairies. Their gospel fervor, Americana grit and Southern Gothic sentimentality will have you dancing in the pews or falling to your knees.  Drawing from personal experiences, SMR offers intimate and honest songs that are equal parts confession and exorcism.  Come on down to the church basement for a good ol’ fashioned hell raising.";
  schema:url <https://www.instagram.com/sundaymorningriot?igsh=bW1peDBlN3ExenQz&utm_source=qr>;
