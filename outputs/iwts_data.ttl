iwts_performer:9981 a schema:PerformingGroup;
  schema:name "Club Flamenco";
  schema:description "Club Flamenco performs classic and contemporary European and Western music arranged around traditional Flamenco palos or “styles.” The focus is to provide an engaging experience while honoring the long history and elegance of Flamenco culture. Guitarist and Club Flamenco founder Geno Kreis is joined by April Kreis on bass. Percussionists Chrysti Smith, Doug Wales and Ben Simpson weave a tapestry of rhythms supporting the dialect.  Club Flamenco’s Nicole Loya brings years of dance experience, flair and emotion to the set.";
  schema:url <https://www.instagram.com/clubflamencomt>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
  schema:genre "Global";
