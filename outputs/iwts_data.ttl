iwts_performer:10173 a schema:Person;
  schema:name "Artaska";
  schema:description "Artaska is a genre-bending violinist blending classical mastery with soul, jazz, and hip hop into an emotionally charged experience. A prodigy since age four, she has 17 million streams and a #37 Smooth Jazz chart hit. In 2026, she performed solo alongside Toni Braxton on the New Edition Way Tour featuring Boyz II Men and New Edition. Her show is a soulful, cinematic journey part concert, part storytelling designed to move and connect audiences of all ages. Her violin doesn't just play, it speaks.";
