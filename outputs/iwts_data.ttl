iwts_performer:9863 a schema:PerformingGroup;
  schema:name "Lache Cercel and Roma Jazz Ensemble";
  schema:description "In the tradition of Django Reinhardt and Stephen Grappelli, Cercel lays classical and improvisational jazz alongside traditional renderings. Cercel plays with the outrageous virtuosity found in contemporary European Roma recordings, and adds his own vision. Together with Canadian guitarist/ composer/arranger Don Ogilvie and Stephen Nikleva he is creating a 3rd stream that is a new genre of music.";
  schema:url <https://lachecercel.com/>;
