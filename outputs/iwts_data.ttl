iwts_performer:9530 a schema:PerformingGroup;
  schema:name "The Deaf Idols";
  schema:description "The Deaf Idols are the modern rock experience you’ve been waiting for. Paying tribute to their heroes while still remaining original, The Deaf Idols are a force of nature onstage, dealing in aggressive riffs, complex harmony, and layered vocals - with a focus on classic songwriting that any listener can latch onto. These elements are fused together in a block of sonic concrete, which the band will happily use to bash your teeth in. The Deaf Idols have released Blasphemy & Sacrilege in 2018/2019 and a full length album Lightning Sauce in 2025.";
  schema:url <https://www.instagram.com/thedeafidols/>;
