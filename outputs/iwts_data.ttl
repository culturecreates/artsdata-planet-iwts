iwts_performer:9450 a schema:PerformingGroup;
  schema:name "Angela Begin";
  schema:description """Angela Begin is a singer-songwriter, radio dj, and music educator based between Treaty 6 Territory (Edmonton) and Tiohtià:ke/Mooniyang (Montreal). 

Her creative practice is informed by the natural world, and the themes of spaciousness, temporality and transformation. 
She is the host of The Spacious Astrology Playlist at Montreal's CJLO and a member of the CARBON artist collective. She has studied with Ariane Moffatt, Ada Lea and Mallory Chipman. With funding from the Edmonton Arts Council, Angela will be releasing her debut EP in 2025.""";
  schema:url <https://angelabegin.com>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
