iwts_performer:9612 a schema:PerformingGroup;
  schema:name "Janinah Burnett";
  schema:description "Visionary artist Janinah Burnett is a versatile singing actor, musician, writer, arranger, and educator. Janinah is in demand and has thrilled audiences internationally and domestically in jazz and opera. Some of her credits include being an original cast member of Baz Luhrmann’s La Bohéme on Broadway as Mimí, being a principal artist at the Metropolitan Opera for 8 consecutive seasons, and making appearances as “Carlotta Giudicelli” in Phantom of the Opera on Broadway. Janinah is currently the Assistant Professor of Commercial Voice at UNCG.";
  schema:url <https://www.janinahburnett.com>;
