iwts_performer:9397 a schema:Organization;
  schema:name "You Could Be My Safe Space - Dave Deveau & JD Derbyshire";
  schema:description """You Could Be My Safe Space delves into the complex and polarized world of trans-exclusionary radical feminism, dividing Vancouver’s queer and feminist communities, and the creative process behind writing it. Set during an open mic night at an East Van dive bar where anything is possible, including hearing from the playwrights themselves.

You Could Be My Safe Space is a meta-theatrical deep cut into how Queer art is made and how we as a society can elevate Trans voices while not speaking for them.""";
  schema:url <https://zeezeetheatre.ca/production/you-could-be-my-safe-space-2/>;
