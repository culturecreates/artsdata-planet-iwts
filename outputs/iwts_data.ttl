iwts_performer:9888 a schema:Person;
  schema:name "Nashie Zim";
  schema:description """Nashie Zim is a Zimbabwean-born, Canada-based singer, songwriter, and performer whose music blends Afro-pop, folk-soul, and contemporary African rhythms with heartfelt storytelling. Singing primarily in Shona and English, his work explores themes of love, identity, faith, and resilience, rooted in lived experience and cultural heritage.
He has built a growing international audience through digital platforms, with millions of cumulative streams and viral success on YouTube and TikTok.""";
