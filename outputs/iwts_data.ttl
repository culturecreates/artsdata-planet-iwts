iwts_performer:6477 a schema:Person;
  schema:name "Kristen Martell";
  schema:description "Kristen Martell is a singer-songwriter from Nova Scotia whose music transcends boundaries. Known for her feathery, soothing vocals and heartfelt lyrics, Kristen weaves together intimate and moving songs that linger long after the music fades. After two successful English albums, numerous award nominations,  Kristen returns with an enchanting French album that pays tribute to her Acadian roots.  With an edgier pop sensibility, the album bridges cultures and moods, offering a unique musical experience that is both reflective and vibrant.";
  schema:url <http://www.kristenmartell.com>;
