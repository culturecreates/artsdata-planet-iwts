iwts_performer:10023 a schema:Person;
  schema:name "Olivia Khoury";
  schema:description "Olivia Khoury is a Montreal-based singer, songwriter, and interdisciplinary artist who blends dance and music in her work. Drawing from jazz, folk, and indie influences, her melodies are both rich and luminous. In 2023, she released her bilingual EP Portraits, inviting listeners to contemplate six sonic portraits that skillfully blend genres and influences to create an authentic and dreamlike musical universe.  Her new EP, Good Company, is set for release in 2026.";
  schema:url <http://www.facebook.com/ok.oliviakhoury>;
