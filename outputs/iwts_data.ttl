iwts_performer:9646 a schema:Person;
  schema:name "Ryan Johnson";
  schema:description "Hailing from Great Falls, Montana, singer/songwriter Ryan Johnson delivers a rich, soulful voice and expressive guitar work across a wide range of styles - from classic rock and country tunes, as well as a collection of modern favorites. An accomplished musician and composer, he also maintains a strong catalogue of original material, seamlessly blending alt-country, blues, and jazz style guitar. His eclectic voice and expressive guitar work provide the perfect atmosphere for a relaxing evening, wedding, or party.";
  schema:url <https://www.youtube.com/channel/UCWX9Sx5hqZA1sf4bpo2wYMg>;
