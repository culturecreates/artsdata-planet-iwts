iwts_performer:9740 a schema:PerformingGroup;
  schema:name "Ménestral";
  schema:description """Savour the tradition of the troubadours, as Ménestrel breathes vivid life into music that has been shaped by centuries. Their voyage through historic repertoire is accented by lute, guitar and the intricate colours of the human voice. With selections ranging from compositions by Purcell, Dowland, and Monteverdi to nostalgic Gaelic, Québécois, and English folk melodies, Ménestrel reminds us of the pleasure of these musical forms.

The group consists of Janelle Lucyk (soprano), Kerry Bursey (tenor, guitar and lute) and Vincent Lauzer (recorder).""";
  schema:url <https://prairiedebut.com/2026-27-menestrel/>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
  schema:genre "Classical";
  iwts:consent "agree_v_1.0";
