iwts_performer:9517 a schema:PerformingGroup;
  schema:name "Colin Craveiro";
  schema:description """Victoria-area \"chamber pop\" indie-rockers Sail Cassady have grown their fan base thanks to their stellar brand of evocative \"chamber pop.\" Now the group are making waves with Lemon Austin Cadence, a new EP out 2025. It's material bound to captivate listeners.
Sail Cassady's innovative, thoughtful sound and style are reminiscent of The National but Iggy Pop, Lou Reed and David Bowie are also influences.
Concepts of mental health and sexuality (including those within LGBTQ2A communities) are run throughout Sail Cassady's discography.""";
  schema:url <https://www.sailcassady.com>;
