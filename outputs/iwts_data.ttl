iwts_performer:10043 a schema:PerformingGroup;
  schema:name "88 Strings";
  schema:description "88 Strings is a Canadian quartet that mixes traditional Chinese, Persian and Western plucked instruments, presenting new musical inventions and adventures written or arranged us. Established in 2020 as an initiative of the Vancouver Inter-cultural Orchestra, our first public concerts were recorded to video during the COVID pandemic. Our debut concert took place 2024-09-20 at Pyatt Hall in Vancouver. Described as \"plucked string heaven,\" our unique sound blends classical and world music together in an enveloping and often hypnotic music.";
  schema:url <https://88strings.ca>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
  schema:genre "Classical";
  iwts:consent "agree_v_1.0";
