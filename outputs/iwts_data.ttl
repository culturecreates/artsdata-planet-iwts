iwts_performer:10099 a schema:PerformingGroup;
  schema:name "Born To Run Canada";
  schema:description "Born To Run Canada is one of the country’s most electrifying Bruce Springsteen salute to experiences—a powerhouse ensemble that channels the grit, heart, and blue collar soul of The Boss with authenticity, passion, and stadium level energy. Built around the unmistakable voice and commanding stage presence of Canadian country-rock icon Julian Austin, the band delivers a high octane celebration of Springsteen’s greatest hits, deep cuts, and timeless anthems.";
