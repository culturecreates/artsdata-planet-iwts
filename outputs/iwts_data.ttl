iwts_performer:8080 a schema:PerformingGroup;
  schema:name "Great Falls Symphony's Cascade Quartet";
  schema:description "The Cascade Quartet is the Great Falls Symphony's resident string quartet. With an incredible level of artistry and an irresistible energy, the quartet draws in new and seasoned listeners through creative programming, informative and engaging interactions from the stage, education, and communicating a passion for music in all that they do. Today's Cascade Quartet includes violinists Mary Papoulis and Victor Tsai, violist Christine Sherlock, and cellist Thad Suits.";
