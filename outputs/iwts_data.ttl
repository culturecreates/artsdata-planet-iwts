iwts_performer:9997 a schema:PerformingGroup;
  schema:name "Rémi Cormier Quartet";
  schema:description "Rémi is a Canadian jazz trumpeter and the 2023 Radio-Canada Jazz Revelation of the Year. His debut album Glimpse blends European, modern, and North African jazz with reflections on social media’s influence. His upcoming release, Rich State of Mind (January 2026), merges jazz with hip-hop, featuring Braxton Cook and David Binney. Inspired by artists like Robert Glasper and Roy Hargrove, Rémi explores what truly makes us “rich”. He has performed with Canadian icons such as Alain Caron, Oliver Jones, and Vox Sambou.";
  schema:url <https://www.remicormier.com/en>;
