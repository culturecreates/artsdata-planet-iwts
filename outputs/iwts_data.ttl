iwts_performer:9853 a schema:PerformingGroup;
  schema:name "Two Crows for Comfort";
  schema:description """Two time MCMA Roots Duo/Group of the Year, Two Crows for Comfort, are a touring folk/Americana duo from the prairie wonderland of Manitoba.  Known for their comedic yet poignant storytelling and off-the-cuff stage banter, the duo promises a show full of positivity, laughter and even a singalong or two. 
They've been seen at festivals across North America including the Winnipeg Folk Festival,Blueberry Festival in Alaska and have opened for the likes of Bruce Cockburn, Ani DiFranco, David Amram, and Pokey LaFarge.""";
  schema:url <https://www.twocrowsforcomfort.com>;
