iwts_performer:10170 a schema:Person;
  schema:name "Laura Enns";
  schema:description "Laura is a Winnipeg-based singer/songwriter who performs and records with acoustic guitar and voice. She sings in a soulful, unique, emotional style, using her music to express herself and reflect on the world around her. Influenced by rock, folk, blues, and pop, she has performed around Winnipeg for 11 years, currently playing weddings and special events. Her CD of 8 original songs, entitled “Nothing to Prove”, was nominated for a Western Canadian Music Award for Pop Album of the Year in 2015.";
