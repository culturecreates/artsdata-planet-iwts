iwts_performer:164 a schema:PerformingGroup;
  schema:name "Cam Neufeld";
  schema:description "The Road to Django is a dynamic concert presented by the Gadjo Collective celebrating the music of Django Reinhardt and the Roma diaspora. Led by violinist Cam Neufeld, the show traces the musical journey of the Romani people from India through Persia, Turkey, the Balkans and Spain, ending with the swing of 1930s Paris. Blending gypsy jazz, Balkan folk and world music, the ensemble features an international cast of musicians and dancers in a vibrant, tourable performance.";
  schema:url <http://www.camneufeld.com>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
  schema:genre "Global";
  iwts:consent "agree_v_1.0";
  schema:location _:c253a2f59a1340d88f830079a014f4e021 .

