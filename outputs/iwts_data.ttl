iwts_performer:10185 a schema:PerformingGroup;
  schema:name "Judy Carmichael";
  schema:description """Grammy-nominated pianist/vocalist, Judy Carmichael, is one of the world’s leading interpreters of swing-style and boogie piano.  
Count Basie famously nicknamed her “Stride,” a nod to her mastery of the style, and she delivers it with warmth, wit, and effortless charm.  Judy has taken this infectious style of music and her equally infectious personality everywhere from posh nightclubs in Paris and Melbourne to Carnegie Hall and a Rio concert for ten thousand Brazilians. Her NPR show \"Jazz Inspired\" is celebrating 26 years on air this year.""";
  schema:url <https://www.judycarmichael.com>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
  schema:genre "Jazz/Blues";
