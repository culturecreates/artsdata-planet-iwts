iwts_performer:9389 a schema:PerformingGroup;
  schema:name "Saveeta Sharma Dance Company";
  schema:description "In 2008, Saveeta founded the Saveeta Sharma Dance Company to present original works in both traditional and contemporary dance. The company presents these original works in both traditional and contemporary styles to explore the ethos of Canada’s kaleidoscopic multicultural matrix. They are drawn from divers and culturally meaningful – sometimes controversial – contemporary themes that enable powerful and innovative choreographies.";
