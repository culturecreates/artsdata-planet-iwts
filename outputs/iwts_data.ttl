iwts_performer:9647 a schema:PerformingGroup;
  schema:name "Kate Voss & The Hot Sauce";
  schema:description "Kate Voss & The Hot Sauce features award-winning vocalist/bassist/melodica player Kate Voss along with her quintet. With a flair for vintage style, they perform a range of styles from Hot Club to originals, Western Swing to Blues and hits from the 50’s-60’s. This band has something for everyone showcasing classic American songs & crooners. With decades on the road, the stories and songs will touch your heart one moment and make you laugh the next. The joy in this show is contagious because as Kate puts it: “We only play songs we love.”";
