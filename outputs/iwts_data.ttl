iwts_performer:8124 a schema:PerformingGroup;
  schema:name "Connie Kaldor";
  schema:description "Connie Kaldor—singer-songwriter, entertainer and women’s music pioneer— celebrated over 45 years in show business  with the  launch, last year of her 19th recording \" Wide Open Spaces\", each song with a connection to western Canada! Funny, profound, her songs and stellar performance have captured a loyal audience.  Connie is a three-time Juno Award winner, member of the Order of Canada, a Queen’s Golden Jubilee Medal recipient and is the first songwriter to receive a Western Literature Association Award of Merit for her masterful songwriting.";
  schema:url <https://www.conniekaldor.com>;
