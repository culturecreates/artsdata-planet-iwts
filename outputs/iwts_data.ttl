iwts_performer:7182 a schema:PerformingGroup;
  schema:name "Nico Rhodes";
  schema:description "Nico Rhodes is a genre jumping, multilingual musician who is equally comfortable playing jazz, classical, funk or roots music, orchestrating a symphony and conducting choirs. He is in demand as a touring artist and has directed 40+ stage musicals to his credit. He has composed 400+ original compositions, and arranged two symphonic pops shows. Nico has been nominated for two Jessie and five Ovation Awards and in 2019 was honoured with Nanaimo’s Emerging Cultural Leader Award. Nico is the creator of the Piano Heist shows.";
  schema:url <http://pianoheist.com>;
