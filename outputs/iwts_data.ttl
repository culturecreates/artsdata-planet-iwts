iwts_performer:10037 a schema:Person;
  schema:name "Kristin Hoff";
  schema:description "Prix Goyer recipient, Mezzo Kristin Hoff has performed with Vancouver Opera, Tanglewood, Vancouver Symphony, Boston Pops, and Festival de Lanaudière. Noted for her “appealing clarity and emotional heft” (New York Times), Kristin is Artistic Director of Musique 3 Femmes, a Montreal opera creation company. Equally at home on the concert stage, Kristin made her Carnegie Hall debut with the MET Chamber Ensemble conducted by James Levine, which garnered praise for her “searing commitment and impressive vocal command” (The Republican).";
  schema:url <https://www.musique3femmes.com/>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
