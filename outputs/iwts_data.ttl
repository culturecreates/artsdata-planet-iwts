iwts_performer:10212 a schema:PerformingGroup;
  schema:name "BrassTactics";
  schema:description "As Edmonton’s premier brass party band, the Brasstactics deliver only the tightest jams in a fresh New Orleans fashion.  Serving up hot tunes in many genres from ska, hip hop, funk and rock, we guarantee you’ll dance and sing along.  Completely mobile (that’s right! no sound system needed) and ready to bring the party anywhere! Throw your worries away and get down to the Brasstactics!";
