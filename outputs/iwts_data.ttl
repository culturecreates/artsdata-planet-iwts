iwts_performer:9950 a schema:Person;
  schema:name "Heather Feather";
  schema:description "Heather Feather is a bilingual (English/French) Kindie Artist based in Montreal, QC, the 2025 East Coast Music Awards winner of Children’s Artist of the Year, and a 2026 Canadian Folk Music Awards Nominee for Children’s Album of the Year. Crafted with intention, intelligence, and a touch of magic, her songs resonate deeply with listeners of all ages.  She has 2 albums, several singles, and a PhD in Music to her credit, is a speaker/representative for RAMPD.org, and has performed in Montreal, across the East Coast of Canada, and in Brooklyn, NY.";
