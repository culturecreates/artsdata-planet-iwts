iwts_performer:10281 a schema:PerformingGroup;
  schema:name "THE CONJURORS: Magic, Mindreading & Storytelling";
  schema:description "Award-winning duo The Conjurors (Matthew Pomeroy and Natasha Lamb) are redefining magic. Blending mindreading with cinematic stagecraft, they made history in 2024 as the first UK duo to sign a multi-year Las Vegas residency - voted \"Best Show\" in the city. After a record-breaking 2025 UK arena tour for 312,000+ fans, they’ve graced iconic stages like the London Palladium and Radio City Music Hall. From royalty to A-listers, their innovative storytelling captivates millions globally, leaving every audience wondering: How did they do that?";
  schema:url <https://www.epicartsmanagement.com/the-conjurors>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/VarietyShow>;
  schema:genre "Magic/Illusion";
  iwts:consent "agree_v_1.0";
