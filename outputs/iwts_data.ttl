iwts_performer:9660 a schema:Person;
  schema:name "Amelia Day";
  schema:description "Amelia Day is a folk rock powerhouse entering the conversation with mainstays like Sheryl Crow, Brandi Carlile, and Hozier. Independent of a label, manager, or agent, Amelia has sold out venues in Seattle, Boston, and DC, joined the bill of festivals like Capitol Hill Block Party, Bumbershoot, Folklife Festival, and Seattle PrideFest, and independently amassed over 4M streams and 100K monthly listeners on Spotify alone. Amelia Day just finished her headlining East Coast tour this March and is currently at work on her next EP, “Ego Trip”!";
  schema:url <https://www.instagram.com/ameliadaymusic/>;
