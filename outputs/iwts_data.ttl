iwts_performer:10155 a schema:PerformingGroup;
  schema:name "Mike Stack";
  schema:description "Mike Stack’s third solo album, Lucky Man, is a stunning blend of self-penned ballads, Alt. Country, bluegrass, and Cajun-tinged grooves. Produced by Steve Dawson and featuring a cast of stellar musicians, the album appeals to fans of Americana and Canadiana music. Following acclaimed solo records, I Need Wheels and 98 Years, and his work with The Grift, Stack continues his musical journey, promising more heartfelt music ahead as he writes, records, and connects with audiences.  Available as solo, duo or trio. https://www.mikestack.ca/epk";
  schema:url <https://www.mikestack.ca/>;
