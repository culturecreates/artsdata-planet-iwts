iwts_performer:9903 a schema:PerformingGroup;
  schema:name "Foreshadow";
  schema:description """Shadow Devereaux, also known by his stage name Foreshadow, is a prominent Salish and Blackfeet hip hop artist, audio engineer, and advocate for indigenous youth.

Hailing from the Flathead Indian Reservation, Shadow has spent over a decade honing his craft, merging his deep cultural roots with the rhythms and beats of modern hip hop.

His music serves as a powerful voice for indigenous communities, blending themes of struggle, resilience, and positivity.""";
  schema:url <https://www.foreshadow406.com>;
