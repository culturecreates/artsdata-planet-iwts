iwts_performer:9448 a schema:Person;
  schema:name "The FloWarrior";
  schema:description """The FloWarrior is an award-winning, internationally acclaimed performer, instructor, and motivational speaker with 20+ years of experience.

He has pioneered his own unique brand of ‘Martial Artistry’, seamlessly blending martial arts, dance, music, and popular culture to captivate and inspire audiences of all ages.

His breathtaking skills and powerful message of authenticity make him an invaluable addition to any event—whether corporate, festival, or school assembly—leaving audiences amazed and inspired to explore their own unique gifts.""";
