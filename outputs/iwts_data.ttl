iwts_performer:6482 a schema:Person;
  schema:name "Gideon Freudmann";
  schema:description "Gideon Freudmann is a genre-melding cellist and composer. He blends classical, jazz and folk traditions to create sounds that are simultaneously fresh and familiar. Incorporating extended technique with real-time digital effects, his music is both intimate and has orchestral swells, hypnotic ambience and funky grooves. Freudmann also employs his sonic palate to accompany classic silent films bringing the best of cinema and live music to another level and to new audiences.";
  schema:url <https://www.cellobop.com>;
