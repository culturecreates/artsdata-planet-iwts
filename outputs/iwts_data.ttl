iwts_performer:10062 a schema:PerformingGroup;
  schema:name "Rena Vee";
  schema:description """Rena Vee & The Real Bad Times deliver timeless folk with a country edge-  music that breaks your heart in two before gently putting it back together. 

Living on Sinixt territory in the Slocan Valley, Rena turned to songwriting as a way to process the grief within her community amid the ongoing overdose crisis. She found medicine in songwriting, music and collaboration- her honest lyrics, along with the bands harmonies and emotion, makes for some heart break country that is just hopeful enough to leave you coming back for more.""";
  schema:url <https://renavee.bandcamp.com/album/funeral-home-parking-lots>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
  schema:genre "Folk/Bluegrass/Americana";
  iwts:consent "agree_v_1.0";
