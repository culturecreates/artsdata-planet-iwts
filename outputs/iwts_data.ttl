iwts_performer:9654 a schema:Person;
  schema:name "Aaron Larget-Caplan";
  schema:description "Classical guitarist and composer, Aaron Larget-Caplan searches for the life in music and music in life. “A riveting artist” (Washington Post), he has performed 1000+ concerts, premiered 120 compositions, and recorded twelve albums on two international labels. A brilliant communicator, Larget-Caplan connects with audiences with virtuosic guitar playing and charismatic dialogue, as he shares musical stories that transport audiences on exciting musical journey. His programs are exciting, thought provoking, and never boring.";
