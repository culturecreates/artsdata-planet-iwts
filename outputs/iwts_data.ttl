iwts_performer:9628 a schema:PerformingGroup;
  schema:name "Justin Adams & Mauro Durante";
  schema:description "Justin Adams & Mauro Durante, who are rooted in very different musical traditions, bonded over a deep fascination with ancient trance rhythms. Guitarist & composer Adams has deep experience in African traditions and post-punk grooves. Vocalist, violinist and percussionist Mauro Durante is one of the leading players in the pizzica style of Southern Italy. Together they play trance blues from the Mediterranean & beyond. Their 2024 CD “Sweet Release” was chosen as one of the year's best albums by Songlines, World Music Central, & many others.";
  schema:url <https://www.riotartists.com/artist-roster/justin-adams-mauro-durante/>;
