iwts_performer:10097 a schema:PerformingGroup;
  schema:name "Funkyard";
  schema:description "Funkyard is a cover band from Vancouver, BC that plays hits from across the genres and decades - but not in the way you expect. They take Top 40 hits, meme songs, and even metal headbangers and toss them into a Jazz-funk blender. What comes out is a fully funk-tastic tune, complete with infectious grooves, lush harmonies, and intricate arrangements. Funkyard's MO is that they never play the songs like the record, but they keep them just as groovy and catchy!";
  schema:url <https://www.instagram.com/funkyardtheband/>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
  schema:genre "Popular";
