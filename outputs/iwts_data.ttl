iwts_performer:9818 a schema:Person;
  schema:name "Holly M Brinkman";
  schema:description """Holly M. Brinkman is an award-winning artist, known for her vulnerability, comedic timing, and physical storytelling. She has captivated audiences across North America with her unique blend of clown, burlesque, and storytelling.
Her works—A Woman’s Guide to Peeing Outside, A Woman's Guide to Romance Novels, My Body of Work, and Pack Animals—have toured nationally and internationally, earning rave reviews and awards (Best Dance Show, The Jenny Revue, Winnipeg; Critic’s Pick, CBC; Critic's Pick Orlando Sentinel).""";
