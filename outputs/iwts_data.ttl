iwts_performer:9834 a schema:PerformingGroup;
  schema:name "Gammons & Knorr";
  schema:description "Guitarist Tom Gammons and fiddler Ray Knorr each followed their passion for traditional music from West to East. Gammons from Montana and Knorr from Saskatchewan, the duo found a source of deep inspiration on PEI. Their debut EP “Bird’s Eye” was released in April 2025, taking influence from Québécois, Acadian, Old Time, and European styles. Through interpretations and original compositions, Gammons & Knorr tell their stories in the space between fiddle and guitar.";
  schema:url <https://www.facebook.com/share/1AKGtFEyYh/?mibextid=wwXIfr>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
