iwts_performer:9928 a schema:PerformingGroup;
  schema:name "Beau Nectar";
  schema:description "Beau Nectar is a bilingual collaboration between two singer-songwriters Marie-Clo, and éemi. The duo delivers intimate and vibrant synth/pop/folk with fauna and flora inspired concepts, that spark their fans’ empathy towards nature. The duo signed with Indica Records and released their first album Two Lips on June 2nd/2023. They’ve since released multiple singles off their upcoming album “Dandy” coming out May 2026. Their latest single is “Tulip” featuring Vox Rea.";
  schema:url <https://beaunectar.ca/>;
