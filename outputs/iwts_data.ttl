iwts_performer:9493 a schema:PerformingGroup;
  schema:name "falllift";
  schema:description "falllift is the musical exploration of Micah Cottingham and William Steven Hall combining the spectrum of Americana-Folk, Jazz, Rock, and genreless energy found in global experiences. The audience appreciates their “dark and holy” harmonies, accentuating their honest songwriting about finding balance, navigating relationships, holding space for hardness, and the collective experience of what it means to be human in today’s world. The dynamic duo performs anything from small, intimate rooms to large festivals with their full band.";
  schema:url <https://www.falllift.com>;
