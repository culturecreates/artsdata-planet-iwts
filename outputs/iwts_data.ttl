iwts_performer:9441 a schema:Person;
  schema:name "Jay Douglas";
  schema:description "Jay Douglas is a celebrated singer and bandleader whose career spans reggae, ska, soul, blues, and jazz. A pioneer in Canada’s music scene, he continues to command global stages with his charismatic performances and rich, soulful vocals. Recognized as the \"Lou Rawls of Reggae\" by Sly Dunbar, Jay’s influence extends from headlining major festivals to collaborating with icons like Monty Alexander. With acclaimed releases like Confessions and his annual CNE Bandshell showcase, Jay remains a vital force in contemporary music.";
  schema:url <https://jaydouglasmusic.com/>;
