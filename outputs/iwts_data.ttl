iwts_performer:9769 a schema:Organization;
  schema:name "Sahana dance company";
  schema:description "Sahana Dance Company is known for its vibrant performances that celebrate Indian classical dance forms, particularly Bharatanatyam. Founded with the mission to promote cultural heritage through dance, the company often blends traditional techniques with contemporary themes. Their repertoire includes solo and group performances, workshops, and community outreach programs, aiming to inspire and educate audiences about the beauty and depth of Indian dance.";
