iwts_performer:9937 a schema:PerformingGroup;
  schema:name "Thistle";
  schema:description "Thistle is a recording and live performing project helmed by brothers Aidan and Declan McLennan. Blending traditional folk with classic rock and blues roots, Thistle’s music is driven by sweeping acoustic guitars and layered vocal harmonies, creating a lush and textured sound. While both brothers had long pursued music individually, their recent collaboration in songwriting marked a turning point - deepening their creative partnership and shaping the relationship-driven songwriting that defines the project.";
