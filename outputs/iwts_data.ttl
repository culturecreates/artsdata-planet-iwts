iwts_performer:10085 a schema:Person;
  schema:name "Bridget Esler";
  schema:description "Praised as “an artist who leads with musical intelligence and technical assurance” (La Scena Musicale), soprano Bridget Esler has performed across Canada, Europe, the United Kingdom, and the US with ensembles including the London Symphony Orchestra and Orchestre symphonique de Montréal. A dedicated recitalist and chamber musician, she champions contemporary music and has premiered works by composers including John Harbison. In 2025–26 she debuts the Governess (The Turn of the Screw) with the Atelier lyrique and tours with Marlboro Music.";
  schema:url <https://www.bridgetesler.com/>;
