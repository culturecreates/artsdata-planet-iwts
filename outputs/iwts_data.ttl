iwts_performer:3807 a schema:Person;
  schema:name "Lloyd Spiegel";
  schema:description "14× Australian Blues Award winner Lloyd Spiegel is one of Australia’s most revered live performers and the youngest-ever inductee into the Blues Music Victoria Hall of Fame. A bluesman at his core — guitarist by trade, comedian by nature, showman at heart — he delivers jaw-dropping guitar work, powerful vocals and deeply human storytelling connecting devoted blues audiences and first-time listeners alike. With 30 years of global touring, Spiegel honours tradition while serving as a link in the chain of the blues’ evolution.";
