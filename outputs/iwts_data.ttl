iwts_performer:9912 a schema:PerformingGroup;
  schema:name "Myles From Home";
  schema:description "Myles From Home, led by Canadian songwriter and guitarist Myles Hildebrand, delivers a bold blend of folk-rock, jazz, and funk with an electrifying live edge. Since the vinyl release of their debut album STILL, the band has drawn critical praise from Citrus Magazine and Canadian Beats. With over 40 shows across Canada and 14K+ streams, Myles From Home is building serious momentum. Known for boundary-pushing visuals, from canoe concerts to winter cold-plunge performances, the band brings fearless creativity and high-impact energy to every stage.";
