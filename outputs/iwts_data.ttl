iwts_performer:9951 a schema:Person;
  schema:name "Ashley King";
  schema:description "Ashley King is a Mexican-Canadian, visually impaired actor and playwright based in Mohkinstsis. Graduate of Company of Rogues Actors’ Studio, having completed their Master Class actor training program. With a bachelor's degree in Journalism, she is passionate about exploring the many ways we can share authentic experiences. She is a Betty Mitchell Award nominee, and Best Podcast of 2025 winner by the Alberta Media Production Industries Association. Her artistic achievements in Calgary awarded her Avenue Magazine’s Top 40 Under 40 in 2025.";
