iwts_performer:10192 a schema:PerformingGroup;
  schema:name "Miles Canyon";
  schema:description """Miles Canyon is a Canadian country artist and accomplished songwriter whose music is rooted in raw honesty, powerful storytelling, and a lifetime of performance. Now based in Alberta after years of musical success in Saskatchewan, Canyon has quickly become a standout voice in the Canadian country music scene.
 Since relocating to Alberta, Canyon has gained significant momentum, turning heads with his powerful vocals and genre-blending approach to modern country. His live performances are  described as electric, authentic, and unforgettable.""";
