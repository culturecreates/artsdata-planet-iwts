iwts_performer:9887 a schema:Person;
  schema:name "Rebekah Hawker";
  schema:description "Rebekah Hawker is an Ontario-based folk-Americana singer-songwriter whose warm, witty, and honest storytelling draws listeners in with kitchen-table banter and heartfelt songs. James Keelaghan calls her “a voice like a bell, an engaging presence, great stories, and an easy rapport with the audience.” She’s played Mariposa, Summerfolk, and Live From the Rock, opened for Langhorne Slim and Dean Brody, and releases her debut album Louise in 2027.";
  schema:url <https://rebekahhawker.com/electronic-press-kit-epk>;
