iwts_performer:8700 a schema:Person;
  schema:name "BirdBelly";
  schema:description "BirdBelly is the cinematic Americana project of Alberta singer-songwriter Cynthia Hamar. Blending string-rich arrangements with evocative storytelling, her music explores land, lineage, and resilience. A CKUA Top 10 and Earshot National Top 50 charting artist, she has performed at major festivals across Western Canada and built a reputation for powerful, intimate live shows rooted in prairie spirit and heart.";
