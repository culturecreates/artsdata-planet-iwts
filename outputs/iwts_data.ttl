iwts_performer:7762 a schema:PerformingGroup;
  schema:name "Abigail Lapell";
  schema:description "Call it Prairie Noir or Canadiana Desert Rock: Abigail Lapell sings haunting, gorgeous modern folk songs. A JUNO Award nominee and four-time Canadian Folk Music Award winner, Lapell tours widely across Canada, the U.S. and Europe, performing on vocals, harmonica, piano and finger style guitar. Her 2024 album Anniversary (2024), co-produced by Tony Dekker of Great Lake Swimmers, is an evocative collection of original love songs.";
