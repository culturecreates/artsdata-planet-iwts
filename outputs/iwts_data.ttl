iwts_performer:9763 a schema:PerformingGroup;
  schema:name "Montuno Cubano";
  schema:description "Jorge Peña, is the composer, lead vocalist, and primary instrumentalist for Montuno Cubano.  He can perform as a duo with his brother on vocals and guitar, or as a quartet with bass and Latin percussion. The repertoire includes salsa, guaracha, son, rumba flamenco, guajira, ballads, bolero, and son Cubano. He was born in Cuba and performed there for years and also for many years in Spain. Now he lives in Prince Edward Island, Canada, and when he writes and performs, he focusses on the rhythm and the story. His themes are optimism and love.";
  schema:url <https://youtube.com/@MontunoCubano>;
