iwts_performer:7114 a schema:PerformingGroup;
  schema:name "NIC & DESI: Song, Dance, and Romance";
  schema:description "Broadway veterans Nicolas Dromard and Desirée Davar boast world-class careers. Nicolas, an Ottawa native, recently starred as Tommy DeVito in Jersey Boys on Broadway. His 17-year career includes leading roles like Bert in Mary Poppins, plus hits like Wicked and The Boy from Oz. Desirée has starred globally as Anita in West Side Story, including the Broadway revival. Her credits span Chicago and Annie (film) to TV’s Glee. Together, this powerhouse duo brings decades of elite stage experience to audiences worldwide.";
  schema:url <http://www.NicandDesi.com>;
