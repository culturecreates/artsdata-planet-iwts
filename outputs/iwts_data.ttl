iwts_performer:9470 a schema:Person;
  schema:name "Marlene";
  schema:description "Marlene (she/her) is a writer, performer, and occasional musician based in so-called Vancouver. She was a 2022 participant in the Banff Playwright's Lab and the recipient of an Amazon Canada grant for BIPOC series pitches in 2021. She has performed in theatres across Canada and the US, including The Arts Club, Shaw Festival, Firehall Arts Centre and Signature Theatre. Most importantly, she spontaneously played violin for Carlos Santana in the lobby of a Manhattan Four Seasons last summer. Marlene is a graduate of Studio 58.";
  schema:url <https://www.marleneginader.com>;
