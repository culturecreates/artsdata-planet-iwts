iwts_performer:7464 a schema:PerformingGroup;
  schema:name "Sophie Lukacs";
  schema:description "Winner of the 2024 Global Album of the Year at the Canadian Folk Music Awards, Sophie is a kora player and singer songwriter. A fortuitous trip to Burkina Faso introduced her to the kora: a 21-stringed harp-lute from the Mandingue empire. She moved to Bamako to study with kora legend Toumani Diabaté and stayed seven years.  Now in Montreal, she performs her own music, interwoven with Mandungue and Hungarian Folk songs. Supported by cello, bass and percussion, she sings in all the languages she speaks:  English, French, Bambara and Hungarian.";
  schema:url <http://www.sophielukacs.com>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
  schema:genre "Global";
  iwts:consent "agree_v_1.0";
