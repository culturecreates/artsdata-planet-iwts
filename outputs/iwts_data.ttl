iwts_performer:8224 a schema:PerformingGroup;
  schema:name "Ty Koch";
  schema:description "New Brunswick born Ty Koch is a vocalist based in Vancouver,  who performs a full gamut of music, from his original songs, the blues, vintage rock, crooner and  his favourites from the Classical genre. Ty has appeared on theatre and festival stages including the Nanaimo Big Band Festival (2023); tours of Northern B.C. and Vancouver Island (2023); Atlantic Canada (Summer  2023) and Alberta in 2025. Ty was a featured performer on The Port Theatre’s Discovery Series in 2024). Ty has released 2 songs: Go to War and Waiting to Be Found.";
