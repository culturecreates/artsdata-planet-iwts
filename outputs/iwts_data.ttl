iwts_performer:5989 a schema:PerformingGroup;
  schema:name "Mads Tolling";
  schema:description """Internationally renowned violinist, composer and two-time Grammy Award-winner Mads Tolling leads The Mads Men, as they celebrate the music of the 1960s with a distinctive style and innovative flair.
Mads grew up in Copenhagen, discovering his passion for the '60s.  When he was fourteen, his father gave him a Miles Davis cassette tape. He found a sense of intimacy and freedom in the 1960s sounds of jazz, soul and early R&B, which inspired him to explore the possibilities with his violin.  Mads also tours with Bob Weir & Wolf Bros/Wolfpack.""";
  schema:url <http://madstolling.com>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
  schema:genre "Jazz/Blues";
