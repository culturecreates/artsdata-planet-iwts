iwts_performer:542 a schema:PerformingGroup;
  schema:name "The Travelling Mabels";
  schema:description "Hailing from southern Alberta, The Travelling Mabels have become a beloved folk and country group over their 16-year journey. Known for their harmonious melodies, humour, and musicianship, they've captivated audiences across Canada. In addition to winning the 2011 ACMA Group of the Year award, they earned the 2024 YYC Music Award for Inspirational/Holiday Recording of the Year. With four acclaimed albums and performances alongside artists like Ian Tyson, they've solidified their place as Canadian music icons.";
  schema:url <http://www.thetravellingmabels.com>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
