iwts_performer:8421 a schema:PerformingGroup;
  schema:name "Créations Girovago";
  schema:description "Productions Girovago is a creative company known for its innovative blend of music, dance, and circus arts. Founded by the creators of the Gypsy Kumbia Orchestra, the company has produced numerous acclaimed projects, including the film \"FAIT VIVIR\" and the show \"BARKA.\" Their work is characterized by a festive chaos that celebrates life and calls for hope and conscious freedom. Productions Girovago has performed over 500 concerts worldwide and continues to push the boundaries of artistic expression";
