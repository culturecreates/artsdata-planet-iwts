iwts_performer:8662 a schema:PerformingGroup;
  schema:name "The Skeleton Dance";
  schema:description "THE SKELETON DANCE is created and performed by artistic duo Ella MacDonald (she/her) and Emma James (they/them). Graduates of the Fountain School of Performing Arts, each hold a Bachelor of Arts in Theatre (Acting) and Certificate in Dance & Movement. Ella + Emma create interactive work for young audiences from a queer, neurodivergent lens. They strive for radical accessibility and inclusion, and value ongoing collaboration. Their cumulative expertise includes education, drag, intimacy direction/coordination, dance and movement, and music.";
