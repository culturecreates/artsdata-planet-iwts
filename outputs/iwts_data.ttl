iwts_performer:9837 a schema:PerformingGroup;
  schema:name "Bayfield String Quartet";
  schema:description "The Bayfield String Quartet is known for their vibrant and engaging performances. Comprising four exceptional musicians—Karen Graves (violin), Kinley Dowling (violin), Jeffrey Bazett-Jones (viola), and Natalie Williams Calhoun (cello)—the quartet has quickly established itself in Charlottetown as one of the most compelling ensembles on the local chamber music scene. Together, they create a harmonious blend of voices that captivates audiences with its depth, clarity, and emotional power.";
