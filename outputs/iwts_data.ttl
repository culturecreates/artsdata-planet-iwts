iwts_performer:9194 a schema:PerformingGroup;
  schema:name "Saint of Soldiers";
  schema:description "Saint of Soldiers is an Americana/rock band blending roots-driven storytelling with driving percussion and haunting, harmony-rich vocals. Their sound balances grit and tenderness delivered through high-energy, intimate performances. They connect history to the present by filming live sessions at historic Montana locations. They’ve shared stages with Hannah Juanita, The Droptines, and Sterling Drake. In 2025, they scored the Montana PBS documentary \"Journey to the Sun\" and secured sponsorships with Ear Trumpet Labs and Rattlesnake Cable Company.";
  schema:url <https://saintofsoldiers.com>;
