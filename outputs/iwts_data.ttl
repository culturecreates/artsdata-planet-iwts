iwts_performer:10243 a schema:Organization;
  schema:name "Repertory Dance Theatre";
  schema:description """Founded in 1966, Repertory Dance Theatre (RDT) serves as a living library of dance, and has curated one of the largest collections of modern dance in the world with 480 significant pieces.  RDT's season activities, which 
include performances, classes, workshops, and residencies use RDT's powerful archive as an educational tool paired with significant new acquisitions and commissions each year.  RDT remains committed to building bridges of understanding that de-mystify the art of dance--touring regionally, nationally and internationally.""";
  schema:url <https://rdtutah.org>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/DancePerformance>;
  schema:genre "Traditional";
