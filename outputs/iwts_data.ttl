iwts_performer:9718 a schema:PerformingGroup;
  schema:name "KT COLLECTIVE DANCE COMPANY";
  schema:description """KT COLLECTIVE is a project based dance company in Durham, North Carolina. Founded by Kristin Taylor Duncan in 2012, the company produces works that stem from modern, contemporary and jazz techniques. Works are often inspired by sculptures, paintings, and life experiences.
KT Collective is a company of dancers learning, growing and experiencing dance with an energy that brings talent, grace and passion to the space. Fulfilling the dream; dedicated to storytelling, challenges and complexities of dance.""";
