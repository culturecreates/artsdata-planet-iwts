iwts_performer:9815 a schema:PerformingGroup;
  schema:name "Caues & Effect Circus";
  schema:description """Founded in 2013, Cause & Effect Circus combines contemporary juggling with theatrical storytelling to explore social themes. Through innovative choreography, research-driven techniques, and collaborations, the company aims to redefine juggling as an expressive art form and build a distinct Canadian circus identity.

Known for award-winning works like The New Conformity and Luminarium, the company has performed internationally and fostered community through events like I Heart Circus Cabaret, continually redefining what juggling can express.""";
  schema:url <https://www.causeeffectcircus.ca/>;
