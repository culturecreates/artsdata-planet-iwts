iwts_performer:6679 a schema:Person;
  schema:name "Kaeley Jade";
  schema:description "Under the sweeping gaze of Edmonton’s prairie skies, Métis artist Kaeley Jade has carved out a space where art and soul converge. Her vibrant debut album, Turpentine, has earned her significant recognition as a singer/songwriter in the Canadian music scene with accolades that include a Canadian Folk Music Award and a Western Canadian Music Award Nomination. Blending folk, pop and indie rock, Kaeley’s lush imagery, stunning vocals, and electric stage presence have enthralled listeners at venues and festivals across the country.";
