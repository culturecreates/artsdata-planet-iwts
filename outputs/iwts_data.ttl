iwts_performer:9827 a schema:PerformingGroup;
  schema:name "The Mike Biggar Jazz & Blues Revue";
  schema:description """The Mike Biggar Jazz & Blues Revue is a potent fusion of classic & original Jazz, Blues & R&B — brimming with soul, style, irresistible energy & fun.

Biggar's multi-award-winning powerhouse vocals blend with masterful band musicianship for a cask-strength cocktail of vintage blues and timeless American Songbook Jazz that jumps & jives - from groovy to gritty, from smooth to smoking. 

Featuring Tim Davidson (upright bass), Sebastian Fleet (guitar), Dave Bartlett (drums), Grant Heckman (guitar), James O'Farrell (saxophone) & Huey Lord (keys).""";
  schema:url <https://www.mikebiggar.com/jazz-blues>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
