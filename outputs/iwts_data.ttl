iwts_performer:9692 a schema:PerformingGroup;
  schema:name "The Imaginaries";
  schema:description "The Imaginaries is an Oklahoma-based Americana act led by husband-and-wife duo Shane Henry (guitar/vocals) & Maggie McClure (piano/vocals). Their cinematic songs and performances appear on Amazon Prime, Apple TV, Hallmark, Starz and more, with 75+ film/TV/ad placements. Their 2025 second album, \"Fever,\" features singles with Vince Gill, Ariel Posen, & Joe Bonamassa; the latter has over 612K Spotify streams. Available as a duo or 4–6 piece band, they deliver stirring originals, vivid storytelling & crowd-loved covers. Guitars 4 Vets Ambassadors.";
