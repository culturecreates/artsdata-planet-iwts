iwts_performer:9340 a schema:Person;
  schema:name "Colleen Reid";
  schema:description "Catching songs from the wild landscapes of the land & soul, Colleen Reid's music is a prayer for empowerment and purpose. Her warm and vibrant vocals inspire hope and solace for the heart. Her folk-influenced music has deep roots with powerful vocals that carry the melody into expanded places. Colleen's debut album, \"Remember\" (Feb '25) is a simple and soulful recording that honours the raw beauty and resonance of her songs. In a world that often feels fragmented, Colleen music is a reminder that we are all part of a larger whole.";
  schema:url <https://open.spotify.com/artist/127osWJhiqlKCa8AKgdeXK?si=nEUDp_DoQN2MrkF8QRleOw>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
