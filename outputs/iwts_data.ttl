iwts_performer:2982 a schema:Person;
  schema:name "Brendan McLeod";
  schema:description "Brendan McLeod is an award-winning poet and musician. He's the former Canadian SLAM champ, the Poet of Honour at the Canadian Festival of Spoken Word, and a JUNO-nominated musician with his folk band The Fugitives. An active arts educator, he created and taught Langara College's inaugural spoken word course, and currently tours his show “Holy Guacamole, It’s a Poetry Show!” to primary schools, festivals, and performing arts centres across Canada.";
  schema:url <http://www.brendanmcleod.ca>;
