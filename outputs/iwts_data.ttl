iwts_performer:5019 a schema:PerformingGroup;
  schema:name "Horizon Ridge";
  schema:description "Storytellers in song, Horizon Ridge is a group of fine multi-instrumentalists and seasoned vocalists known for their intuitive tight harmonies and polished a cappella singing. Based in Calgary, AB, the band has entertained audiences at festivals, music clubs, events and concerts in Canada, the US and the UK. Versatile and engaging, their performances embrace traditional and contemporary folk, country, and roots. Their albums feature original and favourite songs, and showcase their ability to move effortlessly through musical styles and genres.";
  schema:url <http://www.horizonridge.ca>;
