iwts_performer:4919 a schema:Person;
  schema:name "Ryan Lindsay";
  schema:description "Ryan Lindsay is an award-winning and CCMA nominated artist. He has toured thousands of miles as an artist, from listening rooms to major festivals. The road has shaped his songwriting and ability to connect with audiences across the map. His lyrics evoke travel, and his songs are penned to sound like the Alberta prairies he grew up in. From the first winsome note on the microphone that echoes back to the golden era of '90s country, to his storytelling between songs, Ryan Lindsay creates an atmosphere that transports audiences into the songs.";
  schema:url <http://www.ryanlindsaymusic.com>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
