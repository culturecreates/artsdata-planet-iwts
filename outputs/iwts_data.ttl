iwts_performer:10163 a schema:PerformingGroup;
  schema:name "Cordone and Kilgore (Natalie Cordone and Shawn Kilgore)";
  schema:description "Natalie Cordone is an award-winning actress, singer, and producer who has performed worldwide, starring in *Rhapsody & Rhythm* and appearing on CW’s *Dynasty*. A 2022 Carbonell Award winner, she’s sung with major symphonies. Shawn Kilgore, also award-winning, is a featured Orlando Philharmonic soloist, performer, and co-creator of hit shows. Together, they blend humor and powerhouse vocals, touring nationally with acclaimed productions and earning rave reviews for their chemistry and talent.";
