iwts_performer:10079 a schema:PerformingGroup;
  schema:name "Tio Chorinho and Flávia Nascimento";
  schema:description "Tio Chorinho and Flávia Nascimento are two of Canada’s leading Brazilian-rooted artists, electrifying audiences at folk, jazz, and world music festivals nationwide. Flávia, Brazilian-born and Quebec-based, brings soulful vocals, powerful songwriting, and an infectious stage presence. Toronto’s Tio Chorinho, Canada’s first choro ensemble and 2025 Canadian Folk Music Award winners, thrill with virtuosity and dynamic performances. Together, they celebrate Brazil’s original soul music and their own compositions.";
  schema:url <https://www.tiochorinho.com>;
