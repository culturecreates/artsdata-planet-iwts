iwts_performer:9929 a schema:Person;
  schema:name "Teresa Trask";
  schema:description "Teresa Trask is a veteran singer-songwriter re-emerging with honest, lyric-driven country music shaped by decades of lived experience. She grew up playing country in her father’s band and spent much of her adult life bringing music into women’s recovery centres, prisons, and community spaces across Canada. After years of international touring, she stepped away to listen and write. Now rooted in BC’s wine country, Trask returns with intimate songs about survival, love, freedom, and second chances, built for listening rooms where stories matter.";
  schema:url <https://www.facebook.com/teresatrask/>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
  schema:genre "Country";
