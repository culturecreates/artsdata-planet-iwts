iwts_performer:9849 a schema:PerformingGroup;
  schema:name "Okavango African Orchestra";
  schema:description "Okavango African Orchestra blends multiple instruments, languages, and traditions from across Africa into a vibrant, boundary-crossing sound. Winners of the 2017 JUNO for World Music Album of the Year and the 2025 Canadian Folk Music Award for Global Roots Album of the Year, their music celebrates cultural diversity and storytelling, weaving rhythms, melodies, and voices from different countries into an unforgettable, joyous tapestry that connects audiences worldwide.";
