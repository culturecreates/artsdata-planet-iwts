iwts_performer:9741 a schema:PerformingGroup;
  schema:name "Duo Cordelia";
  schema:description """As Duo Cordelia, violinist Vanessa Marcoux and pianist Marie-Christine Poirier invite you into an unexpected musical landscape, where classical compositions mingle with fresh repertoire, playful improvisation, and unconventional technique.

Both graduates of the Université de Montréal and individually recognized as talented musicians, the two have been curating captivating performances together for almost a decade.""";
