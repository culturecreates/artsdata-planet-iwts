iwts_performer:4102 a schema:Person;
  schema:name "Michael Menes";
  schema:description "Michael Menes is a contemporary performing artist drawing from traditions of physical theater and object manipulation. He is celebrating 50 years of juggling through visually striking, finely crafted performances. Blending elemental object work with precise physical control, his shows are engaging, accessible, and adaptable for theaters, festivals, and community audiences. He has performed internationally across stages, television, and major festivals, bringing a distinctive mix of skill, clarity, and visual storytelling to every performance.";
