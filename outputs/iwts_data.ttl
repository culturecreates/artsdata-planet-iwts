iwts_performer:586 a schema:Person;
  schema:name "Dave McCann";
  schema:description "Over nearly two decades, Dave McCann has become a vital voice in Alberta’s roots scene, known for his storytelling and craft. His seventh album, Soothsayer’s Blues, recorded at Zebra Ranch in Mississippi with producer Jimbo Mathus, explores the mythology and the foundational spirit of folk music from the American South. Steeped in blues, country, and rock ’n’ roll, the record reflects a deep connection to tradition and place. In an industry chasing trends, McCann remains committed to the creative process - because, for him, songs matter.";
  schema:url <http://www.davemccann.com>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
  schema:genre "Folk/Bluegrass/Americana";
