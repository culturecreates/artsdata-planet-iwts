iwts_performer:9518 a schema:PerformingGroup;
  schema:name "The Crosby Harle Band";
  schema:description "Crosby and Harle, two Regina-born musicians, began their journey in high school, blending choir and rock influences. In 2016, they placed 3rd in Canada in the CMT Chevy Tailgate Contest with their original “Man in the Mirror.” Since then, they’ve written 14 songs, with “Drinking to Drink” recorded by a Nashville artist and “Mess with the Law” earning local radio play and a 2024 SCMA nomination. Their harmonies and heartfelt songwriting continue to make waves in the classic rock and country scene.";
  schema:url <https://www.facebook.com/events/258645236367141/>;
