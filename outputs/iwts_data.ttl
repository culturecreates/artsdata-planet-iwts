iwts_performer:10201 a schema:PerformingGroup;
  schema:name "Mandy Faye";
  schema:description """Mandy Faye (they/them) is equal parts musician, educator, and coffee. Best described as The Wiggles meets Diana Krall, their high-energy stage presence and thoughtful songwriting have won the hearts of audiences across Canada with highlight performances at The International Children’s Festival for the Arts, Red Deer Children’s Festival, JazzYYC and Calgary Pride.
My Friends is Mandy Faye’s newest album exploring themes of friendship. It features collaborations with some of Alberta’s best jazz players and children’s musicians.""";
