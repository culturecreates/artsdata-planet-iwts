iwts_performer:9924 a schema:PerformingGroup;
  schema:name "Quinton Blair";
  schema:description "Quinton Blair is a Canadian country artist rooted in rodeo culture, prairie life, and honest storytelling. Based in the heart of Canada, his music reflects a lived-in understanding of the western way of life, delivered with warmth, grit, and a natural connection to audiences. Equally at home in theatres, community halls, and western events, Blair’s performances resonate with multigenerational listeners. A multi-time Manitoba Country Music Association award winner, he has showcased at Canadian Country Music Week and Folk Alliance International.";
  schema:url <https://quintonblair.com/>;
