iwts_performer:4970 a schema:Person;
  schema:name "Janoah Bailin";
  schema:description "Janoah the Jester (ze/zir) is a juggler and unicyclist creating shows that mix circus, clown, dance, puppetry, storytelling and performance art. Ze makes interactive family experiences that are educational for younger audiences, engaging for adults, and visually memorable for all. Janoah uses circus tricks and humor to connect with the audience in order to focus on more minute details – philosophy, language, etc. Zir performances focus on metaphors, exploring concepts such as \"circus\" and \"jugging\" in ways that are accessible to six year olds.";
  schema:url <http://www.janoahanygoodjokes.com>;
