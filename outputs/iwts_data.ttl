iwts_performer:8229 a schema:Person;
  schema:name "Bill Bowers";
  schema:description "Bill Bowers is a world renowned actor and mime, who is a master storyteller, with and without words.  A Broadway veteran (The Lion King and The Scarlet Pimpernel) and a student of the legendary Marcel Marceau, Bowers has created numerous solo plays that showcase his unique performance style, implementing, music and mime with exquisite spoken language.  His stories are hilarious and heartbreaking, and show us the humor, beauty and pain of our humanity through simplicity and grace. Bowers has performed throughout the USA,  Europe and Asia.";
  schema:url <https://www.Bill-Bowers.com>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/TheatrePerformance>;
