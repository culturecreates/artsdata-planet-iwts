iwts_performer:5389 a schema:PerformingGroup;
  schema:name "Sticks and Stone Percussion";
  schema:description "Sticks and Stone has been bringing a joyful \"jungle piano\" marimba experience to the Edmonton area since 2017.  They connect broadly with audiences by playing recognizable covers, including Disney and video-game and frequently including humourous antics. Their 2020 debut album “Marimba Around the World” mixed folk music from 15 countries with pop, rock and jazz.  Performances have included playing for the CBC Turkey Drive, the Edmonton Fringe Festival, the North Country Fair and the City of Edmonton New Year's Eve in the Winspear.";
  schema:url <http://www.sticksandstonepercussion.com>;
