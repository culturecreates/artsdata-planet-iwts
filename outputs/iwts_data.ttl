iwts_performer:1209 a schema:PerformingGroup;
  schema:name "BACKYARD BETTIES";
  schema:description "The Backyard Betties are a Calgary-based folk/Americana band known for honest songs, tight harmonies, and live shows that feel more like a hang than a performance. Their music lives in the real stuff: love, loss, starting over, and figuring yourself out. Live, the Betties are welcoming, funny, and deeply human. They have a rare ability to make a room of 300 feel as connected as a house concert. Their shows are full of laughter, reflection, and moments where you catch yourself thinking, yeah… I’ve been there too.";
  schema:url <https://www.backyardbetties.ca/>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
