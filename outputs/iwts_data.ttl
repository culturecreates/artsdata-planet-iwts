iwts_performer:6442 a schema:PerformingGroup;
  schema:name "Fandango!";
  schema:description "?One of the most unique and exciting groups on Chicago's musical scene, FANDANGO! is a spicy mix of Spanish, Latin-American, Balkan, Sephardic and classical sounds. These four multi-award-winning, globe-trotting virtuosi, from Spain, France, Bosnia and Taiwan have appeared on the world's most prestigious stages, and received rave reviews in the international press.";
