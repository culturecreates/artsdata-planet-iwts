iwts_performer:9907 a schema:Person;
  schema:name "Hope Levy";
  schema:description "Folk pop singer-songwriter, actress Hope Levy is a lifelong performer whose work spans folk music, musical theatre, and screen. She began singing as a child recording with Malvina Reynolds, and later appeared in L.A productions of Les Misérables, Rocky Horror Show, Eating Raoul: The Musical, and at the Hollywood Bowl. A veteran voice actor, she voices “Mom” on Netflix’s Boss Baby. Hope tours nationally with her award-winning one-woman Americana cabaret The Connie Converse Universe and released the album Hope Levy Sings Connie Converse!.";
  schema:url <https://ConnieConverseUniverse.com>;
