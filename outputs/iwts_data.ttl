iwts_performer:10102 a schema:Person;
  schema:name "Anders Muskens";
  schema:description """Anders Muskens (b. 1993) is a Canadian pianist, historical  fortepianist, harpsichordist, and ensemble director specializing in historical keyboard performance and musicology. Performing across Europe and North America, he is known for vivid interpretations of 18th- and early 19th-century music. 

He has performed internationally across Europe and North America, with solo recitals at Het Concertgebouw Amsterdam, the Utrecht Early Music Festival, The Catskill Mountain Foundation, and Salle Bourgie, Montreal.""";
  schema:url <http://andersmuskens.com/>;
