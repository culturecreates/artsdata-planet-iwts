iwts_performer:10061 a schema:Organization;
  schema:name "Ballet Vancouver";
  schema:description """Led by Artistic Director Joshua Beamish, Ballet Vancouver is a non-profit charitable dance company based in Vancouver. The primary mandate of the company is to revitalize Vancouver’s access to professional classical, neoclassical, and narrative ballet.

Dedicated to the creation and presentation of innovative, engaging ballets, the company presents multiple home performances annually, in addition to national and international touring. Ballet Vancouver’s programming also encompasses homecoming performances by locally trained ballet stars.""";
  schema:url <https://www.balletvancouver.com>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/DancePerformance>;
