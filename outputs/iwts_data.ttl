iwts_performer:10166 a schema:PerformingGroup;
  schema:name "Beautiful Crazy - Luke Combs Experince";
  schema:description """From the heart of Canada, “Beautiful Crazy:  Luke Combs Experience” is the tribute act that brings the full Luke Combs experience to life. Led by Dave, whose uncanny resemblance to the country superstar goes beyond looks, his voice captures the soulful grit and powerful emotion that defines Luke Combs.

 With a setlist that includes all the hits like “Beer Never Broke My Heart,” “When It Rains It Pours,” and, of course, “Beautiful Crazy,” this tribute band has fans raising their beer cans high, singing along to every word.""";
  schema:url <https://bookinghouse.com/luke-combs-beautiful-crazy/>;
