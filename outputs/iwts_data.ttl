iwts_performer:105 a schema:PerformingGroup;
  schema:name "The Wardens";
  schema:description "Storyteller and songwriters from Canada's most cherished wilderness areas, The Wardens stories and songs rise from the very land they protect as Canadian national park wardens. With haunting three-part harmonies and chilling tales, the band’s mountain music reflects Canada, celebrating the return of species at risk, reflecting on an environment in crisis and honouring the groundbreaking contributions of warden conservationists. A performance by The Wardens has been dubbed “the quintessential mountain-culture concert experience.\"";
  schema:url <http://www.thewardensmusic.com>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/PerformingArtsEvent>;
  schema:genre "Traditional";
  iwts:consent "agree_v_1.0";
