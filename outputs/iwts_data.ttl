iwts_performer:9433 a schema:Person;
  schema:name "Bob Wegner";
  schema:description "Bob Wegner is a multi-instrumentalist, music historian, writer, editor and radio show host. Highlights of his musical career include being selected by Queen’s Brian May and Roger Taylor to play guitar in multiple productions of the “We Will Rock You” musical. His coffee table book and comprehensive history of the legendary rock outfit Max Webster called “High Class” was endorsed by the band’s frontman Kim Mitchell, reviewed by many of Canada’s biggest publications, and sold out its first pressing, with a second on the way.";
  schema:url <https://bobwegner.ca>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
