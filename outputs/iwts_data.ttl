iwts_performer:8887 a schema:Person;
  schema:name "Mairi Dorman-Phaneuf";
  schema:description "MAIRI DORMAN-PHANEUF has established a busy career in New York City as a solo, chamber, Broadway, and recording artist. Since 2003 she has held chairs in 22 Broadway shows, including The Bridges of Madison County, A Little Night Music, Sunday in the Park with George, and currently, Floyd Collins. Her debut solo album, Music of Broadway for Cello and Piano, released in September 2021 on Craft Recordings/Concord Theatricals, has been described as “sublime” by BroadwayWorld.";
  schema:url <https://mairidormanphaneuf.com>;
