iwts_performer:9269 a schema:PerformingGroup;
  schema:name "Sterling Drake";
  schema:description "Montana songwriter Sterling Drake is known for honest storytelling rooted in the landscapes and traditions of the rural West. His songs reflect the people, places, and working cultures that shape the region. Drake’s work is message-forward, advocating for issues facing rural America. He has partnered with the Western Landowners Alliance to support working family ranches and uses his platform to raise awareness about mental health in rural communities and among working cowboys, bringing rural voices into the broader American conversation.";
  schema:url <https://www.instagram.com/sterlingxdrake/>;
