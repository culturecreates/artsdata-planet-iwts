iwts_performer:5310 a schema:Person;
  schema:name "JoJo Worthington";
  schema:description """Producer / songwriter, JoJo Worthington, crafts intimate recollections that explode into limitless soundscapes. Worthington’s work pushes emotionally potent folk songs to the perilous edge.

BAPTIZED I leaves no stone of Worthington’s distinctive sonic palette unturned. Tender acoustic ballads erupt into sweeping electronic passages. 

They bring Death, the devil, and Holy Ghost into scenes of high school bush parties and walks along the St. Lawrence. Combining earthly and celestial sounds,  Worthington yearns \"to be as the spirit is.”""";
  schema:url <http://jojoworthington.com>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
