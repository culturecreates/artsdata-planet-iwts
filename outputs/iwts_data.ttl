iwts_performer:10078 a schema:PerformingGroup;
  schema:name "Brady Lee";
  schema:description "Milwaukee-born singer, songwriter, and performer Brady Lee is a dynamic artist known for his captivating on-stage presence. Drawing inspiration from artists like Kane Brown, Ed Sheeran, and Dan + Shay, Brady’s sound is a mix of pop-infused, radio-friendly anthems that highlight his exceptional vocal talent and charismatic performance style. Whether he’s performing an original song or a well-loved cover, his ability to connect with the audience shines through in every note.";
