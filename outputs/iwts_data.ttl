iwts_performer:9984 a schema:Person;
  schema:name "Ashli St. Armant";
  schema:description """Based in Calgary, AB, this award-winning jazz vocalist channels ten generations of ancestry in New Orleans to craft a gumbo pot of original songs and classic jazz tunes into concerts that audiences are calling “magnetic.”

For over a decade, she has also been the bandleader of Jazzy Ash and the Leaping Lizards, a New Orleans-style jazz band for young audiences. Together, they have produced six studio albums, have performed at numerous venues including Lincoln Center and Sprout Network (NBC), and have been featured by NPR and L.A. Times.""";
  schema:url <https://ashlistarmant.com>;
