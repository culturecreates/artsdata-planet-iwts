iwts_performer:9457 a schema:Person;
  schema:name "Élodie Orsei";
  schema:description "French-Canadian artist from British-Columbia, Élodie Orsei blossoms in a billingual soft pop-soul music, both sensual and juicy, with influences from global francophone artists. Her powerful yet gentle lyrics explore self-discovery, love and the eternal quest to find oneself. Warm and poetic, her performance offers a soft ambience perfect for cuddling your loves. In June 2024, she released her 2nd EP entitled Fleurish, a cross between the French word Fleur and the English word Flourish.";
  schema:url <https://www.elodieorsei.com/>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
