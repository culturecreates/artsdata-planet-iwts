iwts_performer:9548 a schema:PerformingGroup;
  schema:name "Girlz with Guitarz";
  schema:description "Girlz with Guitarz is a trio consisting of two sisters and a cousin from the Gauthier family originating from the small hamlet of Plamondon in North Eastern Alberta.  This bilingual group performs all genres as well as original compositions mainly influenced by country, folk and pop.   With these 3 musicians, you will hear a whole range of instruments such as guitar, ukulele, banjo and harmonica however, it is their 3-part harmony that will delight you the most.";
