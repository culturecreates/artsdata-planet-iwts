iwts_performer:9412 a schema:PerformingGroup;
  schema:name "Chopping Spree";
  schema:description "Chopping Spree is a jazz fusion/experimental band that delves into the groovy, energetic world of jazz rock. They blend elements of Japanese jazz, funk, and psychedelia, with the explosive energy of Vancouver's underground hard rock scene. Sometimes smooth jazz, sometimes metal, Chopping Spree is a sight to see with their wild stage presence and captivating riffs. Taking influence from the likes of Casiopea, SOIL & \"PIMP\" SESSIONS, and King Gizzard and the Lizard Wizard, their unique style creates a soundscape of hypnotic proportions.";
  schema:url <https://choppingspree.bandzoogle.com>;
