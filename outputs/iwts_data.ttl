iwts_performer:2942 a schema:PerformingGroup;
  schema:name "Celeigh Cardinal";
  schema:description "Celeigh Cardinal is a JUNO Award–winning Cree singer-songwriter known for her powerhouse vocals and deeply personal storytelling. Blending folk, soul, and blues, her music explores love, grief, resilience, and spiritual connection. Her 2024 album Boundless Possibilities earned multiple JUNO nominations, and she won Indigenous Songwriter of the Year at the 2025 Canadian Folk Music Awards and the 2025 Western Canadian Music Awards. Her voice, warmth, and honesty leave a lasting impression on every stage she steps onto.";
  schema:url <http://www.celeighcardinal.com>;
