iwts_performer:10270 a schema:Person;
  schema:name "Normie Song";
  schema:description "Normie Song is a singer, songwriter, and dancer based in Atlanta, Georgia. Blending emo-pop and dance R&B, his music explores existential reflection, love, and human connection. A skilled tenor, he has refined his voice through years of training and musical theater experience. On stage, he delivers dynamic performances with striking vocals, movement, and charisma. His image embodies self-love, harmony, and fearless individuality.";
