iwts_performer:9463 a schema:Person;
  schema:name "Etienne Siew";
  schema:description "Etienne’s impactful approach to Alternative Folk/Roots music is winning awards and reaching hearts of people from all walks of life. With an EP, and his debut album \"Chasing Dreams,\" under his belt, he has toured Vancouver Island, performed Internationally and continues to reach the world, with stories from his pursuits as an artist. Whether he is performing in a theater, or near a campfire, his blend of warm guitar melodies, and powerful vocals will speak to your heart and make you feel as though you are walking beside him in his stories";
  schema:url <https://www.etiennesiew.com/>;
