iwts_performer:9836 a schema:Person;
  schema:name "Julia Cunningham";
  schema:description "Julia Cunningham is an indie pop-folk singer-songwriter from Halifax, Nova Scotia.  Her debut EP, Dive Deep, earned her a nomination for Music Nova Scotia’s New Artist Recording of the Year in 2024. She blends acoustic guitars, banjos, and keys with modern sounds to create music that is both current and nostalgic.  Her music invokes the freedom and introspection of the big outdoors. Currently, Julia is working on a new project called “The Morning”, to be released in 2026.";
  schema:url <https://juliacunninghammusic.com/>;
