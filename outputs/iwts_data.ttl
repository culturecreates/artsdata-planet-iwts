iwts_performer:7727 a schema:Person;
  schema:name "Beau Wheeler";
  schema:description "Beau Wheeler is a queer non-binary singer songwriter based in so-called \"Vancouver\". Beau released a new record, Flying Colours last year, and has two others on the way, one self-produced and one produced by Jason Corbett of Actors. Beau recently showcased at Alberta Showcase, Contact East and Folk Music Ontario.  Beau’s dynamic range can lift an audience to its feet in a moment and in the next, stop your heart so the whole room could hear a pin drop. One of Vancouver’s punchiest singers.";
  schema:url <http://www.beauwheeler.com>;
