iwts_performer:9498 a schema:PerformingGroup;
  schema:name "Rebecca and Rachel Gray";
  schema:description """Rebecca Gray is a soprano, composer, and improviser blending classical and contemporary music with queer and feminist themes. She has performed with major opera companies and created award-winning works like Jess and Raccoon Opera.

Rachel Gray is an Ottawa-based interdisciplinary artist exploring storytelling and accessibility. Her work spans visual arts, opera, and disability advocacy, including directing BEING Studio and co-founding Ghost Rooster.""";
