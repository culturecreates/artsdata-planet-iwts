iwts_performer:9987 a schema:Organization;
  schema:name "Dreamqueen Immersive";
  schema:description "Dreamqueen Immersive pushes the boundaries of traditional theatre, creating original, magical experiences that transport Canadian audiences to new worlds. Described in the press as having a “cult following,” the company produces audience-focused, design-driven work that blends immersive world-building with rigorous performance craft. Dreamqueen is known for ambitious aesthetics, strong ensemble storytelling, and visually distinctive productions that tour effectively both in theatres and unconventional venues.";
  schema:url <https://dreamqueenimmersive.com>;
