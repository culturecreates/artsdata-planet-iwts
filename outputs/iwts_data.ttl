iwts_performer:9473 a schema:PerformingGroup;
  schema:name "Cold Hard Cash";
  schema:description "Since 2011, Cold Hard Cash has been entertaining audiences with their energetic and soul-capturing Johnny Cash experience. They have worked hard to hone the details of the show, taking the audience for a time-travelling experience. Different eras are brought to life with the band’s sharp formal dress and authentic vintage instruments changing alongside the many distinct styles of Cash’s music. Seeking a complete entertainment experience, Cold Hard Cash focuses on drawing the audience in with witty humour and dynamic stage presence.";
  schema:url <https://www.coldhardcashmusic.com/>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
