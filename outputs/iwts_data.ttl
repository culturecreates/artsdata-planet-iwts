iwts_performer:9831 a schema:PerformingGroup;
  schema:name "The Divorcees";
  schema:description "For 20 years now, The Divorcees have been nationally recognized as a leading voice in Canada's Americana/Traditional Country music scene. Since their debut in 2005, Alex Madsen, Denis \"Turtle\" Arsenault, Shawn Thomas and Kevin Macintyre have brought their brand of working-class country music to venues and airwaves from Vancouver to Prince Edward Island and everywhere in between.";
