iwts_performer:4540 a schema:PerformingGroup;
  schema:name "Pharis and Jason Romero";
  schema:description "Pharis and Jason Romero are a folk-roots duo based in Horsefly BC. They have won four Juno Awards, seven Canadian Folk Music Awards,  and toured North America and Europe. Their six duo records and multiple collaborations are all self-released except for their last project working with the venerable institution Smithsonian Folkways Recordings. Their gut-tightening singing, songwriting, banjo craftsmanship, and avid old song interpretations have quietly blown audiences away since 2009. They are currently performing with fiddler Trent Freeman.";
  schema:url <http://www.pharisandjason.com>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
