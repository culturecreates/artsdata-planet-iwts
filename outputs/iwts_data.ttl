iwts_performer:3832 a schema:PerformingGroup;
  schema:name "Nuela Charles";
  schema:description "Nuela Charles is a Kenyan-born, Canada-based cinematic alternative-soul artist with four JUNO nominations, including NU2U for Adult Contemporary Album of the Year (2026). Known for soul-stirring vocals and introspective songwriting, her music has earned 30+ sync placements — including a Paris Olympics feature — and seven consecutive weeks atop CBC Radio 2's Top 20. She has performed across North America and Europe, sharing stages with Ziggy Marley, Jann Arden, and Stars.";
