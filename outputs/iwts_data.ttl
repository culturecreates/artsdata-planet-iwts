iwts_performer:2186 a schema:Person;
  schema:name "Joshua Lozoff";
  schema:description """Joshua Lozoff is a speaker/magician/mentalist and former TV and film actor. He currently tours the US performing his magic and mentalism show “Life is Magic” at performing arts centers and corporate events. Additionally, his keynote presentation “The Magic of Communication,” makes him a frequent presenter at conferences around the country.

