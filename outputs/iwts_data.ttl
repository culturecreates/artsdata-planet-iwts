iwts_performer:9298 a schema:PerformingGroup;
  schema:name "Amanda & James";
  schema:description "Amanda & James are award-nominated Canadian recording artists (2x CMAO Group/Duo of the Year nominees) with radio airplay and a reputation for show-stopping vocals. Their unique concert Time of My Life: The Greatest Duets features over 25 iconic songs performed with a full band. From classics like “Ain’t No Mountain High Enough,” “Jackson,” and “Islands in the Stream” to modern hits like “Shallow,” “Need You Now,” and “I’ve Had The Time of My Life,” audiences experience a high-energy, genre-spanning show packed with hits.";
