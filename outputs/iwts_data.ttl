iwts_performer:9577 a schema:Person;
  schema:name "Kaya Hoax";
  schema:description "Listening to Kaya Hoax, you'll find yourself nodding your head with a blend of mischief and passive indignation. Her music sits somewhere between hip-hop and experimental pop, drawing from the impetuous eclecticism of M.I.A., the songwriting sensibilities of Santigold, and the futuristic pop of Charli XCX. In May 2024, Hoax released her debut EP Baby Gear, which earned her a GAMIQ Award. This first opus quickly propelled the artist into the spotlight of Quebec's most prominent festivals, such as Osheaga, Pop Montréal, M pour Montréal and FME.";
  schema:url <https://linktr.ee/kayahoax?fbclid=PAZXh0bgNhZW0CMTEAAaZdA1uvszl51ZRvDmfFt6WEGadbOtrxoBELt4J1ThwXPhaO>;
