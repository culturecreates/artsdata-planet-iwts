iwts_performer:6927 a schema:PerformingGroup;
  schema:name "Bill Brennan and Andrea Koziol";
  schema:description "MusicNL’s Jazz Artists of the Year for their album “I’ll Be Seeing You”, pianist Bill Brennan and vocalist Andrea Koziol now make original music that springs from decades of jazz practice and blends in roots, soul, and even country sensibilities. With songs that tell candid stories, and a love of improvisation, this ensemble is highly entertaining, undeniably masterful and just plain genuine. Audiences are sure to leave with all the feels. New album “Keep the Faith” launching September 2026.";
  schema:url <http://www.andreaandbill.com>;
