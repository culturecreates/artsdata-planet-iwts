iwts_performer:9247 a schema:Person;
  schema:name "REUEL";
  schema:description """Reuel is a virtuosic visual piano artist and arranger known for delivering a genre-blending instrumental experience on stage. Based in Las Vegas, NV, Reuel has dazzled audiences at prestigious venues such as Caesars Palace, The Venetian, Aria, Hilton, and Four Seasons. 

His artistry and innovative performances have earned him features in Parade Magazine, Broadway World, Medium, the Austin American-Statesman, PianoAddict.com, CultureMap Houston, and Influential Magazine, with Austin.com calling him “the most talented pianist in Austin.”""";
