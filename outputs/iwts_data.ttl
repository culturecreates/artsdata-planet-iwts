iwts_performer:10292 a schema:Person;
  schema:name "Scarlet Chen";
  schema:description "Scarlet Chen is a comedian, screenwriter, playwright, and performer based on Gabriola Island, BC. A Chinese immigrant with a background in film, television, and theatre, she creates sharp, personal work about identity, belonging, and cross-cultural experience. Her credits include HBO Asia, opening for Maria Bamford and Julie Kim, and creating and performing Citizen Chen, a Mainstage selection at Vancouver’s rEvolver Festival 2026 and an Official Selection of the Edinburgh Fringe 2026.";
