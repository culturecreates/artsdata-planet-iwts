iwts_performer:5916 a schema:Person;
  schema:name "CRISTIAN DE LA LUNA";
  schema:description "Born in the Colombia of Garcia Marquez, he grew up in the noisy bustle of \"Cumbia\",\"Porro\" and \"San Juanero\".  It was there that he found his undying passion for music. His Exile and his cultural quest for identity brought him to Alberta and shaped this \"new wave\" Canadian into the artist that he is today. This whole process  has transformed Cristian into an ambassador for cultural diversity. His music seeks to promote the unification of races, accents and religions, dismantling divisions and nurturing the capacity to dream.";
  schema:url <http://WWW.CRISTIANDELALUNA.COM>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
  schema:genre "Global";
  iwts:pronouns "Il";
