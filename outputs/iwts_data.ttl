iwts_performer:10125 a schema:Person;
  schema:name "Guy Bavli";
  schema:description "Guy Bavli – Master of the Mind is an internationally acclaimed mentalist who has captivated audiences in over 50 countries. Blending psychology, intuition, and interactive theater, Bavli creates astonishing demonstrations of mind reading, prediction, and influence. His dynamic performances have appeared on television, luxury resorts, and major corporate stages worldwide, leaving audiences questioning the limits of the human mind.";
