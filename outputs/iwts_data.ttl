iwts_performer:10015 a schema:PerformingGroup;
  schema:name "Crossing MacKenzie";
  schema:description "Crossing MacKenzie is Bonnie Gregory (fiddle and vocal) Steve Bell (piano, accordion and vocal) and Andreas Illig (guitar) who have come a long way from the session scene on Edmonton’s Whyte Avenue, through several bands (Celtara,Scona Brae), recordings and tours.  A love for acoustic folk and trad music from Celtic to Scandinavian to Appalachian and Canadiana can be heard in their intricate arrangements of songs and tunes, new and old, originals and traditional. Debuting in 2024, Crossing MacKenzie continues to play regularly around Alberta";
  schema:url <https://www.crossingmackenzie.com>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
  schema:genre "Traditional";
