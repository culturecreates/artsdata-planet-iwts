iwts_performer:6867 a schema:Person;
  schema:name "Jeannine Guyot";
  schema:description "A sensitive, talented, open-minded and determined artist,  Jeannine stands out for her ability to create catchy melodies. Her poetic way of telling the story of her daily life immerses us in her world. Her simplicity and authenticity make her a deeply touching and engaging artist. Always in search of answers, she draws on her reflections to nourish her music. Her project Les Échos offers an intimate musical setting in which Jeannine explores the many facets of the life of a woman, a mother and a grandmother, with unique depth and sensitivity.";
  schema:url <https://www.jeannineguyot.com>;
