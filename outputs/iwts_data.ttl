iwts_performer:8637 a schema:PerformingGroup;
  schema:name "Mallory Chipman";
  schema:description "Award-winning songwriter, Mallory Chipman, has garnered attention for her signature brand of “cinematic folk-rock”; conjuring comparison to Kate Bush and Hozier, while staying strikingly original. In support of her latest album, Songs to a Wild God, Mallory has toured Canada, Asia, and Europe, turning heads at festivals like Alberta Showcase, North by Northeast, Breakout West, and Folk Alliance. Wherever she goes, Mallory enchants audiences with her mix of powerful stories, bare confessionals, and contemporary protest songs.";
  schema:url <https://mallorychipmanmusic.com>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
