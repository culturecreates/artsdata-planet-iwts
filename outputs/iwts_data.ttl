iwts_performer:9986 a schema:PerformingGroup;
  schema:name "The Little Mercies";
  schema:description "The Little Mercies grew from three friends at a local jam to festival headliners in just two years—and their rise feels inevitable the moment you hear them. Their powerful harmonies, twin fiddles, and tear-wrenching lyrics create an experience that is both exhilarating and deeply moving. Recognized as SERFA Official Showcase artists and Freshgrass Award finalists, Bronwyn, Shanice, and Rosalee bring something rare to every stage: music rooted in tradition but alive with joy, heart, and a fierce belief in human connection.";
  schema:url <https://thelittlemercies.com/>;
