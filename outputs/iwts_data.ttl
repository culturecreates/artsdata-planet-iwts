iwts_performer:8929 a schema:PerformingGroup;
  schema:name "Elisa Thorn";
  schema:description "Elisa Thorn is a harpist/vocalist known for her distinctive, contemporary approach to the harp. Blending jazz, folk, indie, experimental, and ambient influences, her music balances sensitivity and boldness, creating lush, cinematic soundscapes that defy genre boundaries Her solo project, showcased on her recent album xiik, explores generosity, play, and sonic experimentation.  For fans of Bjork, Andrew Bird, and Feist.";
