iwts_performer:7274 a schema:Person;
  schema:name "Kung Jaadee";
  schema:description "Kung Jaadee is a Haida storyteller, educator, and bestselling author who has shared Indigenous stories for over 30 years across Canada. A member of the X?aayda (Haida) Raven Clan, she is also connected to the Musqueam, Squamish, Tlingit, Tsleil-Waututh, and Hawaiian peoples. Known for performing Haida and Squamish legends and sharing her people’s history, she’s authored the bestselling children's books, Raven’s Feast, Gifts from Raven, and I Am Connected, and recently helped break a Guinness World Record for longest storytelling in Morocco.";
  schema:url <https://www.pebblestarartists.com/kung-jaadee>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/ChildrensEvent>;
