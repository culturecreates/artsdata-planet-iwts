iwts_performer:3576 a schema:PerformingGroup;
  schema:name "Zachary Lucky";
  schema:description "Zachary Lucky is the genuine article - unapologetically old-school country, armed with a husky, baritone voice. The Grandson of Canadian Country Music pioneer Smilin' Johnnie Lucky, he sings of Canadian places and people as knowingly as he might Townes Van Zandt or the Rio Grande. Hailed as a master storyteller by outlets ranging from No Depression to The Globe and Mail, Zachary has safely reserved his spot at the table of Canadian roots royalty.";
  schema:url <http://www.zacharylucky.com>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
