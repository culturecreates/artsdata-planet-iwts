iwts_performer:10086 a schema:Person;
  schema:name "Tina Chang";
  schema:description "Vancouver-based pianist and coach Tina Chang has performed across Canada, the United States, and Europe. A sought-after recitalist, she has collaborated with artists including Daniel Okulitch, Melody Courage, Lara Ciekiewicz, Manuela Custer, and Alessandra Volpe. She appears regularly with organizations such as the Vancouver Symphony Orchestra and Chor Leoni, and serves on the music staff of Vancouver Opera as Chorus Director, Principal Répétiteur, and Coach. She is also co-founder of the Connective Collective.";
  schema:url <https://tinachangpiano.ca/>;
