iwts_performer:10191 a schema:PerformingGroup;
  schema:name "Laura Rain";
  schema:description "Detroit’s Laura Rain is a product of her surroundings, a hard driving soul singer who uses the power and finesse of her own voice to inspire and electrify the spirit. Born and raised in the Motor City, she delivers her original music with fearless emotion and excitement. Along with her creative partner George Friend, the pair have released five albums, and nine singles with a unique blend of contemporary funky soul, blues and r&b worthy of Detroit’s rich history of musical innovators.";
