iwts_performer:8900 a schema:PerformingGroup;
  schema:name "The Labra Brothers";
  schema:description "The Labra Brothers are the standard for Latin Funk in the Rust Belt. Raised in Youngstown, Ohio, the four siblings and their bandmates blend Mexican-American heritage with a gritty, soulful edge. Known for \"mystical family telepathy\" in their three-part harmonies and explosive live grooves, the Brothers are set to release a self-titled album in 2026. Voted Cleveland’s \"Best Latin\" performing act, they deliver a bilingual and eclectic performance that is both culturally rich and irresistibly danceable—a premier pick for any diverse season.";
  schema:url <https://www.thelabrabrothers.com>;
