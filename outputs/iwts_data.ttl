iwts_performer:10287 a schema:Person;
  schema:name "Nora Spielman";
  schema:description "Nora Spielman is a dynamic classical guitarist who has captivated audiences across the United States and South America with her powerful solo and chamber performances. Recent engagements include appearances with the Bozeman Symphony, Opera Montana, and Montana Theatre Works, as well as solo recitals at Hunter College, University of Montana, Montana State University, and the Melodies for Montana PBS Benefit Concert. Her programs feature repertoire from the classical canon, Latin America, and new works she has commissioned.";
