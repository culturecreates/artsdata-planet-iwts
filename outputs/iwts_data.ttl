iwts_performer:9965 a schema:Person;
  schema:name "Melody McArthur";
  schema:description "Melody McArthur is a multi-award-winning singer, songwriter, and actor from Treaty 8 Northern with a powerful voice and penchant for emotionally-driven performances. She is set to release her seventh album, The Gospel Truth, in 2026 and captivated theatre audiences as a lead actor of Bear Grease during its 2025 off-Broadway debut. McArthur is set to star in the World Premiere of Tomson Highway's musical “Rose” at the National Arts Centre in Ottawa, Ontario March-April 2026.";
