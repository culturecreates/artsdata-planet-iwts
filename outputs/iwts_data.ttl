iwts_performer:9735 a schema:Person;
  schema:name "Linda McLean";
  schema:description """Linda McLean is a singer and writer of songs and books. She's
released several albums including \"Betty's Room\" and \"No
Language,\" both of which garnered critical acclaim internationally. Her \"Songs and Readings\" is a performance that pairs stories and music from her memoir, \"The Importance of Being Important,\" her journey to love, healing, and belonging, with \"Songs for the Book\" intimate and reflective recordings, the pairing of songs with the writing creates a unique and emotional reading experience that McLean replicates on stage.""";
  schema:url <http://www.lindamclean.com>;
