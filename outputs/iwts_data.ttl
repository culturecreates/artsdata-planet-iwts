iwts_performer:5178 a schema:Person;
  schema:name "Jamie Adkins";
  schema:description "Recognized worldwide for his undeniable talent as an acrobat, juggler and clown, Jamie Adkins began his career at age 13 in his hometown of San Diego, CA. He worked with Pickle Family Circus and Cirque Éloize, where he created his first solo show TYPO. His second solo show, Circus Incognitus (2007), has toured 37 countries with 1,300+ performances. Now based in Quebec for over 20 years, he is recognized as one of Canada’s leading contemporary circus artists.";
