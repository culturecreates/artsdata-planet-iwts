iwts_performer:9525 a schema:PerformingGroup;
  schema:name "Kates Outlaw";
  schema:description "Kates Outlaw is a Country-Rock band based out of Dauphin, Manitoba . Formed in 2015, Kates Outlaw began from nothing more than a common interest in simple living, motorcycles and music. Growing up in the rural Parkland region of Manitoba, where they still call home. their similar background makes their music cohesive and the common understanding between its members brings the music together naturally. The band released their first single, Longrider Religion in June 2024, followed up by their debut album of the same name in October 2024.";
  schema:url <https://www.manitobamusic.com/katesoutlaw>;
