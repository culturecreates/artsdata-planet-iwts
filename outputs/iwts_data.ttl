iwts_performer:9696 a schema:Person;
  schema:name "Ronan Tynan";
  schema:description "Ronan Tynan is truly a modern day \"Renaissance Man\". He is an Irish tenor, physician, and former Paralympic athlete. Born with a limb disability and later a double amputee, he won multiple medals at the Paralympics before becoming a doctor and then a celebrated singer. He gained fame with the Irish Tenors and for performances like \"God bless America\" at Yankee Stadium. He is one of the most sought after motivational speakers in the united states presenting nearly 50 speeches annually for major international corporations and organizations.";
  schema:url <https://www.cmientertainment.com/lineups/ronan-tynan>;
