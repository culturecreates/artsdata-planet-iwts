iwts_performer:9561 a schema:PerformingGroup;
  schema:name "Dorant Ricketts";
  schema:description """•	Formed in 2017 Saint And The Full 100 Band is a group of amazing local musicians hailing from England, Jamaica, Trinidad, Nigeria and Canada. Each person bring their own unique style and personality to the table.. But all share the love of music. If I was to list one thing that is unique about this band.. It would be that I’m the drummer and also the lead singer and that’s not something you see every day in reggae music..""";
