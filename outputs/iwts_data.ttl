iwts_performer:9482 a schema:PerformingGroup;
  schema:name "DECADES IN DUET: Six Decades of Chart-Topping Pop/Rock Duets";
  schema:description "Vocalists, multi-instrumentalists, and award-winning husband/wife songwriters Annalyse McCoy and Ryan Dunn celebrate love and music in DECADES IN DUET! This dynamic duo brings their years of headline experience in New York City and Nashville together to create this special concert event featuring the greatest duets of all time. With cross-genre favorites from the 60s/70s, classic pop from the 80s/90s, and modern crossover hits, the eclectic array of music in DECADES IN DUET surprises audiences at every turn.";
  schema:url <https://decadesinduet.com>;
