iwts_performer:10240 a schema:Person;
  schema:name "Stephanie Ann Ball";
  schema:description "Stephanie Ann Ball is a lyric soprano and healing artist whose work bridges classical performance with the science of well-being. Known for her rich, resonant voice and magnetic stage presence, she has performed with ensembles including the Chamber Orchestra of Colorado Springs, and at iconic venues like Red Rocks Amphitheater. Committed to emotional healing through music, she curates transformative experiences that support stress relief, recovery, and renewal. Her repertoire spans opera, oratorio, art song, and original meditation music.";
