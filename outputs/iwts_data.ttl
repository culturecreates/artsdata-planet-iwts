iwts_performer:9975 a schema:Person;
  schema:name "KAZASHIM";
  schema:description "Edmonton-based, Nigerian born artist KAZASHIM fuses alternative Hip-Hop, R&B Soul & Jazz into an evocative sonic experience. Drawing from a vulnerable tri-continental experience, seasons of isolation and self discovery nurtured by a grounding upbringing in the church. KAZASHIM delivers captivating hooks, immersive storytelling on heavy hitting basslines and textural melodies through explosive performances and continues to evolve, bridging ego death, sentimentality and sonic depth into every creation.";
  schema:url <https://linktr.ee/kazashimmusic>;
