iwts_performer:9409 a schema:Person;
  schema:name "JACE CARRILLO";
  schema:description "JACE Carrillo is a Montreal-based singer and songwriter from Venezuela, now holding Canadian citizenship. His musical journey began at a young age when he joined a gospel choir as a teenager, later expanding his influences beyond Latin genres. Singing and performing became his emotional outlet, especially during challenging years in Venezuela. In 2015, he moved to Canada to pursue his dreams, learning English and French while studying Music Production. Today, he blends captivating Spanish vocals with contemporary North American styles.";
  schema:url <https://www.jacecarrillo.com>;
