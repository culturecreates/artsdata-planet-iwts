iwts_performer:7905 a schema:PerformingGroup;
  schema:name "Dee Hernandez";
  schema:description "Cuban-born and Atlantic Canada-based, Dee Hernandez fuses Cuban roots, jazz, R&B, and soul into a vibrant, unforgettable sound. A captivating live performer, Dee blends heartfelt storytelling with danceable grooves, showcasing her powerful vocals and dynamic presence. Recognized with East Coast Music Award nominations, she has shared stages at major showcases and events, captivating audiences with her authenticity, charisma, and passion for music that transcends borders.";
