iwts_performer:10187 a schema:Person;
  schema:name "Erikson  Herz";
  schema:description "Erikson is a modern mentalist and magician known for creating impossible moments that feel deeply personal, astonishing, and unforgettable. Blending sharp humor, psychological illusion, masterful sleight of hand, and effortless audience connection, he invites people into an experience where intuition, memory, and coincidence collide. The result is a theatrical journey that leaves audiences questioning what’s real long after the curtain falls.";
