iwts_performer:10005 a schema:PerformingGroup;
  schema:name "The Hausplants";
  schema:description "The Hausplants are an independent post-punk trio from so-called “Vancouver” Canada. An international group, The Hausplants merge influences from their native Iran, Mongolia, and USA. The band was formed in 2022 and their music centres deeply personal storytelling and surreal imagery. They have played over 50 shows and festivals in the Vancouver area and annually organize an Earth Day fundraiser show. They have released two self-produced EPs and are currently working on their debut LP.";
