iwts_performer:1815 a schema:Person;
  schema:name "De La Terra";
  schema:description "De La Terra is Doug Towle performing live looping with Spanish guitar. Building every layer in real time, he transforms a single nylon-string guitar into a rich, rhythmic soundscape — percussion, bass lines, chords, and soaring melodies created live with no backing tracks. Rooted in Spanish and Latin traditions yet modern in feel, De La Terra is immersive, passionate, and completely in the moment. One musician. One guitar. A full sonic experience built from the ground up.";
  schema:url <http://www.delaterra.ca>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
  schema:genre "Global";
  iwts:consent "agree_v_1.0";
