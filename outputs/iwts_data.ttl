iwts_performer:1182 a schema:PerformingGroup;
  schema:name "Tim Isberg";
  schema:description """Veteran soldier Tim Isberg is an accomplished singer-songwriter.  From Rwanda to Afghanistan, Tim experienced the best and worst humanity has to offer.  As a performer, he has entertained audiences in many corners of the world.
Tim is a gifted storyteller bringing a blend of well-crafted Alt-Country Folk songs and life experiences that he shares to make each listener feel connected. 
A multiple award nominee, Tim's latest and acclaimed history-themed album 'Prairie Fire' provides captivating insights into people and events of 1800s Prairies.""";
  schema:url <https://timisberg.com/index.html>;
