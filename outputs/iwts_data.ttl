iwts_performer:10114 a schema:PerformingGroup;
  schema:name "Jeremiah McKinley";
  schema:description "Jeremiah McKinley is an Americana Folk-Rock duo based in North Carolina. Known for their strong vocal harmonies and dynamic live performances, the band combines the storytelling of folk music with the drive and grit of southern rock. Their original songs — including “Juarez, MX,” “Missing Mississippi,” and “Wildflower”— showcase a blend of heartfelt lyrics, electric and acoustic guitartextures, and a rhythmic, foot-driven setup that fills the stage with energy despite their two-piece lineup.";
  schema:url <https://www.jeremiahmckinley.com>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
