iwts_performer:10039 a schema:Organization;
  schema:name "Théâtre Motus";
  schema:description "Launched at the turn of the millennium, Motus celebrated its 20th anniversary in 2021. We have produced 19 original pieces aimed at young audiences, performing them at the regional, national and international levels – racking up more than 2,200 performances here at home, and also abroad, in China, the U.S., Mexico, Spain, France, Switzerland, Mali, Burkina Faso, Ivory Coast, Senegal, Greece and Costa Rica.";
