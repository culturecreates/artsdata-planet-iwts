iwts_performer:9272 a schema:Organization;
  schema:name "BO Montréal";
  schema:description "BO Montréal (Ballet Ouest de Montréal) is a non-profit organization founded in 1984, dedicated to the creation and performance of innovative works based on a classical dance language. Through its 40-year history, the company has presented original ballets and works of repertoire and has welcomed countless dancers, choreographers, creators, and collaborators onto its stage.";
