iwts_performer:8105 a schema:PerformingGroup;
  schema:name "Jazz Legacy Project";
  schema:description "Created in 2015 after an epiphany Justin Varnes had while teaching a college Jazz History course, the Jazz Legacy Project combines education with entertainment. Each show features compelling stories about the artists and their influence on American music and culture woven in between authentic performances of popular jazz songs designed to engage casual audiences. It's a jazz concert and music appreciation class in one.";
