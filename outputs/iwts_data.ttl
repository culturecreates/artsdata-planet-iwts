iwts_performer:9368 a schema:PerformingGroup;
  schema:name "The Lonesome Town Painters";
  schema:description "The Lonesome Town Painters are a tried-and-true, bona fide bluegrass band hailing from Vancouver.  These fellas have a look, style and sound that harkens back to the raw and ragged edge of the genre. And while they draw deeply from the masters of the golden era, it’s their original songs that demonstrate just how far these fellas have come. Their songwriting is grounded in tradition, anchored by the soaring harmonies, melodic instrumentation and pushing drive that has come to define their spirited and highly entertaining performances.";
  schema:url <https://www.lonesometownpainters.com/>;
