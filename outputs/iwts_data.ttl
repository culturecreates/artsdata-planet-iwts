iwts_performer:10137 a schema:PerformingGroup;
  schema:name "WHITNEY: ONE MOMENT IN TIME: Crystal Stark Celebrates Whitney Houston";
  schema:description "International entertainer and American Idol semi-finalist Crystal Stark is a powerhouse performer and University of Arizona alumna. After touring with Katharine McPhee and appearing on Ellen, she became a premier headliner, sharing stages with icons like Jon Batiste and performing for Barack Obama. Her celebrated tribute shows thrill global audiences. Also a dedicated educator, Crystal founded Crescendo Vocal School. Based in Arizona, she was recently named “Best Jazz Performer.” She resides with her husband and two sons.";
  schema:url <https://www.epicartsmanagement.com/whitney-one-moment-in-time>;
