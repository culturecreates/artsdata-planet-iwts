iwts_performer:9729 a schema:PerformingGroup;
  schema:name "Christine Tassan and Marie-Veronique Bourque";
  schema:description """Flutist Marie-Véronique Bourque and guitarist Christine Tassan are two artists who stand out for their impressive solo careers, both in Canada and internationally. In 2018, their paths and since then, they have performed together on multiple occasions, either as a duo or with various groups.
In May 2023, they decide to join forces in a new project inspired by the natural sounds of Quebec and Saskatchewan, where Christine and Marie-Véronique reside, respectively. The album Bruissement boréal came to life and will be released in May 2025.""";
  schema:url <https://christinetassan.com/marie-veronique-bourque-christine-tassan/>;
