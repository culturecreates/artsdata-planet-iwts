iwts_performer:9568 a schema:PerformingGroup;
  schema:name "Loud in the Pines";
  schema:description "Loud in the Pines is an Edmonton-based indie-folk duo whose songs will transport you from the wide open prairies to the forests and cliffs they dream about. Musicians Spencer Taubner (vocals, guitar) and Kelin Flanagan (vocals, keys) deliver bittersweet, emotional music with seamless vocal harmonies and layered sounds. With a focus on thoughtful storytelling in cinematic settings, their approach to songwriting is heart-forward. Their debut full-length record, Every Colour Left, is out in May 2025 with support from the Edmonton Arts Council.";
  schema:url <https://loudinthepines.com>;
