iwts_performer:9345 a schema:Person;
  schema:name "Celeste (Joshua Holloway)";
  schema:description """Celeste is the cherished drag creation of Nanaimo-based musician, Joshua Holloway. A timeless queen from the silver screen, Celeste is inspired by history’s iconic Hollywood dames: Barbra, Judy, Julie, and Liza. 

A graduate of VIU’s esteemed Jazz Program, Celeste is delighted to bring her live vocals to every performance, subverting audiences’ expectations of drag, and connecting with each crowd in an unforgettable way. 

She recently starred in Dandy’s “Happiest Drag Show on Earth” at The Rio Theatre in Vancouver.""";
  schema:url <https://www.joshuahollowaymusic.com/>;
