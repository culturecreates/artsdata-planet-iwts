iwts_performer:8548 a schema:PerformingGroup;
  schema:name "Audrey Gaussiran";
  schema:description "Through a poetic and socially engaged lens, Audrey Gaussiran creates hybrid works merging flamenco, contemporary, Latin, and urban dance with digital art. Her choreographies address pressing global themes such as migration, identity, environment, social inertia and conflict. From stage to in-situ performances, her creations invite audiences into immersive experiences that bridge emotion, reflection, and social awareness.";
