iwts_performer:9742 a schema:Person;
  schema:name "Tong Wang";
  schema:description "To witness pianist Tong Wang in performance is to venture into a vivid soundscape intersecting eras, cultures, and moods. With a flair for blending classical technique with compelling narrative, Wang has developed a reputation for themes that surprise and intrigue.  Recognized for both technical skill and innovative programming, her programming spans experiences ranging from a tranquil garden setting to explorations of cultural differences.";
