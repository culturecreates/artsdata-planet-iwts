iwts_performer:8232 a schema:PerformingGroup;
  schema:name "Aretha! A Tribute To A Queen!";
  schema:description "ARETHA! A Tribute to a Queen is a high-energy celebration of the legendary Aretha Franklin starring powerhouse vocalist Candi “Sugafoot” Herbin. With electrifying presence and roots in soul, gospel, and R&B, Candi brings Aretha’s spirit to life. This 90-minute live production features a dynamic band and iconic hits like “Respect,” “Natural Woman,” “Chain of Fools,” and gospel classics that honor the Queen of Soul’s timeless legacy.";
