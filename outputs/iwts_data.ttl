iwts_performer:9850 a schema:Person;
  schema:name "Paul Lee Kupfer";
  schema:description "Paul Lee Kupfer is an Americana, folk and country-blues musician and songwriter who has released two solo albums of original material, Where the Wind Goes and Mind Wanderer, as well as two albums as a member of the band The Bus Driver Tour. He has shared the stage with Taj Mahal, Watchhouse, The Carolina Chocolate Drops and numerous other luminaries of the folk music scene. Originally from the Appalachian Mountains of West Virginia, Kupfer actively tours the US, while based out of Knoxville, Tennessee and Livingston, Montana.";
  schema:url <https://paulleekupfer.com>;
