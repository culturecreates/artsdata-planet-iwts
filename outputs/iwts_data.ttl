iwts_performer:10103 a schema:PerformingGroup;
  schema:name "Das Neue Mannheimer Orchester";
  schema:description "Das Neue Mannheimer Orchester is an international period-instrument ensemble founded by fortepianist and harpsichordist Anders Muskens. Inspired by the legendary Mannheim court orchestra, it revives the vivid sound world of the late 18th and early 19th centuries through historically informed performance, rhetorical expression, and adventurous programming. Its projects bring together scholarship and artistry to reawaken the drama, colour, and emotional immediacy of this repertoire.";
  schema:url <https://www.neuemannheimerorchester.de/>;
