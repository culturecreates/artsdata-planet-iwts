iwts_performer:10210 a schema:Person;
  schema:name "2Moods";
  schema:description """2Moods is a francophone hip-hop artist based in Edmonton, originally from Kinshasa, Democratic Republic of the Congo. Active on the Canadian music scene since 2015, he blends rap, hip-hop, and Afrobeats, delivering poetic and thought-provoking lyrics.

A dynamic performer, he has appeared at various francophone festivals and events across Canada and is also deeply involved in community work, using music as a tool for expression, education, and empowerment.""";
