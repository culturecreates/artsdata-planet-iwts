iwts_performer:10255 a schema:PerformingGroup;
  schema:name "Mike Field";
  schema:description "Jazz trumpeter, composer, and vocalist Mike Field is known for his bright, energetic performances and globe-trotting musical adventures. Whether playing a high-velocity instrumental or a playful world-jazz vocal tune, Mike’s music blends technical brilliance with cultural flair and a sense of fun. He has toured extensively across Canada, the USA, Australia, New Zealand, and Europe - with occasional stops in South Korea, Chile, and Antarctica. Performing original compositions with local musicians at jazz clubs and festivals around the world.";
