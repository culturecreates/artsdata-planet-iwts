iwts_performer:8985 a schema:Person;
  schema:name "Sydney Castillo";
  schema:description "Sydney Castillo is a dynamic stand-up comedian, actor, and writer known for his high-energy performances and sharp, charismatic delivery. Blending clever wordplay, relatable storytelling, and bold social commentary, he pulls audiences into his world where no topic is off-limits. A winner of TBS’s Funniest Wins, Sydney has also appeared in 50 Shades of Black, The League, Real Husbands of Hollywood, Marlon, and was a standout cast member on Wild ’N Out. Whether on stage or screen, Sydney delivers nonstop laughs!";
  schema:url <https://www.2funny.com/talent>;
