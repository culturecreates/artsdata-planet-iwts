iwts_performer:8541 a schema:PerformingGroup;
  schema:name "Will & Seeka";
  schema:description "Will Stroet of Will's Jams is a a nationally celebrated musician, educator and former CBC Kids TV star from Vancouver. Over 20+ years, he has performed 3,000+ shows across Canada with his 12 albums garnering multiple nominations from the JUNOs, WCMAs & CFMAs. Jessica Tyndale of Seeka Sings blends jazz, folk, pop, hip-hop, and Afro-Caribbean rhythms in English and French to foster language development, social-emotional learning and diversity. Her EP, debut album I Belong, and Will & Seeka albums have earned her multiple CFMA & WCMA nominations.";
  schema:url <https://www.pebblestarartists.com/willandseeka>;
