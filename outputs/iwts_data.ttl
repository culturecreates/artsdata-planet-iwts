iwts_performer:9988 a schema:Person;
  schema:name "Sa-Young";
  schema:description """Sa-Young is Afro-fusion artist that makes groovy-music with intention. His sound sits at the edge of Afrobeat and Alté, a style which he calls Afro-Twist.
Rooted in percussive groove, and shaped by storytelling lyrics. His Afro-Twist sound is built for both dancing and reflection.
Within two years, he released two EPs and a run of singles that reintroduced his unique voice and videos to the scene.
Sa-Young now performs with the Tribe Band, delivering a live Afro-Twist experience with energy, musicianship, and presence.""";
  schema:url <https://sa-young.com>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
