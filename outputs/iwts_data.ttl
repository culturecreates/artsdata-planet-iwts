iwts_performer:4528 a schema:Person;
  schema:name "Amanda Panda";
  schema:description "With over a decade of experience, Amanda Panda’s larger-than-life personality and colourful performances are sure to leave a lasting impression! As one of Canada’s top hula hoop artists, she brings joy, inspiration, and laughs to every show. Not just a performer, Amanda is also the author of a children’s book encouraging kids to follow their dreams. Through her business, Hula Hoop Circus, Amanda blends education with entertainment—bringing circus fun and workshops to schools, fairs, festivals and more.";
  schema:url <http://www.hulahoopcircus.ca>;
