iwts_performer:8091 a schema:PerformingGroup;
  schema:name "Larry & Joe";
  schema:description "Larry & Joe is  Venezuelan maestro llanero Larry Bellorín and GRAMMY-nominated Latingrass virtuoso Joe Troop (Che Apalache). Both men are versatile multi-instrumentalists and singer-songwriters on a mission to show that music has no borders. As a duo they perform panamerican folk music on harp, banjo, cuatro, fiddle, maracas, guitar, and upright bass. Their joyful bilingual (eng/esp) program offers a distinct blend of their musical inheritances and traditions as well as storytelling about the ways that music and social movements coalesce.";
