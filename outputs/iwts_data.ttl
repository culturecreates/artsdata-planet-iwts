iwts_performer:6805 a schema:PerformingGroup;
  schema:name "Silver Wolf Band";
  schema:description """Silver Wolf Band is an Indigenous folk-rock band from Labrador. Lively, engaging, and self-assured performances of honest and sincere lyrical music is what makes Silver Wolf Band one of the most in-demand music groups from Labrador. Their music is piano driven and rich in harmony. Lyrically, their songs are shaped and informed by family, community, love, and their homeland itself. 
They've won Music NL’s Indigenous Artist of the Year (2020) and East Coast Music Association’s Indigenous Artist of the Year (2021).""";
  schema:url <http://www.silverwolfband.com>;
