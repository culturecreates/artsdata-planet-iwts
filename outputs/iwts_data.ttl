iwts_performer:711 a schema:Person;
  schema:name "Maria Dunn";
  schema:description "2022 Juno Award winning songwriter Maria Dunn draws deeply on the folk tradition of storytelling through song. Melding North American roots music with her Scottish-Irish heritage, she sings about the resilience and grace of ordinary people, past and present. Along with multimedia shows Packingtown, GWG: Piece by Piece, On The River, Troublemakers (with Ground Zero Productions), Maria's 2022 Juno-winning album Joyful Banner Blazing celebrates gratitude, solidarity, joy and the love that fires our actions to make the world a better place.";
  schema:url <http://www.mariadunn.com>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
