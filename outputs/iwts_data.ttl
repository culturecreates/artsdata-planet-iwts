iwts_performer:9411 a schema:Organization;
  schema:name "Vancouver Inter-Cultural Orchestra";
  schema:description "The Vancouver Inter-Cultural Orchestra, founded in 2001, was one of the first professional concert orchestras devoted specifically to performing new intercultural music. It is currently the only ensemble of its kind in Canada, and one of only a handful that exist in the world. The VICO serves together musicians and composers from many cultural and artistic communities in the Greater Vancouver area, including Chinese, Taiwanese, Japanese, Indian, Persian (Iranian), Latin and South American, Vietnamese, African, North American and European.";
  schema:url <https://vi-co.org/>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
