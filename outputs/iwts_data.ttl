iwts_performer:1169 a schema:PerformingGroup;
  schema:name "Derina Harvey Band";
  schema:description "Winners of an East Coast Music Award for “Fan’s Choice Entertainer of the Year” in 2024, and nominated for two Canadian Folk Music Awards in 2025, the Derina Harvey Band has built an international reputation and loyal following with their popular recordings - a fusion of folk and Celtic rock - and authentic, heartfelt performances. Their live show features Derina's vibrant stage presence and powerhouse vocals - a dynamic performance during which storytelling drops the room to a hush, and shanties have the crowd hollering from their seats!";
  schema:url <http://www.derinaharvey.com>;
