iwts_performer:9624 a schema:PerformingGroup;
  schema:name "Mafa Makhubalo";
  schema:description "Rooted in contemporary dance practices that honour South African culture and the ancestral wisdom embedded in our work, MDV prioritizes storytelling and cultural reclamation. Since our inception in 2014, we have continuously evolved, strongly emphasizing developing robust leadership and sustainable operational strategies that amplify our capacity to serve and engage the communities around us. MDV functions as a vehicle for creating choreographic work that is culturally grounded, reflective, and resonant.";
  schema:url <https://www.mafadancevillage.ca>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/DancePerformance>;
  schema:genre "Traditional";
