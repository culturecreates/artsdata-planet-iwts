iwts_performer:10156 a schema:PerformingGroup;
  schema:name "Cara Lianne McLeod";
  schema:description """Cara Lianne McLeod captivates audiences with her disarmingly joyous and meaningful approach to music, whether she's performing in a jazz club, on a recital stage, or in a studio. 
With an album in the works, her current discography ranges from pop to blues. 
After a sold-out debut at Yardbird Suite in January 2025, Cara returned in March, where she was joined by some of Edmonton’s finest musicians, and sold out the venue once again.  Cara is also the curator and host of In & Out of Love, an online radio show streaming on Big E Radio.""";
  schema:url <https://caraliannemcleod.com>;
