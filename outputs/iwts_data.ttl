iwts_performer:6915 a schema:Person;
  schema:name "Luca Stricagnoli";
  schema:description "With over 100 million YouTube views, Italy's LUCA STRICAGNOLI has carved a unique niche with his solo show, featuring high-energy instrumental renditions of classic rock and original songs played on a variety of custom acoustic guitars, including the Triple Neck, the Reverse Slide Neck, and the Soprano Guitar.  Luca has designed these special guitars and created the playing techniques that enable him to play multiple melodies and rhythms simultaneously, Luca has transformed his instrumentals into a solo art form all his own.";
