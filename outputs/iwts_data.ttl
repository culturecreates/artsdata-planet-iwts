iwts_performer:10199 a schema:Person;
  schema:name "Mr. Jeff";
  schema:description "Mr. Jeff creates award-winning, silly, fun, and totally original children’s music made by a real teacher! A former preschool educator and multi-instrumentalist, he blends music, movement, and social-emotional learning into high-energy shows and joyful songs kids can’t get enough of. With three award-winning original children’s albums, his music and videos light up libraries, schools, festivals, and homes everywhere. Based in Ohio with his awesome family, Mr. Jeff brings heart, humor, and teaching magic to every song and performance he creates.";
  schema:url <http://mrjeffisfun.com>;
