iwts_performer:9578 a schema:PerformingGroup;
  schema:name "Temporal Taal Collective";
  schema:description "Temporal Taal Collective merges global rhythms, contemporary grooves, soulful vocals, and Kathak dance into an immersive, cross-cultural performance. Their genre-defying style, rooted in tradition yet forward-thinking, captivates audiences with rich rhythmic textures and compelling storytelling. By transcending cultural boundaries, the Collective energizes any stage and invites audiences on a journey of vibrant collaboration.";
