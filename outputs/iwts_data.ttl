iwts_performer:7776 a schema:PerformingGroup;
  schema:name "The Wheat in the Barley";
  schema:description "This is Canadian roots music with a major make-over. Crack songwriting, brilliant and warped arrangements and stunning instrumental solos unite under the banner of a savvy eclecticism that's always been the band's guiding light. The Wheat in the Barley pulls together a lot of great influences into one package: Celtic, Slavic, French Canadian, Yiddish, Cajun and more. With an impressive array of instruments at their command, the band puts on a show that's as danceable as it is listenable.";
  schema:url <http://wheatinthebarley.ca>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
  schema:genre "Traditional";
  iwts:consent "agree_v_1.0";
