iwts_performer:9802 a schema:Person;
  schema:name "Jake Thompson";
  schema:description "Jake Thompson is puppeteer based in St. John's NL. Since 2016 he has been the puppeteer and writer/director behind the hit NTV series, NL Now, a puppet hosted talk & variety show. Jake also performs regularly for live events all across the province of NL, completing his first island wide tour in the summer of 2025. Jake is also known for Adventures of Gary & Lou, a childrens series he wrote and starred in as the lead puppet with Pete Soucy. Jake is the recipient of a Mount Pearl Impact in Music, Arts & Culture Award.";
