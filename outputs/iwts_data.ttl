iwts_performer:9675 a schema:PerformingGroup;
  schema:name "Cultural Crossroads: Dvorak in America";
  schema:description "“Cultural Crossroads: Dvo?ák in America” brings together internationally acclaimed musicians across multiple disciplines who explore the Indigenous and Black influences on Dvo?ák. The world’s premier Native flutist, R. Carlos Nakai, and his award-winning percussionist Will Clipman, are joined by Kenneth Kellogg, a leading bass with major opera companies, who sings moving spirituals. Duke University’s own Ciompi Quartet weaves in Dvo?ák’s most beloved chamber music. The show is the brainchild of violist and narrator Pamela Freund-Striplen.";
  schema:url <https://www.marianliebowitz.com/specialtyculturalcrossroads>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
