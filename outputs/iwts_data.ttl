iwts_performer:7408 a schema:PerformingGroup;
  schema:name "The Hello Darlins";
  schema:description """Led by Romani-Canadian musician, Candace Lacina and keyboardist Mike Little, The Hello Darlins are some of Canada’s most in-demand professional session & touring musicians who came together to forge a distinct hybrid of traditional country, gospel and blues.

With millions of streams and three Canadian Folk Music Awards nominations, The Hello Darlins took the show on the road for 187 days in 2023-2024, showing that the band sounds just as powerful on stage as it does in the studio.""";
