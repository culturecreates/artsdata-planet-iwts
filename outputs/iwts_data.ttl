iwts_performer:698 a schema:PerformingGroup;
  schema:name "Huu Bac Quintet";
  schema:description """Composer and multi-instrumentalist, Huu Bac Quach founded his quintet in Montreal, combining his Vietnamese and Chinese heritages with Jazz music. Backed by a solid team of some of the most prominent musicians on the Montreal jazz scene, Huu Bac performs his original music inspired by his numerous travels in Asia, Europe, and South America. 

Audiences are charmed by the beauty and intensity of his work and by his mastery of the dan bau (Vietnamese one-string zither), the erhu (Chinese fiddle), the quena (Andean flute), and the jazz guitar.""";
  schema:url <http://huubac.com>;
