iwts_performer:9737 a schema:Person;
  schema:name "Dave Gunning";
  schema:description "With 14 albums to his name, Nova Scotian folk artist Dave Gunning is known for his masterful songwriting, heartfelt storytelling, and razor-sharp wit. A captivating performer, he’s shared stages with legends like Rita MacNeil and Stompin’ Tom Connors, and continues to champion the underdog through songs rooted in community, history, and social conscience. Whether tackling tough issues or making audiences laugh, Gunning’s connection with listeners runs deep—folk music is simply how he sees the world.";
  schema:url <https://www.davegunning.com/>;
