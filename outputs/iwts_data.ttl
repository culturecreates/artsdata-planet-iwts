iwts_performer:9902 a schema:PerformingGroup;
  schema:name "Vincent Bird";
  schema:description "Vincent Bird (Salish-Kootenai) hails from the Flathead Indian Reservation. His music melds the pulse of hip hop with a Native country twang that is impossible to sit still to. Vincent's debut album, produced by Grammy winning producer lophiile,  is scheduled for release in late summer of 2026.";
