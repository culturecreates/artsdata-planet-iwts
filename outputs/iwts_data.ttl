iwts_performer:9835 a schema:PerformingGroup;
  schema:name "Ever Sweet";
  schema:description "Ever Sweet is a dynamic folk duo from Newfoundland and Labrador, made up of Jordan Harnum and Joelle Sunshine. Combining harmonized vocals and acoustic melodies, they bring the rich traditions and stories of their home province to life. Their music reflects the rugged landscapes and coastal communities of Newfoundland, drawing on themes of family, the sea, and rural life. They are currently on a national tour of Canada, sharing their music with new audiences across the region.";
