iwts_performer:9566 a schema:PerformingGroup;
  schema:name "Sam Williams";
  schema:description """Grandson of country pioneer Hank Williams and son of outlaw legend Hank Jr., Sam Williams carries the torch of his family's musical legacy while forging his own path as a
proud member of the LGBTQ community—an important voice in a genre that has often lacked representation. With a distinctive voice and an authentic songwriting style, he
blends gut-wrenching honesty with raw vulnerability and deep empathy. Sam’s performance can scale up to full band or scale down to duo acoustic.""";
