iwts_performer:9490 a schema:Person;
  schema:name "Jeff Corle";
  schema:description """When economic circumstances forced him to shut down his 4th generation dairy farm and to sell his beloved Guernsey cows, Jeff Corle was left heartbroken and depressed.  In the midst of that heartache, he turned to his guitar for comfort and relief and through tears wrote the song that would forever change his life, Empty Barn.   
Now with millions of social media views and legions of fans, Corle uses his original songs, storytelling, and a bit of well-timed farmer humor to tell his unlikely but true tale of going from cows to country music!""";
  schema:url <https://jeffcorlemusic.com/>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
  schema:genre "Spoken Word";
  iwts:consent "agree_v_1.0";
