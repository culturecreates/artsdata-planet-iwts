iwts_performer:10032 a schema:Person;
  schema:name "Levi Taschuk";
  schema:description "Levi Taschuk is a 28 year old singer-songwriter based in the small town of Salmon Arm, BC. His influences range from Bach to Brahms; Chet Baker to Stevie Wonder; Nick Drake to Sibylle Baier; Coldplay to Radiohead; and the list goes on. In 2024 he had the opportunity to spend a week in New York, recording a three-track EP. Taschuk then began work on his forthcoming, debut LP, Dyna Dyvest, in May 2024, finishing the recording process about a year-and-a-half later.";
  schema:url <https://levitaschuk.bandcamp.com/album/times-pearly-wounds>;
