iwts_performer:9377 a schema:PerformingGroup;
  schema:name "Chic Chameleon";
  schema:description """Patrick Froese is a multi-instrumentalist and producer from Edmonton, Alberta. Since 2019, Chic Chameleon has helped him express his musical and melancholic consciousness.
Specifically, Patrick draws melodic inspiration from both dream pop and shoegaze; he uses lush reverbs, cascading delays, and syrupy chorus tones to shade his aural textures.
Currently, Patrick is in the midst of releasing a debut album and gearing up for a release show in early 2025. The fourth single for the album, “Head Against The Floor” was released November 29, 2024.""";
  schema:url <https://www.chicchameleon.com>;
