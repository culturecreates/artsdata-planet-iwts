iwts_performer:9376 a schema:Person;
  schema:name "Scot N. Moir";
  schema:description "Scot Moir is a up and coming Manitoban writer and oral storyteller, specializing in traditional folktales, fairytales, and original stories. His stories are always told imaginatively in the moment, never recited, so that each time is its own unique, intimate event shared between teller and hearers. Infused with passion and humour, audiences will laugh and love their way through each and every story. . As one audience member remarked after seeing the show, “tonight felt more like an evening in a friend’s home than going to the theatre.”";
  schema:url <https://www.lookingglasstheatre.ca/dreamtime-theatre>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/TheatrePerformance>;
