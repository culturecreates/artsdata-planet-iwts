iwts_performer:10314 a schema:PerformingGroup;
  schema:name "Vinyl Velocity starring Drew Pournelle";
  schema:description "Vinyl Velocity is a dynamic live concert experience starring creator and frontman Drew Pournelle celebrating the golden age of vinyl with a powerful mix of pop/rock anthems, smooth yacht rock grooves, high-energy chart-toppers, and unforgettable epic ballads. Vinyl Velocity delivers a nonstop ride through the soundtrack of a generation with hits from Chicago, Toto, Journey, Foreigner, Three Dog Night, Phil Collins, The Doobie Brothers, Hall & Oates, and more! Vinyl Velocity is your ticket to relive the music that defined decades.";
