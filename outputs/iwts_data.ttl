iwts_performer:9197 a schema:PerformingGroup;
  schema:name "The Unfaithful Servants";
  schema:description "The Unfaithful Servants are a standout West Coast acoustic act acclaimed for explosive instrumentals, rich storytelling, and powerful vocals. Praised for their tight harmonies and exceptional musicianship, the band has earned major festival recognition and a Canadian Folk Music Award nomination. Their latest album, Fallen Angel, is charting nationally and internationally on folk music charts. Recent highlights include performing at the IMBA Awards Showcase and touring with multi-Juno Award winning artist Shari Ulrich, filling theatres across BC";
