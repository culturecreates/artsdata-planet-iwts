iwts_performer:9848 a schema:Person;
  schema:name "Puddy Waters";
  schema:description "Canadian/Indigenous indie artist Puddy Waters, from the Kitselas community in Terrace, BC, is a contemporary songwriter working between reflection and release. Blending poetic imagery with emotionally raw lyricism, their songs explore love, loss, contradiction, and personal growth. Rooted in introspection and a deep connection to land and memory, each song feels less like a performance and more like an unfinished, honest conversation.";
  schema:url <https://www.instagram.com/puddywaters/?hl=en>;
