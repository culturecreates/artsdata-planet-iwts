iwts_performer:9594 a schema:PerformingGroup;
  schema:name "HAIDEE";
  schema:description "HAIDEE, a rising pop artist from the Philippines, found refuge in music after moving to Edmonton. Passionate about representation as a woman of color, she crafts heartfelt pop inspired by Ariana Grande and Whitney Houston. A household name in Alberta, she’s performed at JUNOFest, Starlite Room, The King Eddy, and more. Her debut album, *This Shouldn't Be Typical*, won the 2024 Edmonton Music Prize. With her powerful vocals and passion, HAIDEE is poised for a bright future in music.";
  schema:url <https://www.haidee.ca/>;
