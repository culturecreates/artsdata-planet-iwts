iwts_performer:6515 a schema:Person;
  schema:name "Beppie";
  schema:description "Stephanie Nhan (Beppie) is a family entertainer who has released seven children's albums earning two JUNO nominations (2023 & 2019) and a Western Canadian Music Award (2023). She has been a finalist in the International Songwriting Competition multiple times and was an honored recipient of the 2023 Edmonton Arts Trust Fund Award. In 2022, Beppie signed a distribution deal with Platoon (Apple Music). Beppie's multi-genre family music has been featured on radio stations and playlists worldwide reaching over a million streams on Spotify in 2024.";
