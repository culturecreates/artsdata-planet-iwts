iwts_performer:9656 a schema:PerformingGroup;
  schema:name "Cavatina Duo";
  schema:description "The Cavatina Duo—flutist Eugenia Moliner and guitarist Denis Azabagic—is one of the world’s leading flute and guitar duos. Acclaimed for their virtuosity and artistry, they’ve performed in top venues worldwide and expanded the repertoire through nearly 30 commissions. Their discography includes 11 albums, most recently River of Fire with the GRAMMY-winning Pacifica Quartet. They serve on faculty at UIC and direct festivals in Spain and Chicago.";
