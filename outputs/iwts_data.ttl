iwts_performer:10258 a schema:PerformingGroup;
  schema:name "Scott Nolan";
  schema:description """Scott Nolan is an acclaimed Folk/Roots songwriter, poet, multi-instrumentalist, visual artist and producer from Winnipeg, Manitoba, Treaty One Territory. Releasing 9 albums since 2005, including 2023’s 'Before Tonight', which topped the Folk Charts in Canada for several weeks.

Scott is known for his spellbinding, intimate performances based on evocative, poetic lyrics coupled with deft melodies and arrangements.  He is adept at performative and instructional songwriting workshops.""";
