iwts_performer:10093 a schema:Person;
  schema:name "Brendan Ian Cook McLeod";
  schema:description "Brendan McLeod is a writer, theatre creator, and musician. He’s the author of a poetry collection, Friends Without Bodies, a novel, The Convictions of Leonard McKinley, and seven theatre shows, including Ridge, his award-winning musical on the Battle of Vimy, and Brain, his comedic monologue on consciousness. His folk group The Fugitives has been nominated for a JUNO, as well as multiple Canadian Folk Music Awards, including Best Roots Group, Best Songwriter, and Best Vocal Group.";
