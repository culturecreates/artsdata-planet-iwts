iwts_performer:7346 a schema:PerformingGroup;
  schema:name "Jackie K  - Musician";
  schema:description "From North Battleford, Jackie K is an artist with a passion for music and storytelling. Drawing inspiration from the prairies and its people, Jackie’s music is infused with their spirit. Jackie has found her voice as a singer/songwriter, captivating audiences with her storytelling. Jackie received SCMA nominations in 2024 for Alt Country Album of the Year and  Keyboard Player of the Year. Jackie performs regularly with her husband Tom Kroczynski, and was nominated for Music Professional of the Year at the 2023 Saskatchewan Music Awards.";
