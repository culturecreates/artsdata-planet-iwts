iwts_performer:8827 a schema:PerformingGroup;
  schema:name "Jed and the Valentine";
  schema:description "Edmonton's Jed and the Valentine are a pair of dreamers, following threads of inspiration from weaving coastlines to prairie grasses and mountain ridges. Their soaring harmonies, glimmering banjo and guitar and richly melodic riffs weave a sun-dappled, charming indie-folk that feels like wind rushing through a car window while you sing your heart out on the highway.";
  schema:url <https://jedandthevalentine.com>;
