iwts_performer:7992 a schema:PerformingGroup;
  schema:name "Jacquie Daniels";
  schema:description "Jacquie Daniels, 2024 Nashville Josie Awards Songwriter of the Year & 2023 Female Vocalist & Entertainer of the Year (NACMAI), is a Cree-Métis outlaw country artist from Spruce Grove, Alberta with deep roots in the Red River Settlement. Horn-driven & story-first, her sound blends Waylon grit, Dolly shine & cinematic fire. A 2025 Edmonton Artists’ Trust Fund recipient, 11-time Josie nominee & official Country Music Alberta Group of the Year nominee, Jacquie delivers a neon-lit, whiskey-soaked live show that’s fearless, raw & built to linger.";
  schema:url <https://www.jacquiedanielsmuzic.com/>;
