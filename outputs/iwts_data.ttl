iwts_performer:9055 a schema:PerformingGroup;
  schema:name "Jordyn Pollard";
  schema:description "Born in the land of the living skies and wide-open spaces of Saskatchewan, country artist Jordyn Pollard is imbued on the prairie ethos of hard work and humility. Pollard was SCMA Humanitarian of the Year (2024), Emerging Artist (2020) and a 3X SaskMusic Country Artist of the Year nominee. Working with Juno award-winning producer Barter McKay and earning her first Top 40 country radio single at the age of 18, Jordyn is proving to be a bright light in the country scene across Canada. Her sophomore EP, Upside of Being Down, was released in 2025.";
  schema:url <https://www.jordynpollard.com/>;
