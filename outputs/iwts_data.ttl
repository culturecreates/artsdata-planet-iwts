iwts_performer:8181 a schema:PerformingGroup;
  schema:name "Rini";
  schema:description "Blending South Asian roots with the pulse of modern jazz and electronic music, Chennai-born and NJ-based violinist, singer, and composer Harini “Rini” Raghavan defines the sound of Indian Jazztronica. A Berklee alumna grounded in her Indian Classical heritage, Harini draws from her life in the US to create a sonic bridge between her two homes. Leading a collective of acclaimed musicians, she crafts an organic evolution of tradition meeting the global stage.";
