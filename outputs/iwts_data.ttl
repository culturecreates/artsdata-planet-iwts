iwts_performer:9889 a schema:Person;
  schema:name "Adrienne Levay";
  schema:description "Adrienne Levay is a rural, Alberta-based pop-folk songwriter and storyteller whose music blends honest lyrics with memorable melodies. Rooted in reflection and connection, her songs explore the quiet truths of being human—grief, growth, hope, and change—with warmth and clarity. Adrienne’s performances create space for people to really listen, whether she’s playing a house concert, a listening room, or a small stage.";
