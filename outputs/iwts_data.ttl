iwts_performer:616 a schema:PerformingGroup;
  schema:name "Sultans of String";
  schema:description "This multi-award-winning, 3x Juno-nominated and Billboard charting band creates “energetic and exciting music from a band with talent to burn!” (Maverick, UK). For more than a decade, Sultans of String have thrilled audiences with their genre-hopping passport of Celtic reels, Flamenco, Django-jazz, Arabic, Cuban and South Asian rhythms. The group celebrates musical fusion and human creativity with warmth and virtuosity, with world rhythms that excite audiences to their feet!";
