iwts_performer:6954 a schema:PerformingGroup;
  schema:name "Admiral Radio";
  schema:description "Admiral Radio, the award-winning folkgrass act from South Carolina, is the creative partnership of Coty Hoover and Becca Smith. Named after their old wooden radio, this husband-and-wife team blends harmony, storytelling, and raw sincerity. Having met while waiting tables in the Lowcountry, their sound is straightforward yet powerful—exploring the quiet hustle and dogged optimism of everyday life. Recently signed by Too Fine Records out of Nashville, this national touring act aims to leave listeners better than they found them.";
  schema:url <http://www.admiralradiomusic.com>;
