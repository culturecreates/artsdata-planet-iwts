iwts_performer:9324 a schema:PerformingGroup;
  schema:name "Jonathan Dely";
  schema:description "With credits including Lincoln Center and SFJAZZ, trumpeter Jonathan Dely performs one of jazz's most extraordinary live concerts with a band of the world's best musicians at his back. Interweaving musical styles of jazz, rock, classical, and more and drawing frequent comparisons to superstars Chris Botti and Wynton Marsalis, Dely reshapes what a live concert can be, capturing eyes and ears not only for his talent and charisma, but for the story that animates his career: turning down a lucrative career on Wall Street to become a touring Artist.";
  schema:url <https://www.jonathandely.com>;
