iwts_performer:9540 a schema:Person;
  schema:name "Sean Bougie Guitar";
  schema:description "Sean Bougie is an Indigenous classical guitarist from Saskatoon, Saskatchewan who has been playing for over 20 years. This long history with the instrument has allowed Sean to curate an interesting collection of classical guitar repertoire to perform at various festivals and events around Western Canada including the Haywire Farm Festival and the Sasktel Saskatchewan Jazz Festival. Sean's performances make jaws drop, hearts flutter, and minds wander. He was awarded Best Instrumental or Ambient Artist for the 7th Saskatchewan Music Awards.";
