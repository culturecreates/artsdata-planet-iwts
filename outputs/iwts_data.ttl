iwts_performer:10179 a schema:PerformingGroup;
  schema:name "Amanda King's ELLA the Early Years";
  schema:description "Amanda King's ELLA the Early Years is a swinging tribute to the iconic 'First Lady of Song,' Ella Fitzgerald, that captures the elegance and energy of Harlem's Golden Age of Jazz. A captivating vocalist, music historian and engaging storyteller, Fitzgerald's early career, from humble beginnings to her rise with the Chick Webb Orchestra, are traced through timeless jazz classics and rare gems, delivered by a voice critics hail as being \"blessed with Ella's perfect intonation.\"  Features a trio, up to 10-piece band with horn section.";
  schema:url <https://724talent.com/amanda-king-ella-the-early-years-2/>;
