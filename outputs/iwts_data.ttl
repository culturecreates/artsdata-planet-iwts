iwts_performer:9587 a schema:Person;
  schema:name "Trigg Watson - magic for the future";
  schema:description """Trigg Watson is a new breed of magician. He prefers his iPad to a deck of cards. He likes robots more than rabbits. He has wowed audiences from London to Las Vegas with his tech-infused magic, not to mention his TV appearances on Penn & Teller’s Fool Us, Masters of Illusion, and America’s Got Talent. Trigg’s modern stage magic performances blend original stage illusions with interactive
elements to create a high-impact theatrical experience not easily forgotten. You'll rediscover the magic of the modern world and laugh along the way.""";
  schema:url <https://triggmagic.com/>;
