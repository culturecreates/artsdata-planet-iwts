iwts_performer:7034 a schema:Organization;
  schema:name "SQx Dance Company";
  schema:description """SQx is based on the unceded territories of the Sinixt, Syilx & Ktunaxa peoples in British Columbia (BC)'s Slocan Valley (8 hrs drive from Vancouver, BC). 

Our mission is to use dance to promote kinship, collaboration & teamwork. Through contemporary dance performances & education programs, we blend art, culture & social change.

Our work engages vulnerable populations, particularly those who are systemically underserved or facing inequities. Our work recognizes the systemic barriers that prevent people from fully participating in society.""";
  schema:url <http://sqxdance.org>;
