iwts_performer:9794 a schema:Person;
  schema:name "Joel Strauss";
  schema:description "Joel Strauss is a solo Indie artist from Fredericton, NB, blending Indie Rock, Americana, and Retro Rock into a distinctive style. Influenced by Oasis, The Tallest Man On Earth, Smashing Pumpkins, Radiohead, and The Black Keys, his music combines raw emotion, soaring melodies, and bold, textured instrumentation. Described as having 'a voice that could stand out in crowds of thousands' (The East Mag), he pairs his musical vision with striking visuals, creating his own album artwork as an accomplished Watercolour Painter.";
  schema:url <https://www.joelstrauss.bandcamp.com>;
