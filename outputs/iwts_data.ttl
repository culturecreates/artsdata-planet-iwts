iwts_performer:6515 a schema:Person;
  schema:name "Beppie";
  schema:description "Stephanie Nhan (Beppie) is an Alberta based music educator who creates and performs music for families. She has released seven albums earning two JUNO nominations (2023, 2019) and four WCMA nominations (2025, 2023, 2022, 2020), winning the award for Children's Artist of the Year in 2023. She was a recipient of the 2023 Edmonton Arts Trust Fund Award and she signed with Platoon (Apple Music) in 2022. Beppie performs over 70 shows per year at schools, festivals, & events and her music has been streamed over 2 million times.";
  schema:url <https://beppiemusic.com/>;
