iwts_performer:9266 a schema:Person;
  schema:name "David Lane";
  schema:description "Formerly of the Juno-nominated vocal quartet \"Cadence\", David is an internationally touring beatboxer and singer. He has performed in more than 20 countries, appeared on America’s Got Talent, opened for Jay Leno, and his two groups have garnered more than 11 million views on YouTube. As a solo artist, David uses his RC 505 Loopstation to combine vocal experimentations and beatboxing, creating full song arrangements and improvised soundscapes on the fly.";
