iwts_performer:78 a schema:PerformingGroup;
  schema:name "STEVEN TAETZ";
  schema:description "Alberta-born, Toronto-based Steven Taetz writes and performs roots-rock, folk-pop material. Recent touring has included sold-out performances through Alberta including support for Blue Rodeo at Drumhellers Badlands Amphitheatre, and his own shows in Edmonton, Calgary, Red Deer, and across Canada. His 2023's \"Late Bloom\" was nominated for Best Album by Folk Canada, followed by 2024 Christmas album, and 2025's roots-rock project includes collaborations with noteworthy Canadians, and love songs from a queer perspective.";
  schema:url <http://www.steventaetz.com>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
