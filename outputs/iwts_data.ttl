iwts_performer:9569 a schema:Person;
  schema:name "Grant Tilly";
  schema:description "Over the past two decades, Grant Tilly has established a successful career as an actor, writer, and singer/songwriter, performing on stages throughout Canada. He is an award-winning musical theatre writer, with shows like the comedy \"Bingo Ladies\" staged across the country. Tilly released two albums as a singer/songwriter and spent two years performing with the Canadian National Company of \"Jersey Boys\" in Toronto. Recently, he returned to his hometown of Calgary, where he has made a home within the vibrant community of Calgary artists.";
  schema:url <https://granttilly.com>;
