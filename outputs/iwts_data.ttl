iwts_performer:9508 a schema:PerformingGroup;
  schema:name "Special K";
  schema:description """Abby K and Chris Klimecky – two accomplished local songwriters – come together as Special K, a heartfelt musical experience, blending timeless classics with home-spun, original songs.  Abby and Chris light up the stage with their captivating storytelling, melodic harmonies, and toe-tapping grooves.
Abby’s warm vocals and acoustic sound are elevated by Chris’s masterful guitar work, seamlessly woven into every performance.  Abby and Chris bring a special energy, authenticity, and artistry to every note.""";
