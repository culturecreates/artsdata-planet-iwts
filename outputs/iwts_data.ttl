iwts_performer:9468 a schema:Organization;
  schema:name "SQx Dance Company - Second Application";
  schema:description """Our mission is to use dance to promote kinship, collaboration, & teamwork through contemporary dance performances & education programs that blend art, culture, & social change. We present in English & French.  

Based in the unceded territories of the Sinixt, Sylix & Ktunaxa peoples in BC’s Slocan Valley (8 hours drive from Vancouver and Calgary), we target vulnerable populations, engaging those systemically underserved or facing inequities. Our work recognises the systemic barriers that prevent people from fully participating in society.""";
  schema:url <https://sqxdance.org/>;
