iwts_performer:7672 a schema:PerformingGroup;
  schema:name "Munro Patrick Band";
  schema:description "If Munro & Patrick music was the most delectable, hearty pot of stew, it would be a recipe full of all the great musical goodness you can imagine. Their music permeates an aroma rich with roots, rockin’ blues, good old country music, Motown soul, and a sprinkle of jazz. There is no denying deep musical influences & heroes. The brass infused, guitar driven Munro Patrick Band is seasoned with confidence, energy & fiery emotional vocals.  It’s captivating, familiar but fresh, and SO tasty,  you feel it in your guts and it sticks to your insides.";
  schema:url <http://www.munropatrickmusic.com>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
