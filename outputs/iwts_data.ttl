iwts_performer:625 a schema:Organization;
  schema:name "Mocean Dance";
  schema:description "Founded in 2001 and based in Kjipuktuk/Halifax, Mocean Dance is an award-winning contemporary dance company Led by Co-Artistic Directors Susanne Chui and Sara Coffin, Mocean fosters fertile ground for artistic growth and recognized nationally as a leading voice for dance in Atlantic Canada. We share perspectives from our region, create opportunities to engage with the local ecology, and connect to the national performing arts community. Through our work, we aim to strengthen Halifax as a hub for creation, collaboration, and performance.";
  schema:url <http://www.moceandance.com>;
