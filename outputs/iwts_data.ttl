iwts_performer:7344 a schema:PerformingGroup;
  schema:name "Electric Religious";
  schema:description "Electric Religious got his moniker from a Jimi Hendrix quote: “When I get up on stage, that’s my whole life. That’s my religion... I am electric religion.” His latest album, The Taste, straddles pop, rock, and funk – a genre playfully coined as “Métis Disco.\"  Electric Religious has been included twice in the CBC Searchlight Top 100 in recent years, and twice among CKUA’s Top 100 Albums of the year. He has also been honoured with a nomination for Métis Artist of the Year at the Summer Solstice Indigenous Music Awards.";
  schema:url <http://electricreligious.com>;
