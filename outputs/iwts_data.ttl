iwts_performer:6381 a schema:Person;
  schema:name "Terra Spencer";
  schema:description "Raised on the mud banks of the Avon River, Nova Scotian funeral director-turned-songwriter Terra Spencer charms audiences with her cinematic storytelling, deft guitar, gospel piano, butterscotch voice, crackling wit, and wood-paneled warmth. Named the 2026 CFMA English Songwriter of the Year and 2025 Music Nova Scotia Entertainer of the Year, Terra has also caught the eye of collaborators including David Francey, Ben Caplan, and Matt Andersen. Every show is a knee-to-knee conversation with a natural storyteller.";
  schema:url <https://terraspencer.ca/>;
