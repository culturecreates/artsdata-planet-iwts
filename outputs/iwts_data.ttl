iwts_performer:8247 a schema:PerformingGroup;
  schema:name "Ryanhood";
  schema:description "Int'l Acoustic Music Awards winners for ‘Best Group/Duo’, Ryanhood’s tight vocal harmonies & big acoustic riffs have made them favorites on the touring circuit for over 20 years. Merging virtuosic musicianship with rich, transformative storytelling, their shows are driven by strong acoustic guitar interplay & turn-on-a-dime harmonies forged in a decades-long friendship. At turns energetic, hopeful, & quietly moving, Ryanhood offers an invitation to soak in a river of melodies & harmonic hooks; to reflect, laugh, sing, and cheer.";
  schema:url <https://www.ryanhood.com/>;
