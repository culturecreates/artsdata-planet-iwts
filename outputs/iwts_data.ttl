iwts_performer:9991 a schema:Person;
  schema:name "Megan Dolan";
  schema:description """Megan Dolan is a Long Beach based writer | actor | storyteller. 
She has performed at the Moth, Hollywood Fringe Festival, Expressing Motherhood, Untold, and her TEDx talk entitled, Messy Mommy: A Slob in the Shadows can be seen on YouTube.
Her solos show, Not the Right Mom, was chosen to be part of the Amplify series for marginalized voices at the Curtis Theater in Brea, CA before touring nationwide.
Megan is a frequent guest artist at USC, Cal State Northridge, Long Beach City College and her written work was featured in LA Parent Magazine.""";
  schema:url <https://www.nottherightmom.com/>;
