iwts_performer:10299 a schema:PerformingGroup;
  schema:name "Rockabetty";
  schema:description "Rockabetty is a dynamic seven piece group based in Boise, Idaho that features some of the most fun rockabilly hits of female artists from the golden era of that sound, the 40's-60's. We are dedicated to keeping the memories alive of the great female pioneers of Rockabilly music many of whom have been forgotten.  Get ready to get your bobby sox knocked off and make a bee-line for the dancefloor. Rockabetty brings together the best of blues, country, old rock and roll, swing and early R&B with three vocalists and engaging history tidbits!";
  schema:url <https://epkbuilder.com/editor/rockabetty>;
