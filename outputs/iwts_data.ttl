iwts_performer:8672 a schema:PerformingGroup;
  schema:name "Cirque Us";
  schema:description "Based in New England, our circus collective seeks to bring the most passionate, committed, and talented circus artists to the hearts of local communities through a performative or educational lens. Since 2016, Cirque Us has completed 14 tours, produced 7 original shows, partnered with 4 different organizations to host circus camps, has completed in schools residencies and offered over 200 workshops. Cirque Us has is a two time winner of \"Best Circus\" at the International Philadelphia Fringe and winner of \"Best Kids Show\" by the What the Fringe.";
