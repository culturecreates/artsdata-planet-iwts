iwts_performer:10387 a schema:PerformingGroup;
  schema:name "Celtic Roots";
  schema:description "Celtic Roots: A Celebration of Irish & Celtic Music brings the magic of Ireland to the stage with beloved traditional songs, stunning harmonies, and exhilarating Irish dance. Led by acclaimed duo River North (Matt Zaddy & Heather Christine), this uplifting concert features classic and modern Irish & Celtic music, award winning Celtic musicians and championship Irish dance. A joyful, family friendly celebration perfect for the St. Patrick’s season and all year long!";
  schema:url <https://www.celticrootsofficial.com>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/PerformingArtsEvent>;
