iwts_performer:9823 a schema:Organization;
  schema:name "Rooted Dance Projects";
  schema:description """Rooted Dance Projects was founded in 2012 by Kathleen Doherty & Stephanie Mitro. Under the Artistic Direction of Kathleen Doherty since inception, the company is based in Kjipuktuk/Halifax, & is an integral part of the Nova Scotia dance community.

Finding identify in a rooted jazz dance style, the Rooted has become well known for their highly physical, rhythmic, & engaging performances. The company regularly creates, produces & presents work, tours regionally, hosts workshops & classes, engages with youth through the Rooted Youth Project.""";
  schema:url <https://www.rooteddanceprojects.com>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/DancePerformance>;
  schema:genre "Jazz/Blues";
