iwts_performer:10253 a schema:PerformingGroup;
  schema:name "SHe Said";
  schema:description "Jen Ayers is a Seattle-based singer, pianist, songwriter, and playwright whose powerhouse vocals anchor \"SHe Said,\" a critically acclaimed music-driven theatrical work about love, identity, and transformation through one family’s true story. Blending rock, soul-pop, and storytelling, the production premiered in a record-breaking 16-show run at Seattle’s Intiman Theatre. Ayers is joined by an all-star Seattle-based band featuring RL Heyer, Kathy Moore, Richard Davidson, Melissa Montalto, and Geoff Reading.";
