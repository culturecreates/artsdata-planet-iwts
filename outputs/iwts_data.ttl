iwts_performer:10035 a schema:PerformingGroup;
  schema:name "ORIGINZ";
  schema:description "ORIGINZ is a musical collective founded by esteemed hip hop artist Ndidi Cascade, consisting of a crew of acclaimed Canadian hip hop artists.  ORIGINZ artists share musical journeys using rap-poetry, music and dance---Exploring themes of identity, inclusion, anti-bullying, anti-racism, and acceptance.  ORIGINZ artists have performed across Turtle Island and internationally, bringing hundreds of performances and workshops to schools. Every show is rooted in critical thinking, self-reflection, community connection, and absolute fun!";
  schema:url <https://www.ndidicascade.ca>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/PerformingArtsEvent>;
