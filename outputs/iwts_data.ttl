iwts_performer:9558 a schema:Person;
  schema:name "BERLYN";
  schema:description "BERLYN is a Country Music Alberta Youth Horizon Award-winning singer-songwriter, entrepreneur, & cowgirl from Slave Lake. Performing big stages since 13 , she balances farm life with music, releasing two albums & two singles that capture redneck life. She’s opened for artists like Joe Nichols, Drake Milligan, Kim Mitchell, Gord Bamford, & Steven Lee Olsen, earning a 2024 Nashville Josie Music Award nomination. A 2024 Diamonds in the Rough winner and Canadian Music Incubator graduate, Berlyn is relentlessly pursuing her dreams in country music.";
