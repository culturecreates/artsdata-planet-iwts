iwts_performer:9475 a schema:PerformingGroup;
  schema:name "Melyssa Lee with Education Party";
  schema:description """Melyssa Lee writes music that invokes intrigue and vivid imagery - appealing to  the hot and cold sides of the human condition. After experiencing success with her debut acoustic EP, her debut album Treasures dropped in May of 2024; and she was joined for the first time by the band “Education Party”. 

Together, Melyssa Lee and Education Party play heartfelt lyrics amidst a sonic playground that augments the music’s core. Their innovative sound combines folk instruments with fresh and modern Chapman stick, synth and electronic rock elements.""";
  schema:url <https://www.educationpartyband.com>;
