iwts_performer:2722 a schema:Person;
  schema:name "Leland Faulkner";
  schema:description "Leland Faulker is a visionary artist and arts educator who blends profound storytelling with intricate craftsmanship captivating audiences worldwide. His performances—World of Wonder and Dreamcatcher— invite audiences to listen with the heart of a child, the mind of an elder, and the soul of a warrior. Dreamcatcher features traditional Native stories that speak to all of us through the wisdom of indigenous America. Walker Between Worlds is a simplified version of Dreamcatcher for libraries and schools.";
  schema:url <http://www.lelandfaulkner.com>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/ChildrensEvent>;
