iwts_performer:9932 a schema:Person;
  schema:name "Prathyusha Dwibhashi";
  schema:description "Prathyusha Dwibhashi is a Kuchipudi dancer and performer based in Guelph, Ontario. With over two decades of training in India under renowned gurus, she brings precision, expressive storytelling, and a deep respect for tradition to her work. She has performed across India, Dubai, and Canada, sharing the richness of Kuchipudi through vibrant, emotive stage presence and a commitment to preserving and evolving the art form.";
