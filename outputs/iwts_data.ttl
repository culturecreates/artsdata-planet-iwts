iwts_performer:9793 a schema:Organization;
  schema:name "Zuppa";
  schema:description "Based in Halifax, Zuppa is a 27 year old, artist-run, theatre company. We create new works from scratch and premiere them in Halifax before touring them locally, nationally and internationally. These original shows aim to provoke the consideration of new perspectives and ideas. With each project we attempt to do something we don’t know how to do and work with collaborators who bring new life experiences or skill sets to the table. Zuppa, a member of TNS and PACT, began touring in 2004 and has performed throughout Canada, in the U.S. and U.K.";
  schema:url <https://zuppa.works/works/>;
