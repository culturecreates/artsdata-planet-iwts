iwts_performer:10159 a schema:Person;
  schema:name "Jim McCutcheon, guitarist";
  schema:description """With a repertoire ranging from classical guitar masterpieces to original childrens songs, Jim McCutcheon, `The Guitar Man,' has been the ideal choice for many arts presenters for decades. He received the 2017 Ohio Governors Award for the Arts in Arts Education as well as Parents Choice Foundation awards. Holding a BS in Physics and an MM in Music Education, he does workshops and assemblies on the Science of Music as well as the fretted instrument family. 
