iwts_performer:9494 a schema:Person;
  schema:name "Gabriel Dharmoo";
  schema:description "Gabriel Dharmoo’s practice spans interdisciplinary arts, composition, vocal performance, improvisation, drag, and research. His work has been presented across Canada and internationally, earning awards such as the 2017 Jules Léger Prize and a 2018 Opus Award. His 2014 solo show Anthropologies imaginaires won at the 2015 Amsterdam Fringe and 2016 SummerWorks Festival. Blending music, drag, and theatre, his 2022 show Bijuriya has been performed a dozen times in Canada (Montreal, Vancouver, Toronto, Calgary, Kitchener).";
  schema:url <https://www.youtube.com/watch?v=mnbanLzrEQw>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/PerformingArtsEvent>;
