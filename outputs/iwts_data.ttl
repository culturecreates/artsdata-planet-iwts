iwts_performer:9533 a schema:PerformingGroup;
  schema:name "East Side of 2nd";
  schema:description "Aiden Edwards & East Side of 2nd are a high-energy rock ‘n’ roll band from Saskatchewan, made up of two sets of brothers—Aiden and Logan Edwards, plus Kace and Blake Callaghan—along with drummer Evan Ace. Their sound blends classic rock, blues, and country, delivering electrifying performances inspired by The Sheepdogs to Elvis. Known for  there gritty energy, they’ve packed venues and rocked festival stages. Young, hungry, and ready to bring the heat, East Side of 2nd guarantees a show to remember.";
