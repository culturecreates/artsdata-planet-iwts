iwts_performer:9832 a schema:PerformingGroup;
  schema:name "Saint John String Quartet";
  schema:description """Renowned for its musical energy and seamless ensemble work, the Saint John String Quartet has been a cornerstone of the New Brunswick music scene for over three decades. With remarkable versatility, SJSQ collaborates with artists across classical, blues, and rock, continually expanding the boundaries of chamber music.
The SJSQ is celebrated for its contributions to music education and community development in NB. Committed to excellence in artistry and mentorship, the quartet continues to enrich the cultural fabric of their home province.""";
  schema:url <https://www.sjsq.com>;
