iwts_performer:10019 a schema:PerformingGroup;
  schema:name "Marshall Dane";
  schema:description "Marshall Dane is a Canadian country artist known for his powerful voice, energetic live shows, and commitment to accessibility through ASL interpretation at his performances. His music blends modern country with rock influences, delivering anthemic songs and heartfelt storytelling that connect with audiences of all ages. Marshall’s inclusive performances create a dynamic concert experience that brings music to both hearing and Deaf communities.";
