iwts_performer:8264 a schema:PerformingGroup;
  schema:name "TiBert et Douzie";
  schema:description "TiBert and Douzie are a dynamic, multigenerational duo who take audiences on a lively journey through music and storytelling. With fiddle and turntable, Douzie reimagines traditional Métis tunes with a modern twist. Beside him, TiBert, Franco-Manitoban storyteller and juggler, adds jaw harp, percussion, and audience interaction. Rooted in Manitoba’s French-Métis culture, they bring an infectious joie de vivre that gets everyone dancing.";
  schema:url <https://www.tibertetdouzie.ca>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
