iwts_performer:9616 a schema:Person;
  schema:name "Rachel Colman";
  schema:description """Rachel’s music offers peace while addressing life’s experiences with rare honesty. Her songs, both worship-focused and songwriter-style, reflect the fullness of the human experience and where God meets us.
After decades leading church worship, Rachel was inspired by personal grief to share the richness of her faith journey through songwriting. Her self-produced album, Make A Way, released in 2024, moves from lament to gratitude, following the pattern of the Psalms. The title track boldly prays, “Make a way, and help us to walk in it.”""";
  schema:url <https://rachelcolmanmusic.com/>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
