iwts_performer:9922 a schema:PerformingGroup;
  schema:name "Ahead by a Century";
  schema:description """Ahead By A Century is a group of seasoned musicians with decades of experience in a variety of genres from classic rock to blues to metal to country to jazz and lots in between. Based in Edmonton, Alberta, they come together to authentically pay homage to the iconic Canadian band – The Tragically Hip.

They replicate the Hip’s sound with precision, paying attention to the tone, timing, and studio arrangements.

Ahead By A Century blends musical accuracy, the iconic look, stage energy, with a deep respect for The Tragically Hip's legacy.""";
  schema:url <https://www.aheadbyacentury.ca>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
  schema:genre "Rock";
  iwts:consent "agree_v_1.0";
