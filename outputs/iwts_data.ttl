iwts_performer:10017 a schema:Person;
  schema:name "Chloé Dumoulin";
  schema:description "Named one of CBC’s “30 under 30,” pianist Chloé Dumoulin is a leading artist of her generation. Praised for her sensitive playing and \"impressive command of sonority,\" she performs internationally at venues like Carnegie Hall. A soloist with the Orchestre Métropolitain and Orchestre symphonique de Laval, she will debut with the Orchestre Symphonique de Drummondville in 2026. A 2025 Guildhall School graduate, her debut album, Nouveau lyrisme, was released by Leaf Music in June 2025.";
  schema:url <https://www.chloedumoulinpiano.com/en>;
