iwts_performer:9865 a schema:Person;
  schema:name "Jennifer McLeish-Lewis";
  schema:description "My work straddles traditional training and the ephemerality of improvisation. I am keen to destroy the artificial separations between dance and other forms of live performance by melding dance with singing, live instruments and acting. Cross-pollination and collaboration between different performance forms are crucial to my work. In my choreographic process I create strong characters using the dancers’ multi-disciplinary skills, capturing the audience’s attention in an accessible and captivating way to bring the public into the worlds I create.";
  schema:url <https://wolverine-triceratops-khd3.squarespace.com/>;
