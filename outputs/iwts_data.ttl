iwts_performer:8950 a schema:PerformingGroup;
  schema:name "Noel & Maria";
  schema:description "Noel Freidline and Maria Howell define chemistry. Musically, these North Carolina-based artists breathe as one, communicating almost telepathically as they explore and re-interpret some of the best music of the last 80 years. Noel and Maria have made a name for themselves as they offer listeners something they have heard, but in a way that they have never heard before. Combine this fresh musical approach with a rapport and witty \"Rat Pack\" banter and you have Noel and Maria in their element: on stage, thrilling an audience at every turn.";
  schema:url <https://www.noelandmarialive.com>;
