iwts_performer:9868 a schema:PerformingGroup;
  schema:name "John Wort Hannam Trio";
  schema:description "JUNO-nominated John Wort Hannam spins song writing gold from the chaff of the lives he has encountered and those imagined. Recently appointed Alberta’s Artist-in-Residence and won thre Canadian Folk Music Awards. Add to this, two of the finest instrumentalists – Denis Dufresne on fiddle and mandolin and Jason Valleau on upright bass - and you have brotherly, three-part harmonies, blistering solos, and authentic lyrics. It’s easy to see why audiences and critics alike hear something special in this trio’s narrative, lyrically driven songs.";
  schema:url <https://www.johnworthannam.com>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
