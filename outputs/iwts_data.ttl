iwts_performer:9365 a schema:Organization;
  schema:name "Ragamuffin Productions";
  schema:description "Ragamuffin Productions was created in 2019 in Vancouver, British Columbia by Ashley Chodat, Christian Krushel, and Sargil Tongol. They graduated from Douglas College in 2017 and since then have started Ragamuffin Productions to create meaningful work that cultivates conversations with audiences of all ages; ensuring what they see on stage, they can resonate. From the beginning they have been driven to create theatre that explores play and the outlandish. Their shows have been presented throughout British Columbia.";
