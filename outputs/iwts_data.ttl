iwts_performer:9923 a schema:Person;
  schema:name "Yves Cloutier";
  schema:description "Yves Cloutier is a Montreal-based songwriter whose music moves fluidly between folk, country, classical, and jazz. Steeped in myth and folklore, his universe combines rich sonic textures with striking clarity. In 2024, he released Fleuve, his debut album, driven by an 18-string double-neck guitar, to strong critical acclaim and nominations at the 2026 Prix Opus and the Canadian Folk Music Awards. A prolific composer for theatre and visual media, he cultivates a distinctive musical language at the heart of each of his creations.";
  schema:url <https://www.ycloutier.com/>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
