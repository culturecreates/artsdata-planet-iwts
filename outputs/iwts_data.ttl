iwts_performer:9631 a schema:PerformingGroup;
  schema:name "Ultimi 3 Tenors";
  schema:description "Ultimi (Italian for “latest”) combines the talents of Isaac Hurtado, Tyler Nelson, and Brian Stucki. These tenors have separately performed well over 100 operatic tenor roles and sung in numerous concerts across the US and abroad to critical acclaim. With a repertoire modeled after the original Three Tenors, Ultimi sings opera favorites, Broadway standards, and timeless classics accompanied by piano and cello. With voices of immense power, flexibility, and range, Ultimi gives a fresh take on the Three Tenors tradition.";
  schema:url <https://www.ottavacreatives.com>;
