iwts_performer:9400 a schema:Person;
  schema:name "T>G";
  schema:description "T>G is a reggae artist blending Caribbean rhythms with hip-hop energy. Born in Jamaica and now based in Kelowna, BC, his music fuses reggae, dancehall, and hip-hop, drawing inspiration from Bob Marley, Buju Banton, and Busta Rhymes. Known for high-energy performances and uplifting messages, T>G captivates audiences with soulful melodies and powerful lyrics. His music celebrates resilience, love, and unity, making him a rising voice in Canada’s reggae scene.";
