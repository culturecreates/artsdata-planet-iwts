iwts_performer:8540 a schema:Person;
  schema:name "Johnnie McNamara Walker";
  schema:description "Johnnie McNamara Walker is a writer and performer from Toronto. He has performed his solo show The Heterosexuals in Toronto, Edmonton, Vancouver, Victoria, Atlanta (GA), Rochester (NY), and Dublin (Ireland). Johnnie’s previous solo show Redheaded Stepchild also toured extensively and was published by Playwrights Canada Press. His play Shove It Down My Throat premiered at Buddies in Bad Times Theatre in 2019.  Johnnie is also a founding member of burlesque troupe BoylesqueTO and spent 8 years producing the queer nightlife series HEY GIRL HEY.";
