iwts_performer:6608 a schema:Person;
  schema:name "Adrian Sutherland";
  schema:description "Adrian Sutherland is an extraordinary artist from Attawapiskat in Canada’s Far North. He melds roots, rock, folk, and blues to create a signature sound and style all his own. Adrian’s music draws inspiration from his life, the land, and his Cree language and culture, with melodies and messages that ripple far beyond stages. He has a special way of connecting with audiences, and by virtue of who he is and where he comes from. Adrian brings first-hand perspective on many important issues, and is writing a book for Penguin Random House Canada.";
  schema:url <http://www.adriansutherlandmusic.com>;
