iwts_performer:9424 a schema:PerformingGroup;
  schema:name "Trio Harmonie";
  schema:description "We love creating a musical experience that entertains and touches our audience through music and the stories behind the songs. Through compelling narratives and vivid sonic landscapes we perform traditional classical music as well as modern pieces that appeal to a variety of audiences. Our programs can include Brahms and Beethoven but we also specialize in innovative programs that provide the listeners with a wide and colourful array of shorter entertaining pieces. Join us as clarinet, cello and piano create a passionate musical journey.";
