iwts_performer:661 a schema:PerformingGroup;
  schema:name "Jeffery Straker";
  schema:description "Saskatchewan singer-songwriter pianist Jeffery Straker serves up rootsy storytelling songs that transport listeners: out onto a northern lake or to the main street of a prairie town. Award-winning piano playing infused with elements of country underscores messages of hope, inclusivity, and a fondness for his prairie home.  With critical comparisons to the likes of Murray McLauchlan & Kris Kristofferson Jeffery performs over 100 shows each year. He won the 2025 Canadian Folk Music Award for \"Contemporary Folks Singer of the Year\".";
  schema:url <http://www.jeffstraker.com>;
