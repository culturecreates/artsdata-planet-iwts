iwts_performer:10057 a schema:Organization;
  schema:name "Corporeal Imago";
  schema:description """At the crossroads of circus, dance, and visual theatre, Corporeal Imago confronts the myth of individual destiny, revealing instead a vast ecology where humans are fragile, complicit, and entangled with more-than-human forces.
?
It emerged from years of backstage movement research between Gabrielle Martin and Jeremiah Hughes, while they were performing as a principal characters with Cirque du Soleil’s TORUK, and has become a space to pursue circus’ dramaturgical possibilities alongside the cathartic potential of dance. It tours internationally.""";
  schema:url <https://www.corpoimago.com>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/DancePerformance>;
  schema:genre "Circus";
  iwts:consent "agree_v_1.0";
