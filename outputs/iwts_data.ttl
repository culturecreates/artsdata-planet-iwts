iwts_performer:10010 a schema:PerformingGroup;
  schema:name "Generous Mess";
  schema:description "Sarah Hutton and Aiden Cass have been dancing professionally since 2019 in so-called Vancouver BC, both as freelance performers and choreographers of their contemporary dance company, called Generous Mess. They have had the opportunity to tour across Canada and Europe. Generous Mess has undergone artist in residence processes in Western Canada including Dance Victoria, Shadbolt Centre for the Arts, and Decidedly Jazz Dance. Generous Mess has a distinct movement language that puts dynamic partnering, theatrics, and innovation at the forefront.";
  schema:url <https://linktr.ee/GenerousMess?utm_source=linktree_profile_share&ltsid=8f7afaec-097d-45be-b02d-568e8>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/DancePerformance>;
