iwts_performer:9602 a schema:Person;
  schema:name "Mike Wiley";
  schema:description "Mike Wiley is an NC-based actor, playwright and director with more than 20 years of credits in documentary theatre, film, and television. A gifted and visionary artist and communicator, Wiley’s goal is expanding cultural awareness for audiences of all ages through dynamic portrayals based on pivotal moments in African American history. Wiley’s impressive one-man “casts” introduce dozens of characters, morphing between persons of multiple races and ages, men and women, all while inspiring audiences to apply history’s lessons to issues of today.";
  schema:url <https://www.mikewileyproductions.com>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/TheatrePerformance>;
