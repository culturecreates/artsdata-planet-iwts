iwts_performer:7605 a schema:PerformingGroup;
  schema:name "The Barefoot Movement";
  schema:description "Since 2011, progressive acoustic band The Barefoot Movement has cultivated their unique blend of charming, modern roots music. The brainchild of couple Noah Wall & Tommy Norris, the \"movement\" features fiddle, mandolin, guitar, bass and sometimes drums, supporting Wall's soaring vocals on tunes that range in style from trad. Americana to acoustic pop. Their energetic, joyous, and heartfelt performances have garnered them fans nationwide and beyond, as far away as Burkina Faso, Africa and as close to home as their native Granville County, NC.";
  schema:url <https://www.thebarefootmovementofficial.com>;
