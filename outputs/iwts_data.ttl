iwts_performer:9512 a schema:Person;
  schema:name "Tracie Skeet-Brook";
  schema:description "Tracie Skeet-Brook is a passionate, multifaceted artist with a classical and world music background. She creates unique music performances in Celtic, Folk, Christmas, Musical Theatre, Classical, Opera, Jazz and Blues vocal repertoire while playing numerous instruments including the lap harp, tin whistles, Merlin, piano, glockenspiel, and more. Tracie also creates and produces her own background music which can include orchestral productions. Her versatile, creative and emotional performances connect with audiences where you will want more.";
  schema:url <https://www.tracieskeet-brook.com>;
