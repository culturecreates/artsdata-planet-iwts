iwts_performer:10138 a schema:PerformingGroup;
  schema:name "ALL SIMON: From Garfunkel to Graceland with The Jenner Fox Band";
  schema:description "ALL SIMON features all star musicians The Jenner Fox Band. They first dreamed up a Paul Simon Tribute on a 250-mile bicycle tour of their original music where they discovered a shared reverence for Simon’s work. That sparked ALL SIMON: a set that spans Simon’s career from Garfunkel to Graceland, breathing new life into a beloved catalog and lifting audiences to their feet to sing, groove, and celebrate a true American original. The Washington-based band features piano, electric guitar, bass, dobro, acoustic guitar, and rich vocal harmonies.";
  schema:url <https://www.nationalguitarband.com/>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
  schema:genre "Popular";
