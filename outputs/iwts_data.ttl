iwts_performer:10059 a schema:Person;
  schema:name "Tahina Awan";
  schema:description "Tahina Awan is a multi-faceted Indo-Canadian actor and writer most recently seen in her one woman autobiographical comedy, Punjabi Wabi Sabi at the 2025 Edmonton Fringe Festival or on Vancouver comedy stages as her delightful alter ego, Baba Bibiji. A classically trained stage actor and clown, Tahina works in both film/TV and on stage - regularly appearing in commercials, award winning short films and TV as well as creating original work for the stage. Tahina recently completed her first supporting lead in a comedic network feature film.";
