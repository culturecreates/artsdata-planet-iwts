iwts_performer:861 a schema:Person;
  schema:name "Sarah Hagen";
  schema:description "A classical pianist with a wry wit, Sarah Hagen enjoys a rich and diverse concertising life as both soloist and humorist. Her extensive touring has taken her across Canada, to Europe and the United States, including twice to New York City’s Carnegie Hall. Awarded as Artist of the Year by both Ontario Contact and the BC Touring Council, her interpretations have been described as \"outstandingly inventive\" [University of Waterloo Gazette], ”played flawlessly” [ReviewVancouver], “with great sensitivity and heart” [Vernon Morning Star].";
