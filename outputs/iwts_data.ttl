iwts_performer:9552 a schema:PerformingGroup;
  schema:name "Northern Resonance";
  schema:description "Northern Resonance is the Scandinavian string trio that takes folk music into enormous soundscapes. With viola d’amore, hardanger fiddle and nyckelharpa they let Scandinavian music meet grand arrangements that takes folk music in a new direction. Northern Resonance have an intense musical connection that is rare to come across. There is great life in their tunes, and the trio knows how to bring it out. The trio have been nominated for a Swedish grammy and toured during 2024 in Australia, Chile, Colombia, Germany, USA, England and Scotland.";
  schema:url <https://www.northernresonance.se/>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
