iwts_performer:9595 a schema:PerformingGroup;
  schema:name "Basset";
  schema:description "Toronto-based folk duo, Basset, are full of timeless heart, with deeply human lyrics and stunning duo harmonies reminiscent of the early folk revival. Yasmine Shelton has one of those instantly recognizable voices that can dive and soar all in a single phrase, while Sam Clark brings nuanced and tasteful support on guitar and other acoustic instruments. CBC Q’s Tom Power says “I think you’re going to love this”.";
