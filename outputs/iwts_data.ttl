iwts_performer:9466 a schema:PerformingGroup;
  schema:name "Mohamed Assani Trio";
  schema:description "The Mohamed Assani Trio takes music to new realms while remaining committed to the rich roots of South Asian traditions. Mohamed, twice Western Canadian Music Awards nominated artist for Instrumental music, is a dynamic performer and composer known for his genre-defying music. Trained in both Indian/Pakistani and Western Classical music, his music-making seamlessly draws from different genres and cultures with depth & authenticity. He is joined by the talented percussionist, Curtis Andrews, and versatile tabla player, Gurdit Singh.";
  schema:url <https://youtu.be/NxO3L75uUXA?si=s4wiEi81zLWpVYAp>;
