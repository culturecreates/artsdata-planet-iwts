iwts_performer:8181 a schema:PerformingGroup;
  schema:name "Rini";
  schema:description "Shifting South Asian classical elements toward pop and jazz sensibilities in a refreshing, organic way, New Jersey based, Chennai born singer, composer and violinist Harini “Rini” Raghavan creates her own version of Indian Jazztronica. Harini draws from her formal training in Carnatic music and work at Berklee to bring together the music of India and her home in the US. She leads a group of acclaimed NYC musicians from different countries to create ‘a powerful contemporary carnatic/electronic fusion sound’ as described by Rolling Stone India.";
  schema:url <https://www.rinimusic.com>;
