iwts_performer:773 a schema:PerformingGroup;
  schema:name "Boreal";
  schema:description "Boreal brings together Canadian singer-songwriters Katherine Wheatley, Tannis Slimmon and Angie Nussey in a trio renowned for finely woven harmonies and deeply human songwriting. Blending folk, roots, and contemporary influences, their music ranges from intimate and delicate to joyful and uplifting, driven by guitar, mandolin, percussion and keys. Known for inventive vocal arrangements and rich musical textures, their performances are both moving and memorable. Their album Winterbirds is currently nominated for 3 Canadian Folk Music Awards.";
  schema:url <http://www.borealsongs.ca>;
