iwts_performer:9378 a schema:PerformingGroup;
  schema:name "Bad New Days";
  schema:description """Led by Artistic Director Adam Paolozza, Bad New Days has established a unique presence in Canadian theatre creating visually bold and physically innovative theatrical works that explore the complexity of the human condition through a volatile blend of lightness and gravity, drawing from the theatrical traditions of the past and re-imagining them in a contemporary aesthetic context.  

Our mandate is to create collaboratively devised work, to tour, and to offer affordable training opportunities to the community.""";
