iwts_performer:8822 a schema:PerformingGroup;
  schema:name "Jazz Hutch & Friends";
  schema:description "An emerging jazz vocal sensation! With his unique phrasing, voice and understated and care free delivery, and uncommon ability to bring the lyrics of a song alive and communicate with his audience, Jazz Hutch (aka Jim Hutchison)  is a distinctively smooth and swinging interpreter of the many moods found in the jazz standards song book!   Jazz Hutch & Friends - Mood Indigo was nominated for Jazz recording of the year by the 2024 YYC Music Awards and A Jazz Hutch Christmas was nominated for Inspirational/Holiday Album at the 2025 Awards.";
  schema:url <http://www.jazzhutch.jimhutchison.ca>;
