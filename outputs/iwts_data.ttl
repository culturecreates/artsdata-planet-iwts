iwts_performer:9573 a schema:Person;
  schema:name "Southside Denny";
  schema:description """Southside Denny was born and raised in South Bend, Indiana and relocated to Montréal in 2007. He cut his teeth on the Chicago Blues scene and in Northern Indianain the 1980's and 1990's. 
He has 9 albums to his credit, currently working on his 10th.  Denny plays mostly his blues and fingerstyle guitar compositions.  He is a great singer, performer and virtuoso guitarist.
He has been opening act for Buddy Guy, Ray Charles, Stevie Ray Vaughan, the Beach Boys, Styxx, and many others. 
He has played at the Montréal Jazz Festival and many others.""";
  schema:url <https://www.southsidedenny.com>;
