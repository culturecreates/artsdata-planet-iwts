iwts_performer:10271 a schema:Person;
  schema:name "Jeremiah Harmon";
  schema:description "Jeremiah Harmon is a Tennessee based singer-songwriter whose music is rooted in the folk and blues traditions of the South, often blending chamber pop and experimental elements. He credits his inspiration to the likes of Jeff Buckley, Nick Drake, Leonard Cohen, and foundational folk blues artists like Skip James and Odetta.  Since being an American Idol finalist in 2019, he chose to pursue a career as an independent artist and has released five studio albums, earning recognition from NPR’s All Songs Considered, Billboard, and Out Magazine.";
  schema:url <https://jeremiahharmon.com/>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
