iwts_performer:9462 a schema:PerformingGroup;
  schema:name "Gabriel Schwartz | Folk-Bossa";
  schema:description "Gabriel Schwartz's new project titled Folk-Bossa is based on the idea of merging folk music and bossa nova. The desire to go towards folk music is an attempt to make the link between the cultures of Brazil and that of North America. The trio is formed by Gabriel Schwartz, multi-instrumentalist/singer, with the collaboration of Dominique Poirier on accordion/guitar and Bianca Rocha on voice, ukulele and percussion. The trio invites the public to travel on the traditional culture present in the repertoire of Brazilian, French and English songs.";
  schema:url <https://linktr.ee/gabrielschwartzmusic>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
