iwts_performer:10208 a schema:Person;
  schema:name "Mary Beth Orr";
  schema:description "As an artist for Great Lakes Performing Artists Associates, and a PARMA/Navona recording artist, Mary Beth Orr is a passionate classical hornist and folk vocalist intent on bringing connection through music, most recently a finalist for The American Prize in instrumental performance 2023.  She is a multi international prize winning soloist that released her debut crossover fusion album, The Singing Horn, in March 2025 which was awarded a Silver Prize for Outstanding Folk Album by the Global Music Awards.";
