iwts_performer:10068 a schema:Person;
  schema:name "Adrian Sutherland";
  schema:description "Adrian Sutherland is a roots-rock artist from Attawapiskat in Ontario’s Far North. Blending roots, rock, folk, and blues, his music draws on life in the North, the land, and his Cree language and culture. A two-time JUNO nominee, Adrian is also the author of The Work of Our Hands, published by Penguin Random House Canada. One of the few professional recording artists living in a remote fly-in First Nation, he brings a powerful first-hand perspective during this time of reconciliation.";
  schema:url <https://www.adriansutherlandmusic.com>;
