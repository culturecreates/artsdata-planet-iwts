iwts_performer:9379 a schema:Person;
  schema:name "Syd Bosel";
  schema:description "Syd Bosel is a 65-year-old Stand-up comic. Starting her career in 2016, she has been heard on CBC's The Debaters, JFL albums, has won multiple Vancouver area competitions and been featured in the Georgia Straight. She headlines her \"Hot Flash Comedy\" tour. Her comedy stands out because of her age, life experiences, charm and sarcasm! Audiences of all ages relate to her very animated delivery, her tales of her \"adult\" children, surviving breast cancer, having a husband with dementia, and having much in common with her 4-year old Grandson.";
