iwts_performer:9361 a schema:Organization;
  schema:name "Holy Crow Arts";
  schema:description """Holy Crow Arts Society was founded by Justin Neal, a member of the Squamish Nation, for the creation and production of theatrical plays, community-engaged projects, creative collaboration projects & commissions, all with a particular focus on Indigenous and Coast Salish artistic expression and stories that seek to uplift contemporary society.

Holy Crow was created out of a desire to address the dearth of contemporary and honest Indigenous characters on stage. We present unique, artistically-challenging, and genre-defying work.""";
  schema:url <https://holycrowarts.com/>;
