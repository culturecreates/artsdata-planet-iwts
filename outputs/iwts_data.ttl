iwts_performer:9556 a schema:Organization;
  schema:name "Black Radish Theatre";
  schema:description "A Calgary-based theatre company, founded by four established professional actors - Duval Lang, Andy Curtis, Tyrell Crews and Christopher Hunt - Black Radish Theatre aims to offer seasoned Calgary artists the opportunity to showcase their well-developed craft in an environment that is relaxed, respectful and rewarding.  We wish to attract artists, who by their many years of experience, have a refined a work habit or ethic that is now efficient and comfortable but still inquisitive and curious.";
  schema:url <https://www.blackradishtheatre.com>;
