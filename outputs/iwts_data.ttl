iwts_performer:9356 a schema:Person;
  schema:name "Uncle G";
  schema:description "Graeme Shaw, better known as Uncle G, is an Americana singer/songwriter hailing from the rustic landscapes of rural southern Ontario, Canada. Growing up in a small town instilled in him an appreciation for the simplicity and complexities of life, themes that resonate in his music. His sound is woven from his experiences, reflecting the impact of personal relationships and the charm of his home town.";
