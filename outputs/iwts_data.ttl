iwts_performer:10370 a schema:Person;
  schema:name "Andrew Nadon";
  schema:description "Andrew Nadon is a multifaceted performer known for his unique blend of mind-reading, magic, music, and comedy. He crafts an enchanting experience that captivates audiences of all ages and has collaborated with Royal Caribbean, Cunard, and Celebrity cruise lines, as well as an eight-season tenure as the house magician at the Holland America Skagway Inn.  Andrew has also graced the stage at Mystique Dining in Salt Lake City. His dynamic presence and remarkable talent ensure an unforgettable experience for all who attend his shows.";
  schema:url <https://andrewnadon.com>;
