iwts_performer:9426 a schema:PerformingGroup;
  schema:name "Mip Power Trio";
  schema:description "A raw and restless force in Canada’s underground, Mip Power Trio blends rock 'n' roll grit and folk songcraft into something sharp, urgent, and undeniably fun. Fronted by songwriter/guitarist Mip and rounded out by Greg Kowalczyk (bass) and Devin Jannetta (drums), the trio taps into the joy, struggle, and absurdity of navigating these uncertain times. With two LPs, two EPs, and a new record on the way, Mip Power Trio has long been one of Toronto’s best-kept secrets—but not for much longer.";
  schema:url <https://mipsmusic.com/>;
