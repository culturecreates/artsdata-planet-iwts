iwts_performer:1130 a schema:PerformingGroup;
  schema:name "Jocelyn Pettit Band";
  schema:description """From the West Coast of BC, Jocelyn Pettit is a vibrant, award-winning fiddle player, stepdancer and singer.  With uplifting energy and engaging stage presence, Jocelyn integrates Celtic and folk traditions of her roots into her music. She has toured internationally, appeared on CBC and BBC television and radio, and received multiple recognitions at the Canadian Folk Music Awards, Western Canadian Music Awards, and International Acoustic Music Awards.

The Jocelyn Pettit Band presents a lively and joyful performance of “New-Trad Celtic” music.""";
