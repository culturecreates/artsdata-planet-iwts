iwts_performer:9374 a schema:PerformingGroup;
  schema:name "Rebecca Margolick & Hannah Epperson &  Niloufar Nourbakhsh";
  schema:description """Rebecca's contemporary dance works have been presented worldwide. She was named in Dance Magazine's Top 25 to Watch, and has received residencies from top institutions. 
Hannah has been called a neo-classical composer, indie folk/rocker and avant-garde pop artist. She's performed music festivals worldwide. She has worked with Fleet Foxes, Ry X, Julianna Barwick and Canadian spoken word artist Shane Koyczan.
Iranian-American composer Niloufar Nourbakhsh’s new classical music has been commissioned and performed by top institutions worldwide.""";
  schema:url <https://www.rebeccamargolick.com/>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/PerformingArtsEvent>;
