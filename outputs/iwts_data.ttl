iwts_performer:10226 a schema:Organization;
  schema:name "Contemporary West Dance Company";
  schema:description "Led by former Alvin Ailey principal Bernard H. Gaddis, Contemporary West Dance Theatre (CWDT) is an electrifying, award-winning force in American dance. We fuse the technical rigor of classical ballet and modern dance with the visceral narratives of the African Diaspora. Our unique aesthetic is emotionally potent and physically breathtaking, driven by elite athleticism and deep theatricality. Rooted in diverse traditions, CWDT delivers a visionary experience that redefines the boundaries of the contemporary stage.";
  schema:url <https://cwdancetheatre.org/the-company/founder/>;
