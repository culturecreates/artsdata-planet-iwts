iwts_performer:8702 a schema:PerformingGroup;
  schema:name "Pipeline Vocal Project";
  schema:description """Pipeline Vocal Project is an Alaskan vocal trio that performs top hits from all eras with a unique twist! Hopping through genres and decades, you will be entertained with clever arrangements, amazing harmonies, and a soundscape of a band coming from only three voices. 

