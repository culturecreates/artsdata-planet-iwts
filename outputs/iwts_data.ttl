iwts_performer:9476 a schema:PerformingGroup;
  schema:name "PinkFusion";
  schema:description "PinkFusion, featuring Leslie Mauldin (lead vocals, guitar, songwriter) and Sean Rogers (piano/vocals), blends jazz, blues, pop, folk, and a touch of classical music with their own unique arrangements. Expect a dynamic show filled with storytelling, humor (and dancing--though we hope it's not confused with comedy), and a musical journey through jazz standards, blues, originals, and reimagined classical tunes. PinkFusion invites you to join the fun wherever they perform!";
  schema:url <https://www.pinkfusion-music.com/>;
