iwts_performer:9537 a schema:PerformingGroup;
  schema:name "DIVKA";
  schema:description """DIVKA (pronounced ‘diva’ with a k) is comprised of bandurist (esoteric Ukrainian harp) Alina Kuzma, and violist (not a violin) Zoë Ëoz.
They perform primarily Eastern European folk songs about badass women in all their glory.
As a sonic rebel reckoning, DIVKA's music is charged with mythology, traditional village singing, and generations of femme power, mystic whimsy, and a dash of vengeance.""";
  schema:url <https://divka.ca>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
