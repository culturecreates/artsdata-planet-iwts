iwts_performer:8963 a schema:Person;
  schema:name "Andrea Parson";
  schema:description "Andrea parson is a multidisciplinary performing artist based in Portland. Following a 12 year career as a professional contemporary dancer, she has evolved into a solo creator of original autobiographical performances that blend storytelling, physical poetry, and clown. She has presented her work regionally and nationally, and is known for expressing a refined physical prowess, spiritual depth, and comedic sensibility. She is a Princess Grace award winner and recently received an award for best physical theater at United Solo Festival 2024.";
