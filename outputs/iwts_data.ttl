iwts_performer:9795 a schema:Organization;
  schema:name "La Sporée / Sarah Bronsard";
  schema:description "The multidisciplinary works of La Sporée / Sarah Bronsard explore invisible and transitory phenomena through the moving body, rooted in contemporary flamenco. Like mushrooms emerging from hidden connections, each creation reveals what is born from encounters. Centered on co-creation, La Sporée delves into the fertile tension between beings, bodies, traditions, and artistic disciplines.";
