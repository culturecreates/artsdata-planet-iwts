iwts_performer:9529 a schema:Person;
  schema:name "Emily Raff";
  schema:description "Emily Raff, the Rock & Roll Cowgirl from Ohio, embodies heartfelt storytelling through her music. Emily has earned significant recognition for her talent as a vocalist, guitarist and songwriter; allowing her to share the spotlight with Riley Green, Chris Lane, Tyler Farr and Chayce Beckham. Emily is diligently crafting her inaugural EP, Changes, with singles releasing throughout 2025. Join her artistic journey by following her on Instagram, Facebook, or TikTok and immerse yourself in her music on all major streaming platforms.";
