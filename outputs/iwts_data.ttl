iwts_performer:8041 a schema:Person;
  schema:name "Natasha Blackwood";
  schema:description """Natasha Blackwood is a singer, songwriter, and multi-instrumentalist from Newfoundland and Labrador, Canada.

Her latest album “Love Songs for Good Machines” is a jazz/folk album described as \"...a delight. Fun and entertaining at one level, but worth a deeper dive into the lyrics to explore exactly where she is coming from... a rare talent\". 

Blackwood's engaging performances range from solo piano serenades, to doubling on sax with her 8-piece band, paired with the classic Newfoundland charm and humour. Tell your nan she says hi.""";
  schema:url <http://www.natashablackwood.com>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
