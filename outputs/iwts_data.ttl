iwts_performer:9446 a schema:PerformingGroup;
  schema:name "Diana Braithwaite and Chris Whiteley";
  schema:description "Diana Braithwaite and Chris Whiteley are an award-winning blues duo celebrated for their authentic sound and deep-rooted connection to the blues tradition. Diana’s soulful vocals and Chris’s masterful guitar and trumpet playing create a dynamic, captivating performance. With multiple Maple Blues Awards and international tours, they have shared stages with legends like B.B. King and T-Bone Burnett. Their rich storytelling, vintage blues style, and seamless chemistry make them a must-see act on the global blues scene.";
