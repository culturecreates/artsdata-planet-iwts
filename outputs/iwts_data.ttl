iwts_performer:8843 a schema:Person;
  schema:name "Jenene Caramielo";
  schema:description "With acclaimed shows including Celebrating Celine, Icons & Divas, and Broadway to the Big Screen, Jenene Caramielo is a classically-trained powerhouse vocalist praised by BroadwayWorld for her “thrilling voice” and rare ability to perform “at an elite level in so many genres” — from pop and Broadway to opera. A BFA graduate of Shenandoah Conservatory, she’s performed across the U.S. and abroad, opened for the Beach Boys, and headlined at the White House.";
