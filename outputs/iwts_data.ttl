iwts_performer:10175 a schema:Person;
  schema:name "Greg Carroll";
  schema:description "Greg Carroll is an accomplished indigenous musician, singer, songwriter. Greg earned a B.A. in Music (Jazz Studies) from St. Francis Xavier University.  A versatile performer, Greg has toured and recorded as a bassist with noted artists including Amos Garrett and Chad Brownlee, and with his own band, Black Mountain Whiskey Rebellion, garnering recognition in Rolling Stone magazine in 2018.  Greg’s recent album, ‘Writing on the Wall’ highlights his skill as a songwriter, reflecting the depth of experience gained from decades in the industry.";
