iwts_performer:10096 a schema:Organization;
  schema:name "Landon Krentz";
  schema:description "Landon Krentz is an award-winning Deaf theatre creator, performer, and producer based in Calgary. His work blends physical theatre, visual vernacular, and projection design to create visually driven performances that transcend spoken language. Landon has collaborated with companies including Ghost River Theatre, Deaf West Theatre, and Inside Out Theatre, and his work has been presented across Canada and internationally. He is the founder of Sumain Platform Theatre and creates bold Deaf-led performance that bridges Deaf and hearing audiences.";
  schema:url <https://www.ghostrivertheatre.com/aworldwithoutthem>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/TheatrePerformance>;
