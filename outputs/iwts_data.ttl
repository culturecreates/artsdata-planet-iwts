iwts_performer:9961 a schema:PerformingGroup;
  schema:name "Tyson Ray Borsboom";
  schema:description "Tyson Ray Borsboom is a Canadian singer-songwriter blending folk, Americana, alt-country, and indie rock. Born in Winnipeg, raised in Calgary, and now based in Vancouver, his music is rooted in honest storytelling, warm melodies, and raw emotional delivery. Known for intimate, engaging live performances, Borsboom’s songs explore growth, love, and resilience, drawing listeners in with sincerity and a modern roots sound. Bringing together the sounds of Zach Bryan, Tyler Childers, and Turnpike Troubadours.";
  schema:url <https://linktr.ee/tysonrayborsboom>;
