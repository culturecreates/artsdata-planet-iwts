iwts_performer:7845 a schema:PerformingGroup;
  schema:name "None of the Above";
  schema:description "North Carolina’s None of the Above has been performing in the Triad area with their bluegrass-based acoustic music for over twenty-five years. By working with traditional bluegrass instrumentation, NOTA has crafted a unique sound. Their music incorporates elements and material from a variety of styles including Bluegrass, Americana, Alternative Country, Folk, Rock, and their own original compositions. This ultimately produces a sound that lives up to their name: None of the Above.";
