iwts_performer:10285 a schema:PerformingGroup;
  schema:name "Diana Hoffmaster";
  schema:description "D'Vorah Dance Arts (DDA), founded in 2023 by choreographer Diana Mighdoll Hoffmaster, serves as a collaborative platform for innovative multimedia dance creations. DDA’s mission is to inspire creative exploration, nurture self-discovery, and promote expressive movement as vital pathways to meaningful engagement. DDA is dedicated to developing socially conscious works that connect personal stories to broader cultural narratives. Through dance, we seek to embody memory and transformation and to foster a sense of shared experiences.";
  schema:url <https://www.dvorahdancearts.com/about>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/DancePerformance>;
