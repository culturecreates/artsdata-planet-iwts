iwts_performer:9323 a schema:PerformingGroup;
  schema:name "Miina";
  schema:description """Miina is a captivating, female-fronted musical project lead by Laura Mina Mitic. Hailing from Vancouver Island, this six-piece band showcases experienced musicians enamoured with authentic inspiration and a passion for compelling creativity.

“Miina is the sound of the sunlight cutting through the foliage. Everything is brighter, funkier, more danceable... with love for the environment and human emotion.” (Michael Luis, Rifflandia Music Festival).""";
