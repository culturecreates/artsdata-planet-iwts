iwts_performer:9573 a schema:Person;
  schema:name "Southside Denny";
  schema:description """Southside Denny was born and raised in South Bend, Indiana and relocated to Montréal in 2007. He cut his teeth on the Chicago Blues scene and in Northern Indiana during the 1980's and 1990's. 
He has produced 9 albums, currently working on his 10th.  Denny plays mostly his original blues and fingerstyle guitar compositions, and a couple of Django Rheinhardt pieces. 
He has been opening act for Buddy Guy, Ray Charles, Stevie Ray Vaughan, the Beach Boys, Styxx, and too many others to mention here.
Please visit www.southsidedenny.com for more!""";
  schema:url <https://www.southsidedenny.com>;
