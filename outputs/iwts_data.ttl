iwts_performer:9872 a schema:PerformingGroup;
  schema:name "The Festive Brass";
  schema:description """Over 30 years or so ago, The Butchart Gardens in beautiful Victoria B.C. wanted to add some live music for patrons and a brass group was hired to play ‘festive’ music.

Throughout the years, the brass became extremely popular as we combined top-notch musicianship with quirky arrangements of well-loved holiday classics, and some additional cheeky humour interacting with our audiences.  

One year we just simply decided to take the show ‘on the road’ which led us to our current stellar group primed for all concert venues.""";
  schema:url <https://www.festivebrass.ca>;
  schema:knowsAbout <http://kg.artsdata.ca/resource/MusicPerformance>;
  schema:genre "Popular";
