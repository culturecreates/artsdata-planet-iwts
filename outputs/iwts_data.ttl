iwts_performer:3955 a schema:Organization;
  schema:name "Eisenhower Dance Detroit";
  schema:description "Eisenhower Dance Detroit (EDD), now in its 35th season, is a nationally recognized contemporary repertory company led by Artistic Director Stephanie Pizzo, a founding member who assumed leadership in 2017. EDD presents works by acclaimed national and international choreographers and collaborates across disciplines with musicians, filmmakers, and designers. Through touring, performances, and education programs, the company expands appreciation for contemporary dance while engaging communities and exploring issues of social significance.";
