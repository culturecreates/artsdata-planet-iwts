iwts_performer:3788 a schema:Person;
  schema:name "Spencer Jo";
  schema:description "From punk roots to folk authenticity, Spencer Jo crafts razor-sharp social commentary stripped of pretense. Their surreal edge and instrumental prowess serve a deeper purpose – illuminating uncomfortable truths through bare-bones folk arrangements. A punk rocker turned troubadour, they prove that rebellion needs no distortion to cut deep.";
  schema:url <https://spencerjo.com>;
